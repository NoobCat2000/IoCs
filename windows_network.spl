# ── Office Application Initiated Network Connection Over Uncommon Ports ──
# Mức độ  : Trung bình
# Chi tiết: Detects an office suit application (Word, Excel, PowerPoint, Outlook) communicating to target systems over uncommon ports.
EventCode=5156 Channel="Security" Direction="%%14593" Application IN ("*\\excel.exe", "*\\outlook.exe", "*\\powerpnt.exe", "*\\winword.exe", "*\\wordview.exe") NOT (DestPort IN (53, 80, 139, 389, 443, 445, 3268) OR (Application="*:\\Program Files\\Microsoft Office\\*" Application="*\\OUTLOOK.EXE" DestPort IN (143, 465, 587, 993, 995)))

# ── Python Initiated Connection ──
# Mức độ  : Trung bình
# Chi tiết: Detects a Python process initiating a network connection. While this often relates to package installation, it can also indicate a potential malicious script communicating with a C&C server.
EventCode=5156 Channel="Security" Direction="%%14593" Application="*\\python*" Application="*.exe*" NOT ((DestAddress="127.0.0.1" SourceAddress="127.0.0.1") OR (CommandLine="*pip.exe*" CommandLine="*install*")) NOT ((ParentImage="C:\\ProgramData\\Anaconda3\\Scripts\\conda.exe" CommandLine="*:\\ProgramData\\Anaconda3\\Scripts\\conda-script.py*" CommandLine="*update*") OR (ParentImage="C:\\ProgramData\\Anaconda3\\python.exe" CommandLine="*C:\\ProgramData\\Anaconda3\\Scripts\\jupyter-notebook-script.py*"))

# ── Outbound RDP Connections Over Non-Standard Tools ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects Non-Standard tools initiating a connection over port 3389 indicating possible lateral movement. An initial baseline is required before using this utility to exclude third party RDP tooling tha
EventCode=5156 Channel="Security" DestPort=3389 Direction="%%14593" NOT (Application IN ("\\device\\harddiskvolume*\\Windows\\System32\\mstsc.exe", "\\device\\harddiskvolume*\\Windows\\SysWOW64\\mstsc.exe")) NOT ((SourcePort=53 Application="\\device\\harddiskvolume*\\Windows\\System32\\dns.exe" Protocol="17") OR Application IN ("*\\Avast Software\\Avast\\AvastSvc.exe", "*\\Avast\\AvastSvc.exe") OR Application="*\\RDCMan.exe" OR Application="\\device\\harddiskvolume*\\Program Files\\Google\\Chrome\\Application\\chrome.exe" OR Application IN ("*\\FSAssessment.exe", "*\\FSDiscovery.exe", "*\\MobaRTE.exe", "*\\mRemote.exe", "*\\mRemoteNG.exe", "*\\Passwordstate.exe", "*\\RemoteDesktopManager.exe", "*\\RemoteDesktopManager64.exe", "*\\RemoteDesktopManagerFree.exe", "*\\RSSensor.exe", "*\\RTS2App.exe", "*\\RTSApp.exe", "*\\spiceworks-finder.exe", "*\\Terminals.exe", "*\\ws_TunnelService.exe") OR Application IN ("*\\thor.exe", "*\\thor64.exe") OR Application="\\device\\harddiskvolume*\\Program Files\\SplunkUniversalForwarder\\bin\\*" OR Application="*\\Ranger\\SentinelRanger.exe" OR Application="\\device\\harddiskvolume*\\Program Files\\Mozilla Firefox\\firefox.exe" OR Application IN ("\\device\\harddiskvolume*\\Program Files\\TSplus\\Java\\bin\\HTML5service.exe", "\\device\\harddiskvolume*\\Program Files (x86)\\TSplus\\Java\\bin\\HTML5service.exe") OR NOT Application=* OR Application="" OR Application="<unknown process>")

# ── RDP Over Reverse SSH Tunnel ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects svchost hosting RDP termsvcs communicating with the loopback address and on TCP port 3389
EventCode=5156 Channel="Security" SourcePort=3389 Application="*\\svchost.exe" Direction="%%14593" DestAddress="127.0.0.0/8" OR DestAddress="::1/128"

# ── RDP to HTTP or HTTPS Target Ports ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects svchost hosting RDP termsvcs communicating to target systems on TCP port 80 or 443
EventCode=5156 Channel="Security" SourcePort=3389 Application="*\\svchost.exe" Direction="%%14593" DestPort IN (80, 443)

# ── RegAsm.EXE Initiating Network Connection To Public IP ──
# Mức độ  : Trung bình
# Chi tiết: Detects "RegAsm.exe" initiating a network connection to public IP adresses
EventCode=5156 Channel="Security" Direction="%%14593" Application="*\\regasm.exe" NOT (DestAddress="127.0.0.0/8" OR DestAddress="10.0.0.0/8" OR DestAddress="172.16.0.0/12" OR DestAddress="192.168.0.0/16" OR DestAddress="169.254.0.0/16" OR DestAddress="::1/128" OR DestAddress="fe80::/10" OR DestAddress="fc00::/7")

# ── Network Connection Initiated By Regsvr32.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects a network connection initiated by "Regsvr32.exe"
EventCode=5156 Channel="Security" Direction="%%14593" Application="*\\regsvr32.exe"

# ── Remote Access Tool - AnyDesk Incoming Connection ──
# Mức độ  : Trung bình
# Chi tiết: Detects incoming connections to AnyDesk. This could indicate a potential remote attacker trying to connect to a listening instance of AnyDesk and use it as potential command and control channel.
EventCode=5156 Channel="Security" Application IN ("*\\AnyDesk.exe", "*\\AnyDeskMSI.exe") Direction="%%14592"

# ── Rundll32 Internet Connection ──
# Mức độ  : Trung bình
# Chi tiết: Detects a rundll32 that communicates with public IP addresses
EventCode=5156 Channel="Security" Application="*\\rundll32.exe" Direction="%%14593" NOT (DestAddress="127.0.0.0/8" OR DestAddress="10.0.0.0/8" OR DestAddress="172.16.0.0/12" OR DestAddress="192.168.0.0/16" OR DestAddress="169.254.0.0/16" OR DestAddress="::1/128" OR DestAddress="fe80::/10" OR DestAddress="fc00::/7" OR DestAddress="20.0.0.0/8" OR DestAddress="51.103.0.0/16" OR DestAddress="51.104.0.0/16" OR DestAddress="51.105.0.0/16" OR CommandLine="*\\system32\\PcaSvc.dll,PcaPatchSdbTask" OR SourceHostname="*.internal.cloudapp.net" OR (ParentImage="C:\\Windows\\System32\\svchost.exe" DestPort=443))

# ── Silenttrinity Stager Msbuild Activity ──
# Mức độ  : Cao
# Chi tiết: Detects a possible remote connections to Silenttrinity c2
EventCode=5156 Channel="Security" Application="*\\msbuild.exe" DestPort IN (80, 443) Direction="%%14593"

# ── Network Communication Initiated To File Sharing Domains From Process Located In Suspicious Folder ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects executables located in potentially suspicious directories initiating network connections towards file sharing domains.
EventCode=5156 Channel="Security" Application IN ("*:\\$Recycle.bin*", "*:\\Perflogs\\*", "*:\\Temp\\*", "*:\\Users\\Default\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Fonts\\*", "*:\\Windows\\IME\\*", "*:\\Windows\\System32\\Tasks\\*", "*:\\Windows\\Tasks\\*", "*:\\Windows\\Temp\\*", "*\\AppData\\Temp\\*", "*\\config\\systemprofile\\*", "*\\Windows\\addins\\*") DestinationHostname IN ("*.githubusercontent.com", "*0x0.st", "*anonfiles.com", "*bashupload.com", "*cdn.discordapp.com", "*chunk.io", "*ddns.net", "*dl.dropboxusercontent.com", "*ghostbin.co", "*github.com", "*glitch.me", "*gofile.io", "*hastebin.com", "*mediafire.com", "*mega.co.nz", "*mega.nz", "*onrender.com", "*pages.dev", "*paste.ee", "*pastebin.com", "*pastebin.pl", "*pastetext.net", "*pixeldrain.com", "*privatlab.com", "*privatlab.net", "*send.exploit.in", "*sendspace.com", "*storage.googleapis.com", "*storjshare.io", "*supabase.co", "*temp.sh", "*transfer.sh", "*trycloudflare.com", "*ufile.io", "*w3spaces.com", "*workers.dev", "*x0.at") Direction="%%14593"

# ── Network Connection Initiated From Process Located In Potentially Suspicious Or Uncommon Location ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects a network connection initiated by programs or processes running from suspicious or uncommon files system locations.
EventCode=5156 Channel="Security" Direction="%%14593" Application IN ("*:\\$Recycle.bin*", "*:\\Perflogs\\*", "*:\\Temp\\*", "*:\\Users\\Default\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Fonts\\*", "*:\\Windows\\IME\\*", "*:\\Windows\\System32\\Tasks\\*", "*:\\Windows\\Tasks\\*", "*\\config\\systemprofile\\*", "*\\Contacts\\*", "*\\Favorites\\*", "*\\Favourites\\*", "*\\Music\\*", "*\\Pictures\\*", "*\\Videos\\*", "*\\Windows\\addins\\*") NOT (DestinationHostname IN ("*.githubusercontent.com", "*0x0.st", "*anonfiles.com", "*bashupload.com", "*cdn.discordapp.com", "*chunk.io", "*ddns.net", "*dl.dropboxusercontent.com", "*ghostbin.co", "*github.com", "*glitch.me", "*gofile.io", "*hastebin.com", "*mediafire.com", "*mega.co.nz", "*mega.nz", "*onrender.com", "*pages.dev", "*paste.ee", "*pastebin.com", "*pastebin.pl", "*pastetext.net", "*portmap.io", "*privatlab.com", "*privatlab.net", "*send.exploit.in", "*sendspace.com", "*storage.googleapis.com", "*storjshare.io", "*supabase.co", "*temp.sh", "*transfer.sh", "*trycloudflare.com", "*ufile.io", "*w3spaces.com", "*workers.dev", "*x0.at"))

# ── Potentially Suspicious Malware Callback Communication ──
# Mức độ  : Cao
# Chi tiết: Detects programs that connect to known malware callback ports based on statistical analysis from two different sandbox system databases
EventCode=5156 Channel="Security" Direction="%%14593" DestPort IN (100, 198, 200, 243, 473, 666, 700, 743, 777, 1443, 1515, 1777, 1817, 1904, 1960, 2443, 2448, 3360, 3675, 3939, 4040, 4433, 4438, 4443, 4444, 4455, 5445, 5552, 5649, 6625, 7210, 7777, 8143, 8843, 9631, 9943, 10101, 12102, 12103, 12322, 13145, 13394, 13504, 13505, 13506, 13507, 14102, 14103, 14154, 49180, 65520, 65535) NOT (DestAddress="127.0.0.0/8" OR DestAddress="10.0.0.0/8" OR DestAddress="172.16.0.0/12" OR DestAddress="192.168.0.0/16" OR DestAddress="169.254.0.0/16" OR DestAddress="::1/128" OR DestAddress="fe80::/10" OR DestAddress="fc00::/7") NOT (Application IN ("\\device\\harddiskvolume*\\Program Files\\*", "\\device\\harddiskvolume*\\Program Files (x86)\\*"))

# ── Communication To Uncommon Destination Ports ──
# Mức độ  : Trung bình
# Chi tiết: Detects programs that connect to uncommon destination ports
EventCode=5156 Channel="Security" Direction="%%14593" DestPort IN (8080, 8888) NOT (DestAddress="127.0.0.0/8" OR DestAddress="10.0.0.0/8" OR DestAddress="172.16.0.0/12" OR DestAddress="192.168.0.0/16" OR DestAddress="169.254.0.0/16" OR DestAddress="::1/128" OR DestAddress="fe80::/10" OR DestAddress="fc00::/7") NOT (Application IN ("\\device\\harddiskvolume*\\Program Files\\*", "\\device\\harddiskvolume*\\Program Files (x86)\\*"))

# ── Uncommon Outbound Kerberos Connection ──
# Mức độ  : Trung bình
# Chi tiết: Detects uncommon outbound network activity via Kerberos default port indicating possible lateral movement or first stage PrivEsc via delegation.
EventCode=5156 Channel="Security" DestPort=88 Direction="%%14593" NOT Application="\\device\\harddiskvolume*\\Windows\\System32\\lsass.exe" NOT (Application IN ("\\device\\harddiskvolume*\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe", "\\device\\harddiskvolume*\\Program Files\\Google\\Chrome\\Application\\chrome.exe") OR Application IN ("\\device\\harddiskvolume*\\Program Files (x86)\\Mozilla Firefox\\firefox.exe", "\\device\\harddiskvolume*\\Program Files\\Mozilla Firefox\\firefox.exe") OR Application="*\\tomcat\\bin\\tomcat8.exe")

# ── Microsoft Sync Center Suspicious Network Connections ──
# Mức độ  : Trung bình
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: Detects suspicious connections from Microsoft Sync Center to non-private IPs.
EventCode=5156 Channel="Security" Application="*\\mobsync.exe" NOT (DestAddress="127.0.0.0/8" OR DestAddress="10.0.0.0/8" OR DestAddress="172.16.0.0/12" OR DestAddress="192.168.0.0/16" OR DestAddress="169.254.0.0/16" OR DestAddress="::1/128" OR DestAddress="fe80::/10" OR DestAddress="fc00::/7")

# ── Suspicious Outbound SMTP Connections ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may steal data by exfiltrating it over an un-encrypted network protocol other than that of the existing command and control channel. The data may also be sent to an alternate network locat
EventCode=5156 Channel="Security" DestPort IN (25, 587, 465, 2525) Direction="%%14593" NOT (Application IN ("*\\thunderbird.exe", "*\\outlook.exe") OR Application="\\device\\harddiskvolume*\\Program Files\\Microsoft\\Exchange Server\\*" OR (Application="\\device\\harddiskvolume*\\Program Files\\WindowsApps\\microsoft.windowscommunicationsapps_*" Application="*\\HxTsr.exe"))

# ── Outbound Network Connection To Public IP Via Winlogon ──
# Mức độ  : Trung bình
# Chi tiết: Detects a "winlogon.exe" process that initiate network communications with public IP addresses
EventCode=5156 Channel="Security" Application="*\\winlogon.exe" Direction="%%14593" NOT (DestAddress="127.0.0.0/8" OR DestAddress="10.0.0.0/8" OR DestAddress="172.16.0.0/12" OR DestAddress="192.168.0.0/16" OR DestAddress="169.254.0.0/16" OR DestAddress="::1/128" OR DestAddress="fe80::/10" OR DestAddress="fc00::/7")

# ── Suspicious Wordpad Outbound Connections ──
# Mức độ  : Trung bình
# Chi tiết: Detects a network connection initiated by "wordpad.exe" over uncommon destination ports. This might indicate potential process injection activity from a beacon or similar mechanisms.
EventCode=5156 Channel="Security" Direction="%%14593" Application="*\\wordpad.exe" NOT (DestPort IN (80, 139, 443, 445, 465, 587, 993, 995))

# ── Local Network Connection Initiated By Script Interpreter ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects a script interpreter (Wscript/Cscript) initiating a local network connection to download or execute a script hosted on a shared folder.
EventCode=5156 Channel="Security" Direction="%%14593" Application IN ("*\\wscript.exe", "*\\cscript.exe") DestAddress="127.0.0.0/8" OR DestAddress="10.0.0.0/8" OR DestAddress="172.16.0.0/12" OR DestAddress="192.168.0.0/16" OR DestAddress="169.254.0.0/16" OR DestAddress="::1/128" OR DestAddress="fe80::/10" OR DestAddress="fc00::/7"

# ── Outbound Network Connection Initiated By Script Interpreter ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects a script interpreter wscript/cscript opening a network connection to a non-local network. Adversaries may use script to download malicious payloads.
EventCode=5156 Channel="Security" Direction="%%14593" Application IN ("*\\wscript.exe", "*\\cscript.exe") NOT (DestAddress="127.0.0.0/8" OR DestAddress="10.0.0.0/8" OR DestAddress="172.16.0.0/12" OR DestAddress="192.168.0.0/16" OR DestAddress="169.254.0.0/16" OR DestAddress="::1/128" OR DestAddress="fe80::/10" OR DestAddress="fc00::/7" OR DestAddress="20.0.0.0/11")
