# ── Network Connection Initiated By AddinUtil.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects a network connection initiated by the Add-In deployment cache updating utility "AddInutil.exe". This could indicate a potential command and control communication as this tool doesn't usually i
EventCode=5156 Channel="Security" Direction="%%14593" Application="*\\addinutil.exe"

# ── Uncommon Connection to Active Directory Web Services ──
# Mức độ  : Trung bình
# Chi tiết: Detects uncommon network connections to the Active Directory Web Services (ADWS) from processes not typically associated with ADWS management.
EventCode=5156 Channel="Security" Direction="True" DestPort=9389 NOT (Application="\\device\\harddiskvolume*\\Windows\\system32\\dsac.exe" OR Application="\\device\\harddiskvolume*\\Program Files\\Microsoft Monitoring Agent\\" OR Application IN ("\\device\\harddiskvolume*\\Program Files\\PowerShell\\7\\pwsh.exe*", "\\device\\harddiskvolume*\\Program Files\\PowerShell\\7-preview\\pwsh.ex*", "\\device\\harddiskvolume*\\Windows\\System32\\WindowsPowerShell\\*", "\\device\\harddiskvolume*\\Windows\\SysWOW64\\WindowsPowerShell\\*"))

# ── Uncommon Network Connection Initiated By Certutil.EXE ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects a network connection initiated by the certutil.exe utility. Attackers can abuse the utility in order to download malware or additional payloads.
EventCode=5156 Channel="Security" Application="*\\certutil.exe" Direction="%%14593" DestPort IN (80, 135, 443, 445)

# ── Outbound Network Connection Initiated By Cmstp.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects a network connection initiated by Cmstp.EXE Its uncommon for "cmstp.exe" to initiate an outbound network connection. Investigate the source of such requests to determine if they are malicious.
EventCode=5156 Channel="Security" Application="*\\cmstp.exe" Direction="%%14593" NOT (DestAddress="127.0.0.0/8" OR DestAddress="10.0.0.0/8" OR DestAddress="172.16.0.0/12" OR DestAddress="192.168.0.0/16" OR DestAddress="169.254.0.0/16" OR DestAddress="::1/128" OR DestAddress="fe80::/10" OR DestAddress="fc00::/7")

# ── Outbound Network Connection Initiated By Microsoft Dialer ──
# Mức độ  : Cao
# Chi tiết: Detects outbound network connection initiated by Microsoft Dialer. The Microsoft Dialer, also known as Phone Dialer, is a built-in utility application included in various versions of the Microsoft Win
EventCode=5156 Channel="Security" Application="*:\\Windows\\System32\\dialer.exe" Direction="%%14593" NOT (DestAddress="127.0.0.0/8" OR DestAddress="10.0.0.0/8" OR DestAddress="172.16.0.0/12" OR DestAddress="192.168.0.0/16" OR DestAddress="169.254.0.0/16" OR DestAddress="::1/128" OR DestAddress="fe80::/10" OR DestAddress="fc00::/7")

# ── Network Connection Initiated By Eqnedt32.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects network connections from the Equation Editor process "eqnedt32.exe".
EventCode=5156 Channel="Security" Application="*\\eqnedt32.exe"

# ── Network Connection Initiated via Finger.EXE ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects network connections via finger.exe, which can be abused by threat actors to retrieve remote commands for execution on Windows devices. In one ClickFix malware campaign, adversaries leveraged t
EventCode=5156 Channel="Security" Direction="%%14593" Application="*\\finger.exe"

# ── Network Connection Initiated By IMEWDBLD.EXE ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects a network connection initiated by IMEWDBLD.EXE. This might indicate potential abuse of the utility as a LOLBIN in order to download arbitrary files or additional payloads.
EventCode=5156 Channel="Security" Direction="%%14593" Application="*\\IMEWDBLD.exe"

# ── Network Connection Initiated Via Notepad.EXE ──
# Mức độ  : Cao
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: Detects a network connection that is initiated by the "notepad.exe" process. This might be a sign of process injection from a beacon process or something similar. Notepad rarely initiates a network co
EventCode=5156 Channel="Security" Application="*\\notepad.exe" NOT DestPort=9100

# ── Office Application Initiated Network Connection To Non-Local IP ──
# Mức độ  : Trung bình
