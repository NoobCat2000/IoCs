# ── New BgInfo.EXE Custom DB Path Registry Configuration ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects setting of a new registry database value related to BgInfo configuration. Attackers can for example set this value to save the results of the commands executed by BgInfo in order to exfiltrate
EventCode=4657 Channel="Security" ObjectName="*\\Software\\Winternals\\BGInfo\\Database"

# ── New BgInfo.EXE Custom VBScript Registry Configuration ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects setting of a new registry value related to BgInfo configuration, which can be abused to execute custom VBScript via "BgInfo.exe"
EventCode=4657 Channel="Security" ObjectName="*\\Software\\Winternals\\BGInfo\\UserFields\\*" NewValue="4*"

# ── New BgInfo.EXE Custom WMI Query Registry Configuration ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects setting of a new registry value related to BgInfo configuration, which can be abused to execute custom WMI query via "BgInfo.exe"
EventCode=4657 Channel="Security" ObjectName="*\\Software\\Winternals\\BGInfo\\UserFields\\*" NewValue="6*"

# ── Bypass UAC Using DelegateExecute ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Bypasses User Account Control using a fileless method
EventCode=4657 Channel="Security" ObjectName="*\\open\\command\\DelegateExecute" NewValue="(Empty)"

# ── Bypass UAC Using Event Viewer ──
# Mức độ  : Cao
# Mục đích: Persistence qua autorun
# Chi tiết: Bypasses User Account Control using Event Viewer and a relevant Windows Registry modification
EventCode=4657 Channel="Security" ObjectName="*_Classes\\mscfile\\shell\\open\\command\\(Default)" NOT NewValue="%SystemRoot%\\system32\\mmc.exe \"%1\" %*"

# ── Bypass UAC Using SilentCleanup Task ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects the setting of the environement variable "windir" to a non default value. Attackers often abuse this variable in order to trigger a UAC bypass via the "SilentCleanup" task. The SilentCleanup t
EventCode=4657 Channel="Security" ObjectName="*\\Environment\\windir" NOT NewValue="%SystemRoot%"

# ── Default RDP Port Changed to Non Standard Port ──
# Mức độ  : Cao
# Mục đích: Persistence qua autorun
# Chi tiết: Detects changes to the default RDP port. Remote desktop is a common feature in operating systems. It allows a user to log into a remote system using an interactive session with a graphical user interf
EventCode=4657 Channel="Security" ObjectName="*\\Control\\Terminal Server\\WinStations\\RDP-Tcp\\PortNumber" NOT NewValue="DWORD (0x00000d3d)"

# ── IE Change Domain Zone ──
# Mức độ  : Trung bình
# Chi tiết: Hides the file extension through modification of the registry
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Internet Settings\\ZoneMap\\Domains\\*" NOT (NewValue IN ("DWORD (0x00000000)", "DWORD (0x00000001)", "(Empty)"))

# ── Sysmon Driver Altitude Change ──
# Mức độ  : Cao
# Chi tiết: Detects changes in Sysmon driver altitude value. If the Sysmon driver is configured to load at an altitude of another registered service, it will fail to load at boot.
EventCode=4657 Channel="Security" ObjectName="*\\Services\\*" ObjectName="*\\Instances\\Sysmon Instance\\Altitude"

# ── Change Winevt Channel Access Permission Via Registry ──
# Mức độ  : Cao
# Chi tiết: Detects tampering with the "ChannelAccess" registry key in order to change access to Windows event channel.
EventCode=4657 Channel="Security" ObjectName="*\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels\\*" ObjectName="*\\ChannelAccess" NewValue IN ("*(A;;0x1;;;LA)*", "*(A;;0x1;;;SY)*", "*(A;;0x5;;;BA)*") NOT (ProcessName="C:\\Windows\\servicing\\TrustedInstaller.exe" OR (ProcessName="C:\\Windows\\WinSxS\\*" ProcessName="*\\TiWorker.exe"))

# ── Running Chrome VPN Extensions via the Registry 2 VPN Extension ──
# Mức độ  : Cao
# Chi tiết: Running Chrome VPN Extensions via the Registry install 2 vpn extension
EventCode=4657 Channel="Security" ObjectName="*Software\\Wow6432Node\\Google\\Chrome\\Extensions*" ObjectName="*update_url" ObjectName IN ("*fdcgdnkidjaadafnichfpabhfomcebme*", "*fcfhplploccackoneaefokcmbjfbkenj*", "*bihmplhobchoageeokmgbdihknkjbknd*", "*gkojfkhlekighikafcpjkiklfbnlmeio*", "*jajilbjjinjmgcibalaakngmkilboobh*", "*gjknjjomckknofjidppipffbpoekiipm*", "*nabbmpekekjknlbkgpodfndbodhijjem*", "*kpiecbcckbofpmkkkdibbllpinceiihk*", "*nlbejmccbhkncgokjcmghpfloaajcffj*", "*omghfjlpggmjjaagoclmmobgdodcjboh*", "*bibjcjfmgapbfoljiojpipaooddpkpai*", "*mpcaainmfjjigeicjnlkdfajbioopjko*", "*jljopmgdobloagejpohpldgkiellmfnc*", "*lochiccbgeohimldjooaakjllnafhaid*", "*nhnfcgpcbfclhfafjlooihdfghaeinfc*", "*ookhnhpkphagefgdiemllfajmkdkcaim*", "*namfblliamklmeodpcelkokjbffgmeoo*", "*nbcojefnccbanplpoffopkoepjmhgdgh*", "*majdfhpaihoncoakbjgbdhglocklcgno*", "*lnfdmdhmfbimhhpaeocncdlhiodoblbd*", "*eppiocemhmnlbhjplcgkofciiegomcon*", "*cocfojppfigjeefejbpfmedgjbpchcng*", "*foiopecknacmiihiocgdjgbjokkpkohc*", "*hhdobjgopfphlmjbmnpglhfcgppchgje*", "*jgbaghohigdbgbolncodkdlpenhcmcge*", "*inligpkjkhbpifecbdjhmdpcfhnlelja*", "*higioemojdadgdbhbbbkfbebbdlfjbip*", "*hipncndjamdcmphkgngojegjblibadbe*", "*iolonopooapdagdemdoaihahlfkncfgg*", "*nhfjkakglbnnpkpldhjmpmmfefifedcj*", "*jpgljfpmoofbmlieejglhonfofmahini*", "*fgddmllnllkalaagkghckoinaemmogpe*", "*ejkaocphofnobjdedneohbbiilggdlbi*", "*keodbianoliadkoelloecbhllnpiocoi*", "*hoapmlpnmpaehilehggglehfdlnoegck*", "*poeojclicodamonabcabmapamjkkmnnk*", "*dfkdflfgjdajbhocmfjolpjbebdkcjog*", "*kcdahmgmaagjhocpipbodaokikjkampi*", "*klnkiajpmpkkkgpgbogmcgfjhdoljacg*", "*lneaocagcijjdpkcabeanfpdbmapcjjg*", "*pgfpignfckbloagkfnamnolkeaecfgfh*", "*jplnlifepflhkbkgonidnobkakhmpnmh*", "*jliodmnojccaloajphkingdnpljdhdok*", "*hnmpcagpplmpfojmgmnngilcnanddlhb*", "*ffbkglfijbcbgblgflchnbphjdllaogb*", "*kcndmbbelllkmioekdagahekgimemejo*", "*jdgilggpfmjpbodmhndmhojklgfdlhob*", "*bihhflimonbpcfagfadcnbbdngpopnjb*", "*ppajinakbfocjfnijggfndbdmjggcmde*", "*oofgbpoabipfcfjapgnbbjjaenockbdp*", "*bhnhkdgoefpmekcgnccpnhjfdgicfebm*", "*knmmpciebaoojcpjjoeonlcjacjopcpf*", "*dhadilbmmjiooceioladdphemaliiobo*", "*jedieiamjmoflcknjdjhpieklepfglin*", "*mhngpdlhojliikfknhfaglpnddniijfh*", "*omdakjcmkglenbhjadbccaookpfjihpa*", "*npgimkapccfidfkfoklhpkgmhgfejhbj*", "*akeehkgglkmpapdnanoochpfmeghfdln*", "*gbmdmipapolaohpinhblmcnpmmlgfgje*", "*aigmfoeogfnljhnofglledbhhfegannp*", "*cgojmfochfikphincbhokimmmjenhhgk*", "*ficajfeojakddincjafebjmfiefcmanc*", "*ifnaibldjfdmaipaddffmgcmekjhiloa*", "*jbnmpdkcfkochpanomnkhnafobppmccn*", "*apcfdffemoinopelidncddjbhkiblecc*", "*mjolnodfokkkaichkcjipfgblbfgojpa*", "*oifjbnnafapeiknapihcmpeodaeblbkn*", "*plpmggfglncceinmilojdkiijhmajkjh*", "*mjnbclmflcpookeapghfhapeffmpodij*", "*bblcccknbdbplgmdjnnikffefhdlobhp*", "*aojlhgbkmkahabcmcpifbolnoichfeep*", "*lcmammnjlbmlbcaniggmlejfjpjagiia*", "*knajdeaocbpmfghhmijicidfcmdgbdpm*", "*bdlcnpceagnkjnjlbbbcepohejbheilk*", "*edknjdjielmpdlnllkdmaghlbpnmjmgb*", "*eidnihaadmmancegllknfbliaijfmkgo*", "*ckiahbcmlmkpfiijecbpflfahoimklke*", "*macdlemfnignjhclfcfichcdhiomgjjb*", "*chioafkonnhbpajpengbalkececleldf*", "*amnoibeflfphhplmckdbiajkjaoomgnj*", "*llbhddikeonkpbhpncnhialfbpnilcnc*", "*pcienlhnoficegnepejpfiklggkioccm*", "*iocnglnmfkgfedpcemdflhkchokkfeii*", "*igahhbkcppaollcjeaaoapkijbnphfhb*", "*njpmifchgidinihmijhcfpbdmglecdlb*", "*ggackgngljinccllcmbgnpgpllcjepgc*", "*kchocjcihdgkoplngjemhpplmmloanja*", "*bnijmipndnicefcdbhgcjoognndbgkep*", "*lklekjodgannjcccdlbicoamibgbdnmi*", "*dbdbnchagbkhknegmhgikkleoogjcfge*", "*egblhcjfjmbjajhjhpmnlekffgaemgfh*", "*ehbhfpfdkmhcpaehaooegfdflljcnfec*", "*bkkgdjpomdnfemhhkalfkogckjdkcjkg*", "*almalgbpmcfpdaopimbdchdliminoign*", "*akkbkhnikoeojlhiiomohpdnkhbkhieh*", "*gbfgfbopcfokdpkdigfmoeaajfmpkbnh*", "*bniikohfmajhdcffljgfeiklcbgffppl*", "*lejgfmmlngaigdmmikblappdafcmkndb*", "*ffhhkmlgedgcliajaedapkdfigdobcif*", "*gcknhkkoolaabfmlnjonogaaifnjlfnp*", "*pooljnboifbodgifngpppfklhifechoe*", "*fjoaledfpmneenckfbpdfhkmimnjocfa*", "*aakchaleigkohafkfjfjbblobjifikek*", "*dpplabbmogkhghncfbfdeeokoefdjegm*", "*padekgcemlokbadohgkifijomclgjgif*", "*bfidboloedlamgdmenmlbipfnccokknp*")

# ── ClickOnce Trust Prompt Tampering ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects changes to the ClickOnce trust prompt registry key in order to enable an installation from different locations such as the Internet.
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\MICROSOFT\\.NETFramework\\Security\\TrustManager\\PromptingLevel\\*" ObjectName IN ("*\\Internet", "*\\LocalIntranet", "*\\MyComputer", "*\\TrustedSites", "*\\UntrustedSites") NewValue="Enabled"

# ── Potential CobaltStrike Service Installations - Registry ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects known malicious service installs that appear in cases in which a Cobalt Strike beacon elevates privileges or lateral movement.
EventCode=4657 Channel="Security" ObjectName="*\\System\\CurrentControlSet\\Services*" OR (ObjectName="*\\System\\ControlSet*" ObjectName="*\\Services*") (NewValue="*ADMIN$*" NewValue="*.exe*") OR (NewValue="*%COMSPEC%*" NewValue="*start*" NewValue="*powershell*")

# ── COM Hijack via Sdclt ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects changes to 'HKCU\Software\Classes\Folder\shell\open\command\DelegateExecute'
EventCode=4657 Channel="Security" ObjectName="*\\Software\\Classes\\Folder\\shell\\open\\command\\DelegateExecute*"

# ── CrashControl CrashDump Disabled ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects disabling the CrashDump per registry (as used by HermeticWiper)
EventCode=4657 Channel="Security" ObjectName="*SYSTEM\\CurrentControlSet\\Control\\CrashControl*" NewValue="DWORD (0x00000000)"

# ── Security Event Logging Disabled via MiniNt Registry Key - Registry Set ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects the addition of the 'MiniNt' key to the registry. Upon a reboot, Windows Event Log service will stop writing events. Windows Event Log is a service that collects and stores event logs from the
EventCode=4657 Channel="Security" ObjectName="\\REGISTRY\\MACHINE\\System\\CurrentControlSet\\Control\\MiniNt\\(Default)"

# ── Service Binary in Suspicious Folder ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detect the creation of a service with a service binary located in a suspicious directory
EventCode=4657 Channel="Security" (ObjectName="\\REGISTRY\\MACHINE\\System\\CurrentControlSet\\Services\\*" ObjectName="*\\Start" ProcessName IN ("*\\Users\\Public\\*", "*\\Perflogs\\*", "*\\ADMIN$\\*", "*\\Temp\\*") NewValue IN ("DWORD (0x00000000)", "DWORD (0x00000001)", "DWORD (0x00000002)")) OR (ObjectName="\\REGISTRY\\MACHINE\\System\\CurrentControlSet\\Services\\*" ObjectName="*\\ImagePath" NewValue IN ("*\\Users\\Public\\*", "*\\Perflogs\\*", "*\\ADMIN$\\*", "*\\Temp\\*")) NOT ((ProcessName="*\\Common Files\\*" ProcessName="*\\Temp\\*") OR (ObjectName="*\\CurrentControlSet\\Services\\MBAMInstallerService\\ImagePath" NewValue="*\\AppData\\Local\\Temp\\MBAMInstallerService.exe\"" ProcessName="C:\\Windows\\system32\\services.exe"))

# ── Windows Credential Guard Disabled - Registry ──
# Mức độ  : Cao
# Chi tiết: Detects attempts to disable Windows Credential Guard by setting registry values to 0. Credential Guard uses virtualization-based security to isolate secrets so that only privileged system software can
EventCode=4657 Channel="Security" ObjectName IN ("*\\DeviceGuard\\EnableVirtualizationBasedSecurity", "*\\DeviceGuard\\LsaCfgFlags", "*\\Lsa\\LsaCfgFlags") NewValue="DWORD (0x00000000)"

# ── Custom File Open Handler Executes PowerShell ──
# Mức độ  : Cao
# Chi tiết: Detects the abuse of custom file open handler, executing powershell
EventCode=4657 Channel="Security" ObjectName="*shell\\open\\command\\*" NewValue="*powershell*" NewValue="*-command*"

# ── Potential Registry Persistence Attempt Via DbgManagedDebugger ──
# Mức độ  : Trung bình
# Chi tiết: Detects the addition of the "Debugger" value to the "DbgManagedDebugger" key in order to achieve persistence. Which will get invoked when an application crashes
EventCode=4657 Channel="Security" ObjectName="*\\Microsoft\\.NETFramework\\DbgManagedDebugger" NOT NewValue="\"C:\\Windows\\system32\\vsjitdebugger.exe\" PID %d APPDOM %d EXTEXT \"%s\" EVTHDL %d"

# ── Windows Defender Exclusions Added - Registry ──
# Mức độ  : Trung bình
# Chi tiết: Detects the Setting of Windows Defender Exclusions
EventCode=4657 Channel="Security" ObjectName="*\\Microsoft\\Windows Defender\\Exclusions*"

# ── Potentially Suspicious Desktop Background Change Via Registry ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects registry value settings that would replace the user's desktop background. This is a common technique used by malware to change the desktop background to a ransom note or other image.
EventCode=4657 Channel="Security" ObjectName IN ("*Control Panel\\Desktop*", "*CurrentVersion\\Policies\\ActiveDesktop*", "*CurrentVersion\\Policies\\System*") (ObjectName="*NoChangingWallpaper" NewValue="DWORD (0x00000001)") OR ObjectName="*\\Wallpaper" OR (ObjectName="*\\WallpaperStyle" NewValue="2") NOT (ProcessName="*\\svchost.exe" OR (ObjectName="*\\Control Panel\\Desktop\\Wallpaper" NewValue="(Empty)") OR ProcessName="*C:\\Windows\\Explorer.EXE") NOT (ProcessName IN ("C:\\Program Files\\Amazon\\EC2Launch\\EC2Launch.exe", "C:\\Program Files (x86)\\Amazon\\EC2Launch\\EC2Launch.exe") ObjectName="*\\Control Panel\\Desktop\\Wallpaper")

# ── Antivirus Filter Driver Disallowed On Dev Drive - Registry ──
# Mức độ  : Cao
# Chi tiết: Detects activity that indicates a user disabling the ability for Antivirus mini filter to inspect a "Dev Drive".
EventCode=4657 Channel="Security" ObjectName="*\\FilterManager\\FltmgrDevDriveAllowAntivirusFilter" NewValue="DWORD (0x00000000)"

# ── Windows Hypervisor Enforced Code Integrity Disabled ──
# Mức độ  : Cao
# Chi tiết: Detects changes to the HypervisorEnforcedCodeIntegrity registry key and the "Enabled" value being set to 0 in order to disable the Hypervisor Enforced Code Integrity feature. This allows an attacker t
EventCode=4657 Channel="Security" ObjectName IN ("*\\Control\\DeviceGuard\\HypervisorEnforcedCodeIntegrity", "*\\Control\\DeviceGuard\\Scenarios\\HypervisorEnforcedCodeIntegrity\\Enabled", "*\\Microsoft\\Windows\\DeviceGuard\\HypervisorEnforcedCodeIntegrity") NewValue="DWORD (0x00000000)"

# ── Hypervisor Enforced Paging Translation Disabled ──
# Mức độ  : Cao
# Chi tiết: Detects changes to the "DisableHypervisorEnforcedPagingTranslation" registry value. Where the it is set to "1" in order to disable the Hypervisor Enforced Paging Translation feature.
EventCode=4657 Channel="Security" ObjectName="*\\DisableHypervisorEnforcedPagingTranslation" NewValue="DWORD (0x00000001)"

# ── DHCP Callout DLL Installation ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects the installation of a Callout DLL via CalloutDlls and CalloutEnabled parameter in Registry, which can be used to execute code in context of the DHCP server (restart required)
EventCode=4657 Channel="Security" ObjectName IN ("*\\Services\\DHCPServer\\Parameters\\CalloutDlls", "*\\Services\\DHCPServer\\Parameters\\CalloutEnabled")

# ── Disable Administrative Share Creation at Startup ──
# Mức độ  : Trung bình
# Mục đích: Xóa dấu vết
# Chi tiết: Administrative shares are hidden network shares created by Microsoft Windows NT operating systems that grant system administrators remote access to every disk volume on a network-connected system
EventCode=4657 Channel="Security" ObjectName="*\\Services\\LanmanServer\\Parameters\\*" ObjectName IN ("*\\AutoShareWks", "*\\AutoShareServer") NewValue="DWORD (0x00000000)"

# ── Potential AutoLogger Sessions Tampering ──
# Mức độ  : Cao
# Chi tiết: Detects tampering with autologger trace sessions which is a technique used by attackers to disable logging. The AutoLogger event tracing session records events up that occur early in the operating sys
EventCode=4657 Channel="Security" ObjectName="*\\Control\\WMI\\Autologger\\*" ObjectName IN ("*\\EventLog-*", "*\\Defender*") ObjectName IN ("*\\Enabled", "*\\Start") NewValue="DWORD (0x00000000)" NOT (ProcessName="C:\\Windows\\system32\\wevtutil.exe" OR (ProcessName IN ("C:\\ProgramData\\Microsoft\\Windows Defender\\Platform\\*", "C:\\Program Files\\Windows Defender\\*", "C:\\Program Files (x86)\\Windows Defender\\*") ProcessName="*\\MsMpEng.exe" ObjectName IN ("*\\DefenderApiLogger\\*", "*\\DefenderAuditLogger\\*")))

# ── Disable Microsoft Defender Firewall via Registry ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may disable or modify system firewalls in order to bypass controls limiting network usage
EventCode=4657 Channel="Security" ObjectName="*\\Services\\SharedAccess\\Parameters\\FirewallPolicy\\*" ObjectName="*\\EnableFirewall" NewValue="DWORD (0x00000000)"

# ── Disable Internal Tools or Feature in Registry ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects registry modifications that change features of internal Windows tools (malware like Agent Tesla uses this technique)
EventCode=4657 Channel="Security" (ObjectName IN ("*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\DisableCMD", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\NoControlPanel", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\NoRun", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\StartMenuLogOff", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\DisableChangePassword", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\DisableLockWorkstation", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\DisableRegistryTools", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\DisableTaskmgr", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\NoDispBackgroundPage", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\NoDispCPL", "*SOFTWARE\\Policies\\Microsoft\\Windows\\Explorer\\DisableNotificationCenter", "*SOFTWARE\\Policies\\Microsoft\\Windows\\System\\DisableCMD") NewValue="DWORD (0x00000001)") OR (ObjectName IN ("*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\ConsentPromptBehaviorAdmin", "*Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\InactivityTimeoutSecs", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\shutdownwithoutlogon", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\PushNotifications\\ToastEnabled", "*SYSTEM\\CurrentControlSet\\Control\\Storage\\Write Protection", "*SYSTEM\\CurrentControlSet\\Control\\StorageDevicePolicies\\WriteProtect") NewValue="DWORD (0x00000000)")

# ── Disable Macro Runtime Scan Scope ──
# Mức độ  : Cao
# Chi tiết: Detects tampering with the MacroRuntimeScanScope registry key to disable runtime scanning of enabled macros
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\*" ObjectName="*\\Microsoft\\Office\\*" ObjectName="*\\Common\\Security*" ObjectName="*\\MacroRuntimeScanScope" NewValue="DWORD (0x00000000)"

# ── Disable Privacy Settings Experience in Registry ──
# Mức độ  : Trung bình
# Chi tiết: Detects registry modifications that disable Privacy Settings Experience
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\Policies\\Microsoft\\Windows\\OOBE\\DisablePrivacyExperience" NewValue="DWORD (0x00000000)"

# ── Disable Windows Security Center Notifications ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detect set UseActionCenterExperience to 0 to disable the Windows security center notification
EventCode=4657 Channel="Security" ObjectName="*Windows\\CurrentVersion\\ImmersiveShell\\UseActionCenterExperience" NewValue="DWORD (0x00000000)"

# ── Registry Disable System Restore ──
# Mức độ  : Cao
# Mục đích: Phá hủy backup/recovery
# Chi tiết: Detects the modification of the registry to disable a system restore on the computer
EventCode=4657 Channel="Security" ObjectName IN ("*\\Policies\\Microsoft\\Windows NT\\SystemRestore*", "*\\Microsoft\\Windows NT\\CurrentVersion\\SystemRestore*") ObjectName IN ("*DisableConfig", "*DisableSR") NewValue="DWORD (0x00000001)"

# ── Windows Defender Service Disabled - Registry ──
# Mức độ  : Cao
# Chi tiết: Detects when an attacker or tool disables the  Windows Defender service (WinDefend) via the registry
EventCode=4657 Channel="Security" ObjectName="*\\Services\\WinDefend\\Start" NewValue="DWORD (0x00000004)"

# ── Windows Event Log Access Tampering Via Registry ──
# Mức độ  : Cao
# Mục đích: Persistence qua autorun; Sửa registry
# Chi tiết: Detects changes to the Windows EventLog channel permission values. It focuses on changes to the Security Descriptor Definition Language (SDDL) string, as modifications to these values can restrict acc
EventCode=4657 Channel="Security" (ObjectName="*\\SYSTEM\\CurrentControlSet\\Services\\EventLog\\*" ObjectName="*\\CustomSD") OR (ObjectName IN ("*\\Policies\\Microsoft\\Windows\\EventLog\\*", "*\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels*") ObjectName="*\\ChannelAccess") NewValue="*D:(D;*" OR (NewValue="*D:(*" NewValue="*)(D;*") NOT (ProcessName="C:\\Windows\\servicing\\TrustedInstaller.exe" OR (ProcessName="C:\\Windows\\WinSxS\\*" ProcessName="*\\TiWorker.exe")) NOT (ProcessName="" OR NOT ProcessName=*)

# ── Disable Windows Firewall by Registry ──
# Mức độ  : Trung bình
# Chi tiết: Detect set EnableFirewall to 0 to disable the Windows firewall
EventCode=4657 Channel="Security" ObjectName IN ("*\\SOFTWARE\\Policies\\Microsoft\\WindowsFirewall\\StandardProfile\\EnableFirewall", "*\\SOFTWARE\\Policies\\Microsoft\\WindowsFirewall\\DomainProfile\\EnableFirewall") NewValue="DWORD (0x00000000)"

# ── Disable Windows Event Logging Via Registry ──
# Mức độ  : Cao
# Chi tiết: Detects tampering with the "Enabled" registry key in order to disable Windows logging of a Windows event channel
EventCode=4657 Channel="Security" ObjectName="*\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels\\*" ObjectName="*\\Enabled" NewValue="DWORD (0x00000000)" NOT (ProcessName="C:\\Windows\\system32\\wevtutil.exe" OR (ProcessName="C:\\Windows\\winsxs\\*" ProcessName="*\\TiWorker.exe") OR (ProcessName="C:\\Windows\\System32\\svchost.exe" ObjectName IN ("*\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels\\Microsoft-Windows-FileInfoMinifilter*", "*\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels\\Microsoft-Windows-ASN1\\*", "*\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels\\Microsoft-Windows-Kernel-AppCompat\\*", "*\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels\\Microsoft-Windows-Runtime\\Error\\*", "*\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels\\Microsoft-Windows-CAPI2/Operational\\*")) OR (ProcessName="C:\\Windows\\servicing\\TrustedInstaller.exe" ObjectName="*\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels\\Microsoft-Windows-Compat-Appraiser*")) NOT (ProcessName="" OR NOT ProcessName=*)

# ── Disable Exploit Guard Network Protection on Windows Defender ──
# Mức độ  : Trung bình
# Chi tiết: Detects disabling Windows Defender Exploit Guard Network Protection
EventCode=4657 Channel="Security" ObjectName="*SOFTWARE\\Policies\\Microsoft\\Windows Defender Security Center\\App and Browser protection\\DisallowExploitProtectionOverride*" NewValue="DWORD (00000001)"

# ── Disabled Windows Defender Eventlog ──
# Mức độ  : Cao
# Chi tiết: Detects the disabling of the Windows Defender eventlog as seen in relation to Lockbit 3.0 infections
EventCode=4657 Channel="Security" ObjectName="*\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels\\Microsoft-Windows-Windows Defender/Operational\\Enabled*" NewValue="DWORD (0x00000000)"

# ── Disable PUA Protection on Windows Defender ──
# Mức độ  : Cao
# Chi tiết: Detects disabling Windows Defender PUA protection
EventCode=4657 Channel="Security" ObjectName="*\\Policies\\Microsoft\\Windows Defender\\PUAProtection*" NewValue="DWORD (0x00000000)"

# ── Disable Tamper Protection on Windows Defender ──
# Mức độ  : Trung bình
# Chi tiết: Detects disabling Windows Defender Tamper Protection
EventCode=4657 Channel="Security" ObjectName="*\\Microsoft\\Windows Defender\\Features\\TamperProtection*" NewValue="DWORD (0x00000000)" NOT ((ProcessName="C:\\ProgramData\\Microsoft\\Windows Defender\\Platform\\*" ProcessName="*\\MsMpEng.exe") OR ProcessName="C:\\Program Files\\Windows Defender\\MsMpEng.exe")

# ── Add DisallowRun Execution to Registry ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detect set DisallowRun to 1 to prevent user running specific computer program
EventCode=4657 Channel="Security" ObjectName="*Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\DisallowRun" NewValue="DWORD (0x00000001)"

# ── Persistence Via Disk Cleanup Handler - Autorun ──
# Mức độ  : Trung bình
# Chi tiết: Detects when an attacker modifies values of the Disk Cleanup Handler in the registry to achieve persistence via autorun. The disk cleanup manager is part of the operating system. It displays the dialo
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\VolumeCaches\\*" (ObjectName="*\\Autorun*" NewValue="DWORD (0x00000001)") OR (ObjectName IN ("*\\CleanupString*", "*\\PreCleanupString*") NewValue IN ("*cmd*", "*powershell*", "*rundll32*", "*mshta*", "*cscript*", "*wscript*", "*wsl*", "*\\Users\\Public\\*", "*\\Windows\\TEMP\\*", "*\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\\*"))

# ── DNS-over-HTTPS Enabled by Registry ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects when a user enables DNS-over-HTTPS. This can be used to hide internet activity or be used to hide the process of exfiltrating data. With this enabled organization will lose visibility into dat
EventCode=4657 Channel="Security" (ObjectName="*\\SOFTWARE\\Policies\\Microsoft\\Edge\\BuiltInDnsClientEnabled" NewValue="DWORD (0x00000001)") OR (ObjectName="*\\SOFTWARE\\Google\\Chrome\\DnsOverHttpsMode" NewValue="secure") OR (ObjectName="*\\SOFTWARE\\Policies\\Mozilla\\Firefox\\DNSOverHTTPS\\Enabled" NewValue="DWORD (0x00000001)")

# ── New DNS ServerLevelPluginDll Installed ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects the installation of a DNS plugin DLL via ServerLevelPluginDll parameter in registry, which can be used to execute code in context of the DNS server (restart required)
EventCode=4657 Channel="Security" ObjectName="*\\services\\DNS\\Parameters\\ServerLevelPluginDll"

# ── ETW Logging Disabled In .NET Processes - Sysmon Registry ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Potential adversaries stopping ETW providers recording loaded .NET assemblies.
EventCode=4657 Channel="Security" (ObjectName="*SOFTWARE\\Microsoft\\.NETFramework\\ETWEnabled" NewValue="DWORD (0x00000000)") OR (ObjectName IN ("*\\COMPlus_ETWEnabled", "*\\COMPlus_ETWFlags") NewValue IN (0, "DWORD (0x00000000)"))

# ── Directory Service Restore Mode(DSRM) Registry Value Tampering ──
# Mức độ  : Cao
# Chi tiết: Detects changes to "DsrmAdminLogonBehavior" registry value. During a Domain Controller (DC) promotion, administrators create a Directory Services Restore Mode (DSRM) local administrator account with a
EventCode=4657 Channel="Security" ObjectName="*\\Control\\Lsa\\DsrmAdminLogonBehavior" NOT NewValue="DWORD (0x00000000)"

# ── Periodic Backup For System Registry Hives Enabled ──
# Mức độ  : Trung bình
# Chi tiết: Detects the enabling of the "EnablePeriodicBackup" registry value. Once enabled, The OS will backup System registry hives on restarts to the "C:\Windows\System32\config\RegBack" folder. Windows create
EventCode=4657 Channel="Security" ObjectName="*\\Control\\Session Manager\\Configuration Manager\\EnablePeriodicBackup" NewValue="DWORD (0x00000001)"

# ── Windows Recall Feature Enabled - Registry ──
# Mức độ  : Trung bình
# Chi tiết: Detects the enabling of the Windows Recall feature via registry manipulation. Windows Recall can be enabled by setting the value of "DisableAIDataAnalysis" to "0". Adversaries may enable Windows Recal
EventCode=4657 Channel="Security" ObjectName="*\\Software\\Policies\\Microsoft\\Windows\\WindowsAI\\DisableAIDataAnalysis" NewValue="DWORD (0x00000000)"

# ── Enabling COR Profiler Environment Variables ──
# Mức độ  : Trung bình
# Chi tiết: Detects .NET Framework CLR and .NET Core CLR "cor_enable_profiling" and "cor_profiler" variables being set and configured.
EventCode=4657 Channel="Security" ObjectName IN ("*\\COR_ENABLE_PROFILING", "*\\COR_PROFILER", "*\\CORECLR_ENABLE_PROFILING") OR ObjectName="*\\CORECLR_PROFILER_PATH*"

# ── Scripted Diagnostics Turn Off Check Enabled - Registry ──
# Mức độ  : Trung bình
# Chi tiết: Detects enabling TurnOffCheck which can be used to bypass defense of MSDT Follina vulnerability
EventCode=4657 Channel="Security" ObjectName="*\\Policies\\Microsoft\\Windows\\ScriptedDiagnostics\\TurnOffCheck" NewValue="DWORD (0x00000001)"

# ── Potential EventLog File Location Tampering ──
# Mức độ  : Cao
# Chi tiết: Detects tampering with EventLog service "file" key. In order to change the default location of an Evtx file. This technique is used to tamper with log collection and alerting
EventCode=4657 Channel="Security" ObjectName="*\\SYSTEM\\CurrentControlSet\\Services\\EventLog\\*" ObjectName="*\\File" NOT NewValue="*\\System32\\Winevt\\Logs\\*"

# ── Suspicious Application Allowed Through Exploit Guard ──
# Mức độ  : Cao
# Chi tiết: Detects applications being added to the "allowed applications" list of exploit guard in order to bypass controlled folder settings
EventCode=4657 Channel="Security" ObjectName="*SOFTWARE\\Microsoft\\Windows Defender\\Windows Defender Exploit Guard\\Controlled Folder Access\\AllowedApplications*" ObjectName IN ("*\\Users\\Public\\*", "*\\AppData\\Local\\Temp\\*", "*\\Desktop\\*", "*\\PerfLogs\\*", "*\\Windows\\Temp\\*")

# ── Change User Account Associated with the FAX Service ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detect change of the user account associated with the FAX service to avoid the escalation problem.
EventCode=4657 Channel="Security" ObjectName="\\REGISTRY\\MACHINE\\System\\CurrentControlSet\\Services\\Fax\\ObjectName" NOT NewValue="*NetworkService*"

# ── Change the Fax Dll ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detect possible persistence using Fax DLL load when service restart
EventCode=4657 Channel="Security" ObjectName="*\\Software\\Microsoft\\Fax\\Device Providers\\*" ObjectName="*\\ImageName*" NOT NewValue="%systemroot%\\system32\\fxst30.dll"

# ── New File Association Using Exefile ──
# Mức độ  : Cao
# Chi tiết: Detects the abuse of the exefile handler in new file association. Used for bypass of security products.
EventCode=4657 Channel="Security" ObjectName="*Classes\\.*" NewValue="exefile"

# ── FileFix - Command Evidence in TypedPaths ──
# Mức độ  : Cao
# Chi tiết: Detects commonly-used chained commands and strings in the most recent 'url' value of the 'TypedPaths' key, which could be indicative of a user being targeted by the FileFix technique.
EventCode=4657 Channel="Security" ObjectName="*\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\TypedPaths\\url1" NewValue="*#*" NewValue="*http*" NewValue IN ("*account*", "*anti-bot*", "*botcheck*", "*captcha*", "*challenge*", "*confirmation*", "*fraud*", "*human*", "*identification*", "*identificator*", "*identity*", "*robot*", "*validation*", "*verification*", "*verify*") OR NewValue IN ("*%comspec%*", "*bitsadmin*", "*certutil*", "*cmd*", "*cscript*", "*curl*", "*finger*", "*mshta*", "*powershell*", "*pwsh*", "*regsvr32*", "*rundll32*", "*schtasks*", "*wget*", "*wscript*")

# ── Add Debugger Entry To Hangs Key For Persistence ──
# Mức độ  : Cao
# Chi tiết: Detects when an attacker adds a new "Debugger" value to the "Hangs" key in order to achieve persistence which will get invoked when an application crashes
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\Microsoft\\Windows\\Windows Error Reporting\\Hangs\\Debugger*"

# ── Persistence Via Hhctrl.ocx ──
# Mức độ  : Cao
# Chi tiết: Detects when an attacker modifies the registry value of the "hhctrl" to point to a custom binary
EventCode=4657 Channel="Security" ObjectName="*\\CLSID\\{52A2AAAE-085D-4187-97EA-8C30DB990436}\\InprocServer32\\(Default)*" NOT NewValue="C:\\Windows\\System32\\hhctrl.ocx"

# ── Registry Modification to Hidden File Extension ──
# Mức độ  : Trung bình
# Chi tiết: Hides the file extension through modification of the registry
EventCode=4657 Channel="Security" (ObjectName="*\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\\HideFileExt" NewValue="DWORD (0x00000001)") OR (ObjectName="*\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\\Hidden" NewValue="DWORD (0x00000002)")

# ── Displaying Hidden Files Feature Disabled ──
# Mức độ  : Trung bình
# Chi tiết: Detects modifications to the "Hidden" and "ShowSuperHidden" explorer registry values in order to disable showing of hidden files and system files. This technique is abused by several malware families 
EventCode=4657 Channel="Security" ObjectName IN ("*\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\\ShowSuperHidden", "*\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\\Hidden") NewValue="DWORD (0x00000000)"

# ── Registry Hide Function from User ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects registry modifications that hide internal tools or functions from the user (malware like Agent Tesla, Hermetic Wiper uses this technique)
EventCode=4657 Channel="Security" (ObjectName IN ("*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\HideClock", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\HideSCAHealth", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\HideSCANetwork", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\HideSCAPower", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\HideSCAVolume") NewValue="DWORD (0x00000001)") OR (ObjectName IN ("*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\\ShowInfoTip", "*SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\Advanced\\ShowCompColor") NewValue="DWORD (0x00000000)")

# ── Hide Schedule Task Via Index Value Tamper ──
# Mức độ  : Cao
# Chi tiết: Detects when the "index" value of a scheduled task is modified from the registry Which effectively hides it from any tooling such as "schtasks /query" (Read the referenced link for more information ab
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Schedule\\TaskCache\\Tree\\*" ObjectName="*Index*" NewValue="DWORD (0x00000000)"

# ── Driver Added To Disallowed Images In HVCI - Registry ──
# Mức độ  : Cao
# Chi tiết: Detects changes to the "HVCIDisallowedImages" registry value to potentially add a driver to the list, in order to prevent it from loading.
EventCode=4657 Channel="Security" ObjectName="*\\Control\\CI\\*" ObjectName="*\\HVCIDisallowedImages*"

# ── IE ZoneMap Setting Downgraded To MyComputer Zone For HTTP Protocols ──
# Mức độ  : Cao
# Chi tiết: Detects changes to Internet Explorer's (IE / Windows Internet properties) ZoneMap configuration of the "HTTP" and "HTTPS" protocols to point to the "My Computer" zone. This allows downloaded files fro
EventCode=4657 Channel="Security" ObjectName="*\\Microsoft\\Windows\\CurrentVersion\\Internet Settings\\ZoneMap\\ProtocolDefaults*" ObjectName IN ("*\\http", "*\\https") NewValue="*DWORD (0x00000000)*"

# ── Uncommon Extension In Keyboard Layout IME File Registry Value ──
# Mức độ  : Cao
# Chi tiết: Detects usage of Windows Input Method Editor (IME) keyboard layout feature, which allows an attacker to load a DLL into the process after sending the WM_INPUTLANGCHANGEREQUEST message. Before doing th
EventCode=4657 Channel="Security" ObjectName="*\\Control\\Keyboard Layouts\\*" ObjectName="*Ime File*" NOT NewValue="*.ime"

# ── Suspicious Path In Keyboard Layout IME File Registry Value ──
# Mức độ  : Cao
# Chi tiết: Detects usage of Windows Input Method Editor (IME) keyboard layout feature, which allows an attacker to load a DLL into the process after sending the WM_INPUTLANGCHANGEREQUEST message. Before doing th
EventCode=4657 Channel="Security" ObjectName="*\\Control\\Keyboard Layouts\\*" ObjectName="*Ime File*" NewValue IN ("*:\\Perflogs\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Temp\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Roaming\\*", "*\\Temporary Internet*") OR (NewValue="*:\\Users\\*" NewValue="*\\Favorites\\*") OR (NewValue="*:\\Users\\*" NewValue="*\\Favourites\\*") OR (NewValue="*:\\Users\\*" NewValue="*\\Contacts\\*")

# ── New Root or CA or AuthRoot Certificate to Store ──
# Mức độ  : Trung bình
# Mục đích: Phá hủy backup/recovery
# Chi tiết: Detects the addition of new root, CA or AuthRoot certificates to the Windows registry
EventCode=4657 Channel="Security" ObjectName IN ("*\\SOFTWARE\\Microsoft\\SystemCertificates\\Root\\Certificates\\*", "*\\SOFTWARE\\Policies\\Microsoft\\SystemCertificates\\Root\\Certificates\\*", "*\\SOFTWARE\\Microsoft\\EnterpriseCertificates\\Root\\Certificates\\*", "*\\SOFTWARE\\Microsoft\\SystemCertificates\\CA\\Certificates\\*", "*\\SOFTWARE\\Policies\\Microsoft\\SystemCertificates\\CA\\Certificates\\*", "*\\SOFTWARE\\Microsoft\\EnterpriseCertificates\\CA\\Certificates\\*", "*\\SOFTWARE\\Microsoft\\SystemCertificates\\AuthRoot\\Certificates\\*", "*\\SOFTWARE\\Policies\\Microsoft\\SystemCertificates\\AuthRoot\\Certificates\\*", "*\\SOFTWARE\\Microsoft\\EnterpriseCertificates\\AuthRoot\\Certificates\\*") ObjectName="*\\Blob" NewValue="Binary Data"

# ── Internet Explorer DisableFirstRunCustomize Enabled ──
# Mức độ  : Trung bình
# Chi tiết: Detects changes to the Internet Explorer "DisableFirstRunCustomize" value, which prevents Internet Explorer from running the first run wizard the first time a user starts the browser after installing 
EventCode=4657 Channel="Security" ObjectName="*\\Microsoft\\Internet Explorer\\Main\\DisableFirstRunCustomize" NewValue IN ("DWORD (0x00000001)", "DWORD (0x00000002)") NOT (ProcessName IN ("C:\\Windows\\explorer.exe", "C:\\Windows\\System32\\ie4uinit.exe")) NOT ((ProcessName="*\\Temp\\*" ProcessName="*\\.cr\\avira_*" NewValue="*DWORD (0x00000001)*") OR (ProcessName IN ("C:\\Program Files (x86)\\Foxit Software\\Foxit PDF Reader\\FoxitPDFReader.exe", "C:\\Program Files\\Foxit Software\\Foxit PDF Reader\\FoxitPDFReader.exe") NewValue="*DWORD (0x00000001)*"))

# ── Potential Ransomware Activity Using LegalNotice Message ──
# Mức độ  : Cao
# Chi tiết: Detect changes to the "LegalNoticeCaption" or "LegalNoticeText" registry values where the message set contains keywords often used in ransomware ransom messages
EventCode=4657 Channel="Security" ObjectName IN ("*\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\LegalNoticeCaption*", "*\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System\\LegalNoticeText*") NewValue IN ("*encrypted*", "*Unlock-Password*", "*paying*")

# ── Lolbas OneDriveStandaloneUpdater.exe Proxy Download ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects setting a custom URL for OneDriveStandaloneUpdater.exe to download a file from the Internet without executing any anomalous executables with suspicious arguments. The downloaded file will be i
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\Microsoft\\OneDrive\\UpdateOfficeConfig\\UpdateRingSettingURLFromOC*"

# ── RestrictedAdminMode Registry Value Tampering ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects changes to the "DisableRestrictedAdmin" registry value in order to disable or enable RestrictedAdmin mode. RestrictedAdmin mode prevents the transmission of reusable credentials to the remote 
EventCode=4657 Channel="Security" ObjectName="*System\\CurrentControlSet\\Control\\Lsa\\DisableRestrictedAdmin"

# ── Lsass Full Dump Request Via DumpType Registry Settings ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the setting of the "DumpType" registry value to "2" which stands for a "Full Dump". Technique such as LSASS Shtinkering requires this value to be "2" in order to dump LSASS.
EventCode=4657 Channel="Security" ObjectName IN ("*\\SOFTWARE\\Microsoft\\Windows\\Windows Error Reporting\\LocalDumps\\DumpType*", "*\\SOFTWARE\\Microsoft\\Windows\\Windows Error Reporting\\LocalDumps\\lsass.exe\\DumpType*") NewValue="DWORD (0x00000002)"

# ── NET NGenAssemblyUsageLog Registry Key Tamper ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects changes to the NGenAssemblyUsageLog registry key. .NET Usage Log output location can be controlled by setting the NGenAssemblyUsageLog CLR configuration knob in the Registry or by configuring 
EventCode=4657 Channel="Security" ObjectName="*SOFTWARE\\Microsoft\\.NETFramework\\NGenAssemblyUsageLog"

# ── New Netsh Helper DLL Registered From A Suspicious Location ──
# Mức độ  : Cao
# Chi tiết: Detects changes to the Netsh registry key to add a new DLL value that is located on a suspicious location. This change might be an indication of a potential persistence attempt by adding a malicious N
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\Microsoft\\NetSh*" NewValue IN ("*:\\Perflogs\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Temp\\*", "*\\AppData\\Local\\Temp\\*", "*\\Temporary Internet*") OR (NewValue="*:\\Users\\*" NewValue="*\\Favorites\\*") OR (NewValue="*:\\Users\\*" NewValue="*\\Favourites\\*") OR (NewValue="*:\\Users\\*" NewValue="*\\Contacts\\*") OR (NewValue="*:\\Users\\*" NewValue="*\\Pictures\\*")

# ── Potential Persistence Via Netsh Helper DLL - Registry ──
# Mức độ  : Trung bình
# Chi tiết: Detects changes to the Netsh registry key to add a new DLL value. This change might be an indication of a potential persistence attempt by adding a malicious Netsh helper
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\Microsoft\\NetSh*" NewValue="*.dll*" NOT (ProcessName="C:\\Windows\\System32\\poqexec.exe" NewValue IN ("ipmontr.dll", "iasmontr.dll", "ippromon.dll"))

# ── New Application in AppCompat ──
# Mức độ  : Thông tin
# Chi tiết: A General detection for a new application in AppCompat. This indicates an application executing for the first time on an endpoint.
EventCode=4657 Channel="Security" ObjectName="*\\AppCompatFlags\\Compatibility Assistant\\Store\\*"

# ── Potential Credential Dumping Attempt Using New NetworkProvider - REG ──
# Mức độ  : Trung bình
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects when an attacker tries to add a new network provider in order to dump clear text credentials, similar to how the NPPSpy tool does it
EventCode=4657 Channel="Security" ObjectName="*\\System\\CurrentControlSet\\Services\\*" ObjectName="*\\NetworkProvider*" NOT (ObjectName IN ("*\\System\\CurrentControlSet\\Services\\WebClient\\NetworkProvider*", "*\\System\\CurrentControlSet\\Services\\LanmanWorkstation\\NetworkProvider*", "*\\System\\CurrentControlSet\\Services\\RDPNP\\NetworkProvider*") OR ProcessName="C:\\Windows\\System32\\poqexec.exe")

# ── New ODBC Driver Registered ──
# Mức độ  : Thấp
# Chi tiết: Detects the registration of a new ODBC driver.
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\ODBC\\ODBCINST.INI\\*" ObjectName="*\\Driver" NOT (ObjectName="*\\SQL Server\\*" NewValue="%WINDIR%\\System32\\SQLSRV32.dll") NOT ((ObjectName="*\\Microsoft Access *" NewValue="C:\\Progra*" NewValue="*\\ACEODBC.DLL") OR (ObjectName="*\\Microsoft Excel Driver*" NewValue="C:\\Progra*" NewValue="*\\ACEODBC.DLL"))

# ── Potentially Suspicious ODBC Driver Registered ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the registration of a new ODBC driver where the driver is located in a potentially suspicious location
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\ODBC\\ODBCINST.INI\\*" ObjectName IN ("*\\Driver", "*\\Setup") NewValue IN ("*:\\PerfLogs\\*", "*:\\ProgramData\\*", "*:\\Temp\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Registration\\CRMLog*", "*:\\Windows\\System32\\com\\dmp\\*", "*:\\Windows\\System32\\FxsTmp\\*", "*:\\Windows\\System32\\Microsoft\\Crypto\\RSA\\MachineKeys\\*", "*:\\Windows\\System32\\spool\\drivers\\color\\*", "*:\\Windows\\System32\\spool\\PRINTERS\\*", "*:\\Windows\\System32\\spool\\SERVERS\\*", "*:\\Windows\\System32\\Tasks_Migrated\\*", "*:\\Windows\\System32\\Tasks\\Microsoft\\Windows\\SyncCenter\\*", "*:\\Windows\\SysWOW64\\com\\dmp\\*", "*:\\Windows\\SysWOW64\\FxsTmp\\*", "*:\\Windows\\SysWOW64\\Tasks\\Microsoft\\Windows\\PLA\\System\\*", "*:\\Windows\\SysWOW64\\Tasks\\Microsoft\\Windows\\SyncCenter\\*", "*:\\Windows\\Tasks\\*", "*:\\Windows\\Temp\\*", "*:\\Windows\\Tracing\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Roaming\\*")

# ── Trust Access Disable For VBApplications ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects registry changes to Microsoft Office "AccessVBOM" to a value of "1" which disables trust access for VBA on the victim machine and lets attackers execute malicious macros without any Microsoft 
EventCode=4657 Channel="Security" ObjectName="*\\Security\\AccessVBOM" NewValue="DWORD (0x00000001)"

# ── Microsoft Office Protected View Disabled ──
# Mức độ  : Cao
# Chi tiết: Detects changes to Microsoft Office protected view registry keys with which the attacker disables this feature.
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\Microsoft\\Office\\*" ObjectName="*\\Security\\ProtectedView\\*" (NewValue="DWORD (0x00000001)" ObjectName IN ("*\\DisableAttachementsInPV", "*\\DisableInternetFilesInPV", "*\\DisableIntranetCheck", "*\\DisableUnsafeLocationsInPV")) OR (NewValue="DWORD (0x00000000)" ObjectName IN ("*\\enabledatabasefileprotectedview", "*\\enableforeigntextfileprotectedview"))

# ── Python Function Execution Security Warning Disabled In Excel - Registry ──
# Mức độ  : Cao
# Chi tiết: Detects changes to the registry value "PythonFunctionWarnings" that would prevent any warnings or alerts from showing when Python functions are about to be executed. Threat actors could run malicious 
EventCode=4657 Channel="Security" ObjectName="*\\Microsoft\\Office\\*" ObjectName="*\\Excel\\Security\\PythonFunctionWarnings" NewValue="DWORD (0x00000001)"

# ── Enable Microsoft Dynamic Data Exchange ──
# Mức độ  : Trung bình
# Chi tiết: Enable Dynamic Data Exchange protocol (DDE) in all supported editions of Microsoft Word or Excel.
EventCode=4657 Channel="Security" (ObjectName="*\\Word\\Security\\AllowDDE" NewValue IN ("DWORD (0x00000001)", "DWORD (0x00000002)")) OR (ObjectName IN ("*\\Excel\\Security\\DisableDDEServerLaunch", "*\\Excel\\Security\\DisableDDEServerLookup") NewValue="DWORD (0x00000000)")

# ── Potential Persistence Via Outlook LoadMacroProviderOnBoot Setting ──
# Mức độ  : Cao
# Chi tiết: Detects the modification of Outlook setting "LoadMacroProviderOnBoot" which if enabled allows the automatic loading of any configured VBA project/module
EventCode=4657 Channel="Security" ObjectName="*\\Outlook\\LoadMacroProviderOnBoot" NewValue="*0x00000001*"

# ── Outlook Macro Execution Without Warning Setting Enabled ──
# Mức độ  : Cao
# Chi tiết: Detects the modification of Outlook security setting to allow unprompted execution of macros.
EventCode=4657 Channel="Security" ObjectName="*\\Outlook\\Security\\Level" NewValue="*0x00000001*"

# ── Outlook EnableUnsafeClientMailRules Setting Enabled - Registry ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects an attacker trying to enable the outlook security setting "EnableUnsafeClientMailRules" which allows outlook to run applications or execute macros
EventCode=4657 Channel="Security" ObjectName="*\\Outlook\\Security\\EnableUnsafeClientMailRules" NewValue="DWORD (0x00000001)"

# ── Outlook Security Settings Updated - Registry ──
# Mức độ  : Trung bình
# Chi tiết: Detects changes to the registry values related to outlook security settings
EventCode=4657 Channel="Security" ObjectName="*\\SOFTWARE\\Microsoft\\Office\\*" ObjectName="*\\Outlook\\Security\\*" NOT (ProcessName IN ("C:\\Program Files\\Microsoft Office\\*", "C:\\Program Files (x86)\\Microsoft Office\\*") ProcessName="*\\OUTLOOK.EXE")

# ── Macro Enabled In A Potentially Suspicious Document ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects registry changes to Office trust records where the path is located in a potentially suspicious location
EventCode=4657 Channel="Security" ObjectName="*\\Security\\Trusted Documents\\TrustRecords*" ObjectName IN ("*/AppData/Local/Microsoft/Windows/INetCache/*", "*/AppData/Local/Temp/*", "*/PerfLogs/*", "*C:/Users/Public/*", "*file:///D:/*", "*file:///E:/*")

# ── Uncommon Microsoft Office Trusted Location Added ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects changes to registry keys related to "Trusted Location" of Microsoft Office where the path is set to something uncommon. Attackers might add additional trusted locations to avoid macro security
EventCode=4657 Channel="Security" ObjectName="*Security\\Trusted Locations\\Location*" ObjectName="*\\Path" NOT ((ProcessName="*:\\Program Files\\Common Files\\Microsoft Shared\\ClickToRun\\*" ProcessName="*\\OfficeClickToRun.exe") OR ProcessName IN ("*:\\Program Files\\Microsoft Office\\*", "*:\\Program Files (x86)\\Microsoft Office\\*")) NOT (NewValue IN ("*%APPDATA%\\Microsoft\\Templates*", "*%%APPDATA%%\\Microsoft\\Templates*", "*%APPDATA%\\Microsoft\\Word\\Startup*", "*%%APPDATA%%\\Microsoft\\Word\\Startup*", "*:\\Program Files (x86)\\Microsoft Office\\root\\Templates\\*", "*:\\Program Files\\Microsoft Office (x86)\\Templates*", "*:\\Program Files\\Microsoft Office\\root\\Templates\\*", "*:\\Program Files\\Microsoft Office\\Templates\\*"))

# ── Office Macros Warning Disabled ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects registry changes to Microsoft Office "VBAWarning" to a value of "1" which enables the execution of all macros, whether signed or unsigned.
EventCode=4657 Channel="Security" ObjectName="*\\Security\\VBAWarnings" NewValue="DWORD (0x00000001)"

# ── MaxMpxCt Registry Value Changed ──
# Mức độ  : Thấp
# Mục đích: Xóa dấu vết
# Chi tiết: Detects changes to the "MaxMpxCt" registry value. MaxMpxCt specifies the maximum outstanding network requests for the server per client, which is used when negotiating a Server Message Block (SMB) con
EventCode=4657 Channel="Security" ObjectName="*\\Services\\LanmanServer\\Parameters\\MaxMpxCt"

# ── Potential Persistence Via New AMSI Providers - Registry ──
# Mức độ  : Trung bình
