EventCode=4657 Channel="Security" ObjectName="*\\cmmgr32.exe*"

# ── Windows Defender Threat Severity Default Action Modified ──
# Mức độ  : Cao
# Chi tiết: Detects modifications or creations of Windows Defender's default threat action settings based on severity to 'allow' or take 'no action'. This is a highly suspicious configuration change that effectiv
EventCode=4657 Channel="Security" ObjectName="*\\Microsoft\\Windows Defender\\Threats\\ThreatSeverityDefaultAction\\*" ObjectName IN ("*\\1", "*\\2", "*\\4", "*\\5") NewValue IN ("DWORD (0x00000006)", "DWORD (0x00000009)")

# ── Disable Security Events Logging Adding Reg Key MiniNt ──
# Mức độ  : Cao
# Mục đích: Sửa registry
