EventCode=4657 Channel="Security" (ObjectName="\\REGISTRY\\MACHINE\\SYSTEM\\CurrentControlSet\\Control\\MiniNt" OperationType="%%1904") OR NewName="HKLM\\SYSTEM\\CurrentControlSet\\Control\\MiniNt"

# ── Wdigest CredGuard Registry Modification ──
