EventCode=4688 Channel="Security" CommandLine IN ("*COMPlus_ETWEnabled*", "*COMPlus_ETWFlags*")

# ── ETW Trace Evasion Activity ──
# Mức độ  : Cao
# Mục đích: Xóa dấu vết
# Chi tiết: Detects command line activity that tries to clear or disable any ETW trace log which could be a sign of logging evasion.
EventCode=4688 Channel="Security" (CommandLine="*cl*" CommandLine="*/Trace*") OR (CommandLine="*clear-log*" CommandLine="*/Trace*") OR (CommandLine="*sl*" CommandLine="*/e:false*") OR (CommandLine="*set-log*" CommandLine="*/e:false*") OR (CommandLine="*logman*" CommandLine="*update*" CommandLine="*trace*" CommandLine="*--p*" CommandLine="*-ets*") OR CommandLine="*Remove-EtwTraceProvider*" OR (CommandLine="*Set-EtwTraceProvider*" CommandLine="*0x11*")

# ── Suspicious Eventlog Clearing or Configuration Change Activity ──
# Mức độ  : Cao
# Chi tiết: Detects the clearing or configuration tampering of EventLog using utilities such as "wevtutil", "powershell" and "wmic". This technique were seen used by threat actors and ransomware strains in order 
EventCode=4688 Channel="Security" (NewProcessName="*\\wevtutil.exe" OR OriginalFileName="wevtutil.exe" CommandLine IN ("*clear-log *", "* cl *", "*set-log *", "* sl *", "*lfn:*")) OR (NewProcessName IN ("*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe") CommandLine IN ("*Clear-EventLog *", "*Remove-EventLog *", "*Limit-EventLog *", "*Clear-WinEvent *") OR (CommandLine="*Eventing.Reader.EventLogSession*" CommandLine="*ClearLog*") OR (CommandLine="*Diagnostics.EventLog*" CommandLine="*Clear*")) OR (CommandLine="*ClearEventLog*" NewProcessName IN ("*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe", "*\\wmic.exe")) NOT (CommandLine="* sl *" ParentProcessName IN ("C:\\Windows\\SysWOW64\\msiexec.exe", "C:\\Windows\\System32\\msiexec.exe"))

# ── Potentially Suspicious EventLog Recon Activity Using Log Query Utilities ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of different log query utilities and commands to search and dump the content of specific event logs or look for specific event IDs. This technique is used by threat actors in order t
EventCode=4688 Channel="Security" CommandLine IN ("*Microsoft-Windows-PowerShell*", "*Microsoft-Windows-Security-Auditing*", "*Microsoft-Windows-TerminalServices-LocalSessionManager*", "*Microsoft-Windows-TerminalServices-RemoteConnectionManager*", "*Microsoft-Windows-Windows Defender*", "*PowerShellCore*", "*Security*", "*Windows PowerShell*") OR CommandLine IN ("*-InstanceId 462**", "*.eventid -eq 462**", "*.ID -eq 462**", "*EventCode=*462**", "*EventIdentifier=*462**", "*System[EventID=462*]*", "*-InstanceId 4778*", "*.eventid -eq 4778*", "*.ID -eq 4778*", "*EventCode=*4778**", "*EventIdentifier=*4778**", "*System[EventID=4778]*", "*-InstanceId 25*", "*.eventid -eq 25*", "*.ID -eq 25*", "*EventCode=*25**", "*EventIdentifier=*25**", "*System[EventID=25]*", "*-InstanceId 1149*", "*.eventid -eq 1149*", "*.ID -eq 1149*", "*EventCode=*1149**", "*EventIdentifier=*1149**", "*System[EventID=1149]*", "*-InstanceId 21*", "*.eventid -eq 21*", "*.ID -eq 21*", "*EventCode=*21**", "*EventIdentifier=*21**", "*System[EventID=21]*", "*-InstanceId 22*", "*.eventid -eq 22*", "*.ID -eq 22*", "*EventCode=*22**", "*EventIdentifier=*22**", "*System[EventID=22]*") (CommandLine="*Select*" CommandLine="*Win32_NTLogEvent*") OR (NewProcessName="*\\wevtutil.exe" OR OriginalFileName="wevtutil.exe" CommandLine IN ("* qe *", "* query-events *")) OR (NewProcessName="*\\wmic.exe" OR OriginalFileName="wmic.exe" CommandLine="* ntevent*") OR CommandLine IN ("*Get-WinEvent *", "*get-eventlog *")

# ── Potentially Suspicious Execution From Parent Process In Public Folder ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects a potentially suspicious execution of a parent process located in the "\Users\Public" folder executing a child process containing references to shell or scripting binaries and commandlines.
EventCode=4688 Channel="Security" ParentProcessName="*:\\Users\\Public\\*" NewProcessName IN ("*\\bitsadmin.exe", "*\\certutil.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") OR CommandLine IN ("*bitsadmin*", "*certutil*", "*cscript*", "*mshta*", "*powershell*", "*regsvr32*", "*rundll32*", "*wscript*")

# ── Process Execution From A Potentially Suspicious Folder ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects a potentially suspicious execution from an uncommon folder.
EventCode=4688 Channel="Security" NewProcessName IN ("*:\\Perflogs\\*", "*:\\Users\\All Users\\*", "*:\\Users\\Default\\*", "*:\\Users\\NetworkService\\*", "*:\\Windows\\addins\\*", "*:\\Windows\\debug\\*", "*:\\Windows\\Fonts\\*", "*:\\Windows\\Help\\*", "*:\\Windows\\IME\\*", "*:\\Windows\\Media\\*", "*:\\Windows\\repair\\*", "*:\\Windows\\security\\*", "*:\\Windows\\System32\\Tasks\\*", "*:\\Windows\\Tasks\\*", "*$Recycle.bin*", "*\\config\\systemprofile\\*", "*\\Intel\\Logs\\*", "*\\RSA\\MachineKeys\\*") NOT (NewProcessName="C:\\Users\\Public\\IBM\\ClientSolutions\\Start_Programs\\*" OR (NewProcessName="C:\\Windows\\SysWOW64\\config\\systemprofile\\Citrix\\UpdaterBinaries\\*" NewProcessName="*\\CitrixReceiverUpdater.exe"))

# ── Suspicious FileFix Execution Pattern ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious FileFix execution patterns where users are tricked into running malicious commands through browser file upload dialog manipulation. This attack typically begins when users visit mal
EventCode=4688 Channel="Security" CommandLine="*#*" ParentProcessName IN ("*\\brave.exe", "*\\chrome.exe", "*\\firefox.exe", "*\\msedge.exe") CommandLine IN ("*%comspec%*", "*bitsadmin*", "*certutil*", "*cmd*", "*cscript*", "*curl*", "*finger*", "*mshta*", "*powershell*", "*pwsh*", "*regsvr32*", "*rundll32*", "*schtasks*", "*wget*", "*wscript*") OR CommandLine IN ("*account*", "*anti-bot*", "*botcheck*", "*captcha*", "*challenge*", "*confirmation*", "*fraud*", "*human*", "*identification*", "*identificator*", "*identity*", "*robot*", "*validation*", "*verification*", "*verify*")

# ── Suspicious Reconnaissance Activity Via GatherNetworkInfo.VBS ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution of the built-in script located in "C:\Windows\System32\gatherNetworkInfo.vbs". Which can be used to gather information about the target machine
EventCode=4688 Channel="Security" CommandLine="*gatherNetworkInfo.vbs*" NOT (NewProcessName IN ("*\\cscript.exe", "*\\wscript.exe"))

# ── Potential Hidden Directory Creation Via NTFS INDEX_ALLOCATION Stream - CLI ──
# Mức độ  : Trung bình
# Chi tiết: Detects command line containing reference to the "::$index_allocation" stream, which can be used as a technique to prevent access to folders or files from tooling such as "explorer.exe" or "powershell
EventCode=4688 Channel="Security" CommandLine="*::$index_allocation*"

# ── Writing Of Malicious Files To The Fonts Folder ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Monitors for the hiding possible malicious files in the C:\Windows\Fonts\ location. This folder doesn't require admin privillege to be written and executed from.
EventCode=4688 Channel="Security" CommandLine IN ("*echo*", "*copy*", "*type*", "*file createnew*", "*cacls*") CommandLine="*C:\\Windows\\Fonts\\*" CommandLine IN ("*.sh*", "*.exe*", "*.dll*", "*.bin*", "*.bat*", "*.cmd*", "*.js*", "*.msh*", "*.reg*", "*.scr*", "*.ps*", "*.vb*", "*.jar*", "*.pl*", "*.inf*", "*.cpl*", "*.hta*", "*.msi*", "*.vbs*")

# ── Potential Homoglyph Attack Using Lookalike Characters ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects the presence of unicode characters which are homoglyphs, or identical in appearance, to ASCII letter characters. This is used as an obfuscation and masquerading techniques. Only "perfect" homo
EventCode=4688 Channel="Security" CommandLine IN ("*А*", "*В*", "*Е*", "*К*", "*М*", "*Н*", "*О*", "*Р*", "*С*", "*Т*", "*Х*", "*Ѕ*", "*І*", "*Ј*", "*Ү*", "*Ӏ*", "*Ԍ*", "*Ԛ*", "*Ԝ*", "*Α*", "*Β*", "*Ε*", "*Ζ*", "*Η*", "*Ι*", "*Κ*", "*Μ*", "*Ν*", "*Ο*", "*Ρ*", "*Τ*", "*Υ*", "*Χ*") OR CommandLine IN ("*а*", "*е*", "*о*", "*р*", "*с*", "*х*", "*ѕ*", "*і*", "*ӏ*", "*ј*", "*һ*", "*ԁ*", "*ԛ*", "*ԝ*", "*ο*")

# ── Execution Of Non-Existing File ──
# Mức độ  : Cao
# Chi tiết: Checks whether the image specified in a process creation event is not a full, absolute path (caused by process ghosting or other unorthodox methods to start a process)
EventCode=4688 Channel="Security" NOT NewProcessName="*\\*" NOT (NOT NewProcessName=* OR NewProcessName IN ("-", "") OR NewProcessName IN ("System", "Registry", "MemCompression", "vmmem") OR CommandLine IN ("Registry", "MemCompression", "vmmem"))

# ── Base64 MZ Header In CommandLine ──
# Mức độ  : Cao
# Chi tiết: Detects encoded base64 MZ header in the commandline
EventCode=4688 Channel="Security" CommandLine IN ("*TVqQAAMAAAAEAAAA*", "*TVpQAAIAAAAEAA8A*", "*TVqAAAEAAAAEABAA*", "*TVoAAAAAAAAAAAAA*", "*TVpTAQEAAAAEAAAA*")

# ── Potentially Suspicious Inline JavaScript Execution via NodeJS Binary ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects potentially suspicious inline JavaScript execution using Node.js with specific keywords in the command line.
EventCode=4688 Channel="Security" NewProcessName="*\\node.exe" OR OriginalFileName="node.exe" OR Product="Node.js" CommandLine="*http*" CommandLine="*execSync*" CommandLine="*spawn*" CommandLine="*fs*" CommandLine="*path*" CommandLine="*zlib*"

# ── Potential WinAPI Calls Via CommandLine ──
# Mức độ  : Cao
# Chi tiết: Detects the use of WinAPI Functions via the commandline. As seen used by threat actors via the tool winapiexec
EventCode=4688 Channel="Security" CommandLine IN ("*AddSecurityPackage*", "*AdjustTokenPrivileges*", "*Advapi32*", "*CloseHandle*", "*CreateProcessWithToken*", "*CreatePseudoConsole*", "*CreateRemoteThread*", "*CreateThread*", "*CreateUserThread*", "*DangerousGetHandle*", "*DuplicateTokenEx*", "*EnumerateSecurityPackages*", "*FreeHGlobal*", "*FreeLibrary*", "*GetDelegateForFunctionPointer*", "*GetLogonSessionData*", "*GetModuleHandle*", "*GetProcAddress*", "*GetProcessHandle*", "*GetTokenInformation*", "*ImpersonateLoggedOnUser*", "*kernel32*", "*LoadLibrary*", "*memcpy*", "*MiniDumpWriteDump*", "*ntdll*", "*OpenDesktop*", "*OpenProcess*", "*OpenProcessToken*", "*OpenThreadToken*", "*OpenWindowStation*", "*PtrToString*", "*QueueUserApc*", "*ReadProcessMemory*", "*RevertToSelf*", "*RtlCreateUserThread*", "*secur32*", "*SetThreadToken*", "*VirtualAlloc*", "*VirtualFree*", "*VirtualProtect*", "*WaitForSingleObject*", "*WriteInt32*", "*WriteProcessMemory*", "*ZeroFreeGlobalAllocUnicode*") NOT ((CommandLine="*GetLoadLibraryWAddress32*" NewProcessName="*\\MpCmdRun.exe") OR (CommandLine IN ("*FreeHGlobal*", "*PtrToString*", "*kernel32*", "*CloseHandle*") ParentProcessName="*\\CompatTelRunner.exe"))

# ── Potentially Suspicious JWT Token Search Via CLI ──
# Mức độ  : Trung bình
# Chi tiết: Detects potentially suspicious search for JWT tokens via CLI by looking for the string "eyJ0eX" or "eyJhbG". JWT tokens are often used for access-tokens across various applications and services like M
EventCode=4688 Channel="Security" CommandLine IN ("*find *", "*find.exe*", "*findstr*", "*select-string *", "*strings*") CommandLine IN ("*eyJ0eXAiOi*", "*eyJhbGciOi*", "* eyJ0eX*", "* \"eyJ0eX\"*", "* 'eyJ0eX'*", "* eyJhbG*", "* \"eyJhbG\"*", "* 'eyJhbG'*")

# ── Suspicious LNK Command-Line Padding with Whitespace Characters ──
# Mức độ  : Cao
# Chi tiết: Detects exploitation of LNK file command-line length discrepancy, where attackers hide malicious commands beyond the 260-character UI limit while the actual command-line argument field supports 4096 c
EventCode=4688 Channel="Security" ParentProcessName="*\\explorer.exe"
| rex field=CommandLine "(?<CommandLineMatch>\\n\\n\\n\\n\\n\\n)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| search OR ParentCommandLine="*.lnk*" CommandLine IN ("*                 *", "*\\u0009*", "*\\u000A*", "*\\u0011*", "*\\u0012*", "*\\u0013*", "*\\u000B*", "*\\u000C*", "*\\u000D*") OR CommandLineCondition="true"

# ── Local Accounts Discovery ──
# Mức độ  : Thấp
# Mục đích: Thu thập thông tin user
# Chi tiết: Local accounts, System Owner/User discovery using operating systems utilities
EventCode=4688 Channel="Security" (CommandLine="* /c*" CommandLine="*dir *" CommandLine="*\\Users\\*" NewProcessName="*\\cmd.exe" NOT CommandLine="* rmdir *") OR (CommandLine="*user*" NewProcessName IN ("*\\net.exe", "*\\net1.exe") NOT (CommandLine IN ("*/domain*", "*/add*", "*/delete*", "*/active*", "*/expires*", "*/passwordreq*", "*/scriptpath*", "*/times*", "*/workstations*"))) OR NewProcessName IN ("*\\whoami.exe", "*\\quser.exe", "*\\qwinsta.exe") OR OriginalFileName IN ("whoami.exe", "quser.exe", "qwinsta.exe") OR (CommandLine="*useraccount*" CommandLine="*get*" NewProcessName="*\\wmic.exe") OR (CommandLine="* /l*" NewProcessName="*\\cmdkey.exe")

# ── LOLBIN Execution From Abnormal Drive ──
# Mức độ  : Trung bình
# Chi tiết: Detects LOLBINs executing from an abnormal or uncommon drive such as a mounted ISO.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\calc.exe", "*\\certutil.exe", "*\\cmstp.exe", "*\\cscript.exe", "*\\installutil.exe", "*\\mshta.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") OR OriginalFileName IN ("CALC.EXE", "CertUtil.exe", "CMSTP.EXE", "cscript.exe", "installutil.exe", "MSHTA.EXE", "REGSVR32.EXE", "RUNDLL32.EXE", "wscript.exe") NOT (CurrentDirectory="*C:\\*" OR CurrentDirectory="" OR NOT CurrentDirectory=*)

# ── LSASS Dump Keyword In CommandLine ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the presence of the keywords "lsass" and ".dmp" in the commandline, which could indicate a potential attempt to dump or create a dump of the lsass process.
EventCode=4688 Channel="Security" CommandLine IN ("*lsass.dmp*", "*lsass.zip*", "*lsass.rar*", "*Andrew.dmp*", "*Coredump.dmp*", "*NotLSASS.zip*", "*lsass_2*", "*lsassdump*", "*lsassdmp*") OR (CommandLine="*lsass*" CommandLine="*.dmp*") OR (CommandLine="*SQLDmpr*" CommandLine="*.mdmp*") OR (CommandLine="*nanodump*" CommandLine="*.dmp*")

# ── Potential File Download Via MS-AppInstaller Protocol Handler ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the "ms-appinstaller" protocol handler via command line to potentially download arbitrary files via AppInstaller.EXE The downloaded files are temporarly stored in ":\Users\%username%\
EventCode=4688 Channel="Security" CommandLine="*ms-appinstaller://*source=*" CommandLine="*http*"

# ── Suspicious Network Command ──
# Mức độ  : Thấp
# Chi tiết: Adversaries may look for details about the network configuration and settings of systems they access or through information discovery of remote systems
EventCode=4688 Channel="Security"
| rex field=CommandLine "(?<CommandLineMatch>ipconfig\\s+/all)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch2>netsh\\s+interface show interface)"
| eval CommandLineCondition2=if(isnotnull(CommandLineMatch2), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch3>arp\\s+-a)"
| eval CommandLineCondition3=if(isnotnull(CommandLineMatch3), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch4>nbtstat\\s+-n)"
| eval CommandLineCondition4=if(isnotnull(CommandLineMatch4), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch5>net\\s+config)"
| eval CommandLineCondition5=if(isnotnull(CommandLineMatch5), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch6>route\\s+print)"
| eval CommandLineCondition6=if(isnotnull(CommandLineMatch6), "true", "false")
| search CommandLineCondition="true" OR CommandLineCondition2="true" OR CommandLineCondition3="true" OR CommandLineCondition4="true" OR CommandLineCondition5="true" OR CommandLineCondition6="true"

# ── Suspicious Scan Loop Network ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Adversaries may attempt to get a listing of other systems by IP address, hostname, or other logical identifier on a network that may be used for Lateral Movement from the current system
EventCode=4688 Channel="Security" CommandLine IN ("*for *", "*foreach *") CommandLine IN ("*nslookup*", "*ping*")

# ── Potential Network Sniffing Activity Using Network Tools ──
# Mức độ  : Trung bình
# Chi tiết: Detects potential network sniffing via use of network tools such as "tshark", "windump". Network sniffing refers to using the network interface on a system to monitor or capture information sent over 
EventCode=4688 Channel="Security" (CommandLine="*-i*" NewProcessName="*\\tshark.exe") OR NewProcessName="*\\windump.exe"

# ── Process Launched Without Image Name ──
# Mức độ  : Trung bình
# Chi tiết: Detect the use of processes with no name (".exe"), which can be used to evade Image-based detections.
EventCode=4688 Channel="Security" NewProcessName="*\\.exe"

# ── Execution of Suspicious File Type Extension ──
# Mức độ  : Trung bình
# Chi tiết: Detects whether the image specified in a process creation event doesn't refer to an ".exe" (or other known executable extension) file. This can be caused by process ghosting or other unorthodox method
EventCode=4688 Channel="Security" NOT (NewProcessName IN ("*.bin", "*.cgi", "*.com", "*.exe", "*.scr", "*.tmp")) NOT (NewProcessName IN ("System", "Registry", "MemCompression", "vmmem") OR NewProcessName="*:\\Windows\\Installer\\MSI*" OR NewProcessName="*:\\Windows\\System32\\DriverStore\\FileRepository\\*" OR (NewProcessName="*:\\Config.Msi\\*" NewProcessName IN ("*.rbf", "*.rbs")) OR ParentProcessName="*:\\Windows\\Temp\\*" OR NewProcessName="*:\\Windows\\Temp\\*" OR NewProcessName="*:\\$Extend\\$Deleted\\*" OR NewProcessName IN ("-", "") OR NOT NewProcessName=*) NOT (ParentProcessName="*:\\ProgramData\\Avira\\*" OR (NewProcessName="*NVIDIA\\NvBackend\\*" NewProcessName="*.dat") OR (NewProcessName IN ("*:\\Program Files (x86)\\WINPAKPRO\\*", "*:\\Program Files\\WINPAKPRO\\*") NewProcessName="*.ngn") OR NewProcessName IN ("*:\\Program Files (x86)\\MyQ\\Server\\pcltool.dll", "*:\\Program Files\\MyQ\\Server\\pcltool.dll") OR (NewProcessName="*\\AppData\\Local\\Packages\\*" NewProcessName="*\\LocalState\\rootfs\\*") OR NewProcessName="*\\LZMA_EXE" OR NewProcessName="*:\\Program Files\\Mozilla Firefox\\*" OR (ParentProcessName="C:\\Windows\\System32\\services.exe" NewProcessName="*com.docker.service"))

# ── Non-privileged Usage of Reg or Powershell ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Search for usage of reg or Powershell by non-privileged users to modify service configuration in registry
EventCode=4688 Channel="Security" (CommandLine="*reg *" CommandLine="*add*") OR CommandLine IN ("*powershell*", "*set-itemproperty*", "* sp *", "*new-itemproperty*") CommandLine="*ControlSet*" CommandLine="*Services*" CommandLine IN ("*ImagePath*", "*FailureCommand*", "*ServiceDLL*") MandatoryLabel IN ("S-1-16-8192", "None")

# ── Suspicious Process Patterns NTDS.DIT Exfil ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects suspicious process patterns used in NTDS.DIT exfiltration
EventCode=4688 Channel="Security" NewProcessName IN ("*\\NTDSDump.exe", "*\\NTDSDumpEx.exe") OR (CommandLine="*ntds.dit*" CommandLine="*system.hiv*") OR CommandLine="*NTDSgrab.ps1*" OR (CommandLine="*ac i ntds*" CommandLine="*create full*") OR (CommandLine="*/c copy *" CommandLine="*\\windows\\ntds\\ntds.dit*") OR (CommandLine="*activate instance ntds*" CommandLine="*create full*") OR (CommandLine="*powershell*" CommandLine="*ntds.dit*") OR (CommandLine="*ntds.dit*" ParentProcessName IN ("*\\apache*", "*\\tomcat*", "*\\AppData\\*", "*\\Temp\\*", "*\\Public\\*", "*\\PerfLogs\\*") OR NewProcessName IN ("*\\apache*", "*\\tomcat*", "*\\AppData\\*", "*\\Temp\\*", "*\\Public\\*", "*\\PerfLogs\\*"))

# ── Potentially Suspicious Call To Win32_NTEventlogFile Class ──
# Mức độ  : Cao
# Chi tiết: Detects usage of the WMI class "Win32_NTEventlogFile" in a potentially suspicious way (delete, backup, change permissions, etc.) from a PowerShell script
EventCode=4688 Channel="Security" CommandLine="*Win32_NTEventlogFile*" CommandLine IN ("*.BackupEventlog(*", "*.ChangeSecurityPermissions(*", "*.ChangeSecurityPermissionsEx(*", "*.ClearEventLog(*", "*.Delete(*", "*.DeleteEx(*", "*.Rename(*", "*.TakeOwnerShip(*", "*.TakeOwnerShipEx(*")

# ── Use Short Name Path in Image ──
# Mức độ  : Trung bình
# Chi tiết: Detect use of the Windows 8.3 short name. Which could be used as a method to avoid Image detection
EventCode=4688 Channel="Security" NewProcessName IN ("*~1\\*", "*~2\\*") NOT (ParentProcessName IN ("C:\\Windows\\System32\\Dism.exe", "C:\\Windows\\System32\\cleanmgr.exe") OR (NewProcessName="*\\AppData\\*" NewProcessName="*\\Temp\\*") OR NewProcessName IN ("*~1\\unzip.exe", "*~1\\7zG.exe")) NOT (ParentProcessName="*\\WebEx\\WebexHost.exe" OR ParentProcessName="*\\thor\\thor64.exe" OR Product="InstallShield (R)" OR Description="InstallShield (R) Setup Engine" OR Company="InstallShield Software Corporation")

# ── Use NTFS Short Name in Command Line ──
# Mức độ  : Trung bình
# Chi tiết: Detect use of the Windows 8.3 short name. Which could be used as a method to avoid command-line detection
EventCode=4688 Channel="Security" CommandLine IN ("*~1.exe*", "*~1.bat*", "*~1.msi*", "*~1.vbe*", "*~1.vbs*", "*~1.dll*", "*~1.ps1*", "*~1.js*", "*~1.hta*", "*~2.exe*", "*~2.bat*", "*~2.msi*", "*~2.vbe*", "*~2.vbs*", "*~2.dll*", "*~2.ps1*", "*~2.js*", "*~2.hta*") NOT (ParentProcessName IN ("*\\WebEx\\WebexHost.exe", "*\\thor\\thor64.exe") OR CommandLine="*C:\\xampp\\vcredist\\VCREDI~1.EXE*")

# ── Use NTFS Short Name in Image ──
# Mức độ  : Trung bình
# Chi tiết: Detect use of the Windows 8.3 short name. Which could be used as a method to avoid Image based detection
EventCode=4688 Channel="Security" NewProcessName IN ("*~1.bat*", "*~1.dll*", "*~1.exe*", "*~1.hta*", "*~1.js*", "*~1.msi*", "*~1.ps1*", "*~1.tmp*", "*~1.vbe*", "*~1.vbs*", "*~2.bat*", "*~2.dll*", "*~2.exe*", "*~2.hta*", "*~2.js*", "*~2.msi*", "*~2.ps1*", "*~2.tmp*", "*~2.vbe*", "*~2.vbs*") NOT ParentProcessName="C:\\Windows\\explorer.exe" NOT (ParentProcessName="*\\WebEx\\WebexHost.exe" OR ParentProcessName="*\\thor\\thor64.exe" OR NewProcessName="C:\\PROGRA~1\\WinZip\\WZPREL~1.EXE" OR NewProcessName="*\\VCREDI~1.EXE")

# ── Obfuscated IP Download Activity ──
# Mức độ  : Trung bình
# Chi tiết: Detects use of an encoded/obfuscated version of an IP address (hex, octal...) in an URL combined with a download command
EventCode=4688 Channel="Security"
| rex field=CommandLine "(?<CommandLineMatch>https?://[0-9]{1,3}\\.[0-9]{1,3}\\.0[0-9]{3,4})"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch2>https?://[0-9]{1,3}\\.0[0-9]{3,7})"
| eval CommandLineCondition2=if(isnotnull(CommandLineMatch2), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch3>https?://0[0-9]{3,11})"
| eval CommandLineCondition3=if(isnotnull(CommandLineMatch3), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch4>https?://(?:0[0-9]{1,11}\\.){3}0[0-9]{1,11})"
| eval CommandLineCondition4=if(isnotnull(CommandLineMatch4), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch5>https?://0[0-9]{1,11})"
| eval CommandLineCondition5=if(isnotnull(CommandLineMatch5), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch6> [0-7]{7,13})"
| eval CommandLineCondition6=if(isnotnull(CommandLineMatch6), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch7>https?://(?:(?:25[0-5]|(?:2[0-4]|1\\d|[1-9])?\\d)(?:\\.|\\b)){4})"
| eval CommandLineCondition7=if(isnotnull(CommandLineMatch7), "true", "false")
| search CommandLine IN ("*Invoke-WebRequest*", "*iwr *", "*Invoke-RestMethod*", "*irm *", "*wget *", "*curl *", "*DownloadFile*", "*DownloadString*") CommandLine IN ("* 0x*", "*//0x*", "*.0x*", "*.00x*") OR (CommandLine="*http://%*" CommandLine="*%2e*") OR CommandLineCondition="true" OR CommandLineCondition2="true" OR CommandLineCondition3="true" OR CommandLineCondition4="true" OR CommandLineCondition5="true" OR CommandLineCondition6="true" NOT CommandLineCondition7="true"

# ── Obfuscated IP Via CLI ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of an encoded/obfuscated version of an IP address (hex, octal, etc.) via command line
EventCode=4688 Channel="Security"
| rex field=CommandLine "(?<CommandLineMatch>https?://[0-9]{1,3}\\.[0-9]{1,3}\\.0[0-9]{3,4})"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch2>https?://[0-9]{1,3}\\.0[0-9]{3,7})"
| eval CommandLineCondition2=if(isnotnull(CommandLineMatch2), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch3>https?://0[0-9]{3,11})"
| eval CommandLineCondition3=if(isnotnull(CommandLineMatch3), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch4>https?://(?:0[0-9]{1,11}\\.){3}0[0-9]{1,11})"
| eval CommandLineCondition4=if(isnotnull(CommandLineMatch4), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch5>https?://0[0-9]{1,11})"
| eval CommandLineCondition5=if(isnotnull(CommandLineMatch5), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch6> [0-7]{7,13})"
| eval CommandLineCondition6=if(isnotnull(CommandLineMatch6), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch7>https?://(?:(?:25[0-5]|(?:2[0-4]|1\\d|[1-9])?\\d)(?:\\.|\\b)){4})"
| eval CommandLineCondition7=if(isnotnull(CommandLineMatch7), "true", "false")
| search NewProcessName IN ("*\\ping.exe", "*\\arp.exe") CommandLine IN ("* 0x*", "*//0x*", "*.0x*", "*.00x*") OR (CommandLine="*http://%*" CommandLine="*%2e*") OR CommandLineCondition="true" OR CommandLineCondition2="true" OR CommandLineCondition3="true" OR CommandLineCondition4="true" OR CommandLineCondition5="true" OR CommandLineCondition6="true" NOT CommandLineCondition7="true"

# ── Suspicious Process Parents ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects suspicious parent processes that should not have any children or should only have a single possible child program
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\minesweeper.exe", "*\\winver.exe", "*\\bitsadmin.exe") OR (ParentProcessName IN ("*\\csrss.exe", "*\\certutil.exe", "*\\eventvwr.exe", "*\\calc.exe", "*\\notepad.exe") NOT (NewProcessName IN ("*\\WerFault.exe", "*\\wermgr.exe", "*\\conhost.exe", "*\\mmc.exe", "*\\win32calc.exe", "*\\notepad.exe") OR NOT NewProcessName=*))

# ── Potential PowerShell Execution Via DLL ──
# Mức độ  : Cao
# Chi tiết: Detects potential PowerShell execution from a DLL instead of the usual PowerShell process as seen used in PowerShdll. This detection assumes that PowerShell commands are passed via the CommandLine.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\InstallUtil.exe", "*\\RegAsm.exe", "*\\RegSvcs.exe", "*\\regsvr32.exe", "*\\rundll32.exe") OR OriginalFileName IN ("InstallUtil.exe", "RegAsm.exe", "RegSvcs.exe", "REGSVR32.EXE", "RUNDLL32.EXE") CommandLine IN ("*Default.GetString*", "*DownloadString*", "*FromBase64String*", "*ICM *", "*IEX *", "*Invoke-Command*", "*Invoke-Expression*")

# ── Privilege Escalation via Named Pipe Impersonation ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects a remote file copy attempt to a hidden network share. This may indicate lateral movement or data staging activity.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\cmd.exe", "*\\powershell.exe") OR OriginalFileName IN ("Cmd.Exe", "PowerShell.EXE") CommandLine="*echo*" CommandLine="*>*" CommandLine="*\\\\.\\pipe\\*"

# ── Private Keys Reconnaissance Via CommandLine Tools ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may search for private key certificate files on compromised systems for insecurely stored credential
EventCode=4688 Channel="Security" CommandLine IN ("*.key*", "*.pgp*", "*.gpg*", "*.ppk*", "*.p12*", "*.pem*", "*.pfx*", "*.cer*", "*.p7b*", "*.asc*") (NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*dir *") OR (NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine="*Get-ChildItem *") OR NewProcessName="*\\findstr.exe" OR OriginalFileName="FINDSTR.EXE"

# ── Suspicious RunAs-Like Flag Combination ──
# Mức độ  : Trung bình
# Chi tiết: Detects suspicious command line flags that let the user set a target user and command as e.g. seen in PsExec-like tools
EventCode=4688 Channel="Security" CommandLine IN ("* -u system *", "* --user system *", "* -u NT*", "* -u \"NT*", "* -u 'NT*", "* --system *", "* -u administrator *") CommandLine IN ("* -c cmd*", "* -c \"cmd*", "* -c powershell*", "* -c \"powershell*", "* --command cmd*", "* --command powershell*", "* -c whoami*", "* -c wscript*", "* -c cscript*")

# ── Windows Processes Suspicious Parent Directory ──
# Mức độ  : Thấp
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detect suspicious parent processes of well-known Windows processes
EventCode=4688 Channel="Security" NewProcessName IN ("*\\svchost.exe", "*\\taskhost.exe", "*\\lsm.exe", "*\\lsass.exe", "*\\services.exe", "*\\lsaiso.exe", "*\\csrss.exe", "*\\wininit.exe", "*\\winlogon.exe") NOT (ParentProcessName IN ("*\\SavService.exe", "*\\ngen.exe") OR ParentProcessName IN ("*\\System32\\*", "*\\SysWOW64\\*") OR (ParentProcessName IN ("*\\Windows Defender\\*", "*\\Microsoft Security Client\\*") ParentProcessName="*\\MsMpEng.exe") OR NOT ParentProcessName=* OR ParentProcessName IN ("", "-"))

# ── Suspicious Program Names ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious patterns in program names or folders that are often found in malicious samples or hacktools
EventCode=4688 Channel="Security" NewProcessName IN ("*\\CVE-202*", "*\\CVE202*") OR NewProcessName IN ("*\\poc.exe", "*\\artifact.exe", "*\\artifact64.exe", "*\\artifact_protected.exe", "*\\artifact32.exe", "*\\artifact32big.exe", "*obfuscated.exe", "*obfusc.exe", "*\\meterpreter") OR CommandLine IN ("*inject.ps1*", "*Invoke-CVE*", "*pupy.ps1*", "*payload.ps1*", "*beacon.ps1*", "*PowerView.ps1*", "*bypass.ps1*", "*obfuscated.ps1*", "*obfusc.ps1*", "*obfus.ps1*", "*obfs.ps1*", "*evil.ps1*", "*MiniDogz.ps1*", "*_enc.ps1*", "*\\shell.ps1*", "*\\rshell.ps1*", "*revshell.ps1*", "*\\av.ps1*", "*\\av_test.ps1*", "*adrecon.ps1*", "*mimikatz.ps1*", "*\\PowerUp_*", "*powerup.ps1*", "*\\Temp\\a.ps1*", "*\\Temp\\p.ps1*", "*\\Temp\\1.ps1*", "*Hound.ps1*", "*encode.ps1*", "*powercat.ps1*")

# ── Recon Information for Export with Command Prompt ──
# Mức độ  : Trung bình
# Chi tiết: Once established within a system or network, an adversary may use automated techniques for collecting internal data.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\tree.com", "*\\WMIC.exe", "*\\doskey.exe", "*\\sc.exe") OR OriginalFileName IN ("wmic.exe", "DOSKEY.EXE", "sc.exe") ParentCommandLine IN ("* > %TEMP%\\*", "* > %TMP%\\*")

# ── Suspicious Process Execution From Fake Recycle.Bin Folder ──
# Mức độ  : Cao
# Chi tiết: Detects process execution from a fake recycle bin folder, often used to avoid security solution.
EventCode=4688 Channel="Security" NewProcessName IN ("*RECYCLERS.BIN\\*", "*RECYCLER.BIN\\*")

# ── Suspicious Redirection to Local Admin Share ──
# Mức độ  : Cao
# Chi tiết: Detects a suspicious output redirection to the local admins share, this technique is often found in malicious scripts or hacktool stagers
EventCode=4688 Channel="Security" CommandLine="*>*" CommandLine IN ("*\\\\127.0.0.1\\admin$\\*", "*\\\\localhost\\admin$\\*")

# ── Registry Modification of MS-settings Protocol Handler ──
# Mức độ  : Trung bình
# Mục đích: Leo thang đặc quyền; Sửa registry
# Chi tiết: Detects registry modifications to the 'ms-settings' protocol handler, which is frequently targeted for UAC bypass or persistence. Attackers can modify this registry to execute malicious code with elev
EventCode=4688 Channel="Security" (NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="*add*") OR (NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("powershell.exe", "pwsh.dll") CommandLine IN ("*New-ItemProperty*", "*Set-ItemProperty*", "*ni *", "*sp *")) CommandLine="*\\ms-settings\\shell\\open\\command*"

# ── Potential Remote Desktop Tunneling ──
# Mức độ  : Trung bình
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects potential use of an SSH utility to establish RDP over a reverse SSH Tunnel. This can be used by attackers to enable routing of network packets that would otherwise not reach their intended des
EventCode=4688 Channel="Security" CommandLine="*:3389*" CommandLine IN ("* -L *", "* -P *", "* -R *", "* -pw *", "* -ssh *")

# ── Potential Defense Evasion Via Right-to-Left Override ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects the presence of the "u202+E" character, which causes a terminal, browser, or operating system to render text in a right-to-left sequence. This character is used as an obfuscation and masquerad
EventCode=4688 Channel="Security" CommandLine IN ("*\\u202e*", "*[U+202E]*", "*‮*")

# ── Script Interpreter Execution From Suspicious Folder ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious script execution from suspicious directories or folders accessible by environment variables that may indicate malware activity. Script interpreters (cscript, wscript, mshta, powersh
EventCode=4688 Channel="Security" NewProcessName IN ("*\\cscript.exe", "*\\mshta.exe", "*\\wscript.exe") OR CommandLine IN ("* -ep bypass *", "* -ExecutionPolicy bypass *", "* -w hidden *", "*/e:javascript *", "*/e:Jscript *", "*/e:vbscript *") OR OriginalFileName IN ("cscript.exe", "mshta.exe", "wscript.exe") CommandLine IN ("*:\\Perflogs\\*", "*:\\Users\\Public\\*", "*\\%Public%*", "*\\AppData\\Local\\Temp*", "*\\AppData\\Roaming\\Temp*", "*\\Temporary Internet*", "*\\Windows\\Temp*", "*\\Start Menu\\Programs\\Startup\\*", "*%TEMP%*", "*%TMP%*", "*%LocalAppData%\\Temp*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Favorites\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Favourites\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Contacts\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Documents\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Music\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Pictures\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Videos\\*") NOT (CommandLine="*-NoProfile -ExecutionPolicy Bypass -Command*" CommandLine="*AppData\\Local\\Temp\\*" CommandLine="*Install-Chocolatey.ps1*" ParentProcessName IN ("C:\\Windows\\System32\\Msiexec.exe", "C:\\Windows\\SysWOW64\\Msiexec.exe") NewProcessName="*\\powershell.exe")

# ── Script Interpreter Spawning Credential Scanner - Windows ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects a script interpreter process (like node.js or bun) spawning a known credential scanning tool (e.g., trufflehog, gitleaks). This behavior is indicative of an attempt to find and steal secrets, 
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\node.exe", "*\\bun.exe") NewProcessName IN ("*trufflehog.exe", "*gitleaks.exe") OR CommandLine IN ("*trufflehog*", "*gitleaks*")

# ── Sensitive File Access Via Volume Shadow Copy Backup ──
# Mức độ  : Cao
# Mục đích: Phá hủy backup/recovery
# Chi tiết: Detects a command that accesses the VolumeShadowCopy in order to extract sensitive files such as the Security or SAM registry hives or the AD database (ntds.dit)
EventCode=4688 Channel="Security" CommandLine="*\\\\?\\GLOBALROOT\\Device\\HarddiskVolumeShadowCopy*" CommandLine IN ("*\\NTDS.dit*", "*\\SYSTEM*", "*\\SECURITY*")

# ── Suspicious New Service Creation ──
# Mức độ  : Cao
# Chi tiết: Detects creation of a new service via "sc" command or the powershell "new-service" cmdlet with suspicious binary paths
EventCode=4688 Channel="Security" (CommandLine="*create*" CommandLine="*binPath=*" NewProcessName="*\\sc.exe") OR (CommandLine="*New-Service*" CommandLine="*-BinaryPathName*") CommandLine IN ("*powershell*", "*mshta*", "*wscript*", "*cscript*", "*svchost*", "*dllhost*", "*cmd *", "*cmd.exe /c*", "*cmd.exe /k*", "*cmd.exe /r*", "*rundll32*", "*C:\\Users\\Public*", "*\\Downloads\\*", "*\\Desktop\\*", "*\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\\*", "*C:\\Windows\\TEMP\\*", "*\\AppData\\Local\\Temp*")

# ── Suspicious Service Binary Directory ──
# Mức độ  : Cao
# Chi tiết: Detects a service binary running in a suspicious directory
EventCode=4688 Channel="Security" NewProcessName IN ("*\\Users\\Public\\*", "*\\$Recycle.bin*", "*\\Users\\All Users\\*", "*\\Users\\Default\\*", "*\\Users\\Contacts\\*", "*\\Users\\Searches\\*", "*C:\\Perflogs\\*", "*\\config\\systemprofile\\*", "*\\Windows\\Fonts\\*", "*\\Windows\\IME\\*", "*\\Windows\\addins\\*") ParentProcessName IN ("*\\services.exe", "*\\svchost.exe")

