# ── System File Execution Location Anomaly ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects the execution of a Windows system binary that is usually located in the system folder from an uncommon location.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\atbroker.exe", "*\\audiodg.exe", "*\\bcdedit.exe", "*\\bitsadmin.exe", "*\\certreq.exe", "*\\certutil.exe", "*\\cmstp.exe", "*\\conhost.exe", "*\\consent.exe", "*\\cscript.exe", "*\\csrss.exe", "*\\dashost.exe", "*\\defrag.exe", "*\\dfrgui.exe", "*\\dism.exe", "*\\dllhost.exe", "*\\dllhst3g.exe", "*\\dwm.exe", "*\\eventvwr.exe", "*\\fsquirt.exe", "*\\finger.exe", "*\\logonui.exe", "*\\LsaIso.exe", "*\\lsass.exe", "*\\lsm.exe", "*\\msiexec.exe", "*\\ntoskrnl.exe", "*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\runonce.exe", "*\\RuntimeBroker.exe", "*\\schtasks.exe", "*\\services.exe", "*\\sihost.exe", "*\\smartscreen.exe", "*\\smss.exe", "*\\spoolsv.exe", "*\\svchost.exe", "*\\taskhost.exe", "*\\taskhostw.exe", "*\\Taskmgr.exe", "*\\userinit.exe", "*\\werfault.exe", "*\\werfaultsecure.exe", "*\\wininit.exe", "*\\winlogon.exe", "*\\winver.exe", "*\\wlanext.exe", "*\\wscript.exe", "*\\wsl.exe", "*\\wsmprovhost.exe") NOT (NewProcessName IN ("C:\\$WINDOWS.~BT\\*", "C:\\$WinREAgent\\*", "C:\\Windows\\SoftwareDistribution\\*", "C:\\Windows\\System32\\*", "C:\\Windows\\SystemTemp\\*", "C:\\Windows\\SysWOW64\\*", "C:\\Windows\\uus\\*", "C:\\Windows\\WinSxS\\*") OR (NewProcessName IN ("*C:\\Program Files\\PowerShell\\7\\*", "*C:\\Program Files\\PowerShell\\7-preview\\*", "*C:\\Program Files\\WindowsApps\\Microsoft.PowerShellPreview*", "*\\AppData\\Local\\Microsoft\\WindowsApps\\Microsoft.PowerShellPreview*") NewProcessName="*\\pwsh.exe") OR (NewProcessName IN ("C:\\Program Files\\WindowsApps\\MicrosoftCorporationII.WindowsSubsystemForLinux*", "C:\\Program Files\\WSL\\*") NewProcessName="*\\wsl.exe") OR (NewProcessName="C:\\Users\\'*" NewProcessName="*\\AppData\\Local\\Microsoft\\WindowsApps\\*" NewProcessName="*\\wsl.exe")) NOT NewProcessName="*\\SystemRoot\\System32\\*"

# ── Suspicious SYSTEM User Process Creation ──
# Mức độ  : Cao
# Mục đích: Chiếm quyền token; Dump thông tin xác thực
# Chi tiết: Detects a suspicious process creation as SYSTEM user (suspicious program or command line parameter)
EventCode=4688 Channel="Security"
| rex field=CommandLine "(?<CommandLineMatch>net\\s+user\\s+)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| search MandatoryLabel IN ("S-1-16-16384", "None") SubjectUserName IN ("*AUTHORI*", "*AUTORI*") NewProcessName IN ("*\\calc.exe", "*\\cscript.exe", "*\\forfiles.exe", "*\\hh.exe", "*\\mshta.exe", "*\\ping.exe", "*\\wscript.exe") OR CommandLineCondition="true" OR CommandLine IN ("* -NoP *", "* -W Hidden *", "* -decode *", "* /decode *", "* /urlcache *", "* -urlcache *", "* -e* JAB*", "* -e* SUVYI*", "* -e* SQBFAFgA*", "* -e* aWV4I*", "* -e* IAB*", "* -e* PAA*", "* -e* aQBlAHgA*", "*vssadmin delete shadows*", "*reg SAVE HKLM*", "* -ma *", "*Microsoft\\Windows\\CurrentVersion\\Run*", "*.downloadstring(*", "*.downloadfile(*", "* /ticket:*", "*dpapi::*", "*event::clear*", "*event::drop*", "*id::modify*", "*kerberos::*", "*lsadump::*", "*misc::*", "*privilege::*", "*rpc::*", "*sekurlsa::*", "*sid::*", "*token::*", "*vault::cred*", "*vault::list*", "* p::d *", "*;iex(*", "*MiniDump*") NOT ((CommandLine="*ping*" CommandLine="*127.0.0.1*" CommandLine="* -n *") OR (ParentCommandLine="*\\DismFoDInstall.cmd*" NewProcessName="*\\PING.EXE") OR ParentProcessName="*:\\Packages\\Plugins\\Microsoft.GuestConfiguration.ConfigurationforWindows\\*" OR (CommandLine="* -ma *" ParentProcessName IN ("*:\\Program Files (x86)\\Java\\*", "*:\\Program Files\\Java\\*") ParentProcessName="*\\bin\\javaws.exe" NewProcessName IN ("*:\\Program Files (x86)\\Java\\*", "*:\\Program Files\\Java\\*") NewProcessName="*\\bin\\jp2launcher.exe"))

# ── Suspicious SYSVOL Domain Group Policy Access ──
# Mức độ  : Trung bình
# Chi tiết: Detects Access to Domain Group Policies stored in SYSVOL
EventCode=4688 Channel="Security" CommandLine="*\\SYSVOL\\*" CommandLine="*\\policies\\*"

# ── Tasks Folder Evasion ──
# Mức độ  : Cao
# Chi tiết: The Tasks folder in system32 and syswow64 are globally writable paths. Adversaries can take advantage of this and load or influence any script hosts or ANY .NET Application in Tasks to load and execut
EventCode=4688 Channel="Security" CommandLine IN ("*echo *", "*copy *", "*type *", "*file createnew*") CommandLine IN ("* C:\\Windows\\System32\\Tasks\\*", "* C:\\Windows\\SysWow64\\Tasks\\*")

# ── Malicious Windows Script Components File Execution by TAEF Detection ──
# Mức độ  : Thấp
# Chi tiết: Windows Test Authoring and Execution Framework (TAEF) framework allows you to run automation by executing tests files written on different languages (C, C#, Microsoft COM Scripting interfaces Adversar
EventCode=4688 Channel="Security" NewProcessName="*\\te.exe" OR ParentProcessName="*\\te.exe" OR OriginalFileName="\\te.exe"

# ── Malicious PE Execution by Microsoft Visual Studio Debugger ──
# Mức độ  : Trung bình
# Chi tiết: There is an option for a MS VS Just-In-Time Debugger "vsjitdebugger.exe" to launch specified executable and attach a debugger. This option may be used adversaries to execute malicious code by signed v
EventCode=4688 Channel="Security" ParentProcessName="*\\vsjitdebugger.exe" NOT (NewProcessName IN ("*\\vsimmersiveactivatehelper*.exe", "*\\devenv.exe"))

# ── Suspicious Userinit Child Process ──
# Mức độ  : Trung bình
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: Detects a suspicious child process of userinit
EventCode=4688 Channel="Security" ParentProcessName="*\\userinit.exe" NOT (CommandLine="*\\netlogon\\*" OR NewProcessName="*\\explorer.exe" OR OriginalFileName="explorer.exe" OR CommandLine="C:\\Windows\\Explorer.EXE" OR NOT NewProcessName=*)

# ── Suspicious Velociraptor Child Process ──
# Mức độ  : Cao
# Chi tiết: Detects the suspicious use of the Velociraptor DFIR tool to execute other tools or download additional payloads, as seen in a campaign where it was abused for remote access and to stage further attack
EventCode=4688 Channel="Security" ParentProcessName="*\\Velociraptor.exe" (CommandLine="*code.exe*" CommandLine="*tunnel*" CommandLine="*--accept-server-license-terms*") OR (CommandLine="*msiexec*" CommandLine="*/i*" CommandLine="*http*") OR (CommandLine IN ("*Invoke-WebRequest *", "*IWR *", "*.DownloadFile*", "*.DownloadString*") NewProcessName IN ("*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe"))

# ── Weak or Abused Passwords In CLI ──
# Mức độ  : Trung bình
# Chi tiết: Detects weak passwords or often abused passwords (seen used by threat actors) via the CLI. An example would be a threat actor creating a new user via the net command and providing the password inline
EventCode=4688 Channel="Security" CommandLine IN ("*123456789*", "*123123qwE*", "*Asd123.aaaa*", "*Decryptme*", "*P@ssw0rd!*", "*Pass8080*", "*password123*", "*test@202*")

# ── Usage Of Web Request Commands And Cmdlets ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the use of various web request commands with commandline tools and Windows PowerShell cmdlets (including aliases) via CommandLine
EventCode=4688 Channel="Security" CommandLine IN ("*[System.Net.WebRequest]::create*", "*curl *", "*Invoke-RestMethod*", "*Invoke-WebRequest*", "* irm *", "*iwr *", "*Resume-BitsTransfer*", "*Start-BitsTransfer*", "*wget *", "*WinHttp.WinHttpRequest*")

# ── WhoAmI as Parameter ──
# Mức độ  : Cao
# Mục đích: Thu thập thông tin user
# Chi tiết: Detects a suspicious process command line that uses whoami as first parameter (as e.g. used by EfsPotato)
EventCode=4688 Channel="Security" CommandLine="*.exe whoami*"

# ── Execution via WorkFolders.exe ──
# Mức độ  : Cao
# Chi tiết: Detects using WorkFolders.exe to execute an arbitrary control.exe
EventCode=4688 Channel="Security" NewProcessName="*\\control.exe" ParentProcessName="*\\WorkFolders.exe" NOT NewProcessName="C:\\Windows\\System32\\control.exe"

# ── Suspect Svchost Activity ──
# Mức độ  : Cao
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: It is extremely abnormal for svchost.exe to spawn without any CLI arguments and is normally observed when a malicious process spawns the process and injects code into the process memory space.
EventCode=4688 Channel="Security" CommandLine="*svchost.exe" NewProcessName="*\\svchost.exe" NOT (ParentProcessName IN ("*\\rpcnet.exe", "*\\rpcnetp.exe") OR NOT CommandLine=*)

# ── Suspicious Process Masquerading As SvcHost.EXE ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects a suspicious process that is masquerading as the legitimate "svchost.exe" by naming its binary "svchost.exe" and executing from an uncommon location. Adversaries often disguise their malicious
EventCode=4688 Channel="Security" NewProcessName="*\\svchost.exe" NOT (NewProcessName IN ("C:\\Windows\\System32\\svchost.exe", "C:\\Windows\\SysWOW64\\svchost.exe") OR OriginalFileName="svchost.exe")

# ── Uncommon Svchost Command Line Parameter ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Chèn mã vào tiến trình
# Chi tiết: Detects instances of svchost.exe running with an unusual or uncommon command line parameter by excluding known legitimate or common patterns. This could point at a file masquerading as svchost, a proc
EventCode=4688 Channel="Security" NewProcessName="*\\svchost.exe"
| rex field=CommandLine "(?<CommandLineMatch>-k\\s\\w{1,64}(?:\\s?(?:-p|-s))?)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| search NOT (CommandLineCondition="true" OR CommandLine="" OR NOT CommandLine=*) NOT ((CommandLine="*svchost.exe*" ParentProcessName="*\\MsMpEng.exe") OR (CommandLine="svchost.exe" ParentProcessName="*\\MRT.exe"))

# ── Uncommon Svchost Parent Process ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects an uncommon svchost parent process
EventCode=4688 Channel="Security" NewProcessName="*\\svchost.exe" NOT (ParentProcessName IN ("*\\Mrt.exe", "*\\MsMpEng.exe", "*\\ngen.exe", "*\\rpcnet.exe", "*\\services.exe", "*\\TiWorker.exe") OR NOT ParentProcessName=* OR ParentProcessName IN ("-", ""))

# ── Permission Check Via Accesschk.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the usage of the "Accesschk" utility, an access and privilege audit tool developed by SysInternal and often being abused by attacker to verify process privileges
EventCode=4688 Channel="Security" Product="*AccessChk" OR Description="*Reports effective permissions*" OR NewProcessName IN ("*\\accesschk.exe", "*\\accesschk64.exe", "*\\accesschk64a.exe") OR OriginalFileName="accesschk.exe" CommandLine IN ("*uwcqv *", "*kwsu *", "*qwsu *", "*uwdqs *")

# ── Active Directory Database Snapshot Via ADExplorer ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of Sysinternals ADExplorer with the "-snapshot" flag in order to save a local copy of the active directory database. This can be used by attackers to extract data for Bloodhound,
EventCode=4688 Channel="Security" NewProcessName IN ("*\\ADExp.exe", "*\\ADExplorer.exe", "*\\ADExplorer64.exe", "*\\ADExplorer64a.exe") OR OriginalFileName="AdExp" OR Description="Active Directory Editor" OR Product="Sysinternals ADExplorer" CommandLine="*snapshot*"

# ── Suspicious Active Directory Database Snapshot Via ADExplorer ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of Sysinternals ADExplorer with the "-snapshot" flag in order to save a local copy of the active directory database to a suspicious directory. This can be used by attackers to ex
EventCode=4688 Channel="Security" NewProcessName IN ("*\\ADExp.exe", "*\\ADExplorer.exe", "*\\ADExplorer64.exe", "*\\ADExplorer64a.exe") OR OriginalFileName="AdExp" OR Description="Active Directory Editor" OR Product="Sysinternals ADExplorer" CommandLine="*snapshot*" CommandLine IN ("*\\Downloads\\*", "*\\Users\\Public\\*", "*\\AppData\\*", "*\\Windows\\Temp\\*")

# ── Potential Execution of Sysinternals Tools ──
# Mức độ  : Thấp
# Chi tiết: Detects command lines that contain the 'accepteula' flag which could be a sign of execution of one of the Sysinternals tools
EventCode=4688 Channel="Security" CommandLine="* -accepteula*" OR CommandLine="* /accepteula*" OR CommandLine="* –accepteula*" OR CommandLine="* —accepteula*" OR CommandLine="* ―accepteula*"

# ── Potential Memory Dumping Activity Via LiveKD ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of LiveKD based on PE metadata or image name
EventCode=4688 Channel="Security" NewProcessName IN ("*\\livekd.exe", "*\\livekd64.exe") OR OriginalFileName="livekd.exe"

# ── Kernel Memory Dump Via LiveKD ──
# Mức độ  : Cao
# Chi tiết: Detects execution of LiveKD with the "-m" flag to potentially dump the kernel memory
EventCode=4688 Channel="Security" NewProcessName IN ("*\\livekd.exe", "*\\livekd64.exe") OR OriginalFileName="livekd.exe" CommandLine="* -m*" OR CommandLine="* /m*" OR CommandLine="* –m*" OR CommandLine="* —m*" OR CommandLine="* ―m*"

# ── Procdump Execution ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình; Dump thông tin xác thực
# Chi tiết: Detects usage of the SysInternals Procdump utility
EventCode=4688 Channel="Security" NewProcessName IN ("*\\procdump.exe", "*\\procdump64.exe", "*\\procdump64a.exe")

# ── Potential SysInternals ProcDump Evasion ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Dump thông tin xác thực
# Chi tiết: Detects uses of the SysInternals ProcDump utility in which ProcDump or its output get renamed, or a dump file is moved or copied to a different name
EventCode=4688 Channel="Security" CommandLine IN ("*copy procdump*", "*move procdump*") OR (CommandLine="*copy *" CommandLine="*.dmp *" CommandLine IN ("*2.dmp*", "*lsass*", "*out.dmp*")) OR CommandLine IN ("*copy lsass.exe_*", "*move lsass.exe_*")

# ── Potential LSASS Process Dump Via Procdump ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Dump thông tin xác thực
# Chi tiết: Detects potential credential harvesting attempts through LSASS memory dumps using ProcDump. This rule identifies suspicious command-line patterns that combine memory dump flags (-ma, -mm, -mp) with LS
EventCode=4688 Channel="Security" CommandLine="* -ma *" OR CommandLine="* /ma *" OR CommandLine="* –ma *" OR CommandLine="* —ma *" OR CommandLine="* ―ma *" OR CommandLine="* -mm *" OR CommandLine="* /mm *" OR CommandLine="* –mm *" OR CommandLine="* —mm *" OR CommandLine="* ―mm *" OR CommandLine="* -mp *" OR CommandLine="* /mp *" OR CommandLine="* –mp *" OR CommandLine="* —mp *" OR CommandLine="* ―mp *" CommandLine IN ("* ls*", "* keyiso*", "* samss*")

# ── Psexec Execution ──
# Mức độ  : Trung bình
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects user accept agreement execution in psexec commandline
EventCode=4688 Channel="Security" NewProcessName="*\\psexec.exe" OR OriginalFileName="psexec.c"

# ── PsExec/PAExec Escalation to LOCAL SYSTEM ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious commandline flags used by PsExec and PAExec to escalate a command line to LOCAL_SYSTEM rights
EventCode=4688 Channel="Security" CommandLine="* -s cmd*" OR CommandLine="* /s cmd*" OR CommandLine="* –s cmd*" OR CommandLine="* —s cmd*" OR CommandLine="* ―s cmd*" OR CommandLine="* -s -i cmd*" OR CommandLine="* -s /i cmd*" OR CommandLine="* -s –i cmd*" OR CommandLine="* -s —i cmd*" OR CommandLine="* -s ―i cmd*" OR CommandLine="* /s -i cmd*" OR CommandLine="* /s /i cmd*" OR CommandLine="* /s –i cmd*" OR CommandLine="* /s —i cmd*" OR CommandLine="* /s ―i cmd*" OR CommandLine="* –s -i cmd*" OR CommandLine="* –s /i cmd*" OR CommandLine="* –s –i cmd*" OR CommandLine="* –s —i cmd*" OR CommandLine="* –s ―i cmd*" OR CommandLine="* —s -i cmd*" OR CommandLine="* —s /i cmd*" OR CommandLine="* —s –i cmd*" OR CommandLine="* —s —i cmd*" OR CommandLine="* —s ―i cmd*" OR CommandLine="* ―s -i cmd*" OR CommandLine="* ―s /i cmd*" OR CommandLine="* ―s –i cmd*" OR CommandLine="* ―s —i cmd*" OR CommandLine="* ―s ―i cmd*" OR CommandLine="* -i -s cmd*" OR CommandLine="* -i /s cmd*" OR CommandLine="* -i –s cmd*" OR CommandLine="* -i —s cmd*" OR CommandLine="* -i ―s cmd*" OR CommandLine="* /i -s cmd*" OR CommandLine="* /i /s cmd*" OR CommandLine="* /i –s cmd*" OR CommandLine="* /i —s cmd*" OR CommandLine="* /i ―s cmd*" OR CommandLine="* –i -s cmd*" OR CommandLine="* –i /s cmd*" OR CommandLine="* –i –s cmd*" OR CommandLine="* –i —s cmd*" OR CommandLine="* –i ―s cmd*" OR CommandLine="* —i -s cmd*" OR CommandLine="* —i /s cmd*" OR CommandLine="* —i –s cmd*" OR CommandLine="* —i —s cmd*" OR CommandLine="* —i ―s cmd*" OR CommandLine="* ―i -s cmd*" OR CommandLine="* ―i /s cmd*" OR CommandLine="* ―i –s cmd*" OR CommandLine="* ―i —s cmd*" OR CommandLine="* ―i ―s cmd*" OR CommandLine="* -s pwsh*" OR CommandLine="* /s pwsh*" OR CommandLine="* –s pwsh*" OR CommandLine="* —s pwsh*" OR CommandLine="* ―s pwsh*" OR CommandLine="* -s -i pwsh*" OR CommandLine="* -s /i pwsh*" OR CommandLine="* -s –i pwsh*" OR CommandLine="* -s —i pwsh*" OR CommandLine="* -s ―i pwsh*" OR CommandLine="* /s -i pwsh*" OR CommandLine="* /s /i pwsh*" OR CommandLine="* /s –i pwsh*" OR CommandLine="* /s —i pwsh*" OR CommandLine="* /s ―i pwsh*" OR CommandLine="* –s -i pwsh*" OR CommandLine="* –s /i pwsh*" OR CommandLine="* –s –i pwsh*" OR CommandLine="* –s —i pwsh*" OR CommandLine="* –s ―i pwsh*" OR CommandLine="* —s -i pwsh*" OR CommandLine="* —s /i pwsh*" OR CommandLine="* —s –i pwsh*" OR CommandLine="* —s —i pwsh*" OR CommandLine="* —s ―i pwsh*" OR CommandLine="* ―s -i pwsh*" OR CommandLine="* ―s /i pwsh*" OR CommandLine="* ―s –i pwsh*" OR CommandLine="* ―s —i pwsh*" OR CommandLine="* ―s ―i pwsh*" OR CommandLine="* -i -s pwsh*" OR CommandLine="* -i /s pwsh*" OR CommandLine="* -i –s pwsh*" OR CommandLine="* -i —s pwsh*" OR CommandLine="* -i ―s pwsh*" OR CommandLine="* /i -s pwsh*" OR CommandLine="* /i /s pwsh*" OR CommandLine="* /i –s pwsh*" OR CommandLine="* /i —s pwsh*" OR CommandLine="* /i ―s pwsh*" OR CommandLine="* –i -s pwsh*" OR CommandLine="* –i /s pwsh*" OR CommandLine="* –i –s pwsh*" OR CommandLine="* –i —s pwsh*" OR CommandLine="* –i ―s pwsh*" OR CommandLine="* —i -s pwsh*" OR CommandLine="* —i /s pwsh*" OR CommandLine="* —i –s pwsh*" OR CommandLine="* —i —s pwsh*" OR CommandLine="* —i ―s pwsh*" OR CommandLine="* ―i -s pwsh*" OR CommandLine="* ―i /s pwsh*" OR CommandLine="* ―i –s pwsh*" OR CommandLine="* ―i —s pwsh*" OR CommandLine="* ―i ―s pwsh*" OR CommandLine="* -s powershell*" OR CommandLine="* /s powershell*" OR CommandLine="* –s powershell*" OR CommandLine="* —s powershell*" OR CommandLine="* ―s powershell*" OR CommandLine="* -s -i powershell*" OR CommandLine="* -s /i powershell*" OR CommandLine="* -s –i powershell*" OR CommandLine="* -s —i powershell*" OR CommandLine="* -s ―i powershell*" OR CommandLine="* /s -i powershell*" OR CommandLine="* /s /i powershell*" OR CommandLine="* /s –i powershell*" OR CommandLine="* /s —i powershell*" OR CommandLine="* /s ―i powershell*" OR CommandLine="* –s -i powershell*" OR CommandLine="* –s /i powershell*" OR CommandLine="* –s –i powershell*" OR CommandLine="* –s —i powershell*" OR CommandLine="* –s ―i powershell*" OR CommandLine="* —s -i powershell*" OR CommandLine="* —s /i powershell*" OR CommandLine="* —s –i powershell*" OR CommandLine="* —s —i powershell*" OR CommandLine="* —s ―i powershell*" OR CommandLine="* ―s -i powershell*" OR CommandLine="* ―s /i powershell*" OR CommandLine="* ―s –i powershell*" OR CommandLine="* ―s —i powershell*" OR CommandLine="* ―s ―i powershell*" OR CommandLine="* -i -s powershell*" OR CommandLine="* -i /s powershell*" OR CommandLine="* -i –s powershell*" OR CommandLine="* -i —s powershell*" OR CommandLine="* -i ―s powershell*" OR CommandLine="* /i -s powershell*" OR CommandLine="* /i /s powershell*" OR CommandLine="* /i –s powershell*" OR CommandLine="* /i —s powershell*" OR CommandLine="* /i ―s powershell*" OR CommandLine="* –i -s powershell*" OR CommandLine="* –i /s powershell*" OR CommandLine="* –i –s powershell*" OR CommandLine="* –i —s powershell*" OR CommandLine="* –i ―s powershell*" OR CommandLine="* —i -s powershell*" OR CommandLine="* —i /s powershell*" OR CommandLine="* —i –s powershell*" OR CommandLine="* —i —s powershell*" OR CommandLine="* —i ―s powershell*" OR CommandLine="* ―i -s powershell*" OR CommandLine="* ―i /s powershell*" OR CommandLine="* ―i –s powershell*" OR CommandLine="* ―i —s powershell*" OR CommandLine="* ―i ―s powershell*" CommandLine IN ("*psexec*", "*paexec*", "*accepteula*")

# ── Potential PsExec Remote Execution ──
# Mức độ  : Cao
# Chi tiết: Detects potential psexec command that initiate execution on a remote systems via common commandline flags used by the utility
EventCode=4688 Channel="Security" CommandLine="*accepteula*" CommandLine="* -u *" CommandLine="* -p *" CommandLine="* \\\\*" NOT (CommandLine IN ("*\\\\localhost*", "*\\\\127.*"))

# ── PsExec Service Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects launch of the PSEXESVC service, which means that this system was the target of a psexec remote execution
EventCode=4688 Channel="Security" NewProcessName="C:\\Windows\\PSEXESVC.exe" OR OriginalFileName="psexesvc.exe"

# ── PsExec Service Child Process Execution as LOCAL SYSTEM ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious launch of the PSEXESVC service on this system and a sub process run as LOCAL_SYSTEM (-s), which means that someone remotely started a command on this system running it with highest 
EventCode=4688 Channel="Security" ParentProcessName="C:\\Windows\\PSEXESVC.exe" SubjectUserName IN ("*AUTHORI*", "*AUTORI*")

# ── Suspicious Use of PsLogList ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the PsLogList utility to dump event log in order to extract admin accounts and perform account discovery or delete events logs
EventCode=4688 Channel="Security" OriginalFileName="psloglist.exe" OR NewProcessName IN ("*\\psloglist.exe", "*\\psloglist64.exe", "*\\psloglist64a.exe") CommandLine IN ("* security*", "* application*", "* system*") CommandLine="* -d*" OR CommandLine="* /d*" OR CommandLine="* –d*" OR CommandLine="* —d*" OR CommandLine="* ―d*" OR CommandLine="* -x*" OR CommandLine="* /x*" OR CommandLine="* –x*" OR CommandLine="* —x*" OR CommandLine="* ―x*" OR CommandLine="* -s*" OR CommandLine="* /s*" OR CommandLine="* –s*" OR CommandLine="* —s*" OR CommandLine="* ―s*" OR CommandLine="* -c*" OR CommandLine="* /c*" OR CommandLine="* –c*" OR CommandLine="* —c*" OR CommandLine="* ―c*" OR CommandLine="* -g*" OR CommandLine="* /g*" OR CommandLine="* –g*" OR CommandLine="* —g*" OR CommandLine="* ―g*"

# ── Sysinternals PsService Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of Sysinternals PsService which can be abused for service reconnaissance and tampering
EventCode=4688 Channel="Security" OriginalFileName="psservice.exe" OR NewProcessName IN ("*\\PsService.exe", "*\\PsService64.exe", "*\\PsService64a.exe")

# ── Sysinternals PsSuspend Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of Sysinternals PsSuspend which can be abused to suspend critical processes
EventCode=4688 Channel="Security" OriginalFileName="pssuspend.exe" OR NewProcessName IN ("*\\pssuspend.exe", "*\\pssuspend64.exe", "*\\pssuspend64a.exe")

# ── Sysinternals PsSuspend Suspicious Execution ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious execution of Sysinternals PsSuspend, where the utility is used to suspend critical processes such as AV or EDR to bypass defenses
EventCode=4688 Channel="Security" OriginalFileName="pssuspend.exe" OR NewProcessName IN ("*\\pssuspend.exe", "*\\pssuspend64.exe", "*\\pssuspend64a.exe") CommandLine="*msmpeng.exe*"

# ── Potential Privilege Escalation To LOCAL SYSTEM ──
# Mức độ  : Cao
# Chi tiết: Detects unknown program using commandline flags usually used by tools such as PsExec and PAExec to start programs with SYSTEM Privileges
EventCode=4688 Channel="Security" CommandLine="* -s cmd*" OR CommandLine="* /s cmd*" OR CommandLine="* –s cmd*" OR CommandLine="* —s cmd*" OR CommandLine="* ―s cmd*" OR CommandLine="* -s -i cmd*" OR CommandLine="* -s /i cmd*" OR CommandLine="* -s –i cmd*" OR CommandLine="* -s —i cmd*" OR CommandLine="* -s ―i cmd*" OR CommandLine="* /s -i cmd*" OR CommandLine="* /s /i cmd*" OR CommandLine="* /s –i cmd*" OR CommandLine="* /s —i cmd*" OR CommandLine="* /s ―i cmd*" OR CommandLine="* –s -i cmd*" OR CommandLine="* –s /i cmd*" OR CommandLine="* –s –i cmd*" OR CommandLine="* –s —i cmd*" OR CommandLine="* –s ―i cmd*" OR CommandLine="* —s -i cmd*" OR CommandLine="* —s /i cmd*" OR CommandLine="* —s –i cmd*" OR CommandLine="* —s —i cmd*" OR CommandLine="* —s ―i cmd*" OR CommandLine="* ―s -i cmd*" OR CommandLine="* ―s /i cmd*" OR CommandLine="* ―s –i cmd*" OR CommandLine="* ―s —i cmd*" OR CommandLine="* ―s ―i cmd*" OR CommandLine="* -i -s cmd*" OR CommandLine="* -i /s cmd*" OR CommandLine="* -i –s cmd*" OR CommandLine="* -i —s cmd*" OR CommandLine="* -i ―s cmd*" OR CommandLine="* /i -s cmd*" OR CommandLine="* /i /s cmd*" OR CommandLine="* /i –s cmd*" OR CommandLine="* /i —s cmd*" OR CommandLine="* /i ―s cmd*" OR CommandLine="* –i -s cmd*" OR CommandLine="* –i /s cmd*" OR CommandLine="* –i –s cmd*" OR CommandLine="* –i —s cmd*" OR CommandLine="* –i ―s cmd*" OR CommandLine="* —i -s cmd*" OR CommandLine="* —i /s cmd*" OR CommandLine="* —i –s cmd*" OR CommandLine="* —i —s cmd*" OR CommandLine="* —i ―s cmd*" OR CommandLine="* ―i -s cmd*" OR CommandLine="* ―i /s cmd*" OR CommandLine="* ―i –s cmd*" OR CommandLine="* ―i —s cmd*" OR CommandLine="* ―i ―s cmd*" OR CommandLine="* -s pwsh*" OR CommandLine="* /s pwsh*" OR CommandLine="* –s pwsh*" OR CommandLine="* —s pwsh*" OR CommandLine="* ―s pwsh*" OR CommandLine="* -s -i pwsh*" OR CommandLine="* -s /i pwsh*" OR CommandLine="* -s –i pwsh*" OR CommandLine="* -s —i pwsh*" OR CommandLine="* -s ―i pwsh*" OR CommandLine="* /s -i pwsh*" OR CommandLine="* /s /i pwsh*" OR CommandLine="* /s –i pwsh*" OR CommandLine="* /s —i pwsh*" OR CommandLine="* /s ―i pwsh*" OR CommandLine="* –s -i pwsh*" OR CommandLine="* –s /i pwsh*" OR CommandLine="* –s –i pwsh*" OR CommandLine="* –s —i pwsh*" OR CommandLine="* –s ―i pwsh*" OR CommandLine="* —s -i pwsh*" OR CommandLine="* —s /i pwsh*" OR CommandLine="* —s –i pwsh*" OR CommandLine="* —s —i pwsh*" OR CommandLine="* —s ―i pwsh*" OR CommandLine="* ―s -i pwsh*" OR CommandLine="* ―s /i pwsh*" OR CommandLine="* ―s –i pwsh*" OR CommandLine="* ―s —i pwsh*" OR CommandLine="* ―s ―i pwsh*" OR CommandLine="* -i -s pwsh*" OR CommandLine="* -i /s pwsh*" OR CommandLine="* -i –s pwsh*" OR CommandLine="* -i —s pwsh*" OR CommandLine="* -i ―s pwsh*" OR CommandLine="* /i -s pwsh*" OR CommandLine="* /i /s pwsh*" OR CommandLine="* /i –s pwsh*" OR CommandLine="* /i —s pwsh*" OR CommandLine="* /i ―s pwsh*" OR CommandLine="* –i -s pwsh*" OR CommandLine="* –i /s pwsh*" OR CommandLine="* –i –s pwsh*" OR CommandLine="* –i —s pwsh*" OR CommandLine="* –i ―s pwsh*" OR CommandLine="* —i -s pwsh*" OR CommandLine="* —i /s pwsh*" OR CommandLine="* —i –s pwsh*" OR CommandLine="* —i —s pwsh*" OR CommandLine="* —i ―s pwsh*" OR CommandLine="* ―i -s pwsh*" OR CommandLine="* ―i /s pwsh*" OR CommandLine="* ―i –s pwsh*" OR CommandLine="* ―i —s pwsh*" OR CommandLine="* ―i ―s pwsh*" OR CommandLine="* -s powershell*" OR CommandLine="* /s powershell*" OR CommandLine="* –s powershell*" OR CommandLine="* —s powershell*" OR CommandLine="* ―s powershell*" OR CommandLine="* -s -i powershell*" OR CommandLine="* -s /i powershell*" OR CommandLine="* -s –i powershell*" OR CommandLine="* -s —i powershell*" OR CommandLine="* -s ―i powershell*" OR CommandLine="* /s -i powershell*" OR CommandLine="* /s /i powershell*" OR CommandLine="* /s –i powershell*" OR CommandLine="* /s —i powershell*" OR CommandLine="* /s ―i powershell*" OR CommandLine="* –s -i powershell*" OR CommandLine="* –s /i powershell*" OR CommandLine="* –s –i powershell*" OR CommandLine="* –s —i powershell*" OR CommandLine="* –s ―i powershell*" OR CommandLine="* —s -i powershell*" OR CommandLine="* —s /i powershell*" OR CommandLine="* —s –i powershell*" OR CommandLine="* —s —i powershell*" OR CommandLine="* —s ―i powershell*" OR CommandLine="* ―s -i powershell*" OR CommandLine="* ―s /i powershell*" OR CommandLine="* ―s –i powershell*" OR CommandLine="* ―s —i powershell*" OR CommandLine="* ―s ―i powershell*" OR CommandLine="* -i -s powershell*" OR CommandLine="* -i /s powershell*" OR CommandLine="* -i –s powershell*" OR CommandLine="* -i —s powershell*" OR CommandLine="* -i ―s powershell*" OR CommandLine="* /i -s powershell*" OR CommandLine="* /i /s powershell*" OR CommandLine="* /i –s powershell*" OR CommandLine="* /i —s powershell*" OR CommandLine="* /i ―s powershell*" OR CommandLine="* –i -s powershell*" OR CommandLine="* –i /s powershell*" OR CommandLine="* –i –s powershell*" OR CommandLine="* –i —s powershell*" OR CommandLine="* –i ―s powershell*" OR CommandLine="* —i -s powershell*" OR CommandLine="* —i /s powershell*" OR CommandLine="* —i –s powershell*" OR CommandLine="* —i —s powershell*" OR CommandLine="* —i ―s powershell*" OR CommandLine="* ―i -s powershell*" OR CommandLine="* ―i /s powershell*" OR CommandLine="* ―i –s powershell*" OR CommandLine="* ―i —s powershell*" OR CommandLine="* ―i ―s powershell*" NOT (CommandLine IN ("*paexec*", "*PsExec*", "*accepteula*"))

# ── Sysmon Configuration Update ──
# Mức độ  : Trung bình
# Chi tiết: Detects updates to Sysmon's configuration. Attackers might update or replace the Sysmon configuration with a bare bone one to avoid monitoring without shutting down the service completely
EventCode=4688 Channel="Security" NewProcessName IN ("*\\Sysmon64.exe", "*\\Sysmon64a.exe", "*\\Sysmon.exe") OR Description="System activity monitor" CommandLine="*-c*" OR CommandLine="*/c*" OR CommandLine="*–c*" OR CommandLine="*—c*" OR CommandLine="*―c*"

# ── Uninstall Sysinternals Sysmon ──
# Mức độ  : Cao
# Chi tiết: Detects the removal of Sysmon, which could be a potential attempt at defense evasion
EventCode=4688 Channel="Security" NewProcessName IN ("*\\Sysmon64.exe", "*\\Sysmon64a.exe", "*\\Sysmon.exe") OR Description="System activity monitor" CommandLine="*-u*" OR CommandLine="*/u*" OR CommandLine="*–u*" OR CommandLine="*—u*" OR CommandLine="*―u*"

# ── Potential Binary Impersonating Sysinternals Tools ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects binaries that use the same name as legitimate sysinternals tools to evade detection. This rule looks for the execution of binaries that are named similarly to Sysinternals tools. Adversary may
EventCode=4688 Channel="Security" NewProcessName IN ("*\\accesschk.exe", "*\\accesschk64.exe", "*\\AccessEnum.exe", "*\\ADExplorer.exe", "*\\ADExplorer64.exe", "*\\ADInsight.exe", "*\\ADInsight64.exe", "*\\adrestore.exe", "*\\adrestore64.exe", "*\\Autologon.exe", "*\\Autologon64.exe", "*\\Autoruns.exe", "*\\Autoruns64.exe", "*\\autorunsc.exe", "*\\autorunsc64.exe", "*\\Bginfo.exe", "*\\Bginfo64.exe", "*\\Cacheset.exe", "*\\Cacheset64.exe", "*\\Clockres.exe", "*\\Clockres64.exe", "*\\Contig.exe", "*\\Contig64.exe", "*\\Coreinfo.exe", "*\\Coreinfo64.exe", "*\\CPUSTRES.EXE", "*\\CPUSTRES64.EXE", "*\\ctrl2cap.exe", "*\\Dbgview.exe", "*\\dbgview64.exe", "*\\Desktops.exe", "*\\Desktops64.exe", "*\\disk2vhd.exe", "*\\disk2vhd64.exe", "*\\diskext.exe", "*\\diskext64.exe", "*\\Diskmon.exe", "*\\Diskmon64.exe", "*\\DiskView.exe", "*\\DiskView64.exe", "*\\du.exe", "*\\du64.exe", "*\\efsdump.exe", "*\\FindLinks.exe", "*\\FindLinks64.exe", "*\\handle.exe", "*\\handle64.exe", "*\\hex2dec.exe", "*\\hex2dec64.exe", "*\\junction.exe", "*\\junction64.exe", "*\\ldmdump.exe", "*\\listdlls.exe", "*\\listdlls64.exe", "*\\livekd.exe", "*\\livekd64.exe", "*\\loadOrd.exe", "*\\loadOrd64.exe", "*\\loadOrdC.exe", "*\\loadOrdC64.exe", "*\\logonsessions.exe", "*\\logonsessions64.exe", "*\\movefile.exe", "*\\movefile64.exe", "*\\notmyfault.exe", "*\\notmyfault64.exe", "*\\notmyfaultc.exe", "*\\notmyfaultc64.exe", "*\\ntfsinfo.exe", "*\\ntfsinfo64.exe", "*\\pendmoves.exe", "*\\pendmoves64.exe", "*\\pipelist.exe", "*\\pipelist64.exe", "*\\portmon.exe", "*\\procdump.exe", "*\\procdump64.exe", "*\\procexp.exe", "*\\procexp64.exe", "*\\Procmon.exe", "*\\Procmon64.exe", "*\\psExec.exe", "*\\psExec64.exe", "*\\psfile.exe", "*\\psfile64.exe", "*\\psGetsid.exe", "*\\psGetsid64.exe", "*\\psInfo.exe", "*\\psInfo64.exe", "*\\pskill.exe", "*\\pskill64.exe", "*\\pslist.exe", "*\\pslist64.exe", "*\\psLoggedon.exe", "*\\psLoggedon64.exe", "*\\psloglist.exe", "*\\psloglist64.exe", "*\\pspasswd.exe", "*\\pspasswd64.exe", "*\\psping.exe", "*\\psping64.exe", "*\\psService.exe", "*\\psService64.exe", "*\\psshutdown.exe", "*\\psshutdown64.exe", "*\\pssuspend.exe", "*\\pssuspend64.exe", "*\\RAMMap.exe", "*\\RAMMap64.exe", "*\\RDCMan.exe", "*\\RegDelNull.exe", "*\\RegDelNull64.exe", "*\\regjump.exe", "*\\ru.exe", "*\\ru64.exe", "*\\sdelete.exe", "*\\sdelete64.exe", "*\\ShareEnum.exe", "*\\ShareEnum64.exe", "*\\shellRunas.exe", "*\\sigcheck.exe", "*\\sigcheck64.exe", "*\\streams.exe", "*\\streams64.exe", "*\\strings.exe", "*\\strings64.exe", "*\\sync.exe", "*\\sync64.exe", "*\\Sysmon.exe", "*\\Sysmon64.exe", "*\\tcpvcon.exe", "*\\tcpvcon64.exe", "*\\tcpview.exe", "*\\tcpview64.exe", "*\\Testlimit.exe", "*\\Testlimit64.exe", "*\\vmmap.exe", "*\\vmmap64.exe", "*\\Volumeid.exe", "*\\Volumeid64.exe", "*\\whois.exe", "*\\whois64.exe", "*\\Winobj.exe", "*\\Winobj64.exe", "*\\ZoomIt.exe", "*\\ZoomIt64.exe") OR NewProcessName IN ("*\\accesschk64a.exe", "*\\ADExplorer64a.exe", "*\\ADInsight64a.exe", "*\\adrestore64a.exe", "*\\Autologon64a.exe", "*\\Autoruns64a.exe", "*\\autorunsc64a.exe", "*\\Clockres64a.exe", "*\\Contig64a.exe", "*\\Coreinfo64a.exe", "*\\Dbgview64a.exe", "*\\disk2vhd64a.exe", "*\\diskext64a.exe", "*\\DiskView64a.exe", "*\\du64a.exe", "*\\FindLinks64a.exe", "*\\handle64a.exe", "*\\hex2dec64a.exe", "*\\junction64a.exe", "*\\LoadOrd64a.exe", "*\\LoadOrdC64a.exe", "*\\logonsessions64a.exe", "*\\movefile64a.exe", "*\\notmyfault64a.exe", "*\\notmyfaultc64a.exe", "*\\pendmoves64a.exe", "*\\pipelist64a.exe", "*\\procdump64a.exe", "*\\procexp64a.exe", "*\\Procmon64a.exe", "*\\PsExec64a.exe", "*\\psfile64a.exe", "*\\PsGetsid64a.exe", "*\\PsInfo64a.exe", "*\\pskill64a.exe", "*\\psloglist64a.exe", "*\\pspasswd64a.exe", "*\\psping64a.exe", "*\\PsService64a.exe", "*\\pssuspend64a.exe", "*\\RAMMap64a.exe", "*\\RegDelNull64a.exe", "*\\ru64a.exe", "*\\sdelete64a.exe", "*\\sigcheck64a.exe", "*\\streams64a.exe", "*\\strings64a.exe", "*\\sync64a.exe", "*\\Sysmon64a.exe", "*\\tcpvcon64a.exe", "*\\tcpview64a.exe", "*\\vmmap64a.exe", "*\\whois64a.exe", "*\\Winobj64a.exe", "*\\ZoomIt64a.exe") NOT (Company IN ("Sysinternals - www.sysinternals.com", "Sysinternals") OR Product="Sysinternals*" OR NOT Company=* OR NOT Product=*)

# ── Sysprep on AppData Folder ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious sysprep process start with AppData folder as target (as used by Trojan Syndicasec in Thrip report by Symantec)
EventCode=4688 Channel="Security" CommandLine="*\\AppData\\*" NewProcessName="*\\sysprep.exe"

# ── Suspicious Execution of Systeminfo ──
# Mức độ  : Thấp
# Mục đích: Thu thập thông tin hệ thống
# Chi tiết: Detects usage of the "systeminfo" command to retrieve information
EventCode=4688 Channel="Security" NewProcessName="*\\systeminfo.exe" OR OriginalFileName="sysinfo.exe"

# ── Windows Defender Disabled Via SystemSettingsAdminFlows.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects the usage of SystemSettingsAdminFlows.exe to disable Windows Defender. SystemSettingsAdminFlows.exe is a legitimate Windows component used for administrative configuration tasks. However, atta
EventCode=4688 Channel="Security" NewProcessName="*\\SystemSettingsAdminFlows.exe" OR OriginalFileName="SystemSettingsAdminFlows.EXE" CommandLine="*defender*" (CommandLine IN ("*RTP *", "*RealTimeProtection *", "*DisableEnhancedNotifications *") CommandLine="*1*") OR (CommandLine IN ("*SubmitSamplesConsent *", "*SpyNetReporting *", "*DisableCDPUserAuthPolicy *") CommandLine="*0*")

# ── Potential Signing Bypass Via Windows Developer Features ──
# Mức độ  : Cao
# Chi tiết: Detects when a user enable developer features such as "Developer Mode" or "Application Sideloading". Which allows the user to install untrusted packages.
EventCode=4688 Channel="Security" NewProcessName="*\\SystemSettingsAdminFlows.exe" OR OriginalFileName="SystemSettingsAdminFlows.EXE" CommandLine="*TurnOnDeveloperFeatures*" CommandLine IN ("*DeveloperUnlock*", "*EnableSideloading*")

# ── Suspicious Recursive Takeown ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries can interact with the DACLs using built-in Windows commands takeown which can grant adversaries higher permissions on specific files and folders
EventCode=4688 Channel="Security" CommandLine="*/f *" CommandLine="*/r*" NewProcessName="*\\takeown.exe"

# ── Tap Installer Execution ──
# Mức độ  : Trung bình
# Chi tiết: Well-known TAP software installation. Possible preparation for data exfiltration using tunneling techniques
EventCode=4688 Channel="Security" NewProcessName="*\\tapinstall.exe" NOT (NewProcessName IN ("*:\\Program Files\\Avast Software\\SecureLine VPN\\*", "*:\\Program Files (x86)\\Avast Software\\SecureLine VPN\\*") OR NewProcessName="*:\\Program Files\\OpenVPN Connect\\drivers\\tap\\*" OR NewProcessName="*:\\Program Files (x86)\\Proton Technologies\\ProtonVPNTap\\installer\\*")

# ── Compressed File Creation Via Tar.EXE ──
# Mức độ  : Thấp
# Chi tiết: Detects execution of "tar.exe" in order to create a compressed file. Adversaries may abuse various utilities to compress or encrypt data before exfiltration.
EventCode=4688 Channel="Security" NewProcessName="*\\tar.exe" OR OriginalFileName="bsdtar" CommandLine IN ("*-c*", "*-r*", "*-u*")

# ── Compressed File Extraction Via Tar.EXE ──
# Mức độ  : Thấp
# Chi tiết: Detects execution of "tar.exe" in order to extract compressed file. Adversaries may abuse various utilities in order to decompress data to avoid detection.
EventCode=4688 Channel="Security" NewProcessName="*\\tar.exe" OR OriginalFileName="bsdtar" CommandLine="*-x*"

# ── Taskkill Symantec Endpoint Protection ──
# Mức độ  : Cao
# Chi tiết: Detects one of the possible scenarios for disabling Symantec Endpoint Protection. Symantec Endpoint Protection antivirus software services incorrectly implement the protected service mechanism. As a r
EventCode=4688 Channel="Security" CommandLine="*taskkill*" CommandLine="* /F *" CommandLine="* /IM *" CommandLine="*ccSvcHst.exe*"

# ── Loaded Module Enumeration Via Tasklist.EXE ──
# Mức độ  : Trung bình
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the enumeration of a specific DLL or EXE being used by a binary via "tasklist.exe". This is often used by attackers in order to find the specific process identifier (PID) that is using the DLL
EventCode=4688 Channel="Security" NewProcessName="*\\tasklist.exe" OR OriginalFileName="tasklist.exe" CommandLine="*-m*" OR CommandLine="*/m*" OR CommandLine="*–m*" OR CommandLine="*—m*" OR CommandLine="*―m*" CommandLine="*rdpcorets.dll*"

# ── Taskmgr as LOCAL_SYSTEM ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects the creation of taskmgr.exe process in context of LOCAL_SYSTEM
EventCode=4688 Channel="Security" SubjectUserName IN ("*AUTHORI*", "*AUTORI*") NewProcessName="*\\taskmgr.exe"

# ── New Process Created Via Taskmgr.EXE ──
# Mức độ  : Thấp
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects the creation of a process via the Windows task manager. This might be an attempt to bypass UAC
EventCode=4688 Channel="Security" ParentProcessName="*\\taskmgr.exe" NOT (NewProcessName IN ("*:\\Windows\\System32\\mmc.exe", "*:\\Windows\\System32\\resmon.exe", "*:\\Windows\\System32\\Taskmgr.exe"))

# ── Potentially Suspicious Command Targeting Teams Sensitive Files ──
# Mức độ  : Trung bình
# Chi tiết: Detects a commandline containing references to the Microsoft Teams database or cookies files from a process other than Teams. The database might contain authentication tokens and other sensitive infor
EventCode=4688 Channel="Security" CommandLine IN ("*\\Microsoft\\Teams\\Cookies*", "*\\Microsoft\\Teams\\Local Storage\\leveldb*") NOT NewProcessName="*\\Microsoft\\Teams\\current\\Teams.exe"

# ── New Virtual Smart Card Created Via TpmVscMgr.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "Tpmvscmgr.exe" to create a new virtual smart card.
EventCode=4688 Channel="Security" OriginalFileName="TpmVscMgr.exe" NewProcessName="*\\tpmvscmgr.exe" CommandLine="*create*"

# ── Suspicious TSCON Start as SYSTEM ──
# Mức độ  : Cao
# Chi tiết: Detects a tscon.exe start as LOCAL SYSTEM
EventCode=4688 Channel="Security" SubjectUserName IN ("*AUTHORI*", "*AUTORI*") NewProcessName="*\\tscon.exe"

# ── Suspicious RDP Redirect Using TSCON ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects a suspicious RDP session redirect using tscon.exe
EventCode=4688 Channel="Security" CommandLine="* /dest:rdp-tcp#*"

# ── Potential RDP Session Hijacking Activity ──
# Mức độ  : Trung bình
# Chi tiết: Detects potential RDP Session Hijacking activity on Windows systems
EventCode=4688 Channel="Security" NewProcessName="*\\tscon.exe" OR OriginalFileName="tscon.exe" MandatoryLabel IN ("S-1-16-16384", "None")

# ── UAC Bypass Using ChangePK and SLUI ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects an UAC bypass that uses changepk.exe and slui.exe (UACMe 61)
EventCode=4688 Channel="Security" NewProcessName="*\\changepk.exe" ParentProcessName="*\\slui.exe" MandatoryLabel IN ("S-1-16-12288", "S-1-16-16384", "None", "None")

# ── Bypass UAC via CMSTP ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detect commandline usage of Microsoft Connection Manager Profile Installer (cmstp.exe) to install specially formatted local .INF files
EventCode=4688 Channel="Security" NewProcessName="*\\cmstp.exe" OR OriginalFileName="CMSTP.EXE" CommandLine IN ("*/s*", "*-s*", "*/au*", "*-au*", "*/ni*", "*-ni*")

# ── UAC Bypass Tools Using ComputerDefaults ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects tools such as UACMe used to bypass UAC with computerdefaults.exe (UACMe 59)
EventCode=4688 Channel="Security" MandatoryLabel IN ("S-1-16-12288", "S-1-16-16384", "None", "None") NewProcessName="C:\\Windows\\System32\\ComputerDefaults.exe" NOT (ParentProcessName IN ("*:\\Windows\\System32*", "*:\\Program Files*"))

# ── UAC Bypass Using Consent and Comctl32 - Process ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects the pattern of UAC Bypass using consent.exe and comctl32.dll (UACMe 22)
EventCode=4688 Channel="Security" ParentProcessName="*\\consent.exe" NewProcessName="*\\werfault.exe" MandatoryLabel IN ("S-1-16-12288", "S-1-16-16384", "None", "None")

# ── UAC Bypass Using DismHost ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects the pattern of UAC Bypass using DismHost DLL hijacking (UACMe 63)
EventCode=4688 Channel="Security" ParentProcessName="*C:\\Users\\*" ParentProcessName="*\\AppData\\Local\\Temp\\*" ParentProcessName="*\\DismHost.exe*" MandatoryLabel IN ("S-1-16-12288", "S-1-16-16384", "None", "None")

# ── UAC Bypass Using Event Viewer RecentViews ──
# Mức độ  : Cao
# Chi tiết: Detects the pattern of UAC Bypass using Event Viewer RecentViews
EventCode=4688 Channel="Security" CommandLine IN ("*\\Event Viewer\\RecentViews*", "*\\EventV~1\\RecentViews*") CommandLine="*>*"

# ── Bypass UAC via Fodhelper.exe ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Identifies use of Fodhelper.exe to bypass User Account Control. Adversaries use this technique to execute privileged processes.
EventCode=4688 Channel="Security" ParentProcessName="*\\fodhelper.exe"

# ── UAC Bypass Using IEInstal - Process ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects the pattern of UAC Bypass using IEInstal.exe (UACMe 64)
EventCode=4688 Channel="Security" MandatoryLabel IN ("S-1-16-12288", "S-1-16-16384", "None", "None") ParentProcessName="*\\ieinstal.exe" NewProcessName="*\\AppData\\Local\\Temp\\*" NewProcessName="*consent.exe"

# ── UAC Bypass Using MSConfig Token Modification - Process ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects the pattern of UAC Bypass using a msconfig GUI hack (UACMe 55)
EventCode=4688 Channel="Security" CommandLine="\"C:\\Windows\\system32\\msconfig.exe\" -5" MandatoryLabel IN ("S-1-16-12288", "S-1-16-16384", "None", "None") ParentProcessName="*\\AppData\\Local\\Temp\\pkgmgr.exe"

# ── UAC Bypass Using NTFS Reparse Point - Process ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects the pattern of UAC Bypass using NTFS reparse point and wusa.exe DLL hijacking (UACMe 36)
