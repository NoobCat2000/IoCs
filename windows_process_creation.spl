EventCode=4688 Channel="Security" NewProcessName="*\\SharpLdapWhoami.exe" OR OriginalFileName="*SharpLdapWhoami*" OR Product="SharpLdapWhoami" OR CommandLine IN ("* /method:ntlm", "* /method:kerb", "* /method:nego", "* /m:nego", "* /m:ntlm", "* /m:kerb")

# ── HackTool - SharpMove Tool Execution ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects the execution of SharpMove, a .NET utility performing multiple tasks such as "Task Creation", "SCM" query, VBScript execution using WMI via its PE metadata and command line options.
EventCode=4688 Channel="Security" NewProcessName="*\\SharpMove.exe" OR OriginalFileName="SharpMove.exe" OR (CommandLine="*computername=*" CommandLine IN ("*action=create*", "*action=dcom*", "*action=executevbs*", "*action=hijackdcom*", "*action=modschtask*", "*action=modsvc*", "*action=query*", "*action=scm*", "*action=startservice*", "*action=taskscheduler*"))

# ── HKTL - SharpSuccessor Privilege Escalation Tool Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of SharpSuccessor, a tool used to exploit the BadSuccessor attack for privilege escalation in WinServer 2025 Active Directory environments. Successful usage of this tool can let 
EventCode=4688 Channel="Security" NewProcessName="*\\SharpSuccessor.exe" OR OriginalFileName="SharpSuccessor.exe" OR CommandLine="*SharpSuccessor*" OR (CommandLine="* add *" CommandLine="* /impersonate*" CommandLine="* /path*" CommandLine="* /account*" CommandLine="* /name*")

# ── HackTool - SharpUp PrivEsc Tool Execution ──
# Mức độ  : Nghiêm trọng
# Chi tiết: Detects the use of SharpUp, a tool for local privilege escalation
EventCode=4688 Channel="Security" NewProcessName="*\\SharpUp.exe" OR Description="SharpUp" OR CommandLine IN ("*HijackablePaths*", "*UnquotedServicePath*", "*ProcessDLLHijack*", "*ModifiableServiceBinaries*", "*ModifiableScheduledTask*", "*DomainGPPPassword*", "*CachedGPPPassword*")

# ── HackTool - SharpView Execution ──
# Mức độ  : Cao
# Mục đích: Thu thập thông tin user
# Chi tiết: Adversaries may look for details about the network configuration and settings of systems they access or through information discovery of remote systems
EventCode=4688 Channel="Security" OriginalFileName="SharpView.exe" OR NewProcessName="*\\SharpView.exe" OR CommandLine IN ("*Add-RemoteConnection*", "*Convert-ADName*", "*ConvertFrom-SID*", "*ConvertFrom-UACValue*", "*Convert-SidToName*", "*Export-PowerViewCSV*", "*Find-DomainObjectPropertyOutlier*", "*Find-DomainProcess*", "*Find-DomainShare*", "*Find-DomainUserEvent*", "*Find-DomainUserLocation*", "*Find-ForeignGroup*", "*Find-ForeignUser*", "*Find-GPOComputerAdmin*", "*Find-GPOLocation*", "*Find-Interesting*", "*Find-LocalAdminAccess*", "*Find-ManagedSecurityGroups*", "*Get-CachedRDPConnection*", "*Get-DFSshare*", "*Get-DomainComputer*", "*Get-DomainController*", "*Get-DomainDFSShare*", "*Get-DomainDNSRecord*", "*Get-DomainFileServer*", "*Get-DomainForeign*", "*Get-DomainGPO*", "*Get-DomainGroup*", "*Get-DomainGUIDMap*", "*Get-DomainManagedSecurityGroup*", "*Get-DomainObject*", "*Get-DomainOU*", "*Get-DomainPolicy*", "*Get-DomainSID*", "*Get-DomainSite*", "*Get-DomainSPNTicket*", "*Get-DomainSubnet*", "*Get-DomainTrust*", "*Get-DomainUserEvent*", "*Get-ForestDomain*", "*Get-ForestGlobalCatalog*", "*Get-ForestTrust*", "*Get-GptTmpl*", "*Get-GroupsXML*", "*Get-LastLoggedOn*", "*Get-LoggedOnLocal*", "*Get-NetComputer*", "*Get-NetDomain*", "*Get-NetFileServer*", "*Get-NetForest*", "*Get-NetGPO*", "*Get-NetGroupMember*", "*Get-NetLocalGroup*", "*Get-NetLoggedon*", "*Get-NetOU*", "*Get-NetProcess*", "*Get-NetRDPSession*", "*Get-NetSession*", "*Get-NetShare*", "*Get-NetSite*", "*Get-NetSubnet*", "*Get-NetUser*", "*Get-PathAcl*", "*Get-PrincipalContext*", "*Get-RegistryMountedDrive*", "*Get-RegLoggedOn*", "*Get-WMIRegCachedRDPConnection*", "*Get-WMIRegLastLoggedOn*", "*Get-WMIRegMountedDrive*", "*Get-WMIRegProxy*", "*Invoke-ACLScanner*", "*Invoke-CheckLocalAdminAccess*", "*Invoke-Kerberoast*", "*Invoke-MapDomainTrust*", "*Invoke-RevertToSelf*", "*Invoke-Sharefinder*", "*Invoke-UserImpersonation*", "*Remove-DomainObjectAcl*", "*Remove-RemoteConnection*", "*Request-SPNTicket*", "*Set-DomainObject*", "*Test-AdminAccess*")

# ── HackTool - SharpWSUS/WSUSpendu Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of SharpWSUS or WSUSpendu, utilities that allow for lateral movement through WSUS. Windows Server Update Services (WSUS) is a critical component of Windows systems and is frequen
EventCode=4688 Channel="Security" (CommandLine="* -Inject *" CommandLine IN ("* -PayloadArgs *", "* -PayloadFile *")) OR (CommandLine IN ("* approve *", "* create *", "* check *", "* delete *") CommandLine IN ("* /payload:*", "* /payload=*", "* /updateid:*", "* /updateid=*"))

# ── HackTool - Sliver C2 Implant Activity Pattern ──
# Mức độ  : Nghiêm trọng
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects process activity patterns as seen being used by Sliver C2 framework implants
EventCode=4688 Channel="Security" CommandLine="*-NoExit -Command [Console]::OutputEncoding=[Text.UTF8Encoding]::UTF8*"

# ── HackTool - SOAPHound Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of SOAPHound, a .NET tool for collecting Active Directory data, using specific command-line arguments that may indicate an attempt to extract sensitive AD information.
EventCode=4688 Channel="Security" CommandLine IN ("* --buildcache *", "* --bhdump *", "* --certdump *", "* --dnsdump *") CommandLine IN ("* -c *", "* --cachefilename *", "* -o *", "* --outputdirectory*")

# ── HackTool - Stracciatella Execution ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Stracciatella which executes a Powershell runspace from within C# (aka SharpPick technique) with AMSI, ETW and Script Block Logging disabled based on PE metadata characteristics.
EventCode=4688 Channel="Security" NewProcessName="*\\Stracciatella.exe" OR OriginalFileName="Stracciatella.exe" OR Description="Stracciatella" OR Hashes IN ("*SHA256=9d25e61ec1527e2a69d7c2a4e3fe2fe15890710c198a66a9f25d99fdf6c7b956*", "*SHA256=fd16609bd9830c63b9413671678bb159b89c357d21942ddbb6b93add808d121a*")

# ── HackTool - SysmonEOP Execution ──
# Mức độ  : Nghiêm trọng
# Chi tiết: Detects the execution of the PoC that can be used to exploit Sysmon CVE-2022-41120
EventCode=4688 Channel="Security" NewProcessName="*\\SysmonEOP.exe" OR Hashes IN ("*IMPHASH=22F4089EB8ABA31E1BB162C6D9BF72E5*", "*IMPHASH=5123FA4C4384D431CD0D893EEB49BBEC*")

# ── HackTool - TruffleSnout Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of TruffleSnout.exe an iterative AD discovery toolkit for offensive operators, situational awareness and targeted low noise enumeration.
EventCode=4688 Channel="Security" OriginalFileName="TruffleSnout.exe" OR NewProcessName="*\\TruffleSnout.exe"

# ── HackTool - UACMe Akagi Execution ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects the execution of UACMe, a tool used for UAC bypasses, via default PE metadata
EventCode=4688 Channel="Security" Product="UACMe" OR Company IN ("REvol Corp", "APT 92", "UG North", "Hazardous Environments", "CD Project Rekt") OR Description IN ("UACMe main module", "Pentesting utility") OR OriginalFileName IN ("Akagi.exe", "Akagi64.exe") OR NewProcessName IN ("*\\Akagi64.exe", "*\\Akagi.exe") OR Hashes IN ("*IMPHASH=767637C23BB42CD5D7397CF58B0BE688*", "*IMPHASH=14C4E4C72BA075E9069EE67F39188AD8*", "*IMPHASH=3C782813D4AFCE07BBFC5A9772ACDBDC*", "*IMPHASH=7D010C6BB6A3726F327F7E239166D127*", "*IMPHASH=89159BA4DD04E4CE5559F132A9964EB3*", "*IMPHASH=6F33F4A5FC42B8CEC7314947BD13F30F*", "*IMPHASH=5834ED4291BDEB928270428EBBAF7604*", "*IMPHASH=5A8A8A43F25485E7EE1B201EDCBC7A38*", "*IMPHASH=DC7D30B90B2D8ABF664FBED2B1B59894*", "*IMPHASH=41923EA1F824FE63EA5BEB84DB7A3E74*", "*IMPHASH=3DE09703C8E79ED2CA3F01074719906B*")

# ── HackTool - Windows Credential Editor (WCE) Execution ──
# Mức độ  : Nghiêm trọng
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the use of Windows Credential Editor (WCE), a popular post-exploitation tool used to extract plaintext passwords, hash, PIN code and Kerberos tickets from memory. It is often used by threat ac
EventCode=4688 Channel="Security" NewProcessName IN ("*\\WCE.exe", "*\\WCE64.exe") OR Hashes IN ("*IMPHASH=136F0A8572C058A96436C82E541E4C41*", "*IMPHASH=589657C64DDE88533186C39F82FA1F50*", "*IMPHASH=6BFE09EFCB4FFDE061EBDBAFC4DB84CF*", "*IMPHASH=7D490037BF450877E6D0287BDCFF8D2E*", "*IMPHASH=8AB93B061287C79F3088C5BC7E7D97ED*", "*IMPHASH=A53A02B997935FD8EEDCB5F7ABAB9B9F*", "*IMPHASH=BA434A7A729EEC20E136CA4C32D6C740*", "*IMPHASH=BD1D1547DA13C0FCB6C15E86217D5EB8*", "*IMPHASH=E96A73C7BF33A464C510EDE582318BF2*")

# ── HackTool - winPEAS Execution ──
# Mức độ  : Cao
# Mục đích: Thu thập thông tin hệ thống
# Chi tiết: WinPEAS is a script that search for possible paths to escalate privileges on Windows hosts. The checks are explained on book.hacktricks.xyz
EventCode=4688 Channel="Security" OriginalFileName="winPEAS.exe" OR NewProcessName IN ("*\\winPEASany_ofs.exe", "*\\winPEASany.exe", "*\\winPEASx64_ofs.exe", "*\\winPEASx64.exe", "*\\winPEASx86_ofs.exe", "*\\winPEASx86.exe") OR CommandLine IN ("* applicationsinfo*", "* browserinfo*", "* eventsinfo*", "* fileanalysis*", "* filesinfo*", "* processinfo*", "* servicesinfo*", "* windowscreds*") OR CommandLine="*https://github.com/carlospolop/PEASS-ng/releases/latest/download/*" OR ParentCommandLine="* -linpeas" OR CommandLine="* -linpeas"

# ── HackTool - WinPwn Execution ──
# Mức độ  : Cao
# Mục đích: Thu thập thông tin hệ thống; Leo thang đặc quyền
# Chi tiết: Detects commandline keywords indicative of potential usge of the tool WinPwn. A tool for Windows and Active Directory reconnaissance and exploitation.
EventCode=4688 Channel="Security" CommandLine IN ("*Offline_Winpwn*", "*WinPwn *", "*WinPwn.exe*", "*WinPwn.ps1*")

# ── HackTool - Wmiexec Default Powershell Command ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of PowerShell with a specific flag sequence that is used by the Wmiexec script
EventCode=4688 Channel="Security" CommandLine="*-NoP -NoL -sta -NonI -W Hidden -Exec Bypass -Enc*"

# ── HackTool - WSASS Execution ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects execution of WSASS, a tool used to dump LSASS memory on Windows systems by leveraging WER's (Windows Error Reporting) WerFaultSecure.EXE to bypass PPL (Protected Process Light) protections.
EventCode=4688 Channel="Security" NewProcessName="*\\wsass.exe"
| rex field=CommandLine "(?<CommandLineMatch>(?i)\\.exe[\\\"\\']?\\s+[^\\\"]{0,64}werfaultsecure\\.exe[\\\"\\']?\\s+\\d{2,10})"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| search OR Hashes="*IMPHASH=32F5095C9BBDCACF28FD4060EB4DFC42*" OR CommandLineCondition="true"

# ── HackTool - XORDump Execution ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Dump thông tin xác thực
# Chi tiết: Detects suspicious use of XORDump process memory dumping utility
EventCode=4688 Channel="Security" NewProcessName="*\\xordump.exe" OR CommandLine IN ("* -process lsass.exe *", "* -m comsvcs *", "* -m dbghelp *", "* -m dbgcore *")

# ── Suspicious ZipExec Execution ──
# Mức độ  : Trung bình
# Chi tiết: ZipExec is a Proof-of-Concept (POC) tool to wrap binary-based tools into a password-protected zip file.
EventCode=4688 Channel="Security" (CommandLine="*/generic:Microsoft_Windows_Shell_ZipFolder:filename=*" CommandLine="*.zip*" CommandLine="*/pass:*" CommandLine="*/user:*") OR (CommandLine="*/delete*" CommandLine="*Microsoft_Windows_Shell_ZipFolder:filename=*" CommandLine="*.zip*")

# ── Suspicious Execution of Hostname ──
# Mức độ  : Thấp
# Mục đích: Thu thập thông tin hệ thống
# Chi tiết: Use of hostname to get information
EventCode=4688 Channel="Security" NewProcessName="*\\HOSTNAME.EXE"

# ── Hypervisor-protected Code Integrity (HVCI) Related Registry Tampering Via CommandLine ──
# Mức độ  : Cao
# Chi tiết: Detects the tampering of Hypervisor-protected Code Integrity (HVCI) related registry values via command line tool reg.exe. HVCI uses virtualization-based security to protect code integrity by ensuring
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe", "*\\reg.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll", "reg.exe") CommandLine IN ("*add *", "*New-ItemProperty *", "*Set-ItemProperty *", "*si *") CommandLine="*\\DeviceGuard*" CommandLine IN ("*EnableVirtualizationBasedSecurity*", "*HypervisorEnforcedCodeIntegrity*")

# ── Suspicious HWP Sub Processes ──
# Mức độ  : Cao
# Mục đích: Phishing; Thực thi lệnh/script
# Chi tiết: Detects suspicious Hangul Word Processor (Hanword) sub processes that could indicate an exploitation
EventCode=4688 Channel="Security" ParentProcessName="*\\Hwp.exe" NewProcessName="*\\gbb.exe"

# ── Potential Fake Instance Of Hxtsr.EXE Executed ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: HxTsr.exe is a Microsoft compressed executable file called Microsoft Outlook Communications. HxTsr.exe is part of Outlook apps, because it resides in a hidden "WindowsApps" subfolder of "C:\Program Fi
EventCode=4688 Channel="Security" NewProcessName="*\\hxtsr.exe" NOT (NewProcessName="*:\\program files\\windowsapps\\microsoft.windowscommunicationsapps_*" NewProcessName="*\\hxtsr.exe")

# ── Use Icacls to Hide File to Everyone ──
# Mức độ  : Trung bình
# Chi tiết: Detect use of icacls to deny access for everyone in Users folder sometimes used to hide malicious files
EventCode=4688 Channel="Security" OriginalFileName="iCACLS.EXE" OR NewProcessName="*\\icacls.exe" CommandLine="*/deny*" CommandLine="*S-1-1-0:*"

# ── File Download And Execution Via IEExec.EXE ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects execution of the IEExec utility to download and execute files
EventCode=4688 Channel="Security" NewProcessName="*\\IEExec.exe" OR OriginalFileName="IEExec.exe" CommandLine IN ("*http://*", "*https://*")

# ── Self Extracting Package Creation Via Iexpress.EXE From Potentially Suspicious Location ──
# Mức độ  : Cao
# Chi tiết: Detects the use of iexpress.exe to create binaries via Self Extraction Directive (SED) files located in potentially suspicious locations. This behavior has been observed in-the-wild by different threa
EventCode=4688 Channel="Security" NewProcessName="*\\iexpress.exe" OR OriginalFileName="IEXPRESS.exe" CommandLine="* -n *" OR CommandLine="* /n *" OR CommandLine="* –n *" OR CommandLine="* —n *" OR CommandLine="* ―n *" CommandLine IN ("*:\\ProgramData\\*", "*:\\Temp\\*", "*:\\Windows\\System32\\Tasks\\*", "*:\\Windows\\Tasks\\*", "*:\\Windows\\Temp\\*", "*\\AppData\\Local\\Temp\\*")

# ── Disable Windows IIS HTTP Logging ──
# Mức độ  : Cao
# Chi tiết: Disables HTTP logging on a Windows IIS web server as seen by Threat Group 3390 (Bronze Union)
EventCode=4688 Channel="Security" NewProcessName="*\\appcmd.exe" OR OriginalFileName="appcmd.exe" CommandLine="*set*" CommandLine="*config*" CommandLine="*section:httplogging*" CommandLine="*dontLog:true*"

# ── Microsoft IIS Service Account Password Dumped ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the Internet Information Services (IIS) command-line tool, AppCmd, being used to list passwords
EventCode=4688 Channel="Security" NewProcessName="*\\appcmd.exe" OR OriginalFileName="appcmd.exe" CommandLine="*list *" CommandLine IN ("* /config*", "* /xml*", "* -config*", "* -xml*") OR (CommandLine IN ("* /@t*", "* /text*", "* /show*", "* -@t*", "* -text*", "* -show*") CommandLine IN ("*:\**", "*password*"))

# ── IIS Native-Code Module Command Line Installation ──
# Mức độ  : Trung bình
# Chi tiết: Detects suspicious IIS native-code module installations via command line
EventCode=4688 Channel="Security" NewProcessName="*\\appcmd.exe" OR OriginalFileName="appcmd.exe" CommandLine="*install*" CommandLine="*module*" CommandLine="*-name:*" OR CommandLine="*/name:*" OR CommandLine="*–name:*" OR CommandLine="*—name:*" OR CommandLine="*―name:*" NOT ParentProcessName="C:\\Windows\\System32\\inetsrv\\iissetup.exe"

# ── Suspicious IIS URL GlobalRules Rewrite Via AppCmd ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of "appcmd" to create new global URL rewrite rules. This behaviour has been observed being used by threat actors to add new rules so they can access their webshells.
EventCode=4688 Channel="Security" NewProcessName="*\\appcmd.exe" OR OriginalFileName="appcmd.exe" CommandLine="*set*" CommandLine="*config*" CommandLine="*section:system.webServer/rewrite/globalRules*" CommandLine="*commit:*"

# ── Microsoft IIS Connection Strings Decryption ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects use of aspnet_regiis to decrypt Microsoft IIS connection strings. An attacker with Microsoft IIS web server access via a webshell or alike can decrypt and dump any hardcoded connection strings
EventCode=4688 Channel="Security" NewProcessName="*\\aspnet_regiis.exe" OR OriginalFileName="aspnet_regiis.exe" CommandLine="*connectionStrings*" CommandLine="* -pdf*"

# ── IIS WebServer Log Deletion via CommandLine Utilities ──
# Mức độ  : Trung bình
# Mục đích: Xóa dấu vết
# Chi tiết: Detects attempts to delete Internet Information Services (IIS) log files via command line utilities, which is a common defense evasion technique used by attackers to cover their tracks. Threat actors 
EventCode=4688 Channel="Security" NewProcessName IN ("*\\cmd.exe", "*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("cmd.exe", "powershell.exe", "powershell_ise.exe", "pwsh.dll") CommandLine IN ("*del *", "*erase *", "*rm *", "*remove-item *", "*rmdir *") CommandLine="*\\inetpub\\logs\\*"

# ── Suspicious IIS Module Registration ──
# Mức độ  : Cao
# Chi tiết: Detects a suspicious IIS module registration as described in Microsoft threat report on IIS backdoors
EventCode=4688 Channel="Security" ParentProcessName="*\\w3wp.exe" CommandLine="*appcmd.exe add module*" OR (CommandLine="* system.enterpriseservices.internal.publish*" NewProcessName="*\\powershell.exe") OR (CommandLine="*gacutil*" CommandLine="* /I*")

# ── C# IL Code Compilation Via Ilasm.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of "Ilasm.EXE" in order to compile C# intermediate (IL) code to EXE or DLL.
EventCode=4688 Channel="Security" NewProcessName="*\\ilasm.exe" OR OriginalFileName="ilasm.exe" CommandLine IN ("* /dll*", "* /exe*")

# ── ImagingDevices Unusual Parent/Child Processes ──
# Mức độ  : Cao
# Chi tiết: Detects unusual parent or children of the ImagingDevices.exe (Windows Contacts) process as seen being used with Bumblebee activity
EventCode=4688 Channel="Security" (ParentProcessName IN ("*\\WmiPrvSE.exe", "*\\svchost.exe", "*\\dllhost.exe") NewProcessName="*\\ImagingDevices.exe") OR ParentProcessName="*\\ImagingDevices.exe"

# ── Arbitrary File Download Via IMEWDBLD.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects usage of "IMEWDBLD.exe" to download arbitrary files
EventCode=4688 Channel="Security" NewProcessName="*\\IMEWDBLD.exe" OR OriginalFileName="imewdbld.exe" CommandLine IN ("*http://*", "*https://*")

# ── InfDefaultInstall.exe .inf Execution ──
# Mức độ  : Trung bình
# Chi tiết: Executes SCT script using scrobj.dll from a command in entered into a specially prepared INF file.
EventCode=4688 Channel="Security" CommandLine="*InfDefaultInstall.exe *" CommandLine="*.inf*"

# ── File Download Via InstallUtil.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects use of .NET InstallUtil.exe in order to download arbitrary files. The files will be written to "%LOCALAPPDATA%\Microsoft\Windows\INetCache\IE\"
EventCode=4688 Channel="Security" NewProcessName="*\\InstallUtil.exe" OR OriginalFileName="InstallUtil.exe" CommandLine IN ("*ftp://*", "*http://*", "*https://*")

# ── Suspicious Execution of InstallUtil Without Log ──
# Mức độ  : Trung bình
# Chi tiết: Uses the .NET InstallUtil.exe application in order to execute image without log
EventCode=4688 Channel="Security" CommandLine="*/logfile= *" CommandLine="*/LogToConsole=false*" NewProcessName="*\\InstallUtil.exe" NewProcessName="*Microsoft.NET\\Framework*"

# ── Suspicious Shells Spawn by Java Utility Keytool ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious shell spawn from Java utility keytool process (e.g. adselfservice plus exploitation)
EventCode=4688 Channel="Security" ParentProcessName="*\\keytool.exe" NewProcessName IN ("*\\cmd.exe", "*\\sh.exe", "*\\bash.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\schtasks.exe", "*\\certutil.exe", "*\\whoami.exe", "*\\bitsadmin.exe", "*\\wscript.exe", "*\\cscript.exe", "*\\scrcons.exe", "*\\regsvr32.exe", "*\\hh.exe", "*\\wmic.exe", "*\\mshta.exe", "*\\rundll32.exe", "*\\forfiles.exe", "*\\scriptrunner.exe", "*\\mftrace.exe", "*\\AppVLP.exe", "*\\systeminfo.exe", "*\\reg.exe", "*\\query.exe")

# ── Suspicious Child Process Of Manage Engine ServiceDesk ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious child processes of the "Manage Engine ServiceDesk Plus" Java web service
EventCode=4688 Channel="Security" ParentProcessName="*\\ManageEngine\\ServiceDesk\\*" ParentProcessName="*\\java.exe*" NewProcessName IN ("*\\AppVLP.exe", "*\\bash.exe", "*\\bitsadmin.exe", "*\\calc.exe", "*\\certutil.exe", "*\\cscript.exe", "*\\curl.exe", "*\\forfiles.exe", "*\\mftrace.exe", "*\\mshta.exe", "*\\net.exe", "*\\net1.exe", "*\\notepad.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\query.exe", "*\\reg.exe", "*\\schtasks.exe", "*\\scrcons.exe", "*\\sh.exe", "*\\systeminfo.exe", "*\\whoami.exe", "*\\wmic.exe", "*\\wscript.exe") NOT (CommandLine="* stop*" NewProcessName IN ("*\\net.exe", "*\\net1.exe"))

# ── Java Running with Remote Debugging ──
# Mức độ  : Trung bình
# Chi tiết: Detects a JAVA process running with remote debugging allowing more than just localhost to connect
EventCode=4688 Channel="Security" CommandLine="*transport=dt_socket,address=*" CommandLine IN ("*jre1.*", "*jdk1.*") NOT (CommandLine IN ("*address=127.0.0.1*", "*address=localhost*"))

# ── Suspicious Processes Spawned by Java.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious processes spawned from a Java host process which could indicate a sign of exploitation (e.g. log4j)
EventCode=4688 Channel="Security" ParentProcessName="*\\java.exe" NewProcessName IN ("*\\AppVLP.exe", "*\\bitsadmin.exe", "*\\certutil.exe", "*\\cscript.exe", "*\\curl.exe", "*\\forfiles.exe", "*\\hh.exe", "*\\mftrace.exe", "*\\mshta.exe", "*\\net.exe", "*\\net1.exe", "*\\query.exe", "*\\reg.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\schtasks.exe", "*\\scrcons.exe", "*\\scriptrunner.exe", "*\\sh.exe", "*\\systeminfo.exe", "*\\whoami.exe", "*\\wmic.exe", "*\\wscript.exe")

# ── Shell Process Spawned by Java.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects shell spawned from Java host process, which could be a sign of exploitation (e.g. log4j exploitation)
EventCode=4688 Channel="Security" ParentProcessName="*\\java.exe" NewProcessName IN ("*\\bash.exe", "*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe") NOT (CommandLine="*build*" ParentProcessName="*build*")

# ── JScript Compiler Execution ──
# Mức độ  : Thấp
# Chi tiết: Detects the execution of the "jsc.exe" (JScript Compiler). Attacker might abuse this in order to compile JScript files on the fly and bypassing application whitelisting.
EventCode=4688 Channel="Security" NewProcessName="*\\jsc.exe" OR OriginalFileName="jsc.exe"

# ── Kavremover Dropped Binary LOLBIN Usage ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of a signed binary dropped by Kaspersky Lab Products Remover (kavremover) which can be abused as a LOLBIN to execute arbitrary commands and binaries.
EventCode=4688 Channel="Security" CommandLine="* run run-cmd *" NOT (ParentProcessName IN ("*\\cleanapi.exe", "*\\kavremover.exe"))

# ── Windows Kernel Debugger Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of the Windows Kernel Debugger "kd.exe".
EventCode=4688 Channel="Security" NewProcessName="*\\kd.exe" OR OriginalFileName="kd.exe"

# ── Attempts of Kerberos Coercion Via DNS SPN Spoofing ──
# Mức độ  : Cao
# Chi tiết: Detects the presence of "UWhRC....AAYBAAAA" pattern in command line. The pattern "1UWhRCAAAAA..BAAAA" is a base64-encoded signature that corresponds to a marshaled CREDENTIAL_TARGET_INFORMATION struct
EventCode=4688 Channel="Security" CommandLine="*UWhRCA*" CommandLine="*BAAAA*"

# ── Potentially Suspicious Child Process of KeyScrambler.exe ──
# Mức độ  : Trung bình
# Chi tiết: Detects potentially suspicious child processes of KeyScrambler.exe
EventCode=4688 Channel="Security" ParentProcessName="*\\KeyScrambler.exe" NewProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") OR OriginalFileName IN ("Cmd.Exe", "cscript.exe", "mshta.exe", "PowerShell.EXE", "pwsh.dll", "regsvr32.exe", "RUNDLL32.EXE", "wscript.exe")

# ── Computer Password Change Via Ksetup.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects password change for the computer's domain account or host principal via "ksetup.exe"
EventCode=4688 Channel="Security" NewProcessName="*\\ksetup.exe" OR OriginalFileName="ksetup.exe" CommandLine="* /setcomputerpassword *"

# ── Logged-On User Password Change Via Ksetup.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects password change for the logged-on user's via "ksetup.exe"
EventCode=4688 Channel="Security" NewProcessName="*\\ksetup.exe" OR OriginalFileName="ksetup.exe" CommandLine="* /ChangePassword *"

# ── Active Directory Structure Export Via Ldifde.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of "ldifde.exe" in order to export organizational Active Directory structure.
EventCode=4688 Channel="Security" NewProcessName="*\\ldifde.exe" OR OriginalFileName="ldifde.exe" CommandLine="*-f*" NOT CommandLine="* -i*"

# ── Import LDAP Data Interchange Format File Via Ldifde.EXE ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects the execution of "Ldifde.exe" with the import flag "-i". The can be abused to include HTTP-based arguments which will allow the arbitrary download of files from a remote server.
EventCode=4688 Channel="Security" NewProcessName="*\\ldifde.exe" OR OriginalFileName="ldifde.exe" CommandLine="*-i*" CommandLine="*-f*"

# ── Uncommon Link.EXE Parent Process ──
# Mức độ  : Trung bình
# Chi tiết: Detects an uncommon parent process of "LINK.EXE". Link.EXE in Microsoft incremental linker. Its a utility usually bundled with Visual Studio installation. Multiple utilities often found in the same fo
EventCode=4688 Channel="Security" CommandLine="*LINK /*" NewProcessName="*\\link.exe" NOT (ParentProcessName IN ("C:\\Program Files\\Microsoft Visual Studio\\*", "C:\\Program Files (x86)\\Microsoft Visual Studio\\*") ParentProcessName IN ("*\\VC\\bin\\*", "*\\VC\\Tools\\*"))

# ── Rebuild Performance Counter Values Via Lodctr.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of "lodctr.exe" to rebuild the performance counter registry values. This can be abused by attackers by providing a malicious config file to overwrite performance counter configur
EventCode=4688 Channel="Security" OriginalFileName="LODCTR.EXE" NewProcessName="*\\lodctr.exe" CommandLine="* -r*" OR CommandLine="* /r*" OR CommandLine="* –r*" OR CommandLine="* —r*" OR CommandLine="* ―r*"

# ── Suspicious Windows Trace ETW Session Tamper Via Logman.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of "logman" utility in order to disable or delete Windows trace sessions
EventCode=4688 Channel="Security" NewProcessName="*\\logman.exe" OR OriginalFileName="Logman.exe" CommandLine IN ("*stop *", "*delete *") CommandLine IN ("*Circular Kernel Context Logger*", "*EventLog-*", "*SYSMON TRACE*", "*SysmonDnsEtwSession*")

# ── LOLBAS Data Exfiltration by DataSvcUtil.exe ──
# Mức độ  : Trung bình
# Chi tiết: Detects when a user performs data exfiltration by using DataSvcUtil.exe
EventCode=4688 Channel="Security" CommandLine IN ("*/in:*", "*/out:*", "*/uri:*") NewProcessName="*\\DataSvcUtil.exe" OR OriginalFileName="DataSvcUtil.exe"

# ── Devtoolslauncher.exe Executes Specified Binary ──
# Mức độ  : Cao
# Chi tiết: The Devtoolslauncher.exe executes other binary
EventCode=4688 Channel="Security" CommandLine="*LaunchForDeploy*" NewProcessName="*\\devtoolslauncher.exe"

# ── Suspicious Diantz Alternate Data Stream Execution ──
# Mức độ  : Trung bình
# Chi tiết: Compress target file into a cab file stored in the Alternate Data Stream (ADS) of the target file.
EventCode=4688 Channel="Security" CommandLine="*diantz.exe*" CommandLine="*.cab*"
| regex CommandLine=":[^\\\\]"

# ── Suspicious Diantz Download and Compress Into a CAB File ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Download and compress a remote file and store it in a cab file on local machine.
EventCode=4688 Channel="Security" CommandLine="*diantz.exe*" CommandLine="* \\\\*" CommandLine="*.cab*"

# ── Suspicious Extrac32 Execution ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Download or Copy file with Extrac32
EventCode=4688 Channel="Security" CommandLine="*extrac32.exe*" OR NewProcessName="*\\extrac32.exe" OR OriginalFileName="extrac32.exe" CommandLine="*.cab*" CommandLine IN ("*/C*", "*/Y*", "* \\\\*")

# ── Suspicious Extrac32 Alternate Data Stream Execution ──
# Mức độ  : Trung bình
# Chi tiết: Extract data from cab file and hide it in an alternate data stream
EventCode=4688 Channel="Security" CommandLine="*extrac32.exe*" CommandLine="*.cab*"
| regex CommandLine=":[^\\\\]"

# ── Potential Reconnaissance Activity Via GatherNetworkInfo.VBS ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution of the built-in script located in "C:\Windows\System32\gatherNetworkInfo.vbs". Which can be used to gather information about the target machine
EventCode=4688 Channel="Security" NewProcessName IN ("*\\cscript.exe", "*\\wscript.exe") OR OriginalFileName IN ("cscript.exe", "wscript.exe") CommandLine="*gatherNetworkInfo.vbs*"

# ── Gpscript Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of the LOLBIN gpscript, which executes logon or startup scripts configured in Group Policy
EventCode=4688 Channel="Security" NewProcessName="*\\gpscript.exe" OR OriginalFileName="GPSCRIPT.EXE" CommandLine IN ("* /logon*", "* /startup*") NOT ParentCommandLine="C:\\windows\\system32\\svchost.exe -k netsvcs -p -s gpsvc"

# ── Ie4uinit Lolbin Use From Invalid Path ──
# Mức độ  : Trung bình
# Chi tiết: Detect use of ie4uinit.exe to execute commands from a specially prepared ie4uinit.inf file from a directory other than the usual directories
EventCode=4688 Channel="Security" NewProcessName="*\\ie4uinit.exe" OR OriginalFileName="IE4UINIT.EXE" NOT (CurrentDirectory IN ("c:\\windows\\system32\\", "c:\\windows\\sysWOW64\\") OR NOT CurrentDirectory=*)

# ── Launch-VsDevShell.PS1 Proxy Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of the 'Launch-VsDevShell.ps1' Microsoft signed script to execute commands.
EventCode=4688 Channel="Security" CommandLine="*Launch-VsDevShell.ps1*" CommandLine IN ("*VsWherePath *", "*VsInstallationPath *")

# ── Potential Manage-bde.wsf Abuse To Proxy Execution ──
# Mức độ  : Cao
# Chi tiết: Detects potential abuse of the "manage-bde.wsf" script as a LOLBIN to proxy execution
EventCode=4688 Channel="Security" (NewProcessName="*\\wscript.exe" OR OriginalFileName="wscript.exe" CommandLine="*manage-bde.wsf*") OR (ParentCommandLine="*manage-bde.wsf*" ParentProcessName IN ("*\\cscript.exe", "*\\wscript.exe") NOT NewProcessName="*\\cmd.exe")

# ── Mavinject Inject DLL Into Running Process ──
# Mức độ  : Cao
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: Detects process injection using the signed Windows tool "Mavinject" via the "INJECTRUNNING" flag
EventCode=4688 Channel="Security" CommandLine="* /INJECTRUNNING *" NOT ParentProcessName="C:\\Windows\\System32\\AppVClient.exe"

# ── MpiExec Lolbin ──
# Mức độ  : Cao
# Chi tiết: Detects a certain command line flag combination used by mpiexec.exe LOLBIN from HPC pack that can be used to execute any other binary
EventCode=4688 Channel="Security" NewProcessName="*\\mpiexec.exe" OR Hashes="*IMPHASH=d8b52ef6aaa3a81501bdfff9dbb96217*" CommandLine IN ("* /n 1 *", "* -n 1 *")

# ── Execute Files with Msdeploy.exe ──
# Mức độ  : Trung bình
# Chi tiết: Detects file execution using the msdeploy.exe lolbin
EventCode=4688 Channel="Security" CommandLine="*verb:sync*" CommandLine="*-source:RunCommand*" CommandLine="*-dest:runCommand*" NewProcessName="*\\msdeploy.exe"

# ── Use of OpenConsole ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects usage of OpenConsole binary as a LOLBIN to launch other binaries to bypass application Whitelisting
EventCode=4688 Channel="Security" OriginalFileName="OpenConsole.exe" OR NewProcessName="*\\OpenConsole.exe" NOT NewProcessName="C:\\Program Files\\WindowsApps\\Microsoft.WindowsTerminal*"

# ── OpenWith.exe Executes Specified Binary ──
# Mức độ  : Cao
# Chi tiết: The OpenWith.exe executes other binary
EventCode=4688 Channel="Security" CommandLine="*/c*" NewProcessName="*\\OpenWith.exe"

# ── Use of Pcalua For Execution ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execition of commands and binaries from the context of The program compatibility assistant (Pcalua.exe). This can be used as a LOLBIN in order to bypass application whitelisting.
EventCode=4688 Channel="Security" CommandLine="* -a*" NewProcessName="*\\pcalua.exe"

# ── Indirect Command Execution By Program Compatibility Wizard ──
# Mức độ  : Thấp
# Chi tiết: Detect indirect command execution via Program Compatibility Assistant pcwrun.exe
EventCode=4688 Channel="Security" ParentProcessName="*\\pcwrun.exe"

# ── Execute Pcwrun.EXE To Leverage Follina ──
# Mức độ  : Cao
# Chi tiết: Detects indirect command execution via Program Compatibility Assistant "pcwrun.exe" leveraging the follina (CVE-2022-30190) vulnerability
EventCode=4688 Channel="Security" CommandLine="*../*" NewProcessName="*\\pcwrun.exe"

# ── Code Execution via Pcwutl.dll ──
# Mức độ  : Trung bình
# Chi tiết: Detects launch of executable by calling the LaunchApplication function from pcwutl.dll library.
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" CommandLine="*pcwutl*" CommandLine="*LaunchApplication*"

# ── Execute Code with Pester.bat as Parent ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects code execution via Pester.bat (Pester - Powershell Modulte for testing)
EventCode=4688 Channel="Security" ParentCommandLine="*\\WindowsPowerShell\\Modules\\Pester\\*" ParentProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") ParentCommandLine IN ("*{ Invoke-Pester -EnableExit ;*", "*{ Get-Help \"*")

# ── Execute Code with Pester.bat ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects code execution via Pester.bat (Pester - Powershell Modulte for testing)
EventCode=4688 Channel="Security" (CommandLine="*Pester*" CommandLine="*Get-Help*" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe")) OR (CommandLine="*pester*" CommandLine="*;*" NewProcessName="*\\cmd.exe" CommandLine IN ("*help*", "*?*"))

# ── PrintBrm ZIP Creation of Extraction ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects the execution of the LOLBIN PrintBrm.exe, which can be used to create or extract ZIP files. PrintBrm.exe should not be run on a normal workstation.
EventCode=4688 Channel="Security" CommandLine="* -f*" CommandLine="*.zip*" NewProcessName="*\\PrintBrm.exe"

# ── Pubprn.vbs Proxy Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of the 'Pubprn.vbs' Microsoft signed script to execute commands.
EventCode=4688 Channel="Security" CommandLine="*\\pubprn.vbs*" CommandLine="*script:*"

# ── DLL Execution via Rasautou.exe ──
# Mức độ  : Trung bình
# Chi tiết: Detects using Rasautou.exe for loading arbitrary .DLL specified in -d option and executes the export specified in -p.
EventCode=4688 Channel="Security" NewProcessName="*\\rasautou.exe" OR OriginalFileName="rasdlui.exe" CommandLine="* -d *" CommandLine="* -p *"

# ── REGISTER_APP.VBS Proxy Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of a Microsoft signed script 'REGISTER_APP.VBS' to register a VSS/VDS Provider as a COM+ application.
EventCode=4688 Channel="Security" CommandLine="*\\register_app.vbs*" CommandLine="*-register*"

# ── Use of Remote.exe ──
# Mức độ  : Trung bình
# Chi tiết: Remote.exe is part of WinDbg in the Windows SDK and can be used for AWL bypass and running remote files.
EventCode=4688 Channel="Security" NewProcessName="*\\remote.exe" OR OriginalFileName="remote.exe"

# ── Replace.exe Usage ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects the use of Replace.exe which can be used to replace file with another file
EventCode=4688 Channel="Security" NewProcessName="*\\replace.exe" CommandLine="*-a*" OR CommandLine="*/a*" OR CommandLine="*–a*" OR CommandLine="*—a*" OR CommandLine="*―a*"

# ── Lolbin Runexehelper Use As Proxy ──
# Mức độ  : Trung bình
# Chi tiết: Detect usage of the "runexehelper.exe" binary as a proxy to launch other programs
EventCode=4688 Channel="Security" ParentProcessName="*\\runexehelper.exe"

# ── Suspicious Runscripthelper.exe ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution of powershell scripts via Runscripthelper.exe
EventCode=4688 Channel="Security" CommandLine="*surfacecheck*" NewProcessName="*\\Runscripthelper.exe"

# ── Use of Scriptrunner.exe ──
# Mức độ  : Trung bình
# Chi tiết: The "ScriptRunner.exe" binary can be abused to proxy execution through it and bypass possible whitelisting
EventCode=4688 Channel="Security" NewProcessName="*\\ScriptRunner.exe" OR OriginalFileName="ScriptRunner.exe" CommandLine="* -appvscript *"

# ── Use Of The SFTP.EXE Binary As A LOLBIN ──
# Mức độ  : Trung bình
# Chi tiết: Detects the usage of the "sftp.exe" binary as a LOLBIN by abusing the "-D" flag
EventCode=4688 Channel="Security" CommandLine IN ("* -D ..*", "* -D C:\\*") NewProcessName="*\\sftp.exe"

# ── Suspicious Driver Install by pnputil.exe ──
# Mức độ  : Trung bình
# Mục đích: Persistence qua autorun
# Chi tiết: Detects when a possible suspicious driver is being installed via pnputil.exe lolbin
EventCode=4688 Channel="Security" CommandLine IN ("*-i*", "*/install*", "*-a*", "*/add-driver*", "*.inf*") NewProcessName="*\\pnputil.exe"

# ── Suspicious GrpConv Execution ──
# Mức độ  : Cao
# Mục đích: Persistence qua autorun
# Chi tiết: Detects the suspicious execution of a utility to convert Windows 3.x .grp files or for persistence purposes by malicious software or actors
EventCode=4688 Channel="Security" CommandLine IN ("*grpconv.exe -o*", "*grpconv -o*")

# ── Dumping Process via Sqldumper.exe ──
# Mức độ  : Trung bình
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects process dump via legitimate sqldumper.exe binary
EventCode=4688 Channel="Security" CommandLine IN ("*0x0110*", "*0x01100:40*") NewProcessName="*\\sqldumper.exe"

# ── SyncAppvPublishingServer Execute Arbitrary PowerShell Code ──
# Mức độ  : Trung bình
# Chi tiết: Executes arbitrary PowerShell code using SyncAppvPublishingServer.exe.
EventCode=4688 Channel="Security" NewProcessName="*\\SyncAppvPublishingServer.exe" OR OriginalFileName="syncappvpublishingserver.exe" CommandLine="*\"n; *"

# ── SyncAppvPublishingServer VBS Execute Arbitrary PowerShell Code ──
# Mức độ  : Trung bình
# Chi tiết: Executes arbitrary PowerShell code using SyncAppvPublishingServer.vbs
EventCode=4688 Channel="Security" CommandLine="*\\SyncAppvPublishingServer.vbs*" CommandLine="*;*"

# ── Potential DLL Injection Or Execution Using Tracker.exe ──
# Mức độ  : Trung bình
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: Detects potential DLL injection and execution using "Tracker.exe"
EventCode=4688 Channel="Security" NewProcessName="*\\tracker.exe" OR Description="Tracker" CommandLine IN ("* /d *", "* /c *") NOT (CommandLine="* /ERRORREPORT:PROMPT *" OR ParentProcessName IN ("*\\Msbuild\\Current\\Bin\\MSBuild.exe", "*\\Msbuild\\Current\\Bin\\amd64\\MSBuild.exe"))

# ── Use of TTDInject.exe ──
# Mức độ  : Trung bình
# Chi tiết: Detects the executiob of TTDInject.exe, which is used by Windows 10 v1809 and newer to debug time travel (underlying call of tttracer.exe)
EventCode=4688 Channel="Security" NewProcessName="*ttdinject.exe" OR OriginalFileName="TTDInject.EXE"

# ── Time Travel Debugging Utility Usage ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects usage of Time Travel Debugging Utility. Adversaries can execute malicious processes and dump processes, such as lsass.exe, via tttracer.exe.
EventCode=4688 Channel="Security" ParentProcessName="*\\tttracer.exe"

# ── Lolbin Unregmp2.exe Use As Proxy ──
# Mức độ  : Trung bình
# Chi tiết: Detect usage of the "unregmp2.exe" binary as a proxy to launch a custom version of "wmpnscfg.exe"
EventCode=4688 Channel="Security" NewProcessName="*\\unregmp2.exe" OR OriginalFileName="unregmp2.exe" CommandLine="* -HideWMP*" OR CommandLine="* /HideWMP*" OR CommandLine="* –HideWMP*" OR CommandLine="* —HideWMP*" OR CommandLine="* ―HideWMP*"

# ── UtilityFunctions.ps1 Proxy Dll ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of a Microsoft signed script executing a managed DLL with PowerShell.
EventCode=4688 Channel="Security" CommandLine IN ("*UtilityFunctions.ps1*", "*RegSnapin *")

# ── Visual Basic Command Line Compiler Usage ──
# Mức độ  : Cao
# Chi tiết: Detects successful code compilation via Visual Basic Command Line Compiler that utilizes Windows Resource to Object Converter.
EventCode=4688 Channel="Security" ParentProcessName="*\\vbc.exe" NewProcessName="*\\cvtres.exe"

# ── Use of VisualUiaVerifyNative.exe ──
# Mức độ  : Trung bình
# Chi tiết: VisualUiaVerifyNative.exe is a Windows SDK that can be used for AWL bypass and is listed in Microsoft's recommended block rules.
EventCode=4688 Channel="Security" NewProcessName="*\\VisualUiaVerifyNative.exe" OR OriginalFileName="VisualUiaVerifyNative.exe"

# ── Use of VSIISExeLauncher.exe ──
# Mức độ  : Trung bình
# Chi tiết: The "VSIISExeLauncher.exe" binary part of the Visual Studio/VS Code can be used to execute arbitrary binaries
EventCode=4688 Channel="Security" NewProcessName="*\\VSIISExeLauncher.exe" OR OriginalFileName="VSIISExeLauncher.exe" CommandLine IN ("* -p *", "* -a *")

# ── Use of Wfc.exe ──
# Mức độ  : Trung bình
# Chi tiết: The Workflow Command-line Compiler can be used for AWL bypass and is listed in Microsoft's recommended block rules.
EventCode=4688 Channel="Security" NewProcessName="*\\wfc.exe" OR OriginalFileName="wfc.exe"

# ── Potential Register_App.Vbs LOLScript Abuse ──
# Mức độ  : Trung bình
# Chi tiết: Detects potential abuse of the "register_app.vbs" script that is part of the Windows SDK. The script offers the capability to register new VSS/VDS Provider as a COM+ application. Attackers can use thi
EventCode=4688 Channel="Security" NewProcessName IN ("*\\cscript.exe", "*\\wscript.exe") OR OriginalFileName IN ("cscript.exe", "wscript.exe") CommandLine="*.vbs -register *"

# ── LSA PPL Protection Setting Modification via CommandLine ──
# Mức độ  : Trung bình
# Chi tiết: Detects modification of LSA PPL protection settings via CommandLine. It may indicate an attempt to disable protection and enable credential dumping tools to access LSASS process memory.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\reg.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("reg.exe", "powershell.exe", "pwsh.dll") CommandLine="*ControlSet*" CommandLine="*\\Control\\Lsa*" CommandLine IN ("*Set-ItemProperty*", "*New-ItemProperty*", "* add *") CommandLine IN ("*IsPplAutoEnabled*", "*RunAsPPL*", "*RunAsPPLBoot*")

# ── Potential Credential Dumping Via LSASS Process Clone ──
# Mức độ  : Nghiêm trọng
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects a suspicious LSASS process process clone that could be a sign of credential dumping activity
EventCode=4688 Channel="Security" ParentProcessName="*\\Windows\\System32\\lsass.exe" NewProcessName="*\\Windows\\System32\\lsass.exe"

# ── Potential Mftrace.EXE Abuse ──
# Mức độ  : Trung bình
# Chi tiết: Detects child processes of the "Trace log generation tool for Media Foundation Tools" (Mftrace.exe) which can abused to execute arbitrary binaries.
EventCode=4688 Channel="Security" ParentProcessName="*\\mftrace.exe"

# ── Windows Default Domain GPO Modification via GPME ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of the Group Policy Management Editor (GPME) to modify Default Domain or Default Domain Controllers Group Policy Objects (GPOs). Adversaries may leverage GPME to make stealthy changes 
EventCode=4688 Channel="Security" NewProcessName="*\\mmc.exe" OR OriginalFileName="MMC.exe" CommandLine="*gpme.msc*" CommandLine="*gpobject:*" CommandLine IN ("*31B2F340-016D-11D2-945F-00C04FB984F9*", "*6AC1786C-016F-11D2-945F-00C04FB984F9*")

# ── MMC20 Lateral Movement ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects MMC20.Application Lateral Movement; specifically looks for the spawning of the parent MMC.exe with a command line of "-Embedding" as a child of svchost.exe
EventCode=4688 Channel="Security" CommandLine="*-Embedding*" ParentProcessName="*\\svchost.exe" NewProcessName="*\\mmc.exe"

# ── MMC Executing Files with Reversed Extensions Using RTLO Abuse ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects malicious behavior where the MMC utility (`mmc.exe`) executes files with reversed extensions caused by Right-to-Left Override (RLO) abuse, disguising them as document formats.
EventCode=4688 Channel="Security" NewProcessName="*\\mmc.exe" OR OriginalFileName="MMC.exe" CommandLine IN ("*cod.msc*", "*fdp.msc*", "*ftr.msc*", "*lmth.msc*", "*slx.msc*", "*tdo.msc*", "*xcod.msc*", "*xslx.msc*", "*xtpp.msc*")

# ── MMC Spawning Windows Shell ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects a Windows command line executable started from MMC
EventCode=4688 Channel="Security" ParentProcessName="*\\mmc.exe" NewProcessName IN ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wscript.exe", "*\\cscript.exe", "*\\sh.exe", "*\\bash.exe", "*\\reg.exe", "*\\regsvr32.exe") OR NewProcessName="*\\BITSADMIN*"

# ── CodePage Modification Via MODE.COM To Russian Language ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects a CodePage modification using the "mode.com" utility to Russian language. This behavior has been used by threat actors behind Dharma ransomware.
EventCode=4688 Channel="Security" NewProcessName="*\\mode.com" OR OriginalFileName="MODE.COM" CommandLine="* con *" CommandLine="* cp *" CommandLine="* select=*" CommandLine IN ("*=1251", "*=866")

# ── Potential Suspicious Mofcomp Execution ──
# Mức độ  : Cao
# Chi tiết: Detects execution of the "mofcomp" utility as a child of a suspicious shell or script running utility or by having a suspicious path in the commandline. The "mofcomp" utility parses a file containing 
EventCode=4688 Channel="Security" NewProcessName="*\\mofcomp.exe" OR OriginalFileName="mofcomp.exe" ParentProcessName IN ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wsl.exe", "*\\wscript.exe", "*\\cscript.exe") OR CommandLine IN ("*\\AppData\\Local\\Temp*", "*\\Users\\Public\\*", "*\\WINDOWS\\Temp\\*", "*%temp%*", "*%tmp%*", "*%appdata%*") NOT (CommandLine="*C:\\Windows\\TEMP\\*" CommandLine="*.mof" ParentProcessName="C:\\Windows\\System32\\wbem\\WmiPrvSE.exe") NOT (CommandLine="*C:\\Windows\\TEMP\\*" CommandLine="*.mof")

# ── Potential Mpclient.DLL Sideloading Via Defender Binaries ──
# Mức độ  : Cao
# Chi tiết: Detects potential sideloading of "mpclient.dll" by Windows Defender processes ("MpCmdRun" and "NisSrv") from their non-default directory.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\MpCmdRun.exe", "*\\NisSrv.exe") NOT (NewProcessName IN ("C:\\Program Files (x86)\\Windows Defender\\*", "C:\\Program Files\\Microsoft Security Client\\*", "C:\\Program Files\\Windows Defender\\*", "C:\\ProgramData\\Microsoft\\Windows Defender\\Platform\\*", "C:\\Windows\\WinSxS\\*"))

# ── File Download Via Windows Defender MpCmpRun.EXE ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects the use of Windows Defender MpCmdRun.EXE to download files
EventCode=4688 Channel="Security" OriginalFileName="MpCmdRun.exe" OR NewProcessName="*\\MpCmdRun.exe" OR CommandLine="*MpCmdRun.exe*" OR Description="Microsoft Malware Protection Command Line Utility" CommandLine="*DownloadFile*" CommandLine="*url*"

# ── Windows Defender Definition Files Removed ──
# Mức độ  : Cao
# Chi tiết: Adversaries may disable security tools to avoid possible detection of their tools and activities by removing Windows Defender Definition Files
EventCode=4688 Channel="Security" NewProcessName="*\\MpCmdRun.exe" OR OriginalFileName="MpCmdRun.exe" CommandLine="* -RemoveDefinitions*" CommandLine="* -All*"

# ── Suspicious Msbuild Execution By Uncommon Parent Process ──
# Mức độ  : Trung bình
# Chi tiết: Detects suspicious execution of 'Msbuild.exe' by a uncommon parent process
EventCode=4688 Channel="Security" NewProcessName="*\\MSBuild.exe" OR OriginalFileName="MSBuild.exe" NOT (ParentProcessName IN ("*\\devenv.exe", "*\\cmd.exe", "*\\msbuild.exe", "*\\python.exe", "*\\explorer.exe", "*\\nuget.exe"))

# ── MSDT Execution Via Answer File ──
# Mức độ  : Cao
# Chi tiết: Detects execution of "msdt.exe" using an answer file which is simulating the legitimate way of calling msdt via "pcwrun.exe" (For example from the compatibility tab).
EventCode=4688 Channel="Security" CommandLine="*\\WINDOWS\\diagnostics\\index\\PCWDiagnostic.xml*" CommandLine="* -af *" OR CommandLine="* /af *" OR CommandLine="* –af *" OR CommandLine="* —af *" OR CommandLine="* ―af *" NewProcessName="*\\msdt.exe" NOT ParentProcessName="*\\pcwrun.exe"

# ── Potential Arbitrary Command Execution Using Msdt.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects processes leveraging the "ms-msdt" handler or the "msdt.exe" binary to execute arbitrary commands as seen in the follina (CVE-2022-30190) vulnerability
EventCode=4688 Channel="Security" NewProcessName="*\\msdt.exe" OR OriginalFileName="msdt.exe" CommandLine="*IT_BrowseForFile=*" OR (CommandLine="* PCWDiagnostic*" CommandLine="* -af *" OR CommandLine="* /af *" OR CommandLine="* –af *" OR CommandLine="* —af *" OR CommandLine="* ―af *")

# ── Suspicious Cabinet File Execution Via Msdt.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of msdt.exe using the "cab" flag which could indicates suspicious diagcab files with embedded answer files leveraging CVE-2022-30190
EventCode=4688 Channel="Security" NewProcessName="*\\msdt.exe" OR OriginalFileName="msdt.exe" CommandLine="* -cab *" OR CommandLine="* /cab *" OR CommandLine="* –cab *" OR CommandLine="* —cab *" OR CommandLine="* ―cab *"

# ── Suspicious MSDT Parent Process ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects msdt.exe executed by a suspicious parent as seen in CVE-2022-30190 / Follina exploitation
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\schtasks.exe", "*\\wmic.exe", "*\\wscript.exe", "*\\wsl.exe") NewProcessName="*\\msdt.exe" OR OriginalFileName="msdt.exe"

# ── Arbitrary File Download Via MSEDGE_PROXY.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of "msedge_proxy.exe" to download arbitrary files
EventCode=4688 Channel="Security" NewProcessName="*\\msedge_proxy.exe" OR OriginalFileName="msedge_proxy.exe" CommandLine IN ("*http://*", "*https://*")

# ── Remotely Hosted HTA File Executed Via Mshta.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects execution of the "mshta" utility with an argument containing the "http" keyword, which could indicate that an attacker is executing a remotely hosted malicious hta file
EventCode=4688 Channel="Security" NewProcessName="*\\mshta.exe" OR OriginalFileName="MSHTA.EXE" CommandLine IN ("*http://*", "*https://*", "*ftp://*")

# ── Wscript Shell Run In CommandLine ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the presence of the keywords "Wscript", "Shell" and "Run" in the command, which could indicate a suspicious activity
EventCode=4688 Channel="Security" CommandLine="*Wscript.*" CommandLine="*.Shell*" CommandLine="*.Run*"

# ── Suspicious JavaScript Execution Via Mshta.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects execution of javascript code using "mshta.exe".
EventCode=4688 Channel="Security" NewProcessName="*\\mshta.exe" OR OriginalFileName="MSHTA.EXE" CommandLine="*javascript*"

# ── Potential LethalHTA Technique Execution ──
# Mức độ  : Cao
# Chi tiết: Detects potential LethalHTA technique where the "mshta.exe" is spawned by an "svchost.exe" process
EventCode=4688 Channel="Security" ParentProcessName="*\\svchost.exe" NewProcessName="*\\mshta.exe"

# ── Suspicious MSHTA Child Process ──
# Mức độ  : Cao
# Chi tiết: Detects a suspicious process spawning from an "mshta.exe" process, which could be indicative of a malicious HTA script execution
EventCode=4688 Channel="Security" ParentProcessName="*\\mshta.exe" NewProcessName IN ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wscript.exe", "*\\cscript.exe", "*\\sh.exe", "*\\bash.exe", "*\\reg.exe", "*\\regsvr32.exe", "*\\bitsadmin.exe") OR OriginalFileName IN ("Cmd.Exe", "PowerShell.EXE", "pwsh.dll", "wscript.exe", "cscript.exe", "Bash.exe", "reg.exe", "REGSVR32.EXE", "bitsadmin.exe")

# ── MSHTA Execution with Suspicious File Extensions ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution of mshta.exe with file types that looks like they do not typically represent HTA (HTML Application) content, such as .png, .jpg, .zip, .pdf, and others, which are often polyglots. MS
EventCode=4688 Channel="Security" NewProcessName="*\\mshta.exe" OR OriginalFileName="mshta.exe" CommandLine IN ("*.7z*", "*.avi*", "*.bat*", "*.bmp*", "*.conf*", "*.csv*", "*.dll*", "*.doc*", "*.gif*", "*.gz*", "*.ini*", "*.jpe*", "*.jpg*", "*.json*", "*.lnk*", "*.log*", "*.mkv*", "*.mp3*", "*.mp4*", "*.pdf*", "*.png*", "*.ppt*", "*.rar*", "*.rtf*", "*.svg*", "*.tar*", "*.tmp*", "*.txt*", "*.xls*", "*.xml*", "*.yaml*", "*.yml*", "*.zip*", "*vbscript*")

# ── Suspicious Mshta.EXE Execution Patterns ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious mshta process execution patterns
EventCode=4688 Channel="Security" (NewProcessName="*\\mshta.exe" OR OriginalFileName="MSHTA.EXE" CommandLine IN ("*\\AppData\\Local\\*", "*C:\\ProgramData\\*", "*C:\\Users\\Public\\*", "*C:\\Windows\\Temp\\*") ParentProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe")) OR (NewProcessName="*\\mshta.exe" OR OriginalFileName="MSHTA.EXE" NOT (NewProcessName IN ("C:\\Windows\\System32\\*", "C:\\Windows\\SysWOW64\\*") OR CommandLine IN ("*.htm*", "*.hta*") OR CommandLine IN ("*mshta.exe", "*mshta")))

# ── DllUnregisterServer Function Call Via Msiexec.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects MsiExec loading a DLL and calling its DllUnregisterServer function
EventCode=4688 Channel="Security" NewProcessName="*\\msiexec.exe" OR OriginalFileName="\\msiexec.exe" CommandLine="* -z *" OR CommandLine="* /z *" OR CommandLine="* –z *" OR CommandLine="* —z *" OR CommandLine="* ―z *" CommandLine="*.dll*"

# ── Suspicious Msiexec Execute Arbitrary DLL ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may abuse msiexec.exe to proxy execution of malicious payloads. Msiexec.exe is the command-line utility for the Windows Installer and is thus commonly associated with executing installatio
EventCode=4688 Channel="Security" CommandLine="* -Y*" OR CommandLine="* /Y*" OR CommandLine="* –Y*" OR CommandLine="* —Y*" OR CommandLine="* ―Y*" NewProcessName="*\\msiexec.exe" NOT (CommandLine IN ("*\\MsiExec.exe\" /Y \"C:\\Program Files\\*", "*\\MsiExec.exe\" /Y \"C:\\Program Files (x86)\\*", "*\\MsiExec.exe\" /Y \"C:\\Windows\\System32\\*", "*\\MsiExec.exe\" /Y \"C:\\Windows\\SysWOW64\\*"))

# ── Msiexec Quiet Installation ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may abuse msiexec.exe to proxy execution of malicious payloads. Msiexec.exe is the command-line utility for the Windows Installer and is thus commonly associated with executing installatio
EventCode=4688 Channel="Security" NewProcessName="*\\msiexec.exe" OR OriginalFileName="msiexec.exe" CommandLine="*-i*" OR CommandLine="*/i*" OR CommandLine="*–i*" OR CommandLine="*—i*" OR CommandLine="*―i*" OR CommandLine="*-package*" OR CommandLine="*/package*" OR CommandLine="*–package*" OR CommandLine="*—package*" OR CommandLine="*―package*" OR CommandLine="*-a*" OR CommandLine="*/a*" OR CommandLine="*–a*" OR CommandLine="*—a*" OR CommandLine="*―a*" OR CommandLine="*-j*" OR CommandLine="*/j*" OR CommandLine="*–j*" OR CommandLine="*—j*" OR CommandLine="*―j*" CommandLine="*-q*" OR CommandLine="*/q*" OR CommandLine="*–q*" OR CommandLine="*—q*" OR CommandLine="*―q*" NOT ((ParentProcessName="C:\\Users\\*" ParentProcessName="*\\AppData\\Local\\Temp\\*") OR ParentProcessName="C:\\Windows\\Temp\\*" OR (ParentProcessName="C:\\Windows\\CCM\\Ccm32BitLauncher.exe" MandatoryLabel IN ("S-1-16-16384", "None")))

# ── Suspicious Msiexec Quiet Install From Remote Location ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of Msiexec.exe to install packages hosted remotely quietly
EventCode=4688 Channel="Security" NewProcessName="*\\msiexec.exe" OR OriginalFileName="msiexec.exe" CommandLine="*-i*" OR CommandLine="*/i*" OR CommandLine="*–i*" OR CommandLine="*—i*" OR CommandLine="*―i*" OR CommandLine="*-package*" OR CommandLine="*/package*" OR CommandLine="*–package*" OR CommandLine="*—package*" OR CommandLine="*―package*" OR CommandLine="*-a*" OR CommandLine="*/a*" OR CommandLine="*–a*" OR CommandLine="*—a*" OR CommandLine="*―a*" OR CommandLine="*-j*" OR CommandLine="*/j*" OR CommandLine="*–j*" OR CommandLine="*—j*" OR CommandLine="*―j*" CommandLine="*-q*" OR CommandLine="*/q*" OR CommandLine="*–q*" OR CommandLine="*—q*" OR CommandLine="*―q*" CommandLine IN ("*http*", "*\\\\*") NOT (CommandLine="*\\AppData\\Local\\Temp\\OpenOffice*" CommandLine="*Installation Files\\openoffice*")

# ── Potential MsiExec Masquerading ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects the execution of msiexec.exe from an uncommon directory
EventCode=4688 Channel="Security" NewProcessName="*\\msiexec.exe" OR OriginalFileName="\\msiexec.exe" NOT (NewProcessName IN ("C:\\Windows\\System32\\*", "C:\\Windows\\SysWOW64\\*", "C:\\Windows\\WinSxS\\*"))

# ── MsiExec Web Install ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects suspicious msiexec process starts with web addresses as parameter
EventCode=4688 Channel="Security" CommandLine="* msiexec*" CommandLine="*://*"

# ── Arbitrary File Download Via MSOHTMED.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of "MSOHTMED" to download arbitrary files
EventCode=4688 Channel="Security" NewProcessName="*\\MSOHTMED.exe" OR OriginalFileName="MsoHtmEd.exe" CommandLine IN ("*ftp://*", "*http://*", "*https://*")

# ── Arbitrary File Download Via MSPUB.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of "MSPUB" (Microsoft Publisher) to download arbitrary files
EventCode=4688 Channel="Security" NewProcessName="*\\MSPUB.exe" OR OriginalFileName="MSPUB.exe" CommandLine IN ("*ftp://*", "*http://*", "*https://*")

# ── Detection of PowerShell Execution via Sqlps.exe ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: This rule detects execution of a PowerShell code through the sqlps.exe utility, which is included in the standard set of utilities supplied with the MSSQL Server. Script blocks are not logged in this 
EventCode=4688 Channel="Security" ParentProcessName="*\\sqlps.exe" OR (NewProcessName="*\\sqlps.exe" OR OriginalFileName="sqlps.exe" NOT ParentProcessName="*\\sqlagent.exe")

# ── SQL Client Tools PowerShell Session Detection ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: This rule detects execution of a PowerShell code through the sqltoolsps.exe utility, which is included in the standard set of utilities supplied with the Microsoft SQL Server Management studio. Script
EventCode=4688 Channel="Security" NewProcessName="*\\sqltoolsps.exe" OR ParentProcessName="*\\sqltoolsps.exe" OR OriginalFileName="\\sqltoolsps.exe" NOT ParentProcessName="*\\smss.exe"

# ── Suspicious Child Process Of SQL Server ──
# Mức độ  : Cao
# Mục đích: Khai thác dịch vụ công khai
# Chi tiết: Detects suspicious child processes of the SQLServer process. This could indicate potential RCE or SQL Injection.
EventCode=4688 Channel="Security" ParentProcessName="*\\sqlservr.exe" NewProcessName IN ("*\\bash.exe", "*\\bitsadmin.exe", "*\\cmd.exe", "*\\netstat.exe", "*\\nltest.exe", "*\\ping.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\sh.exe", "*\\systeminfo.exe", "*\\tasklist.exe", "*\\wsl.exe") NOT (CommandLine="\"C:\\Windows\\system32\\cmd.exe\" *" ParentProcessName="C:\\Program Files\\Microsoft SQL Server\\*" ParentProcessName="*DATEV_DBENGINE\\MSSQL\\Binn\\sqlservr.exe" NewProcessName="C:\\Windows\\System32\\cmd.exe")

# ── Suspicious Child Process Of Veeam Dabatase ──
# Mức độ  : Nghiêm trọng
# Chi tiết: Detects suspicious child processes of the Veeam service process. This could indicate potential RCE or SQL Injection.
EventCode=4688 Channel="Security" ParentCommandLine="*VEEAMSQL*" ParentProcessName="*\\sqlservr.exe" (CommandLine IN ("*-ex *", "*bypass*", "*cscript*", "*DownloadString*", "*http://*", "*https://*", "*mshta*", "*regsvr32*", "*rundll32*", "*wscript*", "*copy *") NewProcessName IN ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wsl.exe", "*\\wt.exe")) OR NewProcessName IN ("*\\net.exe", "*\\net1.exe", "*\\netstat.exe", "*\\nltest.exe", "*\\ping.exe", "*\\tasklist.exe", "*\\whoami.exe")

# ── Potential MSTSC Shadowing Activity ──
# Mức độ  : Cao
# Chi tiết: Detects RDP session hijacking by using MSTSC shadowing
EventCode=4688 Channel="Security" CommandLine="*noconsentprompt*" CommandLine="*shadow:*"

# ── New Remote Desktop Connection Initiated Via Mstsc.EXE ──
# Mức độ  : Trung bình
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects the usage of "mstsc.exe" with the "/v" flag to initiate a connection to a remote server. Adversaries may use valid accounts to log into a computer using the Remote Desktop Protocol (RDP). The 
EventCode=4688 Channel="Security" NewProcessName="*\\mstsc.exe" OR OriginalFileName="mstsc.exe" CommandLine="* -v:*" OR CommandLine="* /v:*" OR CommandLine="* –v:*" OR CommandLine="* —v:*" OR CommandLine="* ―v:*" NOT (CommandLine="*C:\\ProgramData\\Microsoft\\WSL\\wslg.rdp*" ParentProcessName="C:\\Windows\\System32\\lxss\\wslhost.exe")

# ── Mstsc.EXE Execution With Local RDP File ──
# Mức độ  : Thấp
# Chi tiết: Detects potential RDP connection via Mstsc using a local ".rdp" file
EventCode=4688 Channel="Security" NewProcessName="*\\mstsc.exe" OR OriginalFileName="mstsc.exe" CommandLine IN ("*.rdp", "*.rdp\"") NOT (CommandLine="*C:\\ProgramData\\Microsoft\\WSL\\wslg.rdp*" ParentProcessName="C:\\Windows\\System32\\lxss\\wslhost.exe")

# ── Suspicious Mstsc.EXE Execution With Local RDP File ──
# Mức độ  : Cao
# Chi tiết: Detects potential RDP connection via Mstsc using a local ".rdp" file located in suspicious locations.
EventCode=4688 Channel="Security" NewProcessName="*\\mstsc.exe" OR OriginalFileName="mstsc.exe" CommandLine IN ("*.rdp", "*.rdp\"") CommandLine IN ("*:\\Users\\Public\\*", "*:\\Windows\\System32\\spool\\drivers\\color*", "*:\\Windows\\System32\\Tasks_Migrated *", "*:\\Windows\\Tasks\\*", "*:\\Windows\\Temp\\*", "*:\\Windows\\Tracing\\*", "*\\AppData\\Local\\Temp\\*", "*\\Downloads\\*")

# ── Mstsc.EXE Execution From Uncommon Parent ──
# Mức độ  : Cao
# Chi tiết: Detects potential RDP connection via Mstsc using a local ".rdp" file located in suspicious locations.
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\brave.exe", "*\\CCleanerBrowser.exe", "*\\chrome.exe", "*\\chromium.exe", "*\\firefox.exe", "*\\iexplore.exe", "*\\microsoftedge.exe", "*\\msedge.exe", "*\\opera.exe", "*\\vivaldi.exe", "*\\whale.exe", "*\\outlook.exe") NewProcessName="*\\mstsc.exe" OR OriginalFileName="mstsc.exe"

# ── Msxsl.EXE Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of the MSXSL utility. This can be used to execute Extensible Stylesheet Language (XSL) files. These files are commonly used to describe the processing and rendering of data withi
EventCode=4688 Channel="Security" NewProcessName="*\\msxsl.exe"

# ── Remote XSL Execution Via Msxsl.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of the "msxsl" binary with an "http" keyword in the command line. This might indicate a potential remote execution of XSL files.
EventCode=4688 Channel="Security" CommandLine="*http*" NewProcessName="*\\msxsl.exe"

# ── Suspicious Group And Account Reconnaissance Activity Using Net.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects suspicious reconnaissance command line activity on Windows systems using Net.EXE Check if the user that executed the commands is suspicious (e.g. service accounts, LOCAL_SYSTEM)
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") (CommandLine IN ("* group *", "* localgroup *") CommandLine IN ("*domain admins*", "* administrator*", "* administrateur*", "*enterprise admins*", "*Exchange Trusted Subsystem*", "*Remote Desktop Users*", "*Utilisateurs du Bureau à distance*", "*Usuarios de escritorio remoto*", "* /do*") NOT CommandLine="* /add*") OR (CommandLine="* accounts *" CommandLine="* /do*")

# ── Unmount Share Via Net.EXE ──
# Mức độ  : Thấp
# Mục đích: Xóa dấu vết
# Chi tiết: Detects when when a mounted share is removed. Adversaries may remove share connections that are no longer useful in order to clean up traces of their operation
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") CommandLine="*share*" CommandLine="*/delete*"

# ── Start Windows Service Via Net.EXE ──
# Mức độ  : Thấp
# Chi tiết: Detects the usage of the "net.exe" command to start a service using the "start" flag
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") CommandLine="* start *"

# ── Stop Windows Service Via Net.EXE ──
# Mức độ  : Thấp
# Chi tiết: Detects the stopping of a Windows service via the "net" utility.
EventCode=4688 Channel="Security" OriginalFileName IN ("net.exe", "net1.exe") OR NewProcessName IN ("*\\net.exe", "*\\net1.exe") CommandLine="* stop *"

# ── Windows Admin Share Mount Via Net.EXE ──
# Mức độ  : Trung bình
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects when an admin share is mounted using net.exe
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") CommandLine="* use *" CommandLine="* \\\\*\\*$*"

# ── Windows Internet Hosted WebDav Share Mount Via Net.EXE ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects when an internet hosted webdav share is mounted using the "net.exe" utility
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") CommandLine="* use *" CommandLine="* http*"

# ── Windows Share Mount Via Net.EXE ──
# Mức độ  : Thấp
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects when a share is mounted using the "net.exe" utility
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") CommandLine IN ("* use *", "* \\\\*")

# ── System Network Connections Discovery Via Net.EXE ──
# Mức độ  : Thấp
# Chi tiết: Adversaries may attempt to get a listing of network connections to or from the compromised system they are currently accessing or from remote systems by querying for information over the network.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") CommandLine IN ("* use", "* sessions") OR CommandLine IN ("* use *", "* sessions *")

# ── Password Provided In Command Line Of Net.EXE ──
# Mức độ  : Trung bình
# Mục đích: Di chuyển ngang mạng; Dùng tài khoản hợp lệ
# Chi tiết: Detects a when net.exe is called with a password in the command line
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") CommandLine="* use *" CommandLine="*:*\\*" CommandLine="*/USER:* *" NOT CommandLine="* "

# ── New User Created Via Net.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Identifies the creation of local users via the net.exe command.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") CommandLine="*user*" CommandLine="*add*"

# ── New User Created Via Net.EXE With Never Expire Option ──
# Mức độ  : Cao
# Chi tiết: Detects creation of local users via the net.exe command with the option "never expire"
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") CommandLine="*user*" CommandLine="*add*" CommandLine="*expires:never*"

# ── Suspicious Manipulation Of Default Accounts Via Net.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious manipulations of default accounts such as 'administrator' and 'guest'. For example 'enable' or 'disable' accounts or change the password...etc
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") CommandLine="* user *" CommandLine IN ("* Järjestelmänvalvoja *", "* Rendszergazda *", "* Администратор *", "* Administrateur *", "* Administrador *", "* Administratör *", "* Administrator *", "* guest *", "* DefaultAccount *", "* \"Järjestelmänvalvoja\" *", "* \"Rendszergazda\" *", "* \"Администратор\" *", "* \"Administrateur\" *", "* \"Administrador\" *", "* \"Administratör\" *", "* \"Administrator\" *", "* \"guest\" *", "* \"DefaultAccount\" *", "* 'Järjestelmänvalvoja' *", "* 'Rendszergazda' *", "* 'Администратор' *", "* 'Administrateur' *", "* 'Administrador' *", "* 'Administratör' *", "* 'Administrator' *", "* 'guest' *", "* 'DefaultAccount' *") NOT (CommandLine="*guest*" CommandLine="*/active no*")

# ── Share And Session Enumeration Using Net.EXE ──
# Mức độ  : Thấp
# Chi tiết: Detects attempts to enumerate file shares, printer shares and sessions using "net.exe" with the "view" flag.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\net.exe", "*\\net1.exe") OR OriginalFileName IN ("net.exe", "net1.exe") CommandLine="*view*" NOT CommandLine="*\\\\*"

# ── New Firewall Rule Added Via Netsh.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the addition of a new rule to the Windows firewall via netsh
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" CommandLine="* firewall *" CommandLine="* add *" NOT (CommandLine IN ("*advfirewall firewall add rule name=Dropbox dir=in action=allow \"program=*:\\Program Files (x86)\\Dropbox\\Client\\Dropbox.exe\" enable=yes profile=Any*", "*advfirewall firewall add rule name=Dropbox dir=in action=allow \"program=*:\\Program Files\\Dropbox\\Client\\Dropbox.exe\" enable=yes profile=Any*"))

# ── Suspicious Program Location Whitelisted In Firewall Via Netsh.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects Netsh command execution that whitelists a program located in a suspicious location in the Windows Firewall
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" (CommandLine="*firewall*" CommandLine="*add*" CommandLine="*allowedprogram*") OR (CommandLine="*advfirewall*" CommandLine="*firewall*" CommandLine="*add*" CommandLine="*rule*" CommandLine="*action=allow*" CommandLine="*program=*") CommandLine IN ("*:\\$Recycle.bin\\*", "*:\\RECYCLER.BIN\\*", "*:\\RECYCLERS.BIN\\*", "*:\\SystemVolumeInformation\\*", "*:\\Temp\\*", "*:\\Users\\Default\\*", "*:\\Users\\Desktop\\*", "*:\\Users\\Public\\*", "*:\\Windows\\addins\\*", "*:\\Windows\\cursors\\*", "*:\\Windows\\debug\\*", "*:\\Windows\\drivers\\*", "*:\\Windows\\fonts\\*", "*:\\Windows\\help\\*", "*:\\Windows\\system32\\tasks\\*", "*:\\Windows\\Tasks\\*", "*:\\Windows\\Temp\\*", "*\\Downloads\\*", "*\\Local Settings\\Temporary Internet Files\\*", "*\\Temporary Internet Files\\Content.Outlook\\*", "*%Public%\\*", "*%TEMP%*", "*%TMP%*")

# ── RDP Connection Allowed Via Netsh.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects usage of the netsh command to open and allow connections to port 3389 (RDP). As seen used by Sarwent Malware
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" CommandLine="*firewall *" CommandLine="*add *" CommandLine="*tcp *" CommandLine="*3389*" CommandLine IN ("*portopening*", "*allow*")

# ── Firewall Rule Deleted Via Netsh.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the removal of a port or application rule in the Windows Firewall configuration using netsh
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" CommandLine="*firewall*" CommandLine="*delete *" NOT ((CommandLine="*name=Dropbox*" ParentProcessName="*\\Dropbox.exe") OR (CommandLine="*advfirewall firewall delete rule name=\"Avast Antivirus Admin Client\"*" ParentProcessName="*\\instup.exe"))

# ── Firewall Disabled via Netsh.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects netsh commands that turns off the Windows firewall
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" (CommandLine="*firewall*" CommandLine="*set*" CommandLine="*opmode*" CommandLine="*disable*") OR (CommandLine="*advfirewall*" CommandLine="*set*" CommandLine="*state*" CommandLine="*off*")

# ── Netsh Allow Group Policy on Microsoft Defender Firewall ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may modify system firewalls in order to bypass controls limiting network usage
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" CommandLine="*advfirewall*" CommandLine="*firewall*" CommandLine="*set*" CommandLine="*rule*" CommandLine="*group=*" CommandLine="*new*" CommandLine="*enable=Yes*"

# ── Firewall Configuration Discovery Via Netsh.EXE ──
# Mức độ  : Thấp
# Chi tiết: Adversaries may look for details about the network configuration and settings of systems they access or through information discovery of remote systems
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" CommandLine="*netsh*" CommandLine="*show *" CommandLine="*firewall *" CommandLine IN ("*config *", "*state *", "*rule *", "*name=all*")

# ── Firewall Rule Update Via Netsh.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of netsh with the "advfirewall" and the "set" option in order to set new values for properties of a existing rule
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" CommandLine="* firewall *" CommandLine="* set *"

# ── Potential Persistence Via Netsh Helper DLL ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of netsh with "add helper" flag in order to add a custom helper DLL. This technique can be abused to add a malicious helper DLL that can be used as a persistence proxy that gets 
EventCode=4688 Channel="Security" OriginalFileName="netsh.exe" OR NewProcessName="*\\netsh.exe" CommandLine="*add*" CommandLine="*helper*"

# ── New Network Trace Capture Started Via Netsh.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of netsh with the "trace" flag in order to start a network capture
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" CommandLine="*trace*" CommandLine="*start*"

# ── New Port Forwarding Rule Added Via Netsh.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of netsh commands that configure a new port forwarding (PortProxy) rule
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" (CommandLine="*interface*" CommandLine="*portproxy*" CommandLine="*add*" CommandLine="*v4tov4*") OR (CommandLine="*i *" CommandLine="*p *" CommandLine="*a *" CommandLine="*v *") OR (CommandLine="*connectp*" CommandLine="*listena*" CommandLine="*c=*")

# ── RDP Port Forwarding Rule Added Via Netsh.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of netsh to configure a port forwarding of port 3389 (RDP) rule
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" CommandLine="* i*" CommandLine="* p*" CommandLine="*=3389*" CommandLine="* c*"

# ── Harvesting Of Wifi Credentials Via Netsh.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detect the harvesting of wifi credentials using netsh.exe
EventCode=4688 Channel="Security" NewProcessName="*\\netsh.exe" OR OriginalFileName="netsh.exe" CommandLine="*wlan*" CommandLine="* s*" CommandLine="* p*" CommandLine="* k*" CommandLine="*=clear*"

# ── Nltest.EXE Execution ──
# Mức độ  : Thấp
# Chi tiết: Detects nltest commands that can be used for information discovery
EventCode=4688 Channel="Security" NewProcessName="*\\nltest.exe" OR OriginalFileName="nltestrk.exe"

# ── Potential Recon Activity Via Nltest.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects nltest commands that can be used for information discovery
EventCode=4688 Channel="Security" NewProcessName="*\\nltest.exe" OR OriginalFileName="nltestrk.exe" (CommandLine="*server*" CommandLine="*query*") OR CommandLine IN ("*/user*", "*all_trusts*", "*dclist:*", "*dnsgetdc:*", "*domain_trusts*", "*dsgetdc:*", "*parentdomain*", "*trusted_domains*")

# ── Potential Arbitrary Code Execution Via Node.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects the execution node.exe which is shipped with multiple software such as VMware, Adobe...etc. In order to execute arbitrary code. For example to establish reverse shell as seen in Log4j attacks.
EventCode=4688 Channel="Security" CommandLine IN ("* -e *", "* --eval *") NewProcessName="*\\node.exe" CommandLine="*.exec(*" CommandLine="*net.socket*" CommandLine="*.connect*" CommandLine="*child_process*"

# ── Node Process Executions ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the execution of other scripts using the Node executable packaged with Adobe Creative Cloud
EventCode=4688 Channel="Security" NewProcessName="*\\Adobe Creative Cloud Experience\\libs\\node.exe" NOT CommandLine="*Adobe Creative Cloud Experience\\js*"

# ── New Agent Skills Installation Attempt Via Node.EXE ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the attempt to install new skills for AI agents using the "npx skills" command. Agent skills enhance AI agents with new capabilities, but attackers may abuse this mechanism to inject malicious
EventCode=4688 Channel="Security" NewProcessName="*\\node.exe" OR OriginalFileName="node.exe" CommandLine="*npx-cli.js*" CommandLine="*skills *" CommandLine="* add *"

# ── Notepad Password Files Discovery ──
# Mức độ  : Thấp
# Chi tiết: Detects the execution of Notepad to open a file that has the string "password" which may indicate unauthorized access to credentials or suspicious activity.
EventCode=4688 Channel="Security" CommandLine IN ("*password*.txt", "*password*.csv", "*password*.doc", "*password*.xls") ParentProcessName="*\\explorer.exe" NewProcessName="*\\notepad.exe"

# ── Network Reconnaissance Activity ──
# Mức độ  : Cao
# Mục đích: Thu thập thông tin hệ thống
# Chi tiết: Detects a set of suspicious network related commands often used in recon stages
EventCode=4688 Channel="Security" CommandLine="*nslookup*" CommandLine="*_ldap._tcp.dc._msdcs.*"

# ── Nslookup PowerShell Download Cradle - ProcessCreation ──
# Mức độ  : Trung bình
# Chi tiết: Detects suspicious powershell download cradle using nslookup. This cradle uses nslookup to extract payloads from DNS records
EventCode=4688 Channel="Security" NewProcessName="*\\nslookup.exe*" OR OriginalFileName="\\nslookup.exe" CommandLine IN ("* -q=txt *", "* -querytype=txt *") ParentProcessName IN ("*\\powershell.exe", "*\\pwsh.exe")

# ── Suspicious Usage Of Active Directory Diagnostic Tool (ntdsutil.exe) ──
# Mức độ  : Trung bình
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects execution of ntdsutil.exe to perform different actions such as restoring snapshots...etc.
EventCode=4688 Channel="Security" NewProcessName="*\\ntdsutil.exe" OR OriginalFileName="ntdsutil.exe" (CommandLine="*snapshot*" CommandLine="*mount *") OR (CommandLine="*ac*" CommandLine="* i*" CommandLine="* ntds*")

# ── Invocation of Active Directory Diagnostic Tool (ntdsutil.exe) ──
# Mức độ  : Trung bình
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects execution of ntdsutil.exe, which can be used for various attacks against the NTDS database (NTDS.DIT)
EventCode=4688 Channel="Security" NewProcessName="*\\ntdsutil.exe"

# ── Driver/DLL Installation Via Odbcconf.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "odbcconf" with "INSTALLDRIVER" which installs a new ODBC driver. Attackers abuse this to install and run malicious DLLs.
EventCode=4688 Channel="Security" NewProcessName="*\\odbcconf.exe" OR OriginalFileName="odbcconf.exe" CommandLine="*INSTALLDRIVER *" CommandLine="*.dll*"

# ── Suspicious Driver/DLL Installation Via Odbcconf.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects execution of "odbcconf" with the "INSTALLDRIVER" action where the driver doesn't contain a ".dll" extension. This is often used as a defense evasion method.
EventCode=4688 Channel="Security" NewProcessName="*\\odbcconf.exe" OR OriginalFileName="odbcconf.exe" CommandLine="*INSTALLDRIVER *" NOT CommandLine="*.dll*"

# ── Odbcconf.EXE Suspicious DLL Location ──
# Mức độ  : Cao
# Chi tiết: Detects execution of "odbcconf" where the path of the DLL being registered is located in a potentially suspicious location.
EventCode=4688 Channel="Security" NewProcessName="*\\odbcconf.exe" OR OriginalFileName="odbcconf.exe" CommandLine IN ("*:\\PerfLogs\\*", "*:\\ProgramData\\*", "*:\\Temp\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Registration\\CRMLog*", "*:\\Windows\\System32\\com\\dmp\\*", "*:\\Windows\\System32\\FxsTmp\\*", "*:\\Windows\\System32\\Microsoft\\Crypto\\RSA\\MachineKeys\\*", "*:\\Windows\\System32\\spool\\drivers\\color\\*", "*:\\Windows\\System32\\spool\\PRINTERS\\*", "*:\\Windows\\System32\\spool\\SERVERS\\*", "*:\\Windows\\System32\\Tasks_Migrated\\*", "*:\\Windows\\System32\\Tasks\\Microsoft\\Windows\\SyncCenter\\*", "*:\\Windows\\SysWOW64\\com\\dmp\\*", "*:\\Windows\\SysWOW64\\FxsTmp\\*", "*:\\Windows\\SysWOW64\\Tasks\\Microsoft\\Windows\\PLA\\System\\*", "*:\\Windows\\SysWOW64\\Tasks\\Microsoft\\Windows\\SyncCenter\\*", "*:\\Windows\\Tasks\\*", "*:\\Windows\\Temp\\*", "*:\\Windows\\Tracing\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Roaming\\*")

# ── New DLL Registered Via Odbcconf.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "odbcconf" with "REGSVR" in order to register a new DLL (equivalent to running regsvr32). Attackers abuse this to install and run malicious DLLs.
EventCode=4688 Channel="Security" NewProcessName="*\\odbcconf.exe" OR OriginalFileName="odbcconf.exe" CommandLine="*REGSVR *" CommandLine="*.dll*"

# ── Potentially Suspicious DLL Registered Via Odbcconf.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects execution of "odbcconf" with the "REGSVR" action where the DLL in question doesn't contain a ".dll" extension. Which is often used as a method to evade defenses.
EventCode=4688 Channel="Security" NewProcessName="*\\odbcconf.exe" OR OriginalFileName="odbcconf.exe" CommandLine="*REGSVR *" NOT CommandLine="*.dll*"

# ── Response File Execution Via Odbcconf.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "odbcconf" with the "-f" flag in order to load a response file which might contain a malicious action.
EventCode=4688 Channel="Security" NewProcessName="*\\odbcconf.exe" OR OriginalFileName="odbcconf.exe" CommandLine="* -f *" OR CommandLine="* /f *" OR CommandLine="* –f *" OR CommandLine="* —f *" OR CommandLine="* ―f *" CommandLine="*.rsp*"

# ── Suspicious Response File Execution Via Odbcconf.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects execution of "odbcconf" with the "-f" flag in order to load a response file with a non-".rsp" extension.
EventCode=4688 Channel="Security" NewProcessName="*\\odbcconf.exe" OR OriginalFileName="odbcconf.exe" CommandLine="* -f *" OR CommandLine="* /f *" OR CommandLine="* –f *" OR CommandLine="* —f *" OR CommandLine="* ―f *" NOT (CommandLine="*.rsp*" OR (CommandLine="*.exe /E /F \"C:\\WINDOWS\\system32\\odbcconf.tmp\"*" ParentProcessName="C:\\Windows\\System32\\runonce.exe" NewProcessName="C:\\Windows\\System32\\odbcconf.exe"))

# ── Uncommon Child Process Spawned By Odbcconf.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects an uncommon child process of "odbcconf.exe" binary which normally shouldn't have any child processes.
EventCode=4688 Channel="Security" ParentProcessName="*\\odbcconf.exe"

# ── Potential Arbitrary File Download Using Office Application ──
# Mức độ  : Cao
# Chi tiết: Detects potential arbitrary file download using a Microsoft Office application
EventCode=4688 Channel="Security" NewProcessName IN ("*\\EXCEL.EXE", "*\\POWERPNT.EXE", "*\\WINWORD.exe") OR OriginalFileName IN ("Excel.exe", "POWERPNT.EXE", "WinWord.exe") CommandLine IN ("*http://*", "*https://*")

# ── Potential Excel.EXE DCOM Lateral Movement Via ActivateMicrosoftApp ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects suspicious child processes of Excel which could be an indicator of lateral movement leveraging the "ActivateMicrosoftApp" Excel DCOM object.
EventCode=4688 Channel="Security" ParentProcessName="*\\excel.exe" OriginalFileName IN ("foxprow.exe", "schdplus.exe", "winproj.exe") OR NewProcessName IN ("*\\foxprow.exe", "*\\schdplus.exe", "*\\winproj.exe")

# ── Potentially Suspicious Office Document Executed From Trusted Location ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of an Office application that points to a document that is located in a trusted location. Attackers often used this to avoid macro security and execute their malicious code.
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\explorer.exe", "*\\dopus.exe") NewProcessName IN ("*\\EXCEL.EXE", "*\\POWERPNT.EXE", "*\\WINWORD.exe") OR OriginalFileName IN ("Excel.exe", "POWERPNT.EXE", "WinWord.exe") CommandLine IN ("*\\AppData\\Roaming\\Microsoft\\Templates*", "*\\AppData\\Roaming\\Microsoft\\Word\\Startup\\*", "*\\Microsoft Office\\root\\Templates\\*", "*\\Microsoft Office\\Templates\\*") NOT (CommandLine IN ("*.dotx", "*.xltx", "*.potx"))

# ── OneNote.EXE Execution of Malicious Embedded Scripts ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of malicious OneNote documents that contain embedded scripts. When a user clicks on a OneNote attachment and then on the malicious link inside the ".one" file, it exports and exe
EventCode=4688 Channel="Security" CommandLine IN ("*\\exported\\*", "*\\onenoteofflinecache_files\\*") ParentProcessName="*\\onenote.exe" NewProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wscript.exe")

# ── Suspicious Microsoft OneNote Child Process ──
# Mức độ  : Cao
# Mục đích: Phishing
# Chi tiết: Detects suspicious child processes of the Microsoft OneNote application. This may indicate an attempt to execute malicious embedded objects from a .one file.
EventCode=4688 Channel="Security" ParentProcessName="*\\onenote.exe" OriginalFileName IN ("bitsadmin.exe", "CertOC.exe", "CertUtil.exe", "Cmd.Exe", "CMSTP.EXE", "cscript.exe", "curl.exe", "HH.exe", "IEExec.exe", "InstallUtil.exe", "javaw.exe", "Microsoft.Workflow.Compiler.exe", "msdt.exe", "MSHTA.EXE", "msiexec.exe", "Msxsl.exe", "odbcconf.exe", "pcalua.exe", "PowerShell.EXE", "RegAsm.exe", "RegSvcs.exe", "REGSVR32.exe", "RUNDLL32.exe", "schtasks.exe", "ScriptRunner.exe", "wmic.exe", "WorkFolders.exe", "wscript.exe") OR NewProcessName IN ("*\\AppVLP.exe", "*\\bash.exe", "*\\bitsadmin.exe", "*\\certoc.exe", "*\\certutil.exe", "*\\cmd.exe", "*\\cmstp.exe", "*\\control.exe", "*\\cscript.exe", "*\\curl.exe", "*\\forfiles.exe", "*\\hh.exe", "*\\ieexec.exe", "*\\installutil.exe", "*\\javaw.exe", "*\\mftrace.exe", "*\\Microsoft.Workflow.Compiler.exe", "*\\msbuild.exe", "*\\msdt.exe", "*\\mshta.exe", "*\\msidb.exe", "*\\msiexec.exe", "*\\msxsl.exe", "*\\odbcconf.exe", "*\\pcalua.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regasm.exe", "*\\regsvcs.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\schtasks.exe", "*\\scrcons.exe", "*\\scriptrunner.exe", "*\\sh.exe", "*\\svchost.exe", "*\\verclsid.exe", "*\\wmic.exe", "*\\workfolders.exe", "*\\wscript.exe") OR (CommandLine IN ("*.hta*", "*.vb*", "*.wsh*", "*.js*", "*.ps*", "*.scr*", "*.pif*", "*.bat*", "*.cmd*") NewProcessName="*\\explorer.exe") OR NewProcessName IN ("*\\AppData\\*", "*\\Users\\Public\\*", "*\\ProgramData\\*", "*\\Windows\\Tasks\\*", "*\\Windows\\Temp\\*", "*\\Windows\\System32\\Tasks\\*") NOT ((CommandLine="*-Embedding" NewProcessName="*\\AppData\\Local\\Microsoft\\Teams\\current\\Teams.exe") OR (CommandLine="*-Embedding" NewProcessName="*\\AppData\\Local\\Microsoft\\OneDrive\\*" NewProcessName="*\\FileCoAuth.exe"))

# ── Outlook EnableUnsafeClientMailRules Setting Enabled ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects an attacker trying to enable the outlook security setting "EnableUnsafeClientMailRules" which allows outlook to run applications or execute macros
EventCode=4688 Channel="Security" CommandLine="*\\Outlook\\Security\\EnableUnsafeClientMailRules*"

# ── Suspicious Execution From Outlook Temporary Folder ──
# Mức độ  : Cao
# Mục đích: Phishing
# Chi tiết: Detects a suspicious program execution in Outlook temp folder
EventCode=4688 Channel="Security" NewProcessName="*\\Temporary Internet Files\\Content.Outlook\\*"

# ── Suspicious Outlook Child Process ──
# Mức độ  : Cao
# Chi tiết: Detects a suspicious process spawning from an Outlook process.
EventCode=4688 Channel="Security" ParentProcessName="*\\OUTLOOK.EXE" NewProcessName IN ("*\\AppVLP.exe", "*\\bash.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\forfiles.exe", "*\\hh.exe", "*\\mftrace.exe", "*\\msbuild.exe", "*\\msdt.exe", "*\\mshta.exe", "*\\msiexec.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\schtasks.exe", "*\\scrcons.exe", "*\\scriptrunner.exe", "*\\sh.exe", "*\\svchost.exe", "*\\wmic.exe", "*\\wscript.exe")

# ── Suspicious Remote Child Process From Outlook ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects a suspicious child process spawning from Outlook where the image is located in a remote location (SMB/WebDav shares).
EventCode=4688 Channel="Security" ParentProcessName="*\\outlook.exe" NewProcessName="\\\\*"

# ── Suspicious Binary In User Directory Spawned From Office Application ──
# Mức độ  : Cao
# Chi tiết: Detects an executable in the users directory started from one of the Microsoft Office suite applications (Word, Excel, PowerPoint, Publisher, Visio)
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\WINWORD.EXE", "*\\EXCEL.EXE", "*\\POWERPNT.exe", "*\\MSPUB.exe", "*\\VISIO.exe", "*\\MSACCESS.exe", "*\\EQNEDT32.exe") NewProcessName="C:\\users\\*" NewProcessName="*.exe" NOT NewProcessName="*\\Teams.exe"

# ── Suspicious Microsoft Office Child Process ──
# Mức độ  : Cao
# Chi tiết: Detects a suspicious process spawning from one of the Microsoft Office suite products (Word, Excel, PowerPoint, Publisher, Visio, etc.)
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\EQNEDT32.EXE", "*\\EXCEL.EXE", "*\\MSACCESS.EXE", "*\\MSPUB.exe", "*\\ONENOTE.EXE", "*\\POWERPNT.exe", "*\\VISIO.exe", "*\\WINWORD.EXE", "*\\wordpad.exe", "*\\wordview.exe") OriginalFileName IN ("bitsadmin.exe", "CertOC.exe", "CertUtil.exe", "Cmd.Exe", "CMSTP.EXE", "cscript.exe", "curl.exe", "HH.exe", "IEExec.exe", "InstallUtil.exe", "javaw.exe", "Microsoft.Workflow.Compiler.exe", "msdt.exe", "MSHTA.EXE", "msiexec.exe", "Msxsl.exe", "odbcconf.exe", "pcalua.exe", "PowerShell.EXE", "RegAsm.exe", "RegSvcs.exe", "REGSVR32.exe", "RUNDLL32.exe", "schtasks.exe", "ScriptRunner.exe", "wmic.exe", "WorkFolders.exe", "wscript.exe") OR NewProcessName IN ("*\\AppVLP.exe", "*\\bash.exe", "*\\bitsadmin.exe", "*\\certoc.exe", "*\\certutil.exe", "*\\cmd.exe", "*\\cmstp.exe", "*\\control.exe", "*\\cscript.exe", "*\\curl.exe", "*\\forfiles.exe", "*\\hh.exe", "*\\ieexec.exe", "*\\installutil.exe", "*\\javaw.exe", "*\\mftrace.exe", "*\\Microsoft.Workflow.Compiler.exe", "*\\msbuild.exe", "*\\msdt.exe", "*\\mshta.exe", "*\\msidb.exe", "*\\msiexec.exe", "*\\msxsl.exe", "*\\odbcconf.exe", "*\\pcalua.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regasm.exe", "*\\regsvcs.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\schtasks.exe", "*\\scrcons.exe", "*\\scriptrunner.exe", "*\\sh.exe", "*\\svchost.exe", "*\\verclsid.exe", "*\\wmic.exe", "*\\workfolders.exe", "*\\wscript.exe") OR NewProcessName IN ("*\\AppData\\*", "*\\Users\\Public\\*", "*\\ProgramData\\*", "*\\Windows\\Tasks\\*", "*\\Windows\\Temp\\*", "*\\Windows\\System32\\Tasks\\*")

# ── Potential Arbitrary DLL Load Using Winword ──
# Mức độ  : Trung bình
# Chi tiết: Detects potential DLL sideloading using the Microsoft Office winword process via the '/l' flag.
EventCode=4688 Channel="Security" NewProcessName="*\\WINWORD.exe" OR OriginalFileName="WinWord.exe" CommandLine="*/l *" CommandLine="*.dll*"

# ── Potential Mpclient.DLL Sideloading Via OfflineScannerShell.EXE Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of Windows Defender "OfflineScannerShell.exe" from its non standard directory. The "OfflineScannerShell.exe" binary is vulnerable to DLL side loading and will load any DLL named "mpc
EventCode=4688 Channel="Security" NewProcessName="*\\OfflineScannerShell.exe" OR OriginalFileName="OfflineScannerShell.exe" NOT (CurrentDirectory="C:\\Program Files\\Windows Defender\\Offline\\" OR CurrentDirectory="" OR NOT CurrentDirectory=*)

# ── Potentially Suspicious Execution Of PDQDeployRunner ──
# Mức độ  : Trung bình
# Chi tiết: Detects suspicious execution of "PDQDeployRunner" which is part of the PDQDeploy service stack that is responsible for executing commands and packages on a remote machines
EventCode=4688 Channel="Security" ParentProcessName="*\\PDQDeployRunner-*" NewProcessName IN ("*\\bash.exe", "*\\certutil.exe", "*\\cmd.exe", "*\\csc.exe", "*\\cscript.exe", "*\\dllhost.exe", "*\\mshta.exe", "*\\msiexec.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\scriptrunner.exe", "*\\wmic.exe", "*\\wscript.exe", "*\\wsl.exe") OR NewProcessName IN ("*:\\ProgramData\\*", "*:\\Users\\Public\\*", "*:\\Windows\\TEMP\\*", "*\\AppData\\Local\\Temp*") OR CommandLine IN ("* -decode *", "* -enc *", "* -encodedcommand *", "* -w hidden*", "*DownloadString*", "*FromBase64String*", "*http*", "*iex *", "*Invoke-*")

# ── Perl Inline Command Execution ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution of perl using the "-e"/"-E" flags. This is could be used as a way to launch a reverse shell or execute live perl code.
EventCode=4688 Channel="Security" NewProcessName="*\\perl.exe" OR OriginalFileName="perl.exe" CommandLine="* -e*"

# ── Php Inline Command Execution ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution of php using the "-r" flag. This is could be used as a way to launch a reverse shell or execute live php code.
EventCode=4688 Channel="Security" NewProcessName="*\\php.exe" OR OriginalFileName="php.exe" CommandLine="* -r*"

# ── Ping Hex IP ──
# Mức độ  : Cao
# Chi tiết: Detects a ping command that uses a hex encoded IP address
EventCode=4688 Channel="Security" NewProcessName="*\\ping.exe"
| regex CommandLine="0x[a-fA-F0-9]{8}"

# ── PktMon.EXE Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of PktMon, a tool that captures network packets.
EventCode=4688 Channel="Security" NewProcessName="*\\pktmon.exe" OR OriginalFileName="PktMon.exe"

# ── Potential RDP Tunneling Via Plink ──
# Mức độ  : Cao
# Chi tiết: Execution of plink to perform data exfiltration and tunneling
EventCode=4688 Channel="Security" (CommandLine="*:127.0.0.1:3389*" NewProcessName="*\\plink.exe") OR (CommandLine="*:3389*" NewProcessName="*\\plink.exe" CommandLine IN ("* -P 443*", "* -P 22*"))

# ── Suspicious Powercfg Execution To Change Lock Screen Timeout ──
# Mức độ  : Trung bình
# Chi tiết: Detects suspicious execution of 'Powercfg.exe' to change lock screen timeout
EventCode=4688 Channel="Security" NewProcessName="*\\powercfg.exe" OR OriginalFileName="PowerCfg.exe" (CommandLine="*/setacvalueindex *" CommandLine="*SCHEME_CURRENT*" CommandLine="*SUB_VIDEO*" CommandLine="*VIDEOCONLOCK*") OR (CommandLine="*-change *" CommandLine="*-standby-timeout-*")

# ── AADInternals PowerShell Cmdlets Execution - ProccessCreation ──
# Mức độ  : Cao
# Chi tiết: Detects ADDInternals Cmdlet execution. A tool for administering Azure AD and Office 365. Which can be abused by threat actors to attack Azure AD or Office 365.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.Exe", "pwsh.dll") CommandLine IN ("*Add-AADInt*", "*ConvertTo-AADInt*", "*Disable-AADInt*", "*Enable-AADInt*", "*Export-AADInt*", "*Find-AADInt*", "*Get-AADInt*", "*Grant-AADInt*", "*Initialize-AADInt*", "*Install-AADInt*", "*Invoke-AADInt*", "*Join-AADInt*", "*New-AADInt*", "*Open-AADInt*", "*Read-AADInt*", "*Register-AADInt*", "*Remove-AADInt*", "*Reset-AADInt*", "*Resolve-AADInt*", "*Restore-AADInt*", "*Save-AADInt*", "*Search-AADInt*", "*Send-AADInt*", "*Set-AADInt*", "*Start-AADInt*", "*Unprotect-AADInt*", "*Update-AADInt*")

# ── Potential Active Directory Enumeration Using AD Module - ProcCreation ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the "Import-Module" cmdlet to load the "Microsoft.ActiveDirectory.Management.dl" DLL. Which is often used by attackers to perform AD enumeration.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine IN ("*Import-Module *", "*ipmo *") CommandLine="*Microsoft.ActiveDirectory.Management.dll*"

# ── Add Windows Capability Via PowerShell Cmdlet ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the "Add-WindowsCapability" cmdlet to add Windows capabilities. Notable capabilities could be "OpenSSH" and others.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine="*Add-WindowsCapability*" CommandLine="*OpenSSH.*"

# ── Potential AMSI Bypass Via .NET Reflection ──
# Mức độ  : Cao
# Chi tiết: Detects Request to "amsiInitFailed" that can be used to disable AMSI Scanning
EventCode=4688 Channel="Security" (CommandLine="*System.Management.Automation.AmsiUtils*" CommandLine="*amsiInitFailed*") OR (CommandLine="*[Ref].Assembly.GetType*" CommandLine="*SetValue($null,$true)*" CommandLine="*NonPublic,Static*")

# ── Potential AMSI Bypass Using NULL Bits ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of special strings/null bits in order to potentially bypass AMSI functionalities
EventCode=4688 Channel="Security" CommandLine IN ("*if(0){{{0}}}' -f $(0 -as [char]) +*", "*#<NULL>*")

# ── Audio Capture via PowerShell ──
# Mức độ  : Trung bình
# Chi tiết: Detects audio capture via PowerShell Cmdlet.
EventCode=4688 Channel="Security" CommandLine IN ("*WindowsAudioDevice-Powershell-Cmdlet*", "*Toggle-AudioDevice*", "*Get-AudioDevice *", "*Set-AudioDevice *", "*Write-AudioDevice *")

# ── Suspicious Encoded PowerShell Command Line ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious powershell process starts with base64 encoded commands (e.g. Emotet)
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") (CommandLine="* -e*" CommandLine IN ("* JAB*", "* SUVYI*", "* SQBFAFgA*", "* aQBlAHgA*", "* aWV4I*", "* IAA*", "* IAB*", "* UwB*", "* cwB*")) OR CommandLine IN ("*.exe -ENCOD *", "* BA^J e-*") NOT CommandLine="* -ExecutionPolicy remotesigned *"

# ── Suspicious PowerShell Encoded Command Patterns ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects PowerShell command line patterns in combincation with encoded commands that often appear in malware infection chains
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.Exe", "pwsh.dll") CommandLine IN ("* -e *", "* -en *", "* -enc *", "* -enco*") CommandLine IN ("* JAB*", "* SUVYI*", "* SQBFAFgA*", "* aWV4I*", "* IAB*", "* PAA*", "* aQBlAHgA*") NOT (ParentProcessName IN ("*C:\\Packages\\Plugins\\Microsoft.GuestConfiguration.ConfigurationforWindows\\*", "*\\gc_worker.exe*"))

# ── Suspicious Obfuscated PowerShell Code ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious UTF16 and base64 encoded and often obfuscated PowerShell code often used in command lines
EventCode=4688 Channel="Security" CommandLine IN ("*IAAtAGIAeABvAHIAIAAwAHgA*", "*AALQBiAHgAbwByACAAMAB4A*", "*gAC0AYgB4AG8AcgAgADAAeA*", "*AC4ASQBuAHYAbwBrAGUAKAApACAAfAAg*", "*AuAEkAbgB2AG8AawBlACgAKQAgAHwAI*", "*ALgBJAG4AdgBvAGsAZQAoACkAIAB8AC*", "*AHsAMQB9AHsAMAB9ACIAIAAtAGYAI*", "*B7ADEAfQB7ADAAfQAiACAALQBmAC*", "*AewAxAH0AewAwAH0AIgAgAC0AZgAg*", "*AHsAMAB9AHsAMwB9ACIAIAAtAGYAI*", "*B7ADAAfQB7ADMAfQAiACAALQBmAC*", "*AewAwAH0AewAzAH0AIgAgAC0AZgAg*", "*AHsAMgB9AHsAMAB9ACIAIAAtAGYAI*", "*B7ADIAfQB7ADAAfQAiACAALQBmAC*", "*AewAyAH0AewAwAH0AIgAgAC0AZgAg*", "*AHsAMQB9AHsAMAB9ACcAIAAtAGYAI*", "*B7ADEAfQB7ADAAfQAnACAALQBmAC*", "*AewAxAH0AewAwAH0AJwAgAC0AZgAg*", "*AHsAMAB9AHsAMwB9ACcAIAAtAGYAI*", "*B7ADAAfQB7ADMAfQAnACAALQBmAC*", "*AewAwAH0AewAzAH0AJwAgAC0AZgAg*", "*AHsAMgB9AHsAMAB9ACcAIAAtAGYAI*", "*B7ADIAfQB7ADAAfQAnACAALQBmAC*", "*AewAyAH0AewAwAH0AJwAgAC0AZgAg*")

# ── PowerShell Base64 Encoded FromBase64String Cmdlet ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects usage of a base64 encoded "FromBase64String" cmdlet in a process command line
EventCode=4688 Channel="Security" CommandLine="*OjpGcm9tQmFzZTY0U3RyaW5n*" OR CommandLine="*o6RnJvbUJhc2U2NFN0cmluZ*" OR CommandLine="*6OkZyb21CYXNlNjRTdHJpbm*" OR CommandLine IN ("*OgA6AEYAcgBvAG0AQgBhAHMAZQA2ADQAUwB0AHIAaQBuAGcA*", "*oAOgBGAHIAbwBtAEIAYQBzAGUANgA0AFMAdAByAGkAbgBnA*", "*6ADoARgByAG8AbQBCAGEAcwBlADYANABTAHQAcgBpAG4AZw*")

# ── Malicious Base64 Encoded PowerShell Keywords in Command Lines ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects base64 encoded strings used in hidden malicious PowerShell command lines
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine="* hidden *" CommandLine IN ("*AGkAdABzAGEAZABtAGkAbgAgAC8AdAByAGEAbgBzAGYAZQByA*", "*aXRzYWRtaW4gL3RyYW5zZmVy*", "*IAaQB0AHMAYQBkAG0AaQBuACAALwB0AHIAYQBuAHMAZgBlAHIA*", "*JpdHNhZG1pbiAvdHJhbnNmZX*", "*YgBpAHQAcwBhAGQAbQBpAG4AIAAvAHQAcgBhAG4AcwBmAGUAcg*", "*Yml0c2FkbWluIC90cmFuc2Zlc*", "*AGMAaAB1AG4AawBfAHMAaQB6AGUA*", "*JABjAGgAdQBuAGsAXwBzAGkAegBlA*", "*JGNodW5rX3Npem*", "*QAYwBoAHUAbgBrAF8AcwBpAHoAZQ*", "*RjaHVua19zaXpl*", "*Y2h1bmtfc2l6Z*", "*AE8ALgBDAG8AbQBwAHIAZQBzAHMAaQBvAG4A*", "*kATwAuAEMAbwBtAHAAcgBlAHMAcwBpAG8Abg*", "*lPLkNvbXByZXNzaW9u*", "*SQBPAC4AQwBvAG0AcAByAGUAcwBzAGkAbwBuA*", "*SU8uQ29tcHJlc3Npb2*", "*Ty5Db21wcmVzc2lvb*", "*AE8ALgBNAGUAbQBvAHIAeQBTAHQAcgBlAGEAbQ*", "*kATwAuAE0AZQBtAG8AcgB5AFMAdAByAGUAYQBtA*", "*lPLk1lbW9yeVN0cmVhb*", "*SQBPAC4ATQBlAG0AbwByAHkAUwB0AHIAZQBhAG0A*", "*SU8uTWVtb3J5U3RyZWFt*", "*Ty5NZW1vcnlTdHJlYW*", "*4ARwBlAHQAQwBoAHUAbgBrA*", "*5HZXRDaHVua*", "*AEcAZQB0AEMAaAB1AG4Aaw*", "*LgBHAGUAdABDAGgAdQBuAGsA*", "*LkdldENodW5r*", "*R2V0Q2h1bm*", "*AEgAUgBFAEEARABfAEkATgBGAE8ANgA0A*", "*QASABSAEUAQQBEAF8ASQBOAEYATwA2ADQA*", "*RIUkVBRF9JTkZPNj*", "*SFJFQURfSU5GTzY0*", "*VABIAFIARQBBAEQAXwBJAE4ARgBPADYANA*", "*VEhSRUFEX0lORk82N*", "*AHIAZQBhAHQAZQBSAGUAbQBvAHQAZQBUAGgAcgBlAGEAZA*", "*cmVhdGVSZW1vdGVUaHJlYW*", "*MAcgBlAGEAdABlAFIAZQBtAG8AdABlAFQAaAByAGUAYQBkA*", "*NyZWF0ZVJlbW90ZVRocmVhZ*", "*Q3JlYXRlUmVtb3RlVGhyZWFk*", "*QwByAGUAYQB0AGUAUgBlAG0AbwB0AGUAVABoAHIAZQBhAGQA*", "*0AZQBtAG0AbwB2AGUA*", "*1lbW1vdm*", "*AGUAbQBtAG8AdgBlA*", "*bQBlAG0AbQBvAHYAZQ*", "*bWVtbW92Z*", "*ZW1tb3Zl*")

# ── PowerShell Base64 Encoded IEX Cmdlet ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects usage of a base64 encoded "IEX" cmdlet in a process command line
EventCode=4688 Channel="Security" CommandLine="*SUVYIChb*" OR CommandLine="*lFWCAoW*" OR CommandLine="*JRVggKF*" OR CommandLine="*aWV4IChb*" OR CommandLine="*lleCAoW*" OR CommandLine="*pZXggKF*" OR CommandLine="*aWV4IChOZX*" OR CommandLine="*lleCAoTmV3*" OR CommandLine="*pZXggKE5ld*" OR CommandLine="*SUVYIChOZX*" OR CommandLine="*lFWCAoTmV3*" OR CommandLine="*JRVggKE5ld*" OR CommandLine="*SUVYKF*" OR CommandLine="*lFWChb*" OR CommandLine="*JRVgoW*" OR CommandLine="*aWV4KF*" OR CommandLine="*lleChb*" OR CommandLine="*pZXgoW*" OR CommandLine="*aWV4KE5ld*" OR CommandLine="*lleChOZX*" OR CommandLine="*pZXgoTmV3*" OR CommandLine="*SUVYKE5ld*" OR CommandLine="*lFWChOZX*" OR CommandLine="*JRVgoTmV3*" OR CommandLine="*SUVYKCgn*" OR CommandLine="*lFWCgoJ*" OR CommandLine="*JRVgoKC*" OR CommandLine="*aWV4KCgn*" OR CommandLine="*lleCgoJ*" OR CommandLine="*pZXgoKC*" OR CommandLine IN ("*SQBFAFgAIAAoAFsA*", "*kARQBYACAAKABbA*", "*JAEUAWAAgACgAWw*", "*aQBlAHgAIAAoAFsA*", "*kAZQB4ACAAKABbA*", "*pAGUAeAAgACgAWw*", "*aQBlAHgAIAAoAE4AZQB3A*", "*kAZQB4ACAAKABOAGUAdw*", "*pAGUAeAAgACgATgBlAHcA*", "*SQBFAFgAIAAoAE4AZQB3A*", "*kARQBYACAAKABOAGUAdw*", "*JAEUAWAAgACgATgBlAHcA*")

# ── PowerShell Base64 Encoded Invoke Keyword ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects UTF-8 and UTF-16 Base64 encoded powershell 'Invoke-' calls
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine="* -e*" CommandLine IN ("*SQBuAHYAbwBrAGUALQ*", "*kAbgB2AG8AawBlAC0A*", "*JAG4AdgBvAGsAZQAtA*", "*SW52b2tlL*", "*ludm9rZS*", "*JbnZva2Ut*")

# ── Powershell Base64 Encoded MpPreference Cmdlet ──
# Mức độ  : Cao
# Chi tiết: Detects base64 encoded "MpPreference" PowerShell cmdlet code that tries to modifies or tamper with Windows Defender AV
EventCode=4688 Channel="Security" CommandLine="*QWRkLU1wUHJlZmVyZW5jZS*" OR CommandLine="*FkZC1NcFByZWZlcmVuY2Ug*" OR CommandLine="*BZGQtTXBQcmVmZXJlbmNlI*" OR CommandLine="*U2V0LU1wUHJlZmVyZW5jZS*" OR CommandLine="*NldC1NcFByZWZlcmVuY2Ug*" OR CommandLine="*TZXQtTXBQcmVmZXJlbmNlI*" OR CommandLine="*YWRkLW1wcHJlZmVyZW5jZS*" OR CommandLine="*FkZC1tcHByZWZlcmVuY2Ug*" OR CommandLine="*hZGQtbXBwcmVmZXJlbmNlI*" OR CommandLine="*c2V0LW1wcHJlZmVyZW5jZS*" OR CommandLine="*NldC1tcHByZWZlcmVuY2Ug*" OR CommandLine="*zZXQtbXBwcmVmZXJlbmNlI*" OR CommandLine IN ("*QQBkAGQALQBNAHAAUAByAGUAZgBlAHIAZQBuAGMAZQAgA*", "*EAZABkAC0ATQBwAFAAcgBlAGYAZQByAGUAbgBjAGUAIA*", "*BAGQAZAAtAE0AcABQAHIAZQBmAGUAcgBlAG4AYwBlACAA*", "*UwBlAHQALQBNAHAAUAByAGUAZgBlAHIAZQBuAGMAZQAgA*", "*MAZQB0AC0ATQBwAFAAcgBlAGYAZQByAGUAbgBjAGUAIA*", "*TAGUAdAAtAE0AcABQAHIAZQBmAGUAcgBlAG4AYwBlACAA*", "*YQBkAGQALQBtAHAAcAByAGUAZgBlAHIAZQBuAGMAZQAgA*", "*EAZABkAC0AbQBwAHAAcgBlAGYAZQByAGUAbgBjAGUAIA*", "*hAGQAZAAtAG0AcABwAHIAZQBmAGUAcgBlAG4AYwBlACAA*", "*cwBlAHQALQBtAHAAcAByAGUAZgBlAHIAZQBuAGMAZQAgA*", "*MAZQB0AC0AbQBwAHAAcgBlAGYAZQByAGUAbgBjAGUAIA*", "*zAGUAdAAtAG0AcABwAHIAZQBmAGUAcgBlAG4AYwBlACAA*")

# ── PowerShell Base64 Encoded Reflective Assembly Load ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects base64 encoded .NET reflective loading of Assembly
EventCode=4688 Channel="Security" CommandLine IN ("*WwBSAGUAZgBsAGUAYwB0AGkAbwBuAC4AQQBzAHMAZQBtAGIAbAB5AF0AOgA6AEwAbwBhAGQAKA*", "*sAUgBlAGYAbABlAGMAdABpAG8AbgAuAEEAcwBzAGUAbQBiAGwAeQBdADoAOgBMAG8AYQBkACgA*", "*bAFIAZQBmAGwAZQBjAHQAaQBvAG4ALgBBAHMAcwBlAG0AYgBsAHkAXQA6ADoATABvAGEAZAAoA*", "*AFsAcgBlAGYAbABlAGMAdABpAG8AbgAuAGEAcwBzAGUAbQBiAGwAeQBdADoAOgAoACIATABvAGEAZAAiAC*", "*BbAHIAZQBmAGwAZQBjAHQAaQBvAG4ALgBhAHMAcwBlAG0AYgBsAHkAXQA6ADoAKAAiAEwAbwBhAGQAIgAp*", "*AWwByAGUAZgBsAGUAYwB0AGkAbwBuAC4AYQBzAHMAZQBtAGIAbAB5AF0AOgA6ACgAIgBMAG8AYQBkACIAK*", "*WwBSAGUAZgBsAGUAYwB0AGkAbwBuAC4AQQBzAHMAZQBtAGIAbAB5AF0AOgA6ACgAIgBMAG8AYQBkACIAKQ*", "*sAUgBlAGYAbABlAGMAdABpAG8AbgAuAEEAcwBzAGUAbQBiAGwAeQBdADoAOgAoACIATABvAGEAZAAiACkA*", "*bAFIAZQBmAGwAZQBjAHQAaQBvAG4ALgBBAHMAcwBlAG0AYgBsAHkAXQA6ADoAKAAiAEwAbwBhAGQAIgApA*", "*WwByAGUAZgBsAGUAYwB0AGkAbwBuAC4AYQBzAHMAZQBtAGIAbAB5AF0AOgA6AEwAbwBhAGQAKA*", "*sAcgBlAGYAbABlAGMAdABpAG8AbgAuAGEAcwBzAGUAbQBiAGwAeQBdADoAOgBMAG8AYQBkACgA*", "*bAHIAZQBmAGwAZQBjAHQAaQBvAG4ALgBhAHMAcwBlAG0AYgBsAHkAXQA6ADoATABvAGEAZAAoA*")

# ── Suspicious Encoded And Obfuscated Reflection Assembly Load Function Call ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious base64 encoded and obfuscated "LOAD" keyword used in .NET "reflection.assembly"
EventCode=4688 Channel="Security" CommandLine IN ("*OgA6ACgAIgBMACIAKwAiAG8AYQBkACIAKQ*", "*oAOgAoACIATAAiACsAIgBvAGEAZAAiACkA*", "*6ADoAKAAiAEwAIgArACIAbwBhAGQAIgApA*", "*OgA6ACgAIgBMAG8AIgArACIAYQBkACIAKQ*", "*oAOgAoACIATABvACIAKwAiAGEAZAAiACkA*", "*6ADoAKAAiAEwAbwAiACsAIgBhAGQAIgApA*", "*OgA6ACgAIgBMAG8AYQAiACsAIgBkACIAKQ*", "*oAOgAoACIATABvAGEAIgArACIAZAAiACkA*", "*6ADoAKAAiAEwAbwBhACIAKwAiAGQAIgApA*", "*OgA6ACgAJwBMACcAKwAnAG8AYQBkACcAKQ*", "*oAOgAoACcATAAnACsAJwBvAGEAZAAnACkA*", "*6ADoAKAAnAEwAJwArACcAbwBhAGQAJwApA*", "*OgA6ACgAJwBMAG8AJwArACcAYQBkACcAKQ*", "*oAOgAoACcATABvACcAKwAnAGEAZAAnACkA*", "*6ADoAKAAnAEwAbwAnACsAJwBhAGQAJwApA*", "*OgA6ACgAJwBMAG8AYQAnACsAJwBkACcAKQ*", "*oAOgAoACcATABvAGEAJwArACcAZAAnACkA*", "*6ADoAKAAnAEwAbwBhACcAKwAnAGQAJwApA*")

# ── PowerShell Base64 Encoded WMI Classes ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects calls to base64 encoded WMI class such as "Win32_ShadowCopy", "Win32_ScheduledJob", etc.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine IN ("*VwBpAG4AMwAyAF8AUwBoAGEAZABvAHcAYwBvAHAAeQ*", "*cAaQBuADMAMgBfAFMAaABhAGQAbwB3AGMAbwBwAHkA*", "*XAGkAbgAzADIAXwBTAGgAYQBkAG8AdwBjAG8AcAB5A*", "*V2luMzJfU2hhZG93Y29we*", "*dpbjMyX1NoYWRvd2NvcH*", "*XaW4zMl9TaGFkb3djb3B5*") OR CommandLine IN ("*VwBpAG4AMwAyAF8AUwBjAGgAZQBkAHUAbABlAGQASgBvAGIA*", "*cAaQBuADMAMgBfAFMAYwBoAGUAZAB1AGwAZQBkAEoAbwBiA*", "*XAGkAbgAzADIAXwBTAGMAaABlAGQAdQBsAGUAZABKAG8AYg*", "*V2luMzJfU2NoZWR1bGVkSm9i*", "*dpbjMyX1NjaGVkdWxlZEpvY*", "*XaW4zMl9TY2hlZHVsZWRKb2*") OR CommandLine IN ("*VwBpAG4AMwAyAF8AUAByAG8AYwBlAHMAcw*", "*cAaQBuADMAMgBfAFAAcgBvAGMAZQBzAHMA*", "*XAGkAbgAzADIAXwBQAHIAbwBjAGUAcwBzA*", "*V2luMzJfUHJvY2Vzc*", "*dpbjMyX1Byb2Nlc3*", "*XaW4zMl9Qcm9jZXNz*") OR CommandLine IN ("*VwBpAG4AMwAyAF8AVQBzAGUAcgBBAGMAYwBvAHUAbgB0A*", "*cAaQBuADMAMgBfAFUAcwBlAHIAQQBjAGMAbwB1AG4AdA*", "*XAGkAbgAzADIAXwBVAHMAZQByAEEAYwBjAG8AdQBuAHQA*", "*V2luMzJfVXNlckFjY291bn*", "*dpbjMyX1VzZXJBY2NvdW50*", "*XaW4zMl9Vc2VyQWNjb3Vud*") OR CommandLine IN ("*VwBpAG4AMwAyAF8ATABvAGcAZwBlAGQATwBuAFUAcwBlAHIA*", "*cAaQBuADMAMgBfAEwAbwBnAGcAZQBkAE8AbgBVAHMAZQByA*", "*XAGkAbgAzADIAXwBMAG8AZwBnAGUAZABPAG4AVQBzAGUAcg*", "*V2luMzJfTG9nZ2VkT25Vc2Vy*", "*dpbjMyX0xvZ2dlZE9uVXNlc*", "*XaW4zMl9Mb2dnZWRPblVzZX*")

# ── Potential Process Execution Proxy Via CL_Invocation.ps1 ──
# Mức độ  : Trung bình
# Chi tiết: Detects calls to "SyncInvoke" that is part of the "CL_Invocation.ps1" script to proxy execution using "System.Diagnostics.Process"
EventCode=4688 Channel="Security" CommandLine="*SyncInvoke *"

# ── Assembly Loading Via CL_LoadAssembly.ps1 ──
# Mức độ  : Trung bình
# Chi tiết: Detects calls to "LoadAssemblyFromPath" or "LoadAssemblyFromNS" that are part of the "CL_LoadAssembly.ps1" script. This can be abused to load different assemblies and bypass App locker controls.
EventCode=4688 Channel="Security" CommandLine IN ("*LoadAssemblyFromPath *", "*LoadAssemblyFromNS *")

# ── Potential Script Proxy Execution Via CL_Mutexverifiers.ps1 ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of the Microsoft signed script "CL_mutexverifiers" to proxy the execution of additional PowerShell script commands
EventCode=4688 Channel="Security" CommandLine="* -nologo -windowstyle minimized -file *" ParentProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") NewProcessName="*\\powershell.exe" CommandLine IN ("*\\AppData\\Local\\Temp\\*", "*\\Windows\\Temp\\*")

# ── ConvertTo-SecureString Cmdlet Usage Via CommandLine ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects usage of the "ConvertTo-SecureString" cmdlet via the commandline. Which is fairly uncommon and could indicate potential suspicious activity
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine="*ConvertTo-SecureString*"

# ── Potential PowerShell Obfuscation Via Reversed Commands ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the presence of reversed PowerShell commands in the CommandLine. This is often used as a method of obfuscation by attackers
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine IN ("*hctac*", "*kaerb*", "*dnammoc*", "*ekovn*", "*eliFd*", "*rahc*", "*etirw*", "*golon*", "*tninon*", "*eddih*", "*tpircS*", "*ssecorp*", "*llehsrewop*", "*esnopser*", "*daolnwod*", "*tneilCbeW*", "*tneilc*", "*ptth*", "*elifotevas*", "*46esab*", "*htaPpmeTteG*", "*tcejbO*", "*maerts*", "*hcaerof*", "*retupmoc*") NOT (CommandLine IN ("* -EncodedCommand *", "* -enc *"))

# ── Potential PowerShell Command Line Obfuscation ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the PowerShell command lines with special characters
EventCode=4688 Channel="Security"
| rex field=CommandLine "(?<CommandLineMatch>\\+.*\\+.*\\+.*\\+.*\\+.*\\+.*\\+.*\\+.*\\+.*\\+.*\\+.*\\+.*\\+.*\\+)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch2>\\{.*\\{.*\\{.*\\{.*\\{.*\\{.*\\{.*\\{.*\\{.*\\{)"
| eval CommandLineCondition2=if(isnotnull(CommandLineMatch2), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch3>\\^.*\\^.*\\^.*\\^.*\\^)"
| eval CommandLineCondition3=if(isnotnull(CommandLineMatch3), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch4>`.*`.*`.*`.*`)"
| eval CommandLineCondition4=if(isnotnull(CommandLineMatch4), "true", "false")
| search NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLineCondition="true" OR CommandLineCondition2="true" OR CommandLineCondition3="true" OR CommandLineCondition4="true" NOT (ParentProcessName="C:\\Program Files\\Amazon\\SSM\\ssm-document-worker.exe" OR CommandLine IN ("*new EventSource(\"Microsoft.Windows.Sense.Client.Management\"*", "*public static extern bool InstallELAMCertificateInfo(SafeFileHandle handle);*"))

# ── Obfuscated PowerShell MSI Install via WindowsInstaller COM ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the execution of obfuscated PowerShell commands that attempt to install MSI packages via the Windows Installer COM object (`WindowsInstaller.Installer`). The technique involves manipulating st
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell_ISE.EXE", "PowerShell.EXE", "pwsh.dll") CommandLine="*-ComObject*" CommandLine="*InstallProduct(*" CommandLine="*.Insert(*" CommandLine="*UILevel*"

# ── PowerShell MSI Install via WindowsInstaller COM From Remote Location ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script; Tải file từ mạng
# Chi tiết: Detects the execution of PowerShell commands that attempt to install MSI packages via the Windows Installer COM object (`WindowsInstaller.Installer`) hosted remotely. This could be indication of malic
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell_ISE.EXE", "PowerShell.EXE", "pwsh.dll") CommandLine="*-ComObject*" CommandLine="*InstallProduct(*" CommandLine IN ("*http*", "*\\\\*") NOT (CommandLine IN ("*://127.0.0.1*", "*://localhost*"))

# ── Computer Discovery And Export Via Get-ADComputer Cmdlet ──
# Mức độ  : Trung bình
# Mục đích: Thu thập thông tin user
# Chi tiết: Detects usage of the Get-ADComputer cmdlet to collect computer information and output it to a file
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine="*Get-ADComputer *" CommandLine="* -Filter \**" CommandLine IN ("* > *", "* | Select *", "*Out-File*", "*Set-Content*", "*Add-Content*")

# ── Potential PowerShell Console History Access Attempt via History File ──
# Mức độ  : Trung bình
# Chi tiết: Detects potential access attempts to the PowerShell console history directly via history file (ConsoleHost_history.txt). This can give access to plaintext passwords used in PowerShell commands or used
EventCode=4688 Channel="Security" CommandLine IN ("*ConsoleHost_history.txt*", "*(Get-PSReadLineOption).HistorySavePath*")

# ── New Service Creation Using PowerShell ──
# Mức độ  : Thấp
# Chi tiết: Detects the creation of a new service using powershell.
EventCode=4688 Channel="Security" CommandLine="*New-Service*" CommandLine="*-BinaryPathName*"

# ── Gzip Archive Decode Via PowerShell ──
# Mức độ  : Trung bình
# Chi tiết: Detects attempts of decoding encoded Gzip archives via PowerShell.
EventCode=4688 Channel="Security" CommandLine="*GZipStream*" CommandLine="*::Decompress*"

# ── PowerShell Execution With Potential Decryption Capabilities ──
# Mức độ  : Cao
# Chi tiết: Detects PowerShell commands that decrypt an ".LNK" "file to drop the next stage of the malware.
EventCode=4688 Channel="Security" OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") CommandLine IN ("*Get-ChildItem *", "*dir *", "*gci *", "*ls *") CommandLine IN ("*Get-Content *", "*gc *", "*cat *", "*type *", "*ReadAllBytes*") (CommandLine="* ^| *" CommandLine="*\*.lnk*" CommandLine="*-Recurse*" CommandLine="*-Skip *") OR (CommandLine="* -ExpandProperty *" CommandLine="*\*.lnk*" CommandLine="*WriteAllBytes*" CommandLine="* .length *")

# ── Powershell Defender Disable Scan Feature ──
# Mức độ  : Cao
# Chi tiết: Detects requests to disable Microsoft Defender features using PowerShell commands
EventCode=4688 Channel="Security" (CommandLine IN ("*Add-MpPreference *", "*Set-MpPreference *") CommandLine IN ("*DisableArchiveScanning *", "*DisableRealtimeMonitoring *", "*DisableIOAVProtection *", "*DisableBehaviorMonitoring *", "*DisableBlockAtFirstSeen *", "*DisableCatchupFullScan *", "*DisableCatchupQuickScan *") CommandLine IN ("*$true*", "* 1 *")) OR CommandLine="*ZGlzYWJsZWFyY2hpdmVzY2FubmluZy*" OR CommandLine="*Rpc2FibGVhcmNoaXZlc2Nhbm5pbmcg*" OR CommandLine="*kaXNhYmxlYXJjaGl2ZXNjYW5uaW5nI*" OR CommandLine="*RGlzYWJsZUFyY2hpdmVTY2FubmluZy*" OR CommandLine="*Rpc2FibGVBcmNoaXZlU2Nhbm5pbmcg*" OR CommandLine="*EaXNhYmxlQXJjaGl2ZVNjYW5uaW5nI*" OR CommandLine="*ZGlzYWJsZWJlaGF2aW9ybW9uaXRvcmluZy*" OR CommandLine="*Rpc2FibGViZWhhdmlvcm1vbml0b3Jpbmcg*" OR CommandLine="*kaXNhYmxlYmVoYXZpb3Jtb25pdG9yaW5nI*" OR CommandLine="*RGlzYWJsZUJlaGF2aW9yTW9uaXRvcmluZy*" OR CommandLine="*Rpc2FibGVCZWhhdmlvck1vbml0b3Jpbmcg*" OR CommandLine="*EaXNhYmxlQmVoYXZpb3JNb25pdG9yaW5nI*" OR CommandLine="*ZGlzYWJsZWJsb2NrYXRmaXJzdHNlZW4g*" OR CommandLine="*Rpc2FibGVibG9ja2F0Zmlyc3RzZWVuI*" OR CommandLine="*kaXNhYmxlYmxvY2thdGZpcnN0c2Vlbi*" OR CommandLine="*RGlzYWJsZUJsb2NrQXRGaXJzdFNlZW4g*" OR CommandLine="*Rpc2FibGVCbG9ja0F0Rmlyc3RTZWVuI*" OR CommandLine="*EaXNhYmxlQmxvY2tBdEZpcnN0U2Vlbi*" OR CommandLine="*ZGlzYWJsZWNhdGNodXBmdWxsc2Nhbi*" OR CommandLine="*Rpc2FibGVjYXRjaHVwZnVsbHNjYW4g*" OR CommandLine="*kaXNhYmxlY2F0Y2h1cGZ1bGxzY2FuI*" OR CommandLine="*RGlzYWJsZUNhdGNodXBGdWxsU2Nhbi*" OR CommandLine="*Rpc2FibGVDYXRjaHVwRnVsbFNjYW4g*" OR CommandLine="*EaXNhYmxlQ2F0Y2h1cEZ1bGxTY2FuI*" OR CommandLine="*ZGlzYWJsZWNhdGNodXBxdWlja3NjYW4g*" OR CommandLine="*Rpc2FibGVjYXRjaHVwcXVpY2tzY2FuI*" OR CommandLine="*kaXNhYmxlY2F0Y2h1cHF1aWNrc2Nhbi*" OR CommandLine="*RGlzYWJsZUNhdGNodXBRdWlja1NjYW4g*" OR CommandLine="*Rpc2FibGVDYXRjaHVwUXVpY2tTY2FuI*" OR CommandLine="*EaXNhYmxlQ2F0Y2h1cFF1aWNrU2Nhbi*" OR CommandLine="*ZGlzYWJsZWlvYXZwcm90ZWN0aW9uI*" OR CommandLine="*Rpc2FibGVpb2F2cHJvdGVjdGlvbi*" OR CommandLine="*kaXNhYmxlaW9hdnByb3RlY3Rpb24g*" OR CommandLine="*RGlzYWJsZUlPQVZQcm90ZWN0aW9uI*" OR CommandLine="*Rpc2FibGVJT0FWUHJvdGVjdGlvbi*" OR CommandLine="*EaXNhYmxlSU9BVlByb3RlY3Rpb24g*" OR CommandLine="*ZGlzYWJsZXJlYWx0aW1lbW9uaXRvcmluZy*" OR CommandLine="*Rpc2FibGVyZWFsdGltZW1vbml0b3Jpbmcg*" OR CommandLine="*kaXNhYmxlcmVhbHRpbWVtb25pdG9yaW5nI*" OR CommandLine="*RGlzYWJsZVJlYWx0aW1lTW9uaXRvcmluZy*" OR CommandLine="*Rpc2FibGVSZWFsdGltZU1vbml0b3Jpbmcg*" OR CommandLine="*EaXNhYmxlUmVhbHRpbWVNb25pdG9yaW5nI*" OR CommandLine IN ("*RABpAHMAYQBiAGwAZQBSAGUAYQBsAHQAaQBtAGUATQBvAG4AaQB0AG8AcgBpAG4AZwAgA*", "*QAaQBzAGEAYgBsAGUAUgBlAGEAbAB0AGkAbQBlAE0AbwBuAGkAdABvAHIAaQBuAGcAIA*", "*EAGkAcwBhAGIAbABlAFIAZQBhAGwAdABpAG0AZQBNAG8AbgBpAHQAbwByAGkAbgBnACAA*", "*RABpAHMAYQBiAGwAZQBJAE8AQQBWAFAAcgBvAHQAZQBjAHQAaQBvAG4AIA*", "*QAaQBzAGEAYgBsAGUASQBPAEEAVgBQAHIAbwB0AGUAYwB0AGkAbwBuACAA*", "*EAGkAcwBhAGIAbABlAEkATwBBAFYAUAByAG8AdABlAGMAdABpAG8AbgAgA*", "*RABpAHMAYQBiAGwAZQBCAGUAaABhAHYAaQBvAHIATQBvAG4AaQB0AG8AcgBpAG4AZwAgA*", "*QAaQBzAGEAYgBsAGUAQgBlAGgAYQB2AGkAbwByAE0AbwBuAGkAdABvAHIAaQBuAGcAIA*", "*EAGkAcwBhAGIAbABlAEIAZQBoAGEAdgBpAG8AcgBNAG8AbgBpAHQAbwByAGkAbgBnACAA*", "*RABpAHMAYQBiAGwAZQBCAGwAbwBjAGsAQQB0AEYAaQByAHMAdABTAGUAZQBuACAA*", "*QAaQBzAGEAYgBsAGUAQgBsAG8AYwBrAEEAdABGAGkAcgBzAHQAUwBlAGUAbgAgA*", "*EAGkAcwBhAGIAbABlAEIAbABvAGMAawBBAHQARgBpAHIAcwB0AFMAZQBlAG4AIA*", "*ZABpAHMAYQBiAGwAZQByAGUAYQBsAHQAaQBtAGUAbQBvAG4AaQB0AG8AcgBpAG4AZwAgA*", "*QAaQBzAGEAYgBsAGUAcgBlAGEAbAB0AGkAbQBlAG0AbwBuAGkAdABvAHIAaQBuAGcAIA*", "*kAGkAcwBhAGIAbABlAHIAZQBhAGwAdABpAG0AZQBtAG8AbgBpAHQAbwByAGkAbgBnACAA*", "*ZABpAHMAYQBiAGwAZQBpAG8AYQB2AHAAcgBvAHQAZQBjAHQAaQBvAG4AIA*", "*QAaQBzAGEAYgBsAGUAaQBvAGEAdgBwAHIAbwB0AGUAYwB0AGkAbwBuACAA*", "*kAGkAcwBhAGIAbABlAGkAbwBhAHYAcAByAG8AdABlAGMAdABpAG8AbgAgA*", "*ZABpAHMAYQBiAGwAZQBiAGUAaABhAHYAaQBvAHIAbQBvAG4AaQB0AG8AcgBpAG4AZwAgA*", "*QAaQBzAGEAYgBsAGUAYgBlAGgAYQB2AGkAbwByAG0AbwBuAGkAdABvAHIAaQBuAGcAIA*", "*kAGkAcwBhAGIAbABlAGIAZQBoAGEAdgBpAG8AcgBtAG8AbgBpAHQAbwByAGkAbgBnACAA*", "*ZABpAHMAYQBiAGwAZQBiAGwAbwBjAGsAYQB0AGYAaQByAHMAdABzAGUAZQBuACAA*", "*QAaQBzAGEAYgBsAGUAYgBsAG8AYwBrAGEAdABmAGkAcgBzAHQAcwBlAGUAbgAgA*", "*kAGkAcwBhAGIAbABlAGIAbABvAGMAawBhAHQAZgBpAHIAcwB0AHMAZQBlAG4AIA*", "*RABpAHMAYQBiAGwAZQBDAGEAdABjAGgAdQBwAEYAdQBsAGwAUwBjAGEAbgA*", "*RABpAHMAYQBiAGwAZQBDAGEAdABjAGgAdQBwAFEAdQBpAGMAawBTAGMAYQBuAA*", "*RABpAHMAYQBiAGwAZQBBAHIAYwBoAGkAdgBlAFMAYwBhAG4AbgBpAG4AZwA*")

# ── Powershell Defender Exclusion ──
# Mức độ  : Trung bình
# Chi tiết: Detects requests to exclude files, folders or processes from Antivirus scanning using PowerShell cmdlets
EventCode=4688 Channel="Security" CommandLine IN ("*Add-MpPreference *", "*Set-MpPreference *") CommandLine IN ("* -ExclusionPath *", "* -ExclusionExtension *", "* -ExclusionProcess *", "* -ExclusionIpAddress *")

# ── Disable Windows Defender AV Security Monitoring ──
# Mức độ  : Cao
# Chi tiết: Detects attackers attempting to disable Windows Defender using Powershell
EventCode=4688 Channel="Security" (NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine IN ("*-DisableBehaviorMonitoring $true*", "*-DisableRuntimeMonitoring $true*")) OR (NewProcessName="*\\sc.exe" OR OriginalFileName="sc.exe" (CommandLine="*stop*" CommandLine="*WinDefend*") OR (CommandLine="*delete*" CommandLine="*WinDefend*") OR (CommandLine="*config*" CommandLine="*WinDefend*" CommandLine="*start=disabled*"))

# ── Windows Firewall Disabled via PowerShell ──
# Mức độ  : Trung bình
# Chi tiết: Detects attempts to disable the Windows Firewall using PowerShell
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe", "*\\powershell_ise.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine="*Set-NetFirewallProfile *" CommandLine="* -Enabled *" CommandLine="* False*" CommandLine IN ("* -All *", "*Public*", "*Domain*", "*Private*")

# ── Disabled IE Security Features ──
# Mức độ  : Cao
# Chi tiết: Detects command lines that indicate unwanted modifications to registry keys that disable important Internet Explorer security features
EventCode=4688 Channel="Security" (CommandLine="* -name IEHarden *" CommandLine="* -value 0 *") OR (CommandLine="* -name DEPOff *" CommandLine="* -value 1 *") OR (CommandLine="* -name DisableFirstRunCustomize *" CommandLine="* -value 2 *")

# ── Potential PowerShell Downgrade Attack ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects PowerShell downgrade attack by comparing the host versions with the actually used engine version 2.0
EventCode=4688 Channel="Security" CommandLine IN ("* -version 2 *", "* -versio 2 *", "* -versi 2 *", "* -vers 2 *", "* -ver 2 *", "* -ve 2 *", "* -v 2 *") NewProcessName="*\\powershell.exe"

# ── Potential COM Objects Download Cradles Usage - Process Creation ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects usage of COM objects that can be abused to download files in PowerShell by CLSID
EventCode=4688 Channel="Security" CommandLine="*[Type]::GetTypeFromCLSID(*" CommandLine IN ("*0002DF01-0000-0000-C000-000000000046*", "*F6D90F16-9C73-11D3-B32E-00C04F990BB4*", "*F5078F35-C551-11D3-89B9-0000F81FE221*", "*88d96a0a-f192-11d4-a65f-0040963251e5*", "*AFBA6B42-5692-48EA-8141-DC517DCF0EF1*", "*AFB40FFD-B609-40A3-9828-F88BBE11E4E3*", "*88d96a0b-f192-11d4-a65f-0040963251e5*", "*2087c2f4-2cef-4953-a8ab-66779b670495*", "*000209FF-0000-0000-C000-000000000046*", "*00024500-0000-0000-C000-000000000046*")

# ── Obfuscated PowerShell OneLiner Execution ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the execution of a specific OneLiner to download and execute powershell modules in memory.
EventCode=4688 Channel="Security" CommandLine="*http://127.0.0.1*" CommandLine="*%{(IRM $_)}*" CommandLine="*Invoke*" NewProcessName="*\\powershell.exe"

# ── Potential DLL File Download Via PowerShell Invoke-WebRequest ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script; Tải file từ mạng
# Chi tiết: Detects potential DLL files being downloaded using the PowerShell Invoke-WebRequest or Invoke-RestMethod cmdlets.
EventCode=4688 Channel="Security" CommandLine IN ("*Invoke-RestMethod *", "*Invoke-WebRequest *", "*IRM *", "*IWR *") CommandLine="*http*" CommandLine="*OutFile*" CommandLine="*.dll*"

# ── PowerShell Download and Execution Cradles ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects PowerShell download and execution cradles.
EventCode=4688 Channel="Security" CommandLine IN ("*.DownloadString(*", "*.DownloadFile(*", "*Invoke-WebRequest *", "*iwr *", "*Invoke-RestMethod *", "*irm *") CommandLine IN ("*;iex $*", "*| IEX*", "*|IEX *", "*I`E`X*", "*I`EX*", "*IE`X*", "*iex *", "*IEX (*", "*IEX(*", "*Invoke-Expression*")

# ── PowerShell Download Pattern ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects a Powershell process that contains download commands in its command line string
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell_ISE.EXE", "PowerShell.EXE", "pwsh.dll") CommandLine="*new-object*" CommandLine="*net.webclient).*" CommandLine="*download*" CommandLine IN ("*string(*", "*file(*")

# ── Potentially Suspicious File Download From File Sharing Domain Via PowerShell.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects potentially suspicious file downloads from file sharing domains using PowerShell.exe
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine IN ("*0x0.st*", "*anonfiles.com*", "*bashupload.com*", "*cdn.discordapp.com*", "*chunk.io*", "*ddns.net*", "*dl.dropboxusercontent.com*", "*ghostbin.co*", "*glitch.me*", "*gofile.io*", "*hastebin.com*", "*mediafire.com*", "*mega.nz*", "*onrender.com*", "*pages.dev*", "*paste.ee*", "*pastebin.com*", "*pastebin.pl*", "*pastetext.net*", "*pixeldrain.com*", "*privatlab.com*", "*privatlab.net*", "*send.exploit.in*", "*sendspace.com*", "*storage.googleapis.com*", "*storjshare.io*", "*supabase.co*", "*temp.sh*", "*transfer.sh*", "*trycloudflare.com*", "*ufile.io*", "*w3spaces.com*", "*workers.dev*", "*x0.at*") CommandLine IN ("*.DownloadString(*", "*.DownloadFile(*", "*Invoke-WebRequest *", "*iwr *", "*wget *")

# ── DSInternals Suspicious PowerShell Cmdlets ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution and usage of the DSInternals PowerShell module. Which can be used to perform what might be considered as suspicious activity such as dumping DPAPI backup keys or manipulating NTDS.DI
EventCode=4688 Channel="Security" CommandLine IN ("*Add-ADDBSidHistory*", "*Add-ADNgcKey*", "*Add-ADReplNgcKey*", "*ConvertFrom-ADManagedPasswordBlob*", "*ConvertFrom-GPPrefPassword*", "*ConvertFrom-ManagedPasswordBlob*", "*ConvertFrom-UnattendXmlPassword*", "*ConvertFrom-UnicodePassword*", "*ConvertTo-AADHash*", "*ConvertTo-GPPrefPassword*", "*ConvertTo-KerberosKey*", "*ConvertTo-LMHash*", "*ConvertTo-MsoPasswordHash*", "*ConvertTo-NTHash*", "*ConvertTo-OrgIdHash*", "*ConvertTo-UnicodePassword*", "*Disable-ADDBAccount*", "*Enable-ADDBAccount*", "*Get-ADDBAccount*", "*Get-ADDBBackupKey*", "*Get-ADDBDomainController*", "*Get-ADDBGroupManagedServiceAccount*", "*Get-ADDBKdsRootKey*", "*Get-ADDBSchemaAttribute*", "*Get-ADDBServiceAccount*", "*Get-ADDefaultPasswordPolicy*", "*Get-ADKeyCredential*", "*Get-ADPasswordPolicy*", "*Get-ADReplAccount*", "*Get-ADReplBackupKey*", "*Get-ADReplicationAccount*", "*Get-ADSIAccount*", "*Get-AzureADUserEx*", "*Get-BootKey*", "*Get-KeyCredential*", "*Get-LsaBackupKey*", "*Get-LsaPolicy*", "*Get-SamPasswordPolicy*", "*Get-SysKey*", "*Get-SystemKey*", "*New-ADDBRestoreFromMediaScript*", "*New-ADKeyCredential*", "*New-ADNgcKey*", "*New-NTHashSet*", "*Remove-ADDBObject*", "*Save-DPAPIBlob*", "*Set-ADAccountPasswordHash*", "*Set-ADDBAccountPassword*", "*Set-ADDBBootKey*", "*Set-ADDBDomainController*", "*Set-ADDBPrimaryGroup*", "*Set-ADDBSysKey*", "*Set-AzureADUserEx*", "*Set-LsaPolicy*", "*Set-SamAccountPasswordHash*", "*Set-WinUserPasswordHash*", "*Test-ADDBPasswordQuality*", "*Test-ADPasswordQuality*", "*Test-ADReplPasswordQuality*", "*Test-PasswordQuality*", "*Unlock-ADDBAccount*", "*Write-ADNgcKey*", "*Write-ADReplNgcKey*")

# ── Email Exifiltration Via Powershell ──
# Mức độ  : Cao
# Chi tiết: Detects email exfiltration via powershell cmdlets
EventCode=4688 Channel="Security" CommandLine="*Add-PSSnapin*" CommandLine="*Get-Recipient*" CommandLine="*-ExpandProperty*" CommandLine="*EmailAddresses*" CommandLine="*SmtpAddress*" CommandLine="*-hidetableheaders*" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe")

# ── Potential Suspicious Windows Feature Enabled - ProcCreation ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the built-in PowerShell cmdlet "Enable-WindowsOptionalFeature" used as a Deployment Image Servicing and Management tool. Similar to DISM.exe, this cmdlet is used to enumerate, install
EventCode=4688 Channel="Security" CommandLine="*Enable-WindowsOptionalFeature*" CommandLine="*-Online*" CommandLine="*-FeatureName*" CommandLine IN ("*TelnetServer*", "*Internet-Explorer-Optional-amd64*", "*TFTP*", "*SMB1Protocol*", "*Client-ProjFS*", "*Microsoft-Windows-Subsystem-Linux*")

# ── Suspicious Execution of Powershell with Base64 ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Commandline to launch powershell with a base64 payload
EventCode=4688 Channel="Security" CommandLine IN ("* -e *", "* -en *", "* -enc *", "* -enco*", "* -ec *") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") NOT (CommandLine="* -Encoding *" OR ParentProcessName IN ("*C:\\Packages\\Plugins\\Microsoft.GuestConfiguration.ConfigurationforWindows\\*", "*\\gc_worker.exe*"))

# ── Potential Encoded PowerShell Patterns In CommandLine ──
# Mức độ  : Thấp
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects specific combinations of encoding methods in PowerShell via the commandline
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") (CommandLine IN ("*ToInt*", "*ToDecimal*", "*ToByte*", "*ToUint*", "*ToSingle*", "*ToSByte*") CommandLine IN ("*ToChar*", "*ToString*", "*String*")) OR (CommandLine="*char*" CommandLine="*join*") OR (CommandLine="*split*" CommandLine="*join*")

# ── Powershell Inline Execution From A File ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects inline execution of PowerShell code from a file
EventCode=4688 Channel="Security" CommandLine IN ("*iex *", "*Invoke-Expression *", "*Invoke-Command *", "*icm *") CommandLine IN ("*cat *", "*get-content *", "*type *") CommandLine="* -raw*"

# ── Certificate Exported Via PowerShell ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects calls to cmdlets that are used to export certificates from the local certificate store. Threat actors were seen abusing this to steal private keys from compromised machines.
EventCode=4688 Channel="Security" CommandLine IN ("*Export-PfxCertificate *", "*Export-Certificate *")

# ── Base64 Encoded PowerShell Command Detected ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects usage of the "FromBase64String" function in the commandline which is used to decode a base64 encoded string
EventCode=4688 Channel="Security" CommandLine="*::FromBase64String(*"

# ── Suspicious FromBase64String Usage On Gzip Archive - Process Creation ──
# Mức độ  : Trung bình
# Chi tiết: Detects attempts of decoding a base64 Gzip archive via PowerShell. This technique is often used as a method to load malicious content into memory afterward.
EventCode=4688 Channel="Security" CommandLine="*FromBase64String*" CommandLine="*MemoryStream*" CommandLine="*H4sI*"

# ── PowerShell Get-Clipboard Cmdlet Via CLI ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the 'Get-Clipboard' cmdlet via CLI
EventCode=4688 Channel="Security" CommandLine="*Get-Clipboard*"

# ── Suspicious Reconnaissance Activity Using Get-LocalGroupMember Cmdlet ──
# Mức độ  : Trung bình
# Chi tiết: Detects suspicious reconnaissance command line activity on Windows systems using the PowerShell Get-LocalGroupMember Cmdlet
EventCode=4688 Channel="Security" CommandLine="*Get-LocalGroupMember *" CommandLine IN ("*domain admins*", "* administrator*", "* administrateur*", "*enterprise admins*", "*Exchange Trusted Subsystem*", "*Remote Desktop Users*", "*Utilisateurs du Bureau à distance*", "*Usuarios de escritorio remoto*")

# ── PowerShell Get-Process LSASS ──
# Mức độ  : Cao
# Chi tiết: Detects a "Get-Process" cmdlet and it's aliases on lsass process, which is in almost all cases a sign of malicious activity
EventCode=4688 Channel="Security" CommandLine IN ("*Get-Process lsas*", "*ps lsas*", "*gps lsas*")

# ── Abuse of Service Permissions to Hide Services Via Set-Service ──
# Mức độ  : Cao
# Chi tiết: Detects usage of the "Set-Service" powershell cmdlet to configure a new SecurityDescriptor that allows a service to be hidden from other utilities such as "sc.exe", "Get-Service"...etc. (Works only in
EventCode=4688 Channel="Security" NewProcessName="*\\pwsh.exe" OR OriginalFileName="pwsh.dll" CommandLine="*Set-Service *" CommandLine="*DCLCWPDTSD*" CommandLine IN ("*-SecurityDescriptorSddl *", "*-sd *")

# ── Suspicious PowerShell IEX Execution Patterns ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious ways to run Invoke-Execution using IEX alias
EventCode=4688 Channel="Security" (CommandLine IN ("* | iex;*", "* | iex *", "* | iex}*", "* | IEX ;*", "* | IEX -Error*", "* | IEX (new*", "*);IEX *") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") CommandLine IN ("*::FromBase64String*", "*.GetString([System.Convert]::*")) OR CommandLine IN ("*)|iex;$*", "*);iex($*", "*);iex $*", "* | IEX | *", "* | iex\\\"*")

# ── Root Certificate Installed From Susp Locations ──
# Mức độ  : Cao
# Chi tiết: Adversaries may install a root certificate on a compromised system to avoid warnings when connecting to adversary controlled web servers.
EventCode=4688 Channel="Security" CommandLine="*Import-Certificate*" CommandLine="* -FilePath *" CommandLine="*Cert:\\LocalMachine\\Root*" CommandLine IN ("*\\AppData\\Local\\Temp\\*", "*:\\Windows\\TEMP\\*", "*\\Desktop\\*", "*\\Downloads\\*", "*\\Perflogs\\*", "*:\\Users\\Public\\*")

# ── Import PowerShell Modules From Suspicious Directories - ProcCreation ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects powershell scripts that import modules from suspicious directories
EventCode=4688 Channel="Security" CommandLine IN ("*Import-Module \"$Env:Temp\\*", "*Import-Module '$Env:Temp\\*", "*Import-Module $Env:Temp\\*", "*Import-Module \"$Env:Appdata\\*", "*Import-Module '$Env:Appdata\\*", "*Import-Module $Env:Appdata\\*", "*Import-Module C:\\Users\\Public\\*", "*ipmo \"$Env:Temp\\*", "*ipmo '$Env:Temp\\*", "*ipmo $Env:Temp\\*", "*ipmo \"$Env:Appdata\\*", "*ipmo '$Env:Appdata\\*", "*ipmo $Env:Appdata\\*", "*ipmo C:\\Users\\Public\\*")

# ── Unsigned AppX Installation Attempt Using Add-AppxPackage ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the "Add-AppxPackage" or it's alias "Add-AppPackage" to install unsigned AppX packages
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine IN ("*Add-AppPackage *", "*Add-AppxPackage *") CommandLine="* -AllowUnsigned*"

# ── Suspicious PowerShell Invocations - Specific - ProcessCreation ──
# Mức độ  : Trung bình
# Chi tiết: Detects suspicious PowerShell invocation command parameters
EventCode=4688 Channel="Security" (CommandLine="*-nop*" CommandLine="* -w *" CommandLine="*hidden*" CommandLine="* -c *" CommandLine="*[Convert]::FromBase64String*") OR (CommandLine="* -w *" CommandLine="*hidden*" CommandLine="*-noni*" CommandLine="*-nop*" CommandLine="* -c *" CommandLine="*iex*" CommandLine="*New-Object*") OR (CommandLine="* -w *" CommandLine="*hidden*" CommandLine="*-ep*" CommandLine="*bypass*" CommandLine="*-Enc*") OR (CommandLine="*powershell*" CommandLine="*reg*" CommandLine="*add*" CommandLine="*\\software\\*") OR (CommandLine="*bypass*" CommandLine="*-noprofile*" CommandLine="*-windowstyle*" CommandLine="*hidden*" CommandLine="*new-object*" CommandLine="*system.net.webclient*" CommandLine="*.download*") OR (CommandLine="*iex*" CommandLine="*New-Object*" CommandLine="*Net.WebClient*" CommandLine="*.Download*") NOT (CommandLine IN ("*(New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1*", "*Write-ChocolateyWarning*"))

# ── Suspicious Invoke-WebRequest Execution With DirectIP ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects calls to PowerShell with Invoke-WebRequest cmdlet using direct IP access
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("powershell_ise.EXE", "PowerShell.EXE", "pwsh.dll") CommandLine IN ("*curl *", "*Invoke-RestMethod*", "*Invoke-WebRequest*", "* irm *", "*iwr *", "*wget *") CommandLine IN ("*://1*", "*://2*", "*://3*", "*://4*", "*://5*", "*://6*", "*://7*", "*://8*", "*://9*")

# ── Suspicious Invoke-WebRequest Execution ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects a suspicious call to Invoke-WebRequest cmdlet where the and output is located in a suspicious location
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("powershell_ise.EXE", "PowerShell.EXE", "pwsh.dll") CommandLine IN ("*curl *", "*Invoke-WebRequest*", "*iwr *", "*wget *") CommandLine IN ("* -ur*", "* -o*") CommandLine IN ("*\\AppData\\*", "*\\Desktop\\*", "*\\Temp\\*", "*\\Users\\Public\\*", "*%AppData%*", "*%Public%*", "*%Temp%*", "*%tmp%*", "*:\\Windows\\*")

# ── Suspicious Kerberos Ticket Request via CLI ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious Kerberos ticket requests via command line using System.IdentityModel.Tokens.KerberosRequestorSecurityToken class. Threat actors may use command line interfaces to request Kerberos t
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("powershell.exe", "pwsh.dll") CommandLine="*System.IdentityModel.Tokens.KerberosRequestorSecurityToken*" CommandLine="*.GetRequest()*"

# ── Suspicious PowerShell Mailbox Export to Share ──
# Mức độ  : Nghiêm trọng
# Chi tiết: Detects usage of the powerShell New-MailboxExportRequest Cmdlet to exports a mailbox to a remote or local share, as used in ProxyShell exploitations
EventCode=4688 Channel="Security" CommandLine="*New-MailboxExportRequest*" CommandLine="* -Mailbox *" CommandLine="* -FilePath \\\\*"

# ── Malicious PowerShell Commandlets - ProcessCreation ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Commandlet names from well-known PowerShell exploitation frameworks
EventCode=4688 Channel="Security" CommandLine IN ("*Add-Exfiltration*", "*Add-Persistence*", "*Add-RegBackdoor*", "*Add-RemoteRegBackdoor*", "*Add-ScrnSaveBackdoor*", "*Check-VM*", "*ConvertTo-Rc4ByteStream*", "*Decrypt-Hash*", "*Disable-ADIDNSNode*", "*Disable-MachineAccount*", "*Do-Exfiltration*", "*Enable-ADIDNSNode*", "*Enable-MachineAccount*", "*Enabled-DuplicateToken*", "*Exploit-Jboss*", "*Export-ADR*", "*Export-ADRCSV*", "*Export-ADRExcel*", "*Export-ADRHTML*", "*Export-ADRJSON*", "*Export-ADRXML*", "*Find-Fruit*", "*Find-GPOLocation*", "*Find-TrustedDocuments*", "*Get-ADIDNS*", "*Get-ApplicationHost*", "*Get-ChromeDump*", "*Get-ClipboardContents*", "*Get-FoxDump*", "*Get-GPPPassword*", "*Get-IndexedItem*", "*Get-KerberosAESKey*", "*Get-Keystrokes*", "*Get-LSASecret*", "*Get-MachineAccountAttribute*", "*Get-MachineAccountCreator*", "*Get-PassHashes*", "*Get-RegAlwaysInstallElevated*", "*Get-RegAutoLogon*", "*Get-RemoteBootKey*", "*Get-RemoteCachedCredential*", "*Get-RemoteLocalAccountHash*", "*Get-RemoteLSAKey*", "*Get-RemoteMachineAccountHash*", "*Get-RemoteNLKMKey*", "*Get-RickAstley*", "*Get-Screenshot*", "*Get-SecurityPackages*", "*Get-ServiceFilePermission*", "*Get-ServicePermission*", "*Get-ServiceUnquoted*", "*Get-SiteListPassword*", "*Get-System*", "*Get-TimedScreenshot*", "*Get-UnattendedInstallFile*", "*Get-Unconstrained*", "*Get-USBKeystrokes*", "*Get-VaultCredential*", "*Get-VulnAutoRun*", "*Get-VulnSchTask*", "*Grant-ADIDNSPermission*", "*Gupt-Backdoor*", "*HTTP-Login*", "*Install-ServiceBinary*", "*Install-SSP*", "*Invoke-ACLScanner*", "*Invoke-ADRecon*", "*Invoke-ADSBackdoor*", "*Invoke-AgentSmith*", "*Invoke-AllChecks*", "*Invoke-ARPScan*", "*Invoke-AzureHound*", "*Invoke-BackdoorLNK*", "*Invoke-BadPotato*", "*Invoke-BetterSafetyKatz*", "*Invoke-BypassUAC*", "*Invoke-Carbuncle*", "*Invoke-Certify*", "*Invoke-ConPtyShell*", "*Invoke-CredentialInjection*", "*Invoke-DAFT*", "*Invoke-DCSync*", "*Invoke-DinvokeKatz*", "*Invoke-DllInjection*", "*Invoke-DNSUpdate*", "*Invoke-DNSExfiltrator*", "*Invoke-DomainPasswordSpray*", "*Invoke-DowngradeAccount*", "*Invoke-EgressCheck*", "*Invoke-Eyewitness*", "*Invoke-FakeLogonScreen*", "*Invoke-Farmer*", "*Invoke-Get-RBCD-Threaded*", "*Invoke-Gopher*", "*Invoke-Grouper*", "*Invoke-HandleKatz*", "*Invoke-ImpersonatedProcess*", "*Invoke-ImpersonateSystem*", "*Invoke-InteractiveSystemPowerShell*", "*Invoke-Internalmonologue*", "*Invoke-Inveigh*", "*Invoke-InveighRelay*", "*Invoke-KrbRelay*", "*Invoke-LdapSignCheck*", "*Invoke-Lockless*", "*Invoke-MalSCCM*", "*Invoke-Mimikatz*", "*Invoke-Mimikittenz*", "*Invoke-MITM6*", "*Invoke-NanoDump*", "*Invoke-NetRipper*", "*Invoke-Nightmare*", "*Invoke-NinjaCopy*", "*Invoke-OfficeScrape*", "*Invoke-OxidResolver*", "*Invoke-P0wnedshell*", "*Invoke-Paranoia*", "*Invoke-PortScan*", "*Invoke-PoshRatHttp*", "*Invoke-PostExfil*", "*Invoke-PowerDump*", "*Invoke-PowerDPAPI*", "*Invoke-PowerShellTCP*", "*Invoke-PowerShellWMI*", "*Invoke-PPLDump*", "*Invoke-PsExec*", "*Invoke-PSInject*", "*Invoke-PsUaCme*", "*Invoke-ReflectivePEInjection*", "*Invoke-ReverseDNSLookup*", "*Invoke-Rubeus*", "*Invoke-RunAs*", "*Invoke-SafetyKatz*", "*Invoke-SauronEye*", "*Invoke-SCShell*", "*Invoke-Seatbelt*", "*Invoke-ServiceAbuse*", "*Invoke-ShadowSpray*", "*Invoke-Sharp*", "*Invoke-Shellcode*", "*Invoke-SMBScanner*", "*Invoke-Snaffler*", "*Invoke-Spoolsample*", "*Invoke-SpraySinglePassword*", "*Invoke-SSHCommand*", "*Invoke-StandIn*", "*Invoke-StickyNotesExtract*", "*Invoke-SystemCommand*", "*Invoke-Tasksbackdoor*", "*Invoke-Tater*", "*Invoke-Thunderfox*", "*Invoke-ThunderStruck*", "*Invoke-TokenManipulation*", "*Invoke-Tokenvator*", "*Invoke-TotalExec*", "*Invoke-UrbanBishop*", "*Invoke-UserHunter*", "*Invoke-VoiceTroll*", "*Invoke-Whisker*", "*Invoke-WinEnum*", "*Invoke-winPEAS*", "*Invoke-WireTap*", "*Invoke-WmiCommand*", "*Invoke-WMIExec*", "*Invoke-WScriptBypassUAC*", "*Invoke-Zerologon*", "*MailRaider*", "*New-ADIDNSNode*", "*New-DNSRecordArray*", "*New-HoneyHash*", "*New-InMemoryModule*", "*New-MachineAccount*", "*New-SOASerialNumberArray*", "*Out-Minidump*", "*Port-Scan*", "*PowerBreach*", "*powercat *", "*PowerUp*", "*PowerView*", "*Remove-ADIDNSNode*", "*Remove-MachineAccount*", "*Remove-Update*", "*Rename-ADIDNSNode*", "*Revoke-ADIDNSPermission*", "*Set-ADIDNSNode*", "*Set-MacAttribute*", "*Set-MachineAccountAttribute*", "*Set-Wallpaper*", "*Show-TargetScreen*", "*Start-CaptureServer*", "*Start-Dnscat2*", "*Start-WebcamRecorder*", "*Veeam-Get-Creds*", "*VolumeShadowCopyTools*")

# ── MSExchange Transport Agent Installation ──
# Mức độ  : Trung bình
# Chi tiết: Detects the Installation of a Exchange Transport Agent
EventCode=4688 Channel="Security" CommandLine="*Install-TransportAgent*"

# ── Non Interactive PowerShell Process Spawned ──
# Mức độ  : Thấp
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects non-interactive PowerShell activity by looking at the "powershell" process with a non-user GUI process such as "explorer.exe" as a parent.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") NOT (ParentProcessName IN ("*:\\Windows\\explorer.exe", "*:\\Windows\\System32\\CompatTelRunner.exe", "*:\\Windows\\SysWOW64\\explorer.exe") OR ParentProcessName=":\\$WINDOWS.~BT\\Sources\\SetupHost.exe") NOT ((ParentCommandLine="* --ms-enable-electron-run-as-node *" ParentProcessName="*\\AppData\\Local\\Programs\\Microsoft VS Code\\Code.exe") OR (ParentProcessName="*:\\Program Files\\WindowsApps\\Microsoft.WindowsTerminal_*" ParentProcessName="*\\WindowsTerminal.exe") OR ParentProcessName="*:\\Program Files\\Windows Defender Advanced Threat Protection\\SenseIR.exe")

# ── Potential PowerShell Obfuscation Via WCHAR/CHAR ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious encoded character syntax often used for defense evasion
EventCode=4688 Channel="Security" CommandLine IN ("*[char]0x*", "*(WCHAR)0x*")

# ── Execution of Powershell Script in Public Folder ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: This rule detects execution of PowerShell scripts located in the "C:\Users\Public" folder
EventCode=4688 Channel="Security" CommandLine IN ("*-f C:\\Users\\Public*", "*-f \"C:\\Users\\Public*", "*-f %Public%*", "*-fi C:\\Users\\Public*", "*-fi \"C:\\Users\\Public*", "*-fi %Public%*", "*-fil C:\\Users\\Public*", "*-fil \"C:\\Users\\Public*", "*-fil %Public%*", "*-file C:\\Users\\Public*", "*-file \"C:\\Users\\Public*", "*-file %Public%*") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe")

# ── RemoteFXvGPUDisablement Abuse Via AtomicTestHarnesses ──
# Mức độ  : Cao
# Chi tiết: Detects calls to the AtomicTestHarnesses "Invoke-ATHRemoteFXvGPUDisablementCommand" which is designed to abuse the "RemoteFXvGPUDisablement.exe" binary to run custom PowerShell code via module load-or
EventCode=4688 Channel="Security" CommandLine IN ("*Invoke-ATHRemoteFXvGPUDisablementCommand*", "*Invoke-ATHRemoteFXvGPUDisableme*")

# ── Tamper Windows Defender Remove-MpPreference ──
# Mức độ  : Cao
# Chi tiết: Detects attempts to remove Windows Defender configurations using the 'MpPreference' cmdlet
EventCode=4688 Channel="Security" CommandLine="*Remove-MpPreference*" CommandLine IN ("*-ControlledFolderAccessProtectedFolders *", "*-AttackSurfaceReductionRules_Ids *", "*-AttackSurfaceReductionRules_Actions *", "*-CheckForSignaturesBeforeRunningScan *")

# ── Potential Powershell ReverseShell Connection ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects usage of the "TcpClient" class. Which can be abused to establish remote connections and reverse-shells. As seen used by the Nishang "Invoke-PowerShellTcpOneLine" reverse shell and other.
EventCode=4688 Channel="Security" OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") OR NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") CommandLine="* Net.Sockets.TCPClient*" CommandLine="*.GetStream(*" CommandLine="*.Write(*"

# ── Run PowerShell Script from ADS ──
# Mức độ  : Cao
# Chi tiết: Detects PowerShell script execution from Alternate Data Stream (ADS)
EventCode=4688 Channel="Security" CommandLine="*Get-Content*" CommandLine="*-Stream*" ParentProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe")

# ── Run PowerShell Script from Redirected Input Stream ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects PowerShell script execution via input stream redirect
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe")
| regex CommandLine="\\s-\\s*<"

# ── PowerShell SAM Copy ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects suspicious PowerShell scripts accessing SAM hives
EventCode=4688 Channel="Security" CommandLine="*\\HarddiskVolumeShadowCopy*" CommandLine="*System32\\config\\sam*" CommandLine IN ("*Copy-Item*", "*cp $_.*", "*cpi $_.*", "*copy $_.*", "*.File]::Copy(*")

# ── Suspicious PowerShell Invocation From Script Engines ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious powershell invocations from interpreters or unusual programs
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\wscript.exe", "*\\cscript.exe") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") NOT CurrentDirectory="*\\Health Service State\\*"

# ── Potentially Suspicious Powershell Script Execution From Temp Folder ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects a potentially suspicious powershell script executions from temporary folder
EventCode=4688 Channel="Security" CommandLine IN ("*\\Windows\\Temp*", "*\\Temporary Internet*", "*\\AppData\\Local\\Temp*", "*\\AppData\\Roaming\\Temp*", "*%TEMP%*", "*%TMP%*", "*%LocalAppData%\\Temp*") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") NOT (CommandLine="*-WindowStyle hidden -Verb runAs*" OR CommandLine="*\\Windows\\system32\\config\\systemprofile\\AppData\\Local\\Temp\\Amazon\\EC2-Windows\\*" OR CommandLine IN ("* >*", "*Out-File*", "*ConvertTo-Json*") OR (CommandLine="*-NoProfile -ExecutionPolicy Bypass -Command*" CommandLine="*AppData\\Local\\Temp\\*" CommandLine="*Install-Chocolatey.ps1*" ParentProcessName IN ("C:\\Windows\\System32\\Msiexec.exe", "C:\\Windows\\SysWOW64\\Msiexec.exe") NewProcessName="*\\powershell.exe"))

# ── Suspicious Service DACL Modification Via Set-Service Cmdlet ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious DACL modifications via the "Set-Service" cmdlet using the "SecurityDescriptorSddl" flag (Only available with PowerShell 7) that can be used to hide services or make them unstopable
EventCode=4688 Channel="Security" NewProcessName="*\\pwsh.exe" OR OriginalFileName="pwsh.dll" CommandLine IN ("*-SecurityDescriptorSddl *", "*-sd *") CommandLine="*Set-Service *" CommandLine="*D;;*" CommandLine IN ("*;;;IU*", "*;;;SU*", "*;;;BA*", "*;;;SY*", "*;;;WD*")

# ── PowerShell Script Change Permission Via Set-Acl ──
# Mức độ  : Cao
# Chi tiết: Detects PowerShell execution to set the ACL of a file or a folder
EventCode=4688 Channel="Security" OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") OR NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") CommandLine="*Set-Acl *" CommandLine="*-AclObject *" CommandLine="*-Path *"

# ── PowerShell Set-Acl On Windows Folder ──
# Mức độ  : Cao
# Chi tiết: Detects PowerShell scripts to set the ACL to a file in the Windows folder
EventCode=4688 Channel="Security" OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") OR NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") CommandLine="*Set-Acl *" CommandLine="*-AclObject *" CommandLine IN ("*-Path \"C:\\Windows*", "*-Path 'C:\\Windows*", "*-Path %windir%*", "*-Path $env:windir*") CommandLine IN ("*FullControl*", "*Allow*")

# ── Change PowerShell Policies to an Insecure Level ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects changing the PowerShell script execution policy to a potentially insecure level using the "-ExecutionPolicy" flag.
EventCode=4688 Channel="Security" OriginalFileName IN ("powershell_ise.exe", "PowerShell.EXE", "pwsh.dll") OR NewProcessName IN ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe") CommandLine IN ("*-executionpolicy *", "* -ep *", "* -exec *") CommandLine IN ("*Bypass*", "*Unrestricted*") NOT (CommandLine IN ("*-NoProfile -ExecutionPolicy Bypass -File \"C:\\Program Files\\PowerShell\\7\\*", "*-NoProfile -ExecutionPolicy Bypass -File \"C:\\Program Files (x86)\\PowerShell\\7\\*") ParentProcessName IN ("C:\\Windows\\SysWOW64\\msiexec.exe", "C:\\Windows\\System32\\msiexec.exe")) NOT (CommandLine IN ("*-ExecutionPolicy ByPass -File \"C:\\Program Files\\Avast Software\\Avast*", "*-ExecutionPolicy ByPass -File \"C:\\Program Files (x86)\\Avast Software\\Avast\\*") ParentProcessName IN ("*C:\\Program Files\\Avast Software\\Avast\\*", "*C:\\Program Files (x86)\\Avast Software\\Avast\\*", "*\\instup.exe*"))

# ── Service StartupType Change Via PowerShell Set-Service ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of the PowerShell "Set-Service" cmdlet to change the startup type of a service to "disabled" or "manual"
EventCode=4688 Channel="Security" NewProcessName="*\\powershell.exe" OR OriginalFileName="PowerShell.EXE" CommandLine="*Set-Service*" CommandLine="*-StartupType*" CommandLine IN ("*Disabled*", "*Manual*")

# ── Deletion of Volume Shadow Copies via WMI with PowerShell ──
# Mức độ  : Cao
# Mục đích: Phá hủy backup/recovery
# Chi tiết: Detects deletion of Windows Volume Shadow Copies with PowerShell code and Get-WMIObject. This technique is used by numerous ransomware families such as Sodinokibi/REvil
EventCode=4688 Channel="Security" CommandLine IN ("*Get-WmiObject*", "*gwmi*", "*Get-CimInstance*", "*gcim*") CommandLine="*Win32_ShadowCopy*" CommandLine IN ("*.Delete()*", "*Remove-WmiObject*", "*rwmi*", "*Remove-CimInstance*", "*rcim*")

# ── Exchange PowerShell Snap-Ins Usage ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects adding and using Exchange PowerShell snap-ins to export mailbox data. As seen used by HAFNIUM and APT27
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine="*Add-PSSnapin*" CommandLine IN ("*Microsoft.Exchange.Powershell.Snapin*", "*Microsoft.Exchange.Management.PowerShell.SnapIn*") NOT (CommandLine="*$exserver=Get-ExchangeServer ([Environment]::MachineName) -ErrorVariable exerr 2> $null*" ParentProcessName="C:\\Windows\\System32\\msiexec.exe")

# ── Stop Windows Service Via PowerShell Stop-Service ──
# Mức độ  : Thấp
# Chi tiết: Detects the stopping of a Windows service via the PowerShell Cmdlet "Stop-Service"
EventCode=4688 Channel="Security" OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") OR NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") CommandLine="*Stop-Service *"

# ── Suspicious PowerShell Download and Execute Pattern ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious PowerShell download patterns that are often used in malicious scripts, stagers or downloaders (make sure that your backend applies the strings case-insensitive)
EventCode=4688 Channel="Security" CommandLine IN ("*IEX ((New-Object Net.WebClient).DownloadString*", "*IEX (New-Object Net.WebClient).DownloadString*", "*IEX((New-Object Net.WebClient).DownloadString*", "*IEX(New-Object Net.WebClient).DownloadString*", "* -command (New-Object System.Net.WebClient).DownloadFile(*", "* -c (New-Object System.Net.WebClient).DownloadFile(*")

# ── Suspicious PowerShell Parameter Substring ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious PowerShell invocation with a parameter substring
EventCode=4688 Channel="Security" CommandLine IN ("* -windowstyle h *", "* -windowstyl h*", "* -windowsty h*", "* -windowst h*", "* -windows h*", "* -windo h*", "* -wind h*", "* -win h*", "* -wi h*", "* -win h *", "* -win hi *", "* -win hid *", "* -win hidd *", "* -win hidde *", "* -NoPr *", "* -NoPro *", "* -NoProf *", "* -NoProfi *", "* -NoProfil *", "* -nonin *", "* -nonint *", "* -noninte *", "* -noninter *", "* -nonintera *", "* -noninterac *", "* -noninteract *", "* -noninteracti *", "* -noninteractiv *", "* -ec *", "* -encodedComman *", "* -encodedComma *", "* -encodedComm *", "* -encodedCom *", "* -encodedCo *", "* -encodedC *", "* -encoded *", "* -encode *", "* -encod *", "* -enco *", "* -en *", "* -executionpolic *", "* -executionpoli *", "* -executionpol *", "* -executionpo *", "* -executionp *", "* -execution bypass*", "* -executio bypass*", "* -executi bypass*", "* -execut bypass*", "* -execu bypass*", "* -exec bypass*", "* -exe bypass*", "* -ex bypass*", "* -ep bypass*", "* /windowstyle h *", "* /windowstyl h*", "* /windowsty h*", "* /windowst h*", "* /windows h*", "* /windo h*", "* /wind h*", "* /win h*", "* /wi h*", "* /win h *", "* /win hi *", "* /win hid *", "* /win hidd *", "* /win hidde *", "* /NoPr *", "* /NoPro *", "* /NoProf *", "* /NoProfi *", "* /NoProfil *", "* /nonin *", "* /nonint *", "* /noninte *", "* /noninter *", "* /nonintera *", "* /noninterac *", "* /noninteract *", "* /noninteracti *", "* /noninteractiv *", "* /ec *", "* /encodedComman *", "* /encodedComma *", "* /encodedComm *", "* /encodedCom *", "* /encodedCo *", "* /encodedC *", "* /encoded *", "* /encode *", "* /encod *", "* /enco *", "* /en *", "* /executionpolic *", "* /executionpoli *", "* /executionpol *", "* /executionpo *", "* /executionp *", "* /execution bypass*", "* /executio bypass*", "* /executi bypass*", "* /execut bypass*", "* /execu bypass*", "* /exec bypass*", "* /exe bypass*", "* /ex bypass*", "* /ep bypass*") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe")

# ── Suspicious PowerShell Parent Process ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects a suspicious or uncommon parent processes of PowerShell
EventCode=4688 Channel="Security" ParentProcessName="*tomcat*" OR ParentProcessName IN ("*\\amigo.exe", "*\\browser.exe", "*\\chrome.exe", "*\\firefox.exe", "*\\httpd.exe", "*\\iexplore.exe", "*\\jbosssvc.exe", "*\\microsoftedge.exe", "*\\microsoftedgecp.exe", "*\\MicrosoftEdgeSH.exe", "*\\mshta.exe", "*\\nginx.exe", "*\\outlook.exe", "*\\php-cgi.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\safari.exe", "*\\services.exe", "*\\sqlagent.exe", "*\\sqlserver.exe", "*\\sqlservr.exe", "*\\vivaldi.exe", "*\\w3wp.exe") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR CommandLine IN ("*/c powershell*", "*/c pwsh*") OR Description="Windows PowerShell" OR Product="PowerShell Core 6" OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll")

# ── PowerShell Script Run in AppData ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects a suspicious command line execution that invokes PowerShell with reference to an AppData folder
EventCode=4688 Channel="Security" CommandLine IN ("*powershell.exe*", "*\\powershell*", "*\\pwsh*", "*pwsh.exe*") CommandLine="*/c *" CommandLine="*\\AppData\\*" CommandLine IN ("*Local\\*", "*Roaming\\*")

# ── Powershell Token Obfuscation - Process Creation ──
# Mức độ  : Cao
# Chi tiết: Detects TOKEN OBFUSCATION technique from Invoke-Obfuscation
EventCode=4688 Channel="Security"
| rex field=CommandLine "(?<CommandLineMatch>\\w+`(?:\\w+|-|.)`[\\w+|\\s])"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch2>\"(?:\\{\\d\\})+\"\\s*-f)"
| eval CommandLineCondition2=if(isnotnull(CommandLineMatch2), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch3>(?i)\\$\\{`?e`?n`?v`?:`?p`?a`?t`?h`?\\})"
| eval CommandLineCondition3=if(isnotnull(CommandLineMatch3), "true", "false")
| search CommandLineCondition="true" OR CommandLineCondition2="true" OR CommandLineCondition3="true" NOT CommandLine="*${env:path}*"

# ── Suspicious Uninstall of Windows Defender Feature via PowerShell ──
# Mức độ  : Cao
# Chi tiết: Detects the use of PowerShell with Uninstall-WindowsFeature or Remove-WindowsFeature cmdlets to disable or remove the Windows Defender GUI feature, a common technique used by adversaries to evade defe
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell_ISE.EXE", "PowerShell.EXE", "pwsh.dll") CommandLine IN ("*Uninstall-WindowsFeature*", "*Remove-WindowsFeature*") CommandLine="*Windows-Defender*"

# ── User Discovery And Export Via Get-ADUser Cmdlet ──
# Mức độ  : Trung bình
# Mục đích: Thu thập thông tin user
# Chi tiết: Detects usage of the Get-ADUser cmdlet to collect user information and output it to a file
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine="*Get-ADUser *" CommandLine="* -Filter \**" CommandLine IN ("* > *", "* | Select *", "*Out-File*", "*Set-Content*", "*Add-Content*")

# ── Net WebClient Casing Anomalies ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects PowerShell command line contents that include a suspicious abnormal casing in the Net.Webclient (e.g. nEt.WEbCliEnT) string as used in obfuscation techniques
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine IN ("*TgBlAFQALgB3AEUAQg*", "*4AZQBUAC4AdwBFAEIA*", "*OAGUAVAAuAHcARQBCA*", "*bgBFAHQALgB3AGUAYg*", "*4ARQB0AC4AdwBlAGIA*", "*uAEUAdAAuAHcAZQBiA*", "*TgBFAHQALgB3AGUAYg*", "*OAEUAdAAuAHcAZQBiA*", "*bgBlAFQALgB3AGUAYg*", "*4AZQBUAC4AdwBlAGIA*", "*uAGUAVAAuAHcAZQBiA*", "*TgBlAFQALgB3AGUAYg*", "*OAGUAVAAuAHcAZQBiA*", "*bgBFAFQALgB3AGUAYg*", "*4ARQBUAC4AdwBlAGIA*", "*uAEUAVAAuAHcAZQBiA*", "*bgBlAHQALgBXAGUAYg*", "*4AZQB0AC4AVwBlAGIA*", "*uAGUAdAAuAFcAZQBiA*", "*bgBFAHQALgBXAGUAYg*", "*4ARQB0AC4AVwBlAGIA*", "*uAEUAdAAuAFcAZQBiA*", "*TgBFAHQALgBXAGUAYg*", "*OAEUAdAAuAFcAZQBiA*", "*bgBlAFQALgBXAGUAYg*", "*4AZQBUAC4AVwBlAGIA*", "*uAGUAVAAuAFcAZQBiA*", "*TgBlAFQALgBXAGUAYg*", "*OAGUAVAAuAFcAZQBiA*", "*bgBFAFQALgBXAGUAYg*", "*4ARQBUAC4AVwBlAGIA*", "*uAEUAVAAuAFcAZQBiA*", "*bgBlAHQALgB3AEUAYg*", "*4AZQB0AC4AdwBFAGIA*", "*uAGUAdAAuAHcARQBiA*", "*TgBlAHQALgB3AEUAYg*", "*OAGUAdAAuAHcARQBiA*", "*bgBFAHQALgB3AEUAYg*", "*4ARQB0AC4AdwBFAGIA*", "*uAEUAdAAuAHcARQBiA*", "*TgBFAHQALgB3AEUAYg*", "*OAEUAdAAuAHcARQBiA*", "*bgBlAFQALgB3AEUAYg*", "*4AZQBUAC4AdwBFAGIA*", "*uAGUAVAAuAHcARQBiA*", "*TgBlAFQALgB3AEUAYg*", "*OAGUAVAAuAHcARQBiA*", "*bgBFAFQALgB3AEUAYg*", "*4ARQBUAC4AdwBFAGIA*", "*uAEUAVAAuAHcARQBiA*", "*TgBFAFQALgB3AEUAYg*", "*OAEUAVAAuAHcARQBiA*", "*bgBlAHQALgBXAEUAYg*", "*4AZQB0AC4AVwBFAGIA*", "*uAGUAdAAuAFcARQBiA*", "*TgBlAHQALgBXAEUAYg*", "*OAGUAdAAuAFcARQBiA*", "*bgBFAHQALgBXAEUAYg*", "*4ARQB0AC4AVwBFAGIA*", "*uAEUAdAAuAFcARQBiA*", "*TgBFAHQALgBXAEUAYg*", "*OAEUAdAAuAFcARQBiA*", "*bgBlAFQALgBXAEUAYg*", "*4AZQBUAC4AVwBFAGIA*", "*uAGUAVAAuAFcARQBiA*", "*TgBlAFQALgBXAEUAYg*", "*OAGUAVAAuAFcARQBiA*", "*bgBFAFQALgBXAEUAYg*", "*4ARQBUAC4AVwBFAGIA*", "*uAEUAVAAuAFcARQBiA*", "*TgBFAFQALgBXAEUAYg*", "*OAEUAVAAuAFcARQBiA*", "*bgBlAHQALgB3AGUAQg*", "*4AZQB0AC4AdwBlAEIA*", "*uAGUAdAAuAHcAZQBCA*", "*TgBlAHQALgB3AGUAQg*", "*OAGUAdAAuAHcAZQBCA*", "*bgBFAHQALgB3AGUAQg*", "*4ARQB0AC4AdwBlAEIA*", "*uAEUAdAAuAHcAZQBCA*", "*TgBFAHQALgB3AGUAQg*", "*OAEUAdAAuAHcAZQBCA*", "*bgBlAFQALgB3AGUAQg*", "*4AZQBUAC4AdwBlAEIA*", "*uAGUAVAAuAHcAZQBCA*", "*TgBlAFQALgB3AGUAQg*", "*OAGUAVAAuAHcAZQBCA*", "*bgBFAFQALgB3AGUAQg*", "*4ARQBUAC4AdwBlAEIA*", "*uAEUAVAAuAHcAZQBCA*", "*TgBFAFQALgB3AGUAQg*", "*OAEUAVAAuAHcAZQBCA*", "*bgBlAHQALgBXAGUAQg*", "*4AZQB0AC4AVwBlAEIA*", "*uAGUAdAAuAFcAZQBCA*", "*TgBlAHQALgBXAGUAQg*", "*OAGUAdAAuAFcAZQBCA*", "*bgBFAHQALgBXAGUAQg*", "*4ARQB0AC4AVwBlAEIA*", "*uAEUAdAAuAFcAZQBCA*", "*TgBFAHQALgBXAGUAQg*", "*OAEUAdAAuAFcAZQBCA*", "*bgBlAFQALgBXAGUAQg*", "*4AZQBUAC4AVwBlAEIA*", "*uAGUAVAAuAFcAZQBCA*", "*TgBlAFQALgBXAGUAQg*", "*OAGUAVAAuAFcAZQBCA*", "*bgBFAFQALgBXAGUAQg*", "*4ARQBUAC4AVwBlAEIA*", "*uAEUAVAAuAFcAZQBCA*", "*TgBFAFQALgBXAGUAQg*", "*OAEUAVAAuAFcAZQBCA*", "*bgBlAHQALgB3AEUAQg*", "*4AZQB0AC4AdwBFAEIA*", "*uAGUAdAAuAHcARQBCA*", "*TgBlAHQALgB3AEUAQg*", "*OAGUAdAAuAHcARQBCA*", "*bgBFAHQALgB3AEUAQg*", "*4ARQB0AC4AdwBFAEIA*", "*uAEUAdAAuAHcARQBCA*", "*TgBFAHQALgB3AEUAQg*", "*OAEUAdAAuAHcARQBCA*", "*bgBlAFQALgB3AEUAQg*", "*uAGUAVAAuAHcARQBCA*", "*bgBFAFQALgB3AEUAQg*", "*4ARQBUAC4AdwBFAEIA*", "*uAEUAVAAuAHcARQBCA*", "*TgBFAFQALgB3AEUAQg*", "*OAEUAVAAuAHcARQBCA*", "*TgBlAHQALgBXAEUAQg*", "*4AZQB0AC4AVwBFAEIA*", "*OAGUAdAAuAFcARQBCA*", "*bgBFAHQALgBXAEUAQg*", "*4ARQB0AC4AVwBFAEIA*", "*uAEUAdAAuAFcARQBCA*", "*TgBFAHQALgBXAEUAQg*", "*OAEUAdAAuAFcARQBCA*", "*bgBlAFQALgBXAEUAQg*", "*4AZQBUAC4AVwBFAEIA*", "*uAGUAVAAuAFcARQBCA*", "*TgBlAFQALgBXAEUAQg*", "*OAGUAVAAuAFcARQBCA*", "*bgBFAFQALgBXAEUAQg*", "*4ARQBUAC4AVwBFAEIA*", "*uAEUAVAAuAFcARQBCA*")

# ── Suspicious X509Enrollment - Process Creation ──
# Mức độ  : Trung bình
# Chi tiết: Detect use of X509Enrollment
EventCode=4688 Channel="Security" CommandLine IN ("*X509Enrollment.CBinaryConverter*", "*884e2002-217d-11da-b2a4-000e7bbb2b09*")

# ── Suspicious XOR Encoded PowerShell Command ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects presence of a potentially xor encoded powershell command
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") OR Description="Windows PowerShell" OR Product="PowerShell Core 6" CommandLine="*bxor*" CommandLine IN ("*ForEach*", "*for(*", "*for *", "*-join *", "*-join'*", "*-join\"*", "*-join`*", "*::Join*", "*[char]*")

# ── Folder Compress To Potentially Suspicious Output Via Compress-Archive Cmdlet ──
# Mức độ  : Trung bình
# Chi tiết: Detects PowerShell scripts that make use of the "Compress-Archive" Cmdlet in order to compress folders and files where the output is stored in a potentially suspicious location that is used often by m
EventCode=4688 Channel="Security" CommandLine IN ("*Compress-Archive -Path*-DestinationPath $env:TEMP*", "*Compress-Archive -Path*-DestinationPath*\\AppData\\Local\\Temp\\*", "*Compress-Archive -Path*-DestinationPath*:\\Windows\\Temp\\*")

# ── Arbitrary File Download Via PresentationHost.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of "PresentationHost" which is a utility that runs ".xbap" (Browser Applications) files to download arbitrary files
EventCode=4688 Channel="Security" NewProcessName="*\\presentationhost.exe" OR OriginalFileName="PresentationHost.exe" CommandLine IN ("*http://*", "*https://*", "*ftp://*")

# ── XBAP Execution From Uncommon Locations Via PresentationHost.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of ".xbap" (Browser Applications) files via PresentationHost.EXE from an uncommon location. These files can be abused to run malicious ".xbap" files any bypass AWL
EventCode=4688 Channel="Security" NewProcessName="*\\presentationhost.exe" OR OriginalFileName="PresentationHost.exe" CommandLine="*.xbap*" NOT (CommandLine IN ("* C:\\Windows\\*", "* C:\\Program Files*"))

# ── Visual Studio NodejsTools PressAnyKey Arbitrary Binary Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects child processes of Microsoft.NodejsTools.PressAnyKey.exe that can be used to execute any other binary
EventCode=4688 Channel="Security" ParentProcessName="*\\Microsoft.NodejsTools.PressAnyKey.exe"

# ── Sensitive File Dump Via Print.EXE ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the abuse of the Print.exe utility for credential harvesting which involves using Print.Exe to copy sensitive files such as ntds.dit, SAM, SECURITY, or SYSTEM from the Windows directory in ord
EventCode=4688 Channel="Security" NewProcessName="*\\print.exe" OR OriginalFileName="Print.EXE" CommandLine="*-D*" OR CommandLine="*/D*" OR CommandLine="*–D*" OR CommandLine="*—D*" OR CommandLine="*―D*" CommandLine IN ("*\\config\\SAM*", "*\\config\\SECURITY*", "*\\config\\SYSTEM*", "*\\windows\\ntds\\ntds.dit*")

# ── Abusing Print Executable ──
# Mức độ  : Trung bình
# Chi tiết: Attackers can use print.exe for remote file copy
EventCode=4688 Channel="Security" CommandLine="print*" CommandLine="*/D*" CommandLine="*.exe*" NewProcessName="*\\print.exe" NOT CommandLine="*print.exe*"

# ── File Download Using ProtocolHandler.exe ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of "ProtocolHandler" to download files. Downloaded files will be located in the cache folder (for example - %LOCALAPPDATA%\Microsoft\Windows\INetCache\IE)
EventCode=4688 Channel="Security" NewProcessName="*\\protocolhandler.exe" OR OriginalFileName="ProtocolHandler.exe" CommandLine IN ("*ftp://*", "*http://*", "*https://*")

# ── Potential Provlaunch.EXE Binary Proxy Execution Abuse ──
# Mức độ  : Trung bình
# Chi tiết: Detects child processes of "provlaunch.exe" which might indicate potential abuse to proxy execution.
EventCode=4688 Channel="Security" ParentProcessName="*\\provlaunch.exe" NOT (NewProcessName IN ("*\\calc.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\notepad.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") OR NewProcessName IN ("*:\\PerfLogs\\*", "*:\\Temp\\*", "*:\\Users\\Public\\*", "*\\AppData\\Temp\\*", "*\\Windows\\System32\\Tasks\\*", "*\\Windows\\Tasks\\*", "*\\Windows\\Temp\\*"))

# ── Suspicious Provlaunch.EXE Child Process ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious child processes of "provlaunch.exe" which might indicate potential abuse to proxy execution.
EventCode=4688 Channel="Security" ParentProcessName="*\\provlaunch.exe" NewProcessName IN ("*\\calc.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\notepad.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") OR NewProcessName IN ("*:\\PerfLogs\\*", "*:\\Temp\\*", "*:\\Users\\Public\\*", "*\\AppData\\Temp\\*", "*\\Windows\\System32\\Tasks\\*", "*\\Windows\\Tasks\\*", "*\\Windows\\Temp\\*")

# ── Screen Capture Activity Via Psr.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of Windows Problem Steps Recorder (psr.exe), a utility used to record the user screen and clicks.
EventCode=4688 Channel="Security" CommandLine IN ("*/start*", "*-start*") NewProcessName="*\\Psr.exe"

# ── PUA - 3Proxy Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of 3proxy, a tiny free proxy server
EventCode=4688 Channel="Security" NewProcessName="*\\3proxy.exe" OR Description="3proxy - tiny proxy server" OR CommandLine="*.exe -i127.0.0.1 -p*"

# ── PUA - Suspicious ActiveDirectory Enumeration Via AdFind.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects active directory enumeration activity using known AdFind CLI flags
EventCode=4688 Channel="Security" CommandLine IN ("*lockoutduration*", "*lockoutthreshold*", "*lockoutobservationwindow*", "*maxpwdage*", "*minpwdage*", "*minpwdlength*", "*pwdhistorylength*", "*pwdproperties*") OR CommandLine="*-sc admincountdmp*" OR CommandLine="*-sc exchaddresses*"

# ── PUA - AdFind.EXE Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of Adfind.exe utility, which can be used for reconnaissance in an Active Directory environment
EventCode=4688 Channel="Security" NewProcessName="*\\AdFind.exe" OR OriginalFileName="AdFind.exe" OR Hashes IN ("*IMPHASH=d144de8117df2beceaba2201ad304764*", "*IMPHASH=12ce1c0f3f5837ecc18a3782408fa975*", "*IMPHASH=bca5675746d13a1f246e2da3c2217492*", "*IMPHASH=4fbf3f084fbbb2470b80b2013134df35*", "*IMPHASH=49b639b4acbecc49d72a01f357aa4930*", "*IMPHASH=53e117a96057eaf19c41380d0e87f1c2*", "*IMPHASH=680dad9e300346e05a85023965867201*", "*IMPHASH=21aa085d54992511b9f115355e468782*")

# ── PUA - AdFind Suspicious Execution ──
# Mức độ  : Cao
# Chi tiết: Detects AdFind execution with common flags seen used during attacks
EventCode=4688 Channel="Security" CommandLine IN ("*domainlist*", "*trustdmp*", "*dcmodes*", "*adinfo*", "*-sc dclist*", "*computer_pwdnotreqd*", "*objectcategory=*", "*-subnets -f*", "*name=\"Domain Admins\"*", "*-sc u:*", "*domainncs*", "*dompol*", "* oudmp *", "*subnetdmp*", "*gpodmp*", "*fspdmp*", "*users_noexpire*", "*computers_active*", "*computers_pwdnotreqd*")

# ── PUA - Advanced IP Scanner Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of Advanced IP Scanner. Seems to be a popular tool for ransomware groups.
EventCode=4688 Channel="Security" NewProcessName="*\\advanced_ip_scanner*" OR OriginalFileName="*advanced_ip_scanner*" OR Description="*Advanced IP Scanner*" OR (CommandLine="*/portable*" CommandLine="*/lng*")

# ── PUA - Advanced Port Scanner Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of Advanced Port Scanner.
EventCode=4688 Channel="Security" NewProcessName="*\\advanced_port_scanner*" OR OriginalFileName="*advanced_port_scanner*" OR Description="*Advanced Port Scanner*" OR (CommandLine="*/portable*" CommandLine="*/lng*")

# ── PUA - AdvancedRun Suspicious Execution ──
# Mức độ  : Cao
# Mục đích: Chiếm quyền token
# Chi tiết: Detects the execution of AdvancedRun utility in the context of the TrustedInstaller, SYSTEM, Local Service or Network Service accounts
EventCode=4688 Channel="Security" CommandLine IN ("*/EXEFilename*", "*/CommandLine*") CommandLine IN ("* /RunAs 8 *", "* /RunAs 4 *", "* /RunAs 10 *", "* /RunAs 11 *") OR CommandLine IN ("*/RunAs 8", "*/RunAs 4", "*/RunAs 10", "*/RunAs 11")

# ── PUA - Chisel Tunneling Tool Execution ──
# Mức độ  : Cao
# Chi tiết: Detects usage of the Chisel tunneling tool via the commandline arguments
EventCode=4688 Channel="Security" NewProcessName="*\\chisel.exe" OR (CommandLine IN ("*exe client *", "*exe server *") CommandLine IN ("*-socks5*", "*-reverse*", "* r:*", "*:127.0.0.1:*", "*-tls-skip-verify *", "*:socks*"))

# ── PUA - CleanWipe Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of CleanWipe a tool usually used to delete Symantec antivirus.
EventCode=4688 Channel="Security" NewProcessName="*\\SepRemovalToolNative_x64.exe" OR (CommandLine="*--uninstall*" NewProcessName="*\\CATClean.exe") OR (CommandLine="*-r*" NewProcessName="*\\NetInstaller.exe") OR (CommandLine="*/uninstall*" CommandLine="*/enterprise*" NewProcessName="*\\WFPUnins.exe")

# ── PUA - Crassus Execution ──
# Mức độ  : Cao
# Chi tiết: Detects Crassus, a Windows privilege escalation discovery tool, based on PE metadata characteristics.
EventCode=4688 Channel="Security" NewProcessName="*\\Crassus.exe" OR OriginalFileName="Crassus.exe" OR Description="*Crassus*"

# ── PUA - CsExec Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of the lesser known remote execution tool named CsExec a PsExec alternative
EventCode=4688 Channel="Security" NewProcessName="*\\csexec.exe" OR Description="csexec"

# ── PUA - DefenderCheck Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of DefenderCheck, a tool to evaluate the signatures used in Microsoft Defender. It can be used to figure out the strings / byte chains used in Microsoft Defender to detect a tool and t
EventCode=4688 Channel="Security" NewProcessName="*\\DefenderCheck.exe" OR Description="DefenderCheck"

# ── PUA - DIT Snapshot Viewer ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the use of Ditsnap tool, an inspection tool for Active Directory database, ntds.dit.
EventCode=4688 Channel="Security" NewProcessName="*\\ditsnap.exe" OR CommandLine="*ditsnap.exe*"

# ── PUA - Fast Reverse Proxy (FRP) Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of Fast Reverse Proxy. frp is a fast reverse proxy to help you expose a local server behind a NAT or firewall to the Internet.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\frpc.exe", "*\\frps.exe") OR CommandLine="*\\frpc.ini*" OR Hashes IN ("*MD5=7D9C233B8C9E3F0EA290D2B84593C842*", "*SHA1=06DDC9280E1F1810677935A2477012960905942F*", "*SHA256=57B0936B8D336D8E981C169466A15A5FD21A7D5A2C7DAF62D5E142EE860E387C*")

# ── PUA- IOX Tunneling Tool Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of IOX - a tool for port forwarding and intranet proxy purposes
EventCode=4688 Channel="Security" NewProcessName="*\\iox.exe" OR CommandLine IN ("*.exe fwd -l *", "*.exe fwd -r *", "*.exe proxy -l *", "*.exe proxy -r *") OR Hashes IN ("*MD5=9DB2D314DD3F704A02051EF5EA210993*", "*SHA1=039130337E28A6623ECF9A0A3DA7D92C5964D8DD*", "*SHA256=C6CF82919B809967D9D90EA73772A8AA1C1EB3BC59252D977500F64F1A0D6731*")

# ── PUA - Kernel Driver Utility (KDU) Execution ──
# Mức độ  : Cao
# Chi tiết: Detects execution of the Kernel Driver Utility (KDU) tool. KDU can be used to bypass driver signature enforcement and load unsigned or malicious drivers into the Windows kernel. Potentially allowing f
EventCode=4688 Channel="Security" NewProcessName IN ("*\\kdu.exe", "*\\hamakaze.exe") OR OriginalFileName="hamakaze.exe" CommandLine IN ("*-map *", "*-prv *", "*-dse *", "*-ps *")

# ── PUA - Memory Dump Mount Via MemProcFS ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects execution of MemProcFS a memory forensics tool with the '-device' parameter. MemProcFS mounts physical memory as a virtual file system, allowing direct access to process memory and system stru
EventCode=4688 Channel="Security" NewProcessName="*\\MemProcFS.exe" OR OriginalFileName="MemProcFS.exe" OR Description="MemProcFS" CommandLine="*-device*"

# ── PUA - Netcat Suspicious Execution ──
# Mức độ  : Cao
# Chi tiết: Detects execution of Netcat. Adversaries may use a non-application layer protocol for communication between host and C2 server or among infected hosts within a network
EventCode=4688 Channel="Security" NewProcessName IN ("*\\nc.exe", "*\\ncat.exe", "*\\netcat.exe") OR CommandLine IN ("* -lvp *", "* -lvnp*", "* -l -v -p *", "* -lv -p *", "* -l --proxy-type http *", "* -vnl --exec *", "* -vnl -e *", "* --lua-exec *", "* --sh-exec *")

# ── PUA - SoftPerfect Netscan Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of SoftPerfect's "netscan.exe". An application for scanning networks. It is actively used in-the-wild by threat actors to inspect and understand the network architecture of a victim.
EventCode=4688 Channel="Security" NewProcessName="*\\netscan.exe" OR Product="Network Scanner" OR Description="Application for scanning networks"

# ── PUA - Ngrok Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of Ngrok, a utility used for port forwarding and tunneling, often used by threat actors to make local protected services publicly available. Involved domains are bin.equinox.io for dow
EventCode=4688 Channel="Security" CommandLine IN ("* tcp 139*", "* tcp 445*", "* tcp 3389*", "* tcp 5985*", "* tcp 5986*") OR (CommandLine="* start *" CommandLine="*--all*" CommandLine="*--config*" CommandLine="*.yml*") OR (CommandLine IN ("* tcp *", "* http *", "* authtoken *") NewProcessName="*ngrok.exe") OR CommandLine IN ("*.exe authtoken *", "*.exe start --all*")

# ── PUA - Nimgrab Execution ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects the usage of nimgrab, a tool bundled with the Nim programming framework and used for downloading files.
EventCode=4688 Channel="Security" NewProcessName="*\\nimgrab.exe" OR Hashes IN ("*MD5=2DD44C3C29D667F5C0EF5F9D7C7FFB8B*", "*SHA256=F266609E91985F0FE3E31C5E8FAEEEC4FFA5E0322D8B6F15FE69F4C5165B9559*", "*IMPHASH=C07FDDD21D123EA9B3A08EEF44AAAC45*")

# ── PUA - NimScan Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of NimScan, a portscanner utility. In early 2025, adversaries were observed using this utility to scan for open ports on remote hosts in a compromised environment. This rule identifies t
EventCode=4688 Channel="Security" NewProcessName="*\\NimScan.exe" OR Hashes IN ("*IMPHASH=41BB1C7571B3A724EB83A1D2B96DBB8C*", "*IMPHASH=B1B6ADACB172795480179EFD18A29549*", "*IMPHASH=0D1F896DC7642AD8384F9042F30279C2*")

# ── PUA - NirCmd Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of NirCmd tool for command execution, which could be the result of legitimate administrative activity
EventCode=4688 Channel="Security" NewProcessName="*\\NirCmd.exe" OR OriginalFileName="NirCmd.exe" OR CommandLine IN ("* execmd *", "*.exe script *", "*.exe shexec *", "* runinteractive *") OR (CommandLine IN ("* exec *", "* exec2 *") CommandLine IN ("* show *", "* hide *"))

# ── PUA - NirCmd Execution As LOCAL SYSTEM ──
# Mức độ  : Cao
# Chi tiết: Detects the use of NirCmd tool for command execution as SYSTEM user
EventCode=4688 Channel="Security" CommandLine="* runassystem *"

# ── PUA - Nmap/Zenmap Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of namp/zenmap. Adversaries may attempt to get a listing of services running on remote hosts, including those that may be vulnerable to remote software exploitation
EventCode=4688 Channel="Security" NewProcessName IN ("*\\nmap.exe", "*\\zennmap.exe") OR OriginalFileName IN ("nmap.exe", "zennmap.exe")

# ── PUA - NPS Tunneling Tool Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of NPS, a port forwarding and intranet penetration proxy server
EventCode=4688 Channel="Security" NewProcessName="*\\npc.exe" OR (CommandLine="* -server=*" CommandLine="* -vkey=*" CommandLine="* -password=*") OR CommandLine="* -config=npc*" OR Hashes IN ("*MD5=AE8ACF66BFE3A44148964048B826D005*", "*SHA1=CEA49E9B9B67F3A13AD0BE1C2655293EA3C18181*", "*SHA256=5A456283392FFCEEEACA3D3426C306EB470304637520D72FED1CC1FEBBBD6856*")

# ── PUA - NSudo Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of NSudo tool for command execution
EventCode=4688 Channel="Security" NewProcessName IN ("*\\NSudo.exe", "*\\NSudoLC.exe", "*\\NSudoLG.exe") OR OriginalFileName IN ("NSudo.exe", "NSudoLC.exe", "NSudoLG.exe") CommandLine IN ("*-U:S *", "*-U:T *", "*-U:E *", "*-P:E *", "*-M:S *", "*-M:H *", "*-U=S *", "*-U=T *", "*-U=E *", "*-P=E *", "*-M=S *", "*-M=H *", "*-ShowWindowMode:Hide*")

# ── PUA - PingCastle Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of PingCastle, a tool designed to quickly assess the Active Directory security level.
EventCode=4688 Channel="Security" Hashes IN ("*MD5=f741f25ac909ee434e50812d436c73ff*", "*MD5=d40acbfc29ee24388262e3d8be16f622*", "*MD5=01bb2c16fadb992fa66228cd02d45c60*", "*MD5=9e1b18e62e42b5444fc55b51e640355b*", "*MD5=b7f8fe33ac471b074ca9e630ba0c7e79*", "*MD5=324579d717c9b9b8e71d0269d13f811f*", "*MD5=63257a1ddaf83cfa43fe24a3bc06c207*", "*MD5=049e85963826b059c9bac273bb9c82ab*", "*MD5=ecb98b7b4d4427eb8221381154ff4cb2*", "*MD5=faf87749ac790ec3a10dd069d10f9d63*", "*MD5=f296dba5d21ad18e6990b1992aea8f83*", "*MD5=93ba94355e794b6c6f98204cf39f7a11*", "*MD5=a258ef593ac63155523a461ecc73bdba*", "*MD5=97000eb5d1653f1140ee3f47186463c4*", "*MD5=95eb317fbbe14a82bd9fdf31c48b8d93*", "*MD5=32fe9f0d2630ac40ea29023920f20f49*", "*MD5=a05930dde939cfd02677fc18bb2b7df5*", "*MD5=124283924e86933ff9054a549d3a268b*", "*MD5=ceda6909b8573fdeb0351c6920225686*", "*MD5=60ce120040f2cd311c810ae6f6bbc182*", "*MD5=2f10cdc5b09100a260703a28eadd0ceb*", "*MD5=011d967028e797a4c16d547f7ba1463f*", "*MD5=2da9152c0970500c697c1c9b4a9e0360*", "*MD5=b5ba72034b8f44d431f55275bace9f8b*", "*MD5=d6ed9101df0f24e27ff92ddab42dacca*", "*MD5=3ed3cdb6d12aa1ac562ad185cdbf2d1d*", "*MD5=5e083cd0143ae95a6cb79b68c07ca573*", "*MD5=28caff93748cb84be70486e79f04c2df*", "*MD5=9d4f12c30f9b500f896efd1800e4dd11*", "*MD5=4586f7dd14271ad65a5fb696b393f4c0*", "*MD5=86ba9dddbdf49215145b5bcd081d4011*", "*MD5=9dce0a481343874ef9a36c9a825ef991*", "*MD5=85890f62e231ad964b1fda7a674747ec*", "*MD5=599be548da6441d7fe3e9a1bb8cb0833*", "*MD5=9b0c7fd5763f66e9b8c7b457fce53f96*", "*MD5=32d45718164205aec3e98e0223717d1d*", "*MD5=6ff5f373ee7f794cd17db50704d00ddb*", "*MD5=88efbdf41f0650f8f58a3053b0ca0459*", "*MD5=ef915f61f861d1fb7cbde9afd2e7bd93*", "*MD5=781fa16511a595757154b4304d2dd350*", "*MD5=5018ec39be0e296f4fc8c8575bfa8486*", "*MD5=f4a84d6f1caf0875b50135423d04139f*", "*SHA1=9c1431801fa6342ed68f047842b9a11778fc669b*", "*SHA1=c36c862f40dad78cb065197aad15fef690c262f2*", "*SHA1=bc8e23faea8b3c537f268b3e81d05b937012272d*", "*SHA1=12e0357658614ff60d480d1a6709be6