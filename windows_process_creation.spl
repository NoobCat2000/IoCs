# ── 7Zip Compressing Dump Files ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of 7z in order to compress a file with a ".dmp"/".dump" extension, which could be a step in a process of dump file exfiltration.
EventCode=4688 Channel="Security" Description="*7-Zip*" OR NewProcessName IN ("*\\7z.exe", "*\\7zr.exe", "*\\7za.exe") OR OriginalFileName IN ("7z.exe", "7za.exe", "7zr.exe") CommandLine IN ("*.dmp*", "*.dump*", "*.hdmp*")

# ── Compress Data and Lock With Password for Exfiltration With 7-ZIP ──
# Mức độ  : Trung bình
# Chi tiết: An adversary may compress or encrypt data that is collected prior to exfiltration using 3rd party utilities
EventCode=4688 Channel="Security" Description="*7-Zip*" OR NewProcessName IN ("*\\7z.exe", "*\\7zr.exe", "*\\7za.exe") OR OriginalFileName IN ("7z.exe", "7za.exe", "7zr.exe") CommandLine="* -p*" CommandLine IN ("* a *", "* u *")

# ── Potential DLL Injection Via AccCheckConsole ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution "AccCheckConsole" a command-line tool for verifying the accessibility implementation of an application's UI. One of the tests that this checker can run are called "verification r
EventCode=4688 Channel="Security" NewProcessName="*\\AccCheckConsole.exe" OR OriginalFileName="AccCheckConsole.exe" CommandLine IN ("* -hwnd*", "* -process *", "* -window *")

# ── Suspicious AddinUtil.EXE CommandLine Execution ──
# Mức độ  : Cao
# Chi tiết: Detects execution of the Add-In deployment cache updating utility (AddInutil.exe) with suspicious Addinroot or Pipelineroot paths. An adversary may execute AddinUtil.exe with uncommon Addinroot/Pipeli
EventCode=4688 Channel="Security" NewProcessName="*\\addinutil.exe" OR OriginalFileName="AddInUtil.exe" (CommandLine IN ("*-AddInRoot:*", "*-PipelineRoot:*") CommandLine IN ("*\\AppData\\Local\\Temp\\*", "*\\Desktop\\*", "*\\Downloads\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*")) OR (CommandLine IN ("*-AddInRoot:.*", "*-AddInRoot:\".\"*", "*-PipelineRoot:.*", "*-PipelineRoot:\".\"*") CurrentDirectory IN ("*\\AppData\\Local\\Temp\\*", "*\\Desktop\\*", "*\\Downloads\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*"))

# ── Uncommon Child Process Of AddinUtil.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects uncommon child processes of the Add-In deployment cache updating utility (AddInutil.exe) which could be a sign of potential abuse of the binary to proxy execution via a custom Addins.Store pay
EventCode=4688 Channel="Security" ParentProcessName="*\\addinutil.exe" NOT (NewProcessName IN ("*:\\Windows\\System32\\conhost.exe", "*:\\Windows\\System32\\werfault.exe", "*:\\Windows\\SysWOW64\\werfault.exe"))

# ── Uncommon AddinUtil.EXE CommandLine Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of the Add-In deployment cache updating utility (AddInutil.exe) with uncommon Addinroot or Pipelineroot paths. An adversary may execute AddinUtil.exe with uncommon Addinroot/Pipeline
EventCode=4688 Channel="Security" NewProcessName="*\\addinutil.exe" OR OriginalFileName="AddInUtil.exe" CommandLine IN ("*-AddInRoot:*", "*-PipelineRoot:*") NOT (CommandLine IN ("*-AddInRoot:\"C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*", "*-AddInRoot:C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*", "*-PipelineRoot:\"C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*", "*-PipelineRoot:C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*"))

# ── AddinUtil.EXE Execution From Uncommon Directory ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of the Add-In deployment cache updating utility (AddInutil.exe) from a non-standard directory.
EventCode=4688 Channel="Security" NewProcessName="*\\addinutil.exe" OR OriginalFileName="AddInUtil.exe" NOT (NewProcessName IN ("*:\\Windows\\Microsoft.NET\\Framework\\*", "*:\\Windows\\Microsoft.NET\\Framework64\\*", "*:\\Windows\\Microsoft.NET\\FrameworkArm\\*", "*:\\Windows\\Microsoft.NET\\FrameworkArm64\\*", "*:\\Windows\\WinSxS\\*"))

# ── Potential Adplus.EXE Abuse ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects execution of "AdPlus.exe", a binary that is part of the Windows SDK that can be used as a LOLBIN in order to dump process memory and execute arbitrary commands.
EventCode=4688 Channel="Security" NewProcessName="*\\adplus.exe" OR OriginalFileName="Adplus.exe" CommandLine IN ("* -hang *", "* -pn *", "* -pmn *", "* -p *", "* -po *", "* -c *", "* -sc *")

# ── AgentExecutor PowerShell Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of the AgentExecutor.exe binary. Which can be abused as a LOLBIN to execute powershell scripts with the ExecutionPolicy "Bypass" or any binary named "powershell.exe" located in the p
EventCode=4688 Channel="Security" NewProcessName="\\AgentExecutor.exe" OR OriginalFileName="AgentExecutor.exe" CommandLine IN ("* -powershell*", "* -remediationScript*") NOT ParentProcessName="*\\Microsoft.Management.Services.IntuneWindowsAgent.exe"

# ── Suspicious AgentExecutor PowerShell Execution ──
# Mức độ  : Cao
# Chi tiết: Detects execution of the AgentExecutor.exe binary. Which can be abused as a LOLBIN to execute powershell scripts with the ExecutionPolicy "Bypass" or any binary named "powershell.exe" located in the p
EventCode=4688 Channel="Security" NewProcessName="*\\AgentExecutor.exe" OR OriginalFileName="AgentExecutor.exe" CommandLine IN ("* -powershell*", "* -remediationScript*") NOT (CommandLine IN ("*C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\*", "*C:\\Windows\\SysWOW64\\WindowsPowerShell\\v1.0\\*") OR ParentProcessName="*\\Microsoft.Management.Services.IntuneWindowsAgent.exe")

# ── Windows AMSI Related Registry Tampering Via CommandLine ──
# Mức độ  : Cao
# Chi tiết: Detects tampering of AMSI (Anti-Malware Scan Interface) related registry values via command line tools such as reg.exe or PowerShell. AMSI provides a generic interface for applications and services to
EventCode=4688 Channel="Security" CommandLine="*\\Software\\Microsoft\\Windows Script\\Settings*" CommandLine="*AmsiEnable*" (NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine IN ("*Set-ItemProperty*", "*New-ItemProperty*", "*sp *")) OR (NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="*add*")

# ── Uncommon Child Process Of Appvlp.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects uncommon child processes of Appvlp.EXE Appvlp or the Application Virtualization Utility is included with Microsoft Office. Attackers are able to abuse "AppVLP" to execute shell commands. Norma
EventCode=4688 Channel="Security" ParentProcessName="*\\appvlp.exe" NOT (NewProcessName IN ("*:\\Windows\\SysWOW64\\rundll32.exe", "*:\\Windows\\System32\\rundll32.exe")) NOT ((NewProcessName="*:\\Program Files\\Microsoft Office*" NewProcessName="*\\msoasb.exe") OR (NewProcessName="*:\\Program Files\\Microsoft Office*" NewProcessName="*\\SkypeSrv\\*" NewProcessName="*\\SKYPESERVER.EXE") OR (NewProcessName="*:\\Program Files\\Microsoft Office*" NewProcessName="*\\MSOUC.EXE"))

# ── Suspicious ArcSOC.exe Child Process ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects script interpreters, command-line tools, and similar suspicious child processes of ArcSOC.exe. ArcSOC.exe is the process name which hosts ArcGIS Server REST services. If an attacker compromise
EventCode=4688 Channel="Security" ParentProcessName="*\\ArcSOC.exe" NewProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wmic.exe", "*\\wscript.exe") NOT (CommandLine="cmd.exe /c \"ver\"" NewProcessName="*\\cmd.exe")

# ── AspNetCompiler Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "aspnet_compiler.exe" which can be abused to compile and execute C# code.
EventCode=4688 Channel="Security" NewProcessName IN ("*:\\Windows\\Microsoft.NET\\Framework\\*", "*:\\Windows\\Microsoft.NET\\Framework64\\*", "*:\\Windows\\Microsoft.NET\\FrameworkArm\\*", "*:\\Windows\\Microsoft.NET\\FrameworkArm64\\*") NewProcessName="*\\aspnet_compiler.exe"

# ── Suspicious Child Process of AspNetCompiler ──
# Mức độ  : Cao
# Chi tiết: Detects potentially suspicious child processes of "aspnet_compiler.exe".
EventCode=4688 Channel="Security" ParentProcessName="*\\aspnet_compiler.exe" NewProcessName IN ("*\\calc.exe", "*\\notepad.exe") OR NewProcessName IN ("*\\Users\\Public\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Local\\Roaming\\*", "*:\\Temp\\*", "*:\\Windows\\Temp\\*", "*:\\Windows\\System32\\Tasks\\*", "*:\\Windows\\Tasks\\*")

# ── Potentially Suspicious ASP.NET Compilation Via AspNetCompiler ──
# Mức độ  : Cao
# Chi tiết: Detects execution of "aspnet_compiler.exe" with potentially suspicious paths for compilation.
EventCode=4688 Channel="Security" CommandLine IN ("*\\Users\\Public\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Local\\Roaming\\*", "*:\\Temp\\*", "*:\\Windows\\Temp\\*", "*:\\Windows\\System32\\Tasks\\*", "*:\\Windows\\Tasks\\*") NewProcessName IN ("*:\\Windows\\Microsoft.NET\\Framework\\*", "*:\\Windows\\Microsoft.NET\\Framework64\\*", "*:\\Windows\\Microsoft.NET\\FrameworkArm\\*", "*:\\Windows\\Microsoft.NET\\FrameworkArm64\\*") NewProcessName="*\\aspnet_compiler.exe"

# ── Interactive AT Job ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects an interactive AT job, which may be used as a form of privilege escalation.
EventCode=4688 Channel="Security" CommandLine="*interactive*" NewProcessName="*\\at.exe"

# ── Uncommon  Assistive Technology Applications Execution Via AtBroker.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the start of a non built-in assistive technology applications via "Atbroker.EXE".
EventCode=4688 Channel="Security" NewProcessName="*\\AtBroker.exe" OR OriginalFileName="AtBroker.exe" CommandLine="*start*" NOT (CommandLine IN ("*animations*", "*audiodescription*", "*caretbrowsing*", "*caretwidth*", "*colorfiltering*", "*cursorindicator*", "*cursorscheme*", "*filterkeys*", "*focusborderheight*", "*focusborderwidth*", "*highcontrast*", "*keyboardcues*", "*keyboardpref*", "*livecaptions*", "*magnifierpane*", "*messageduration*", "*minimumhitradius*", "*mousekeys*", "*Narrator*", "*osk*", "*overlappedcontent*", "*showsounds*", "*soundsentry*", "*speechreco*", "*stickykeys*", "*togglekeys*", "*voiceaccess*", "*windowarranging*", "*windowtracking*", "*windowtrackingtimeout*", "*windowtrackingzorder*")) NOT CommandLine="*Oracle_JavaAccessBridge*"

# ── Hiding Files with Attrib.exe ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of attrib.exe to hide files from users.
EventCode=4688 Channel="Security" NewProcessName="*\\attrib.exe" OR OriginalFileName="ATTRIB.EXE" CommandLine="* +h *" NOT CommandLine="*\\desktop.ini *" NOT (CommandLine="+R +H +S +A \\\*.cui" ParentCommandLine="C:\\WINDOWS\\system32\\\*.bat" ParentProcessName="*\\cmd.exe")

# ── Set Suspicious Files as System Files Using Attrib.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects the usage of attrib with the "+s" option to set scripts or executables located in suspicious locations as system files to hide them from users and make them unable to be deleted with simple ri
EventCode=4688 Channel="Security" NewProcessName="*\\attrib.exe" OR OriginalFileName="ATTRIB.EXE" CommandLine="* +s*" CommandLine IN ("* %*", "*\\Users\\Public\\*", "*\\AppData\\Local\\*", "*\\ProgramData\\*", "*\\Downloads\\*", "*\\Windows\\Temp\\*") CommandLine IN ("*.bat*", "*.dll*", "*.exe*", "*.hta*", "*.ps1*", "*.vbe*", "*.vbs*") NOT (CommandLine="*\\Windows\\TEMP\\*" CommandLine="*.exe*")

# ── Audit Policy Tampering Via NT Resource Kit Auditpol ──
# Mức độ  : Cao
# Chi tiết: Threat actors can use an older version of the auditpol binary available inside the NT resource kit to change audit policy configuration to impair detection capability. This can be carried out by selec
EventCode=4688 Channel="Security" CommandLine IN ("*/logon:none*", "*/system:none*", "*/sam:none*", "*/privilege:none*", "*/object:none*", "*/process:none*", "*/policy:none*")

# ── Audit Policy Tampering Via Auditpol ──
# Mức độ  : Cao
# Chi tiết: Threat actors can use auditpol binary to change audit policy configuration to impair detection capability. This can be carried out by selectively disabling/removing certain audit policies as well as r
EventCode=4688 Channel="Security" NewProcessName="*\\auditpol.exe" OR OriginalFileName="AUDITPOL.EXE" CommandLine IN ("*disable*", "*clear*", "*remove*", "*restore*")

# ── Windows EventLog Autologger Session Registry Modification Via CommandLine ──
# Mức độ  : Cao
# Chi tiết: Detects attempts to disable Windows EventLog autologger sessions via registry modification. The AutoLogger event tracing session records events that occur early in the operating system boot process. A
EventCode=4688 Channel="Security" NewProcessName IN ("*\\reg.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("reg.exe", "PowerShell.EXE", "pwsh.dll") CommandLine IN ("*add *", "*Set-ItemProperty*", "*New-ItemProperty*", "*si *") CommandLine="*\\Control\\WMI\\Autologger\\*" CommandLine IN ("*Start*", "*Enabled*")

# ── Suspicious Autorun Registry Modified via WMI ──
# Mức độ  : Cao
# Mục đích: Persistence qua autorun
# Chi tiết: Detects suspicious activity where the WMIC process is used to create an autorun registry entry via reg.exe, which is often indicative of persistence mechanisms employed by malware.
EventCode=4688 Channel="Security" NewProcessName="*\\wmic.exe" OR OriginalFileName="wmic.exe" OR ParentProcessName="*\\wmiprvse.exe" CommandLine="*reg*" CommandLine="* add *" CommandLine IN ("*\\Software\\Microsoft\\Windows\\CurrentVersion\\Run*", "*\\Software\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Run*", "*\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\Run*") CommandLine IN ("*:\\Perflogs*", "*:\\ProgramData'*", "*:\\Windows\\Temp*", "*:\\Temp*", "*\\AppData\\Local\\Temp*", "*\\AppData\\Roaming*", "*:\\$Recycle.bin*", "*:\\Users\\Default*", "*:\\Users\\public*", "*%temp%*", "*%tmp%*", "*%Public%*", "*%AppData%*") OR (CommandLine="*:\\Users\\*" CommandLine IN ("*\\Favorites*", "*\\Favourites*", "*\\Contacts*", "*\\Music*", "*\\Pictures*", "*\\Documents*", "*\\Photos*"))

# ── Suspicious BitLocker Access Agent Update Utility Execution ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects the execution of the BitLocker Access Agent Update Utility (baaupdate.exe) which is not a common parent process for other processes. Suspicious child processes spawned by baaupdate.exe could i
EventCode=4688 Channel="Security" ParentProcessName="*\\baaupdate.exe" NewProcessName IN ("*\\bitsadmin.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell_ise.exe", "*\\powershell.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\schtasks.exe", "*\\wmic.exe", "*\\wscript.exe")

# ── Indirect Inline Command Execution Via Bash.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of Microsoft bash launcher with the "-c" flag. This can be used to potentially bypass defenses and execute Linux or Windows-based binaries directly via bash.
EventCode=4688 Channel="Security" NewProcessName IN ("*:\\Windows\\System32\\bash.exe", "*:\\Windows\\SysWOW64\\bash.exe") OR OriginalFileName="Bash.exe" CommandLine="* -c *"

# ── Indirect Command Execution From Script File Via Bash.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of Microsoft bash launcher without any flags to execute the content of a bash script directly. This can be used to potentially bypass defenses and execute Linux or Windows-based bina
EventCode=4688 Channel="Security" NewProcessName IN ("*:\\Windows\\System32\\bash.exe", "*:\\Windows\\SysWOW64\\bash.exe") OR OriginalFileName="Bash.exe" NOT (CommandLine IN ("*bash.exe -*", "*bash -*") OR NOT CommandLine=* OR CommandLine="" OR CommandLine IN ("bash.exe", "bash"))

# ── Boot Configuration Tampering Via Bcdedit.EXE ──
# Mức độ  : Cao
# Mục đích: Phá hủy backup/recovery
# Chi tiết: Detects the use of the bcdedit command to tamper with the boot configuration data. This technique is often times used by malware or attackers as a destructive way before launching ransomware.
EventCode=4688 Channel="Security" NewProcessName="*\\bcdedit.exe" OR OriginalFileName="bcdedit.exe" CommandLine="*set*" (CommandLine="*bootstatuspolicy*" CommandLine="*ignoreallfailures*") OR (CommandLine="*recoveryenabled*" CommandLine="*no*")

# ── Potential Ransomware or Unauthorized MBR Tampering Via Bcdedit.EXE ──
# Mức độ  : Trung bình
# Mục đích: Xóa dấu vết
# Chi tiết: Detects potential malicious and unauthorized usage of bcdedit.exe
EventCode=4688 Channel="Security" NewProcessName="*\\bcdedit.exe" OR OriginalFileName="bcdedit.exe" CommandLine IN ("*delete*", "*deletevalue*", "*import*", "*safeboot*", "*network*")

# ── Data Export From MSSQL Table Via BCP.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of the BCP utility in order to export data from the database. Attackers were seen saving their malware to a database column or table and then later extracting it via "bcp.exe" in
EventCode=4688 Channel="Security" NewProcessName="*\\bcp.exe" OR OriginalFileName="BCP.exe" CommandLine IN ("* out *", "* queryout *")

# ── Suspicious Child Process Of BgInfo.EXE ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious child processes of "BgInfo.exe" which could be a sign of potential abuse of the binary to proxy execution via external VBScript
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\bginfo.exe", "*\\bginfo64.exe") NewProcessName IN ("*\\calc.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\notepad.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wscript.exe") OR NewProcessName IN ("*\\AppData\\Local\\*", "*\\AppData\\Roaming\\*", "*:\\Users\\Public\\*", "*:\\Temp\\*", "*:\\Windows\\Temp\\*", "*:\\PerfLogs\\*")

# ── Uncommon Child Process Of BgInfo.EXE ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects uncommon child processes of "BgInfo.exe" which could be a sign of potential abuse of the binary to proxy execution via external VBScript
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\bginfo.exe", "*\\bginfo64.exe")

# ── BitLockerTogo.EXE Execution ──
# Mức độ  : Thấp
# Chi tiết: Detects the execution of "BitLockerToGo.EXE". BitLocker To Go is BitLocker Drive Encryption on removable data drives. This feature includes the encryption of, USB flash drives, SD cards, External hard
EventCode=4688 Channel="Security" NewProcessName="*\\BitLockerToGo.exe"

# ── File Download Via Bitsadmin ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình; Tải file từ mạng
# Chi tiết: Detects usage of bitsadmin downloading a file
EventCode=4688 Channel="Security" NewProcessName="*\\bitsadmin.exe" OR OriginalFileName="bitsadmin.exe" CommandLine="* /transfer *" OR (CommandLine IN ("* /create *", "* /addfile *") CommandLine="*http*")

# ── Suspicious Download From Direct IP Via Bitsadmin ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects usage of bitsadmin downloading a file using an URL that contains an IP
EventCode=4688 Channel="Security" NewProcessName="*\\bitsadmin.exe" OR OriginalFileName="bitsadmin.exe" CommandLine IN ("* /transfer *", "* /create *", "* /addfile *") CommandLine IN ("*://1*", "*://2*", "*://3*", "*://4*", "*://5*", "*://6*", "*://7*", "*://8*", "*://9*") NOT CommandLine="*://7-*"

# ── Suspicious Download From File-Sharing Website Via Bitsadmin ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Tải file từ mạng
# Chi tiết: Detects usage of bitsadmin downloading a file from a suspicious domain
EventCode=4688 Channel="Security" NewProcessName="*\\bitsadmin.exe" OR OriginalFileName="bitsadmin.exe" CommandLine IN ("* /transfer *", "* /create *", "* /addfile *") CommandLine IN ("*.githubusercontent.com*", "*0x0.st*", "*anonfiles.com*", "*bashupload.com*", "*cdn.discordapp.com*", "*chunk.io*", "*ddns.net*", "*dl.dropboxusercontent.com*", "*ghostbin.co*", "*github.com*", "*glitch.me*", "*gofile.io*", "*hastebin.com*", "*mediafire.com*", "*mega.nz*", "*onrender.com*", "*pages.dev*", "*paste.ee*", "*pastebin.com*", "*pastebin.pl*", "*pastetext.net*", "*privatlab.com*", "*privatlab.net*", "*send.exploit.in*", "*sendspace.com*", "*storage.googleapis.com*", "*storjshare.io*", "*supabase.co*", "*temp.sh*", "*transfer.sh*", "*trycloudflare.com*", "*ufile.io*", "*w3spaces.com*", "*workers.dev*", "*x0.at*")

# ── File With Suspicious Extension Downloaded Via Bitsadmin ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Tải file từ mạng
# Chi tiết: Detects usage of bitsadmin downloading a file with a suspicious extension
EventCode=4688 Channel="Security" NewProcessName="*\\bitsadmin.exe" OR OriginalFileName="bitsadmin.exe" CommandLine IN ("* /transfer *", "* /create *", "* /addfile *") CommandLine IN ("*.7z*", "*.asax*", "*.ashx*", "*.asmx*", "*.asp*", "*.aspx*", "*.bat*", "*.cfm*", "*.cgi*", "*.chm*", "*.cmd*", "*.dll*", "*.gif*", "*.jpeg*", "*.jpg*", "*.jsp*", "*.jspx*", "*.log*", "*.png*", "*.ps1*", "*.psm1*", "*.rar*", "*.scf*", "*.sct*", "*.txt*", "*.vbe*", "*.vbs*", "*.war*", "*.wsf*", "*.wsh*", "*.xll*", "*.zip*")

# ── File Download Via Bitsadmin To A Suspicious Target Folder ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Tải file từ mạng
# Chi tiết: Detects usage of bitsadmin downloading a file to a suspicious target folder
EventCode=4688 Channel="Security" NewProcessName="*\\bitsadmin.exe" OR OriginalFileName="bitsadmin.exe" CommandLine IN ("* /transfer *", "* /create *", "* /addfile *") CommandLine IN ("*:\\Perflogs*", "*:\\ProgramData\\*", "*:\\Temp\\*", "*:\\Users\\Public\\*", "*:\\Windows\\*", "*\\$Recycle.Bin\\*", "*\\AppData\\Local\\*", "*\\AppData\\Roaming\\*", "*\\Contacts\\*", "*\\Desktop\\*", "*\\Favorites\\*", "*\\Favourites\\*", "*\\inetpub\\wwwroot\\*", "*\\Music\\*", "*\\Pictures\\*", "*\\Start Menu\\Programs\\Startup\\*", "*\\Users\\Default\\*", "*\\Videos\\*", "*%ProgramData%*", "*%public%*", "*%temp%*", "*%tmp%*")

# ── Monitoring For Persistence Via BITS ──
# Mức độ  : Trung bình
# Chi tiết: BITS will allow you to schedule a command to execute after a successful download to notify you that the job is finished. When the job runs on the system the command specified in the BITS job will be e
EventCode=4688 Channel="Security" NewProcessName="*\\bitsadmin.exe" OR OriginalFileName="bitsadmin.exe" (CommandLine="*/SetNotifyCmdLine*" CommandLine IN ("*%COMSPEC%*", "*cmd.exe*", "*regsvr32.exe*")) OR (CommandLine="*/Addfile*" CommandLine IN ("*http:*", "*https:*", "*ftp:*", "*ftps:*"))

# ── Potential Data Stealing Via Chromium Headless Debugging ──
# Mức độ  : Cao
# Chi tiết: Detects chromium based browsers starting in headless and debugging mode and pointing to a user profile. This could be a sign of data stealing or remote control
EventCode=4688 Channel="Security" CommandLine="*--remote-debugging-*" CommandLine="*--user-data-dir*" CommandLine="*--headless*"

# ── Browser Execution In Headless Mode ──
# Mức độ  : Thấp
# Mục đích: Tải file từ mạng
# Chi tiết: Detects execution of Chromium based browser in headless mode
EventCode=4688 Channel="Security" CommandLine="*--headless*" NewProcessName IN ("*\\brave.exe", "*\\chrome.exe", "*\\msedge.exe", "*\\opera.exe", "*\\vivaldi.exe")

# ── File Download with Headless Browser ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects execution of chromium based browser in headless mode using the "dump-dom" command line to download files
EventCode=4688 Channel="Security" CommandLine="*--headless*" CommandLine="*dump-dom*" CommandLine="*http*" NewProcessName IN ("*\\brave.exe", "*\\chrome.exe", "*\\msedge.exe", "*\\opera.exe", "*\\vivaldi.exe") NOT ((CommandLine="*--headless --disable-gpu --disable-extensions --disable-plugins --mute-audio --no-first-run --incognito --aggressive-cache-discard --dump-dom*" NewProcessName IN ("C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\*", "C:\\Program Files (x86)\\Microsoft\\EdgeCore\\*", "C:\\Program Files (x86)\\Microsoft\\EdgeWebView\\*", "C:\\Program Files\\Microsoft\\Edge\\Application\\*", "C:\\Program Files\\Microsoft\\EdgeCore\\*", "C:\\Program Files\\Microsoft\\EdgeWebView\\*", "C:\\Program Files\\WindowsApps\\Microsoft.MicrosoftEdge*") NewProcessName IN ("*\\msedge.exe", "*\\msedgewebview2.exe", "*\\MicrosoftEdge.exe")) OR (CommandLine="*--headless --disable-gpu --disable-extensions --disable-plugins --mute-audio --no-first-run --incognito --aggressive-cache-discard --dump-dom*" NewProcessName IN ("*\\AppData\\Local\\Microsoft\\WindowsApps\\*", "*\\Windows\\SystemApps\\Microsoft.MicrosoftEdge*") NewProcessName IN ("*\\msedge.exe", "*\\MicrosoftEdge.exe")))

# ── Chromium Browser Instance Executed With Custom Extension ──
# Mức độ  : Trung bình
# Chi tiết: Detects a Chromium based browser process with the 'load-extension' flag to start a instance with a custom extension
EventCode=4688 Channel="Security" CommandLine="*--load-extension=*" NewProcessName IN ("*\\brave.exe", "*\\chrome.exe", "*\\msedge.exe", "*\\opera.exe", "*\\vivaldi.exe")

# ── Chromium Browser Headless Execution To Mockbin Like Site ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of a Chromium based browser process with the "headless" flag and a URL pointing to the mockbin.org service (which can be used to exfiltrate data).
EventCode=4688 Channel="Security" NewProcessName IN ("*\\brave.exe", "*\\chrome.exe", "*\\msedge.exe", "*\\opera.exe", "*\\vivaldi.exe") CommandLine="*--headless*" CommandLine IN ("*://run.mocky*", "*://mockbin*")

# ── Suspicious Chromium Browser Instance Executed With Custom Extension ──
# Mức độ  : Cao
# Chi tiết: Detects a suspicious process spawning a Chromium based browser process with the 'load-extension' flag to start an instance with a custom extension
EventCode=4688 Channel="Security" CommandLine="*--load-extension=*" ParentProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") NewProcessName IN ("*\\brave.exe", "*\\chrome.exe", "*\\msedge.exe", "*\\opera.exe", "*\\vivaldi.exe")

# ── File Download From Browser Process Via Inline URL ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects execution of a browser process with a URL argument pointing to a file with a potentially interesting extension. This can be abused to download arbitrary files or to hide from the user for exam
EventCode=4688 Channel="Security" NewProcessName IN ("*\\brave.exe", "*\\chrome.exe", "*\\msedge.exe", "*\\opera.exe", "*\\vivaldi.exe") CommandLine="*http*" CommandLine IN ("*.7z", "*.dat", "*.dll", "*.exe", "*.hta", "*.ps1", "*.psm1", "*.txt", "*.vbe", "*.vbs", "*.zip") OR CommandLine IN ("*.7z\"*", "*.dat\"*", "*.dll\"*", "*.hta\"*", "*.ps1\"*", "*.psm1\"*", "*.txt\"*", "*.vbe\"*", "*.vbs\"*", "*.zip\"*")

# ── Browser Started with Remote Debugging ──
# Mức độ  : Trung bình
# Chi tiết: Detects browsers starting with the remote debugging flags. Which is a technique often used to perform browser injection attacks
EventCode=4688 Channel="Security" CommandLine="* --remote-debugging-*" OR (CommandLine="* -start-debugger-server*" NewProcessName="*\\firefox.exe")

# ── Tor Client/Browser Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of Tor or Tor-Browser to connect to onion routing networks
EventCode=4688 Channel="Security" Description="Tor Browser" OR Product="Tor Browser" OR NewProcessName IN ("*\\tor.exe", "*\\Tor Browser\\Browser\\firefox.exe")

# ── Suspicious Calculator Usage ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects suspicious use of 'calc.exe' with command line parameters or in a suspicious directory, which is likely caused by some PoC or detection evasion.
EventCode=4688 Channel="Security" CommandLine="*\\calc.exe *" OR (NewProcessName="*\\calc.exe" NOT (NewProcessName IN ("*:\\Windows\\System32\\*", "*:\\Windows\\SysWOW64\\*", "*:\\Windows\\WinSxS\\*")))

# ── Potential Binary Proxy Execution Via Cdb.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of "cdb.exe" to launch arbitrary processes or commands from a debugger script file
EventCode=4688 Channel="Security" NewProcessName="*\\cdb.exe" OR OriginalFileName="CDB.Exe" CommandLine IN ("* -c *", "* -cf *")

# ── New Root Certificate Installed Via CertMgr.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "certmgr" with the "add" flag in order to install a new certificate on the system. Adversaries may install a root certificate on a compromised system to avoid warnings when connec
EventCode=4688 Channel="Security" NewProcessName="*\\CertMgr.exe" OR OriginalFileName="CERTMGT.EXE" CommandLine="*/add*" CommandLine="*root*"

# ── File Download via CertOC.EXE ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects when a user downloads a file by using CertOC.exe
EventCode=4688 Channel="Security" NewProcessName="*\\certoc.exe" OR OriginalFileName="CertOC.exe" CommandLine="*-GetCACAPS*" CommandLine="*http*"

# ── File Download From IP Based URL Via CertOC.EXE ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects when a user downloads a file from an IP based URL using CertOC.exe
EventCode=4688 Channel="Security" NewProcessName="*\\certoc.exe" OR OriginalFileName="CertOC.exe" CommandLine="*-GetCACAPS*"
| regex CommandLine="://[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}"

# ── DLL Loaded via CertOC.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects when a user installs certificates by using CertOC.exe to loads the target DLL file.
EventCode=4688 Channel="Security" NewProcessName="*\\certoc.exe" OR OriginalFileName="CertOC.exe" CommandLine="* -LoadDLL *" OR CommandLine="* /LoadDLL *" OR CommandLine="* –LoadDLL *" OR CommandLine="* —LoadDLL *" OR CommandLine="* ―LoadDLL *"

# ── Suspicious DLL Loaded via CertOC.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects when a user installs certificates by using CertOC.exe to load the target DLL file.
EventCode=4688 Channel="Security" NewProcessName="*\\certoc.exe" OR OriginalFileName="CertOC.exe" CommandLine="* -LoadDLL *" OR CommandLine="* /LoadDLL *" OR CommandLine="* –LoadDLL *" OR CommandLine="* —LoadDLL *" OR CommandLine="* ―LoadDLL *" CommandLine IN ("*\\Appdata\\Local\\Temp\\*", "*\\Desktop\\*", "*\\Downloads\\*", "*\\Users\\Public\\*", "*C:\\Windows\\Tasks\\*", "*C:\\Windows\\Temp\\*")

# ── Suspicious CertReq Command to Download ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects a suspicious CertReq execution downloading a file. This behavior is often used by attackers to download additional payloads or configuration files. Certreq is a built-in Windows utility used t
EventCode=4688 Channel="Security" NewProcessName="*\\certreq.exe" OR OriginalFileName="CertReq.exe" CommandLine="*-Post*" OR CommandLine="*/Post*" OR CommandLine="*–Post*" OR CommandLine="*—Post*" OR CommandLine="*―Post*" CommandLine="*-config*" OR CommandLine="*/config*" OR CommandLine="*–config*" OR CommandLine="*—config*" OR CommandLine="*―config*" CommandLine="*http*"

# ── New Root Certificate Installed Via Certutil.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "certutil" with the "addstore" flag in order to install a new certificate on the system. Adversaries may install a root certificate on a compromised system to avoid warnings when 
EventCode=4688 Channel="Security" NewProcessName="*\\certutil.exe" OR OriginalFileName="CertUtil.exe" CommandLine="*-addstore*" OR CommandLine="*/addstore*" OR CommandLine="*–addstore*" OR CommandLine="*—addstore*" OR CommandLine="*―addstore*" CommandLine="*root*"

# ── File Decoded From Base64/Hex Via Certutil.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of certutil with either the "decode" or "decodehex" flags to decode base64 or hex encoded files. This can be abused by attackers to decode an encoded payload before execution
EventCode=4688 Channel="Security" NewProcessName="*\\certutil.exe" OR OriginalFileName="CertUtil.exe" CommandLine="*-decode *" OR CommandLine="*/decode *" OR CommandLine="*–decode *" OR CommandLine="*—decode *" OR CommandLine="*―decode *" OR CommandLine="*-decodehex *" OR CommandLine="*/decodehex *" OR CommandLine="*–decodehex *" OR CommandLine="*—decodehex *" OR CommandLine="*―decodehex *"

# ── Suspicious Download Via Certutil.EXE ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects the execution of certutil with certain flags that allow the utility to download files.
EventCode=4688 Channel="Security" NewProcessName="*\\certutil.exe" OR OriginalFileName="CertUtil.exe" CommandLine IN ("*urlcache *", "*verifyctl *", "*URL *") CommandLine="*http*"

# ── Suspicious File Downloaded From Direct IP Via Certutil.EXE ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects the execution of certutil with certain flags that allow the utility to download files from direct IPs.
EventCode=4688 Channel="Security" NewProcessName="*\\certutil.exe" OR OriginalFileName="CertUtil.exe" CommandLine IN ("*urlcache *", "*verifyctl *", "*URL *") CommandLine IN ("*://1*", "*://2*", "*://3*", "*://4*", "*://5*", "*://6*", "*://7*", "*://8*", "*://9*") NOT CommandLine="*://7-*"

# ── Suspicious File Downloaded From File-Sharing Website Via Certutil.EXE ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects the execution of certutil with certain flags that allow the utility to download files from file-sharing websites.
EventCode=4688 Channel="Security" NewProcessName="*\\certutil.exe" OR OriginalFileName="CertUtil.exe" CommandLine IN ("*urlcache *", "*verifyctl *", "*URL *") CommandLine IN ("*.githubusercontent.com*", "*0x0.st*", "*anonfiles.com*", "*bashupload.com*", "*cdn.discordapp.com*", "*chunk.io*", "*ddns.net*", "*dl.dropboxusercontent.com*", "*ghostbin.co*", "*github.com*", "*glitch.me*", "*gofile.io*", "*hastebin.com*", "*mediafire.com*", "*mega.nz*", "*onrender.com*", "*pages.dev*", "*paste.ee*", "*pastebin.com*", "*pastebin.pl*", "*pastetext.net*", "*privatlab.com*", "*privatlab.net*", "*send.exploit.in*", "*sendspace.com*", "*storage.googleapis.com*", "*storjshare.io*", "*supabase.co*", "*temp.sh*", "*transfer.sh*", "*trycloudflare.com*", "*ufile.io*", "*w3spaces.com*", "*workers.dev*", "*x0.at*")

# ── File Encoded To Base64 Via Certutil.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of certutil with the "encode" flag to encode a file to base64. This can be abused by threat actors and attackers for data exfiltration
EventCode=4688 Channel="Security" NewProcessName="*\\certutil.exe" OR OriginalFileName="CertUtil.exe" CommandLine="*-encode*" OR CommandLine="*/encode*" OR CommandLine="*–encode*" OR CommandLine="*—encode*" OR CommandLine="*―encode*"

# ── Suspicious File Encoded To Base64 Via Certutil.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of certutil with the "encode" flag to encode a file to base64 where the extensions of the file is suspicious
EventCode=4688 Channel="Security" NewProcessName="*\\certutil.exe" OR OriginalFileName="CertUtil.exe" CommandLine="*-encode*" OR CommandLine="*/encode*" OR CommandLine="*–encode*" OR CommandLine="*—encode*" OR CommandLine="*―encode*" CommandLine IN ("*.acl*", "*.bat*", "*.doc*", "*.gif*", "*.jpeg*", "*.jpg*", "*.mp3*", "*.pdf*", "*.png*", "*.ppt*", "*.tmp*", "*.xls*", "*.xml*")

# ── File In Suspicious Location Encoded To Base64 Via Certutil.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of certutil with the "encode" flag to encode a file to base64 where the files are located in potentially suspicious locations
EventCode=4688 Channel="Security" NewProcessName="*\\certutil.exe" OR OriginalFileName="CertUtil.exe" CommandLine="*-encode*" OR CommandLine="*/encode*" OR CommandLine="*–encode*" OR CommandLine="*—encode*" OR CommandLine="*―encode*" CommandLine IN ("*\\AppData\\Roaming\\*", "*\\Desktop\\*", "*\\Local\\Temp\\*", "*\\PerfLogs\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*", "*$Recycle.Bin*")

# ── Certificate Exported Via Certutil.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of the certutil with the "exportPFX" flag which allows the utility to export certificates.
EventCode=4688 Channel="Security" NewProcessName="*\\certutil.exe" OR OriginalFileName="CertUtil.exe" CommandLine="*-exportPFX *" OR CommandLine="*/exportPFX *" OR CommandLine="*–exportPFX *" OR CommandLine="*—exportPFX *" OR CommandLine="*―exportPFX *"

# ── Potential NTLM Coercion Via Certutil.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects possible NTLM coercion via certutil using the 'syncwithWU' flag
EventCode=4688 Channel="Security" NewProcessName="*\\certutil.exe" OR OriginalFileName="CertUtil.exe" CommandLine="* -syncwithWU *" CommandLine="* \\\\*"

# ── Suspicious CodePage Switch Via CHCP ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects a code page switch in command line or batch scripts to a rare language
EventCode=4688 Channel="Security" CommandLine IN ("* 936", "* 1258") NewProcessName="*\\chcp.com"

# ── Deleted Data Overwritten Via Cipher.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the "cipher" built-in utility in order to overwrite deleted data from disk. Adversaries may destroy data and files on specific systems or in large numbers on a network to interrupt av
EventCode=4688 Channel="Security" OriginalFileName="CIPHER.EXE" OR NewProcessName="*\\cipher.exe" CommandLine="* /w:*"

# ── Process Access via TrolleyExpress Exclusion ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects a possible process memory dump that uses the white-listed Citrix TrolleyExpress.exe filename as a way to dump the lsass process memory
EventCode=4688 Channel="Security" CommandLine IN ("*\\TrolleyExpress 7*", "*\\TrolleyExpress 8*", "*\\TrolleyExpress 9*", "*\\TrolleyExpress.exe 7*", "*\\TrolleyExpress.exe 8*", "*\\TrolleyExpress.exe 9*", "*\\TrolleyExpress.exe -ma *") OR (NewProcessName="*\\TrolleyExpress.exe" NOT (OriginalFileName="*CtxInstall*" OR NOT OriginalFileName=*))

# ── Data Copied To Clipboard Via Clip.EXE ──
# Mức độ  : Thấp
# Chi tiết: Detects the execution of clip.exe in order to copy data to the clipboard. Adversaries may collect data stored in the clipboard from users copying information within or between applications.
EventCode=4688 Channel="Security" NewProcessName="*\\clip.exe" OR OriginalFileName="clip.exe"

# ── Cloudflared Portable Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of the "cloudflared" binary from a non standard location.
EventCode=4688 Channel="Security" NewProcessName="*\\cloudflared.exe" NOT (NewProcessName IN ("*:\\Program Files (x86)\\cloudflared\\*", "*:\\Program Files\\cloudflared\\*"))

# ── Cloudflared Quick Tunnel Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects creation of an ad-hoc Cloudflare Quick Tunnel, which can be used to tunnel local services such as HTTP, RDP, SSH and SMB. The free TryCloudflare Quick Tunnel will generate a random subdomain o
EventCode=4688 Channel="Security" (NewProcessName IN ("*\\cloudflared.exe", "*\\cloudflared-windows-386.exe", "*\\cloudflared-windows-amd64.exe") OR Hashes IN ("*SHA256=2fb6c04c4f95fb8d158af94c137f90ac820716deaf88d8ebec956254e046cb29*", "*SHA256=b3d21940a10fdef5e415ad70331ce257c24fe3bcf7722262302e0421791f87e8*", "*SHA256=1fbd8362b2d2d2e6a5750ae3db69cd1815e6c1d31da48a98b796450971a8e039*", "*SHA256=0409c9b12f9d0eda86e461ed9bdabeefb00172b26322079681a0bdf48e68dc28*", "*SHA256=7cfb411d04bac42ef93d1f0c93c0a481e38c6f4612b97ae89d4702595988edc7*", "*SHA256=5b3c2d846ab162dc6bc595cce3a49de5731afde5d6060be7066d21b013a28373*", "*SHA256=ce95df7f69664c3df19b76028e115931919a71517b776da7b42d353e2ff4a670*", "*SHA256=1293525a19cfe3bc8296b62fbfe19f083632ed644a1c18c10b045a1d3030d81a*", "*SHA256=af2b9161cfcb654b16408cd6b098afe9d1fb61a037d18d7090a119d4c0c8e0f0*", "*SHA256=39ddceb56a15798826a5fc4892fa2b474c444bb4d7a8bf2fa95e41cab10fa7a1*", "*SHA256=ccd11f2328023a0e7929e845d5b6e7bc783fb4650d65faef3ae090239d4bbce2*", "*SHA256=b6e5c5d2567ae8c69cc012ebcae30e6c9b5359d64a58d17ba75ec89f8bce71ac*", "*SHA256=f813484ea441404f18caad96f28138e8aaf0cb256163c09c2ab8a3acab87f69f*", "*SHA256=fc4a0802ab9c7409b892ca00636bec61e2acfc911bccfdeb9978b8ab5a2f828d*", "*SHA256=083150724b49604c8765c1ba19541fa260b133be0acb0647fcd936d81f054499*", "*SHA256=44303d6572956f28a0f2e4b188934fb9874f2584f5c81fa431a463cfbf28083b*", "*SHA256=5d38c46032a58e28ae5f7d174d8761ec3d64d186677f3ec53af5f51afb9bfd2f*", "*SHA256=e1e70fa42059911bc6685fafef957f9a73fc66f214d0704a9b932683a5204032*", "*SHA256=c01356092a365b84f84f0e66870bd1a05ba3feb53cafd973fa5fea2534bee234*", "*SHA256=b3f9c06151e30ee43d39e788a79cd918a314f24e04fe87f3de8272a2057b624f*", "*SHA256=cd81b2792f0739f473c31c9cb7cf2313154bfa28b839975802b90e8790bb5058*", "*SHA256=9ec7e6c8e1bfd883663d8d9d62c9e4f9ae373b731407181e32491b27a7218a2c*", "*SHA256=c2cfd23fdc6c0e1b1ffa0e545cbe556f18d11b362b4a89ba0713f6ab01c4827f*", "*SHA256=53f8adbd76c0eb16f5e43cadde422474d8a06f9c8f959389c1930042ad8beaa5*", "*SHA256=648c8d2f8001c113d2986dd00b7bbd181593d462bef73522cee212c4f71f95b3*", "*SHA256=ae047e2095e46c3f9c518b2be67ec753f4f0aad23b261a361fcb6144dcdb63b4*", "*SHA256=3153d2baa462978dd22ab33d1c2274ecc88c200225d6a3327f98d5b752d08f5c*", "*SHA256=f49cde976e628012c9db73e1c8d76081944ecf2297cdafeb78bb13290da274c4*", "*SHA256=d2513e58bb03ccc83affde685c6ef987924c37ce6707d8e9857e2524b0d7e90f*", "*SHA256=bb67c7623ba92fe64ffd9816b8d5b3b1ea3013960a30bd4cf6e295b3eb5b1bad*", "*SHA256=b34b3c3a91e3165d1481f0b3ec23eab93a1cfba94345a6cbfe5b18ddbd48eac7*", "*SHA256=f7848034e010d55f15e474ca998f96391e320ff29b00cfcc4c5e536529703e75*", "*SHA256=b6fc9493778cbe3bfc062d73f5cc604bc0ff058bc5e5dc6aac87f3a4008b54b6*", "*SHA256=f5c5e962577e2293c4ad10603816dce7cc273585969615fbf4e4bfa9eaff1688*", "*SHA256=d14c52d9220b606f428a8fe9f7c108b0d6f14cf71e7384749e98e6a95962e68f*", "*SHA256=d3a0e1a79158f3985cd49607ebe0cdfcc49cb9af96b8f43aefd0cdfe2f22e663*", "*SHA256=2fbbfc8299537ff80cadf9d0e27c223fe0ccb9052bf9d8763ad717bbfa521c77*", "*SHA256=19074674c6fbdaa573b3081745e5e26144fdf7a086d14e0e220d1814f1f13078*") (CommandLine="*-url*" CommandLine="*tunnel*") OR CommandLine IN ("*.exe -url*", "*.exe --url*")) OR (CommandLine="*-url*" CommandLine="*-no-autoupdate*")

# ── Cloudflared Tunnel Connections Cleanup ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of the "cloudflared" tool with the tunnel "cleanup" flag in order to cleanup tunnel connections.
EventCode=4688 Channel="Security" CommandLine="* tunnel *" CommandLine="*cleanup *" CommandLine IN ("*-config *", "*-connector-id *")

# ── Cloudflared Tunnel Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of the "cloudflared" tool to connect back to a tunnel. This was seen used by threat actors to maintain persistence and remote access to compromised networks.
EventCode=4688 Channel="Security" CommandLine="* tunnel *" CommandLine="* run *" CommandLine IN ("*-config *", "*-credentials-contents *", "*-credentials-file *", "*-token *")

# ── Change Default File Association Via Assoc ──
# Mức độ  : Thấp
# Chi tiết: Detects file association changes using the builtin "assoc" command. When a file is opened, the default program used to open the file (also called the file association or handler) is checked. File asso
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*assoc*"

# ── Change Default File Association To Executable Via Assoc ──
# Mức độ  : Cao
# Chi tiết: Detects when a program changes the default file association of any extension to an executable. When a file is opened, the default program used to open the file (also called the file association or han
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*assoc *" CommandLine="*exefile*" NOT CommandLine="*.exe=exefile*"

# ── Copy .DMP/.DUMP Files From Remote Share Via Cmd.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects usage of the copy builtin cmd command to copy files with the ".dmp"/".dump" extension from a remote share
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*copy *" CommandLine="* \\\\*" CommandLine IN ("*.dmp*", "*.dump*", "*.hdmp*")

# ── Curl Download And Execute Combination ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Adversaries can use curl to download payloads remotely and execute them. Curl is included by default in Windows 10 build 17063 and later.
EventCode=4688 Channel="Security" CommandLine="* -c *" OR CommandLine="* /c *" OR CommandLine="* –c *" OR CommandLine="* —c *" OR CommandLine="* ―c *" CommandLine="*curl *" CommandLine="*http*" CommandLine="*-o*" CommandLine="*&*"

# ── File Deletion Via Del ──
# Mức độ  : Thấp
# Mục đích: Xóa dấu vết
# Chi tiết: Detects execution of the builtin "del"/"erase" commands in order to delete files. Adversaries may delete files left behind by the actions of their intrusion activity. Malware, tools, or other non-nati
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine IN ("*del *", "*erase *") CommandLine="* -f*" OR CommandLine="* /f*" OR CommandLine="* –f*" OR CommandLine="* —f*" OR CommandLine="* ―f*" OR CommandLine="* -s*" OR CommandLine="* /s*" OR CommandLine="* –s*" OR CommandLine="* —s*" OR CommandLine="* ―s*" OR CommandLine="* -q*" OR CommandLine="* /q*" OR CommandLine="* –q*" OR CommandLine="* —q*" OR CommandLine="* ―q*"

# ── Greedy File Deletion Using Del ──
# Mức độ  : Trung bình
# Mục đích: Xóa dấu vết
# Chi tiết: Detects execution of the "del" builtin command to remove files using greedy/wildcard expression. This is often used by malware to delete content of folders that perhaps contains the initial malware in
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine IN ("*del *", "*erase *") CommandLine IN ("*\\\*.au3*", "*\\\*.dll*", "*\\\*.exe*", "*\\\*.js*")

# ── File And SubFolder Enumeration Via Dir Command ──
# Mức độ  : Thấp
# Chi tiết: Detects usage of the "dir" command part of Windows CMD with the "/S" command line flag in order to enumerate files in a specified directory and all subdirectories.
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*-s*" OR CommandLine="*/s*" OR CommandLine="*–s*" OR CommandLine="*—s*" OR CommandLine="*―s*" CommandLine="*dir *" NOT CommandLine="*rmdir*"

# ── Potential Dosfuscation Activity ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects possible payload obfuscation via the commandline
EventCode=4688 Channel="Security" CommandLine IN ("*^^*", "*^|^*", "*,;,*", "*;;;;*", "*;; ;;*", "*(,(,*", "*%COMSPEC:~*", "* c^m^d*", "*^c^m^d*", "* c^md*", "* cm^d*", "*^cm^d*", "* s^et *", "* s^e^t *", "* se^t *")

# ── Command Line Execution with Suspicious URL and AppData Strings ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script; Tải file từ mạng
# Chi tiết: Detects a suspicious command line execution that includes an URL and AppData string in the command line parameters as used by several droppers (js/vbs > powershell)
EventCode=4688 Channel="Security" CommandLine="*http*" CommandLine="*://*" CommandLine="*%AppData%*" NewProcessName="*\\cmd.exe"

# ── Cmd Launched with Hidden Start Flags to Suspicious Targets ──
# Mức độ  : Trung bình
# Chi tiết: Detects cmd.exe executing commands with the "start" utility using "/b" (no window) or "/min" (minimized) flags. To reduce false positives from standard background tasks, detection is restricted to sce
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*start *" OR CommandLine="*start/b*" OR CommandLine="*start/min*" CommandLine="*-b *" OR CommandLine="*/b *" OR CommandLine="*–b *" OR CommandLine="*—b *" OR CommandLine="*―b *" OR CommandLine="*-b\"*" OR CommandLine="*/b\"*" OR CommandLine="*–b\"*" OR CommandLine="*—b\"*" OR CommandLine="*―b\"*" OR CommandLine="*-min *" OR CommandLine="*/min *" OR CommandLine="*–min *" OR CommandLine="*—min *" OR CommandLine="*―min *" OR CommandLine="*-min\"*" OR CommandLine="*/min\"*" OR CommandLine="*–min\"*" OR CommandLine="*—min\"*" OR CommandLine="*―min\"*" CommandLine IN ("*:\\Perflogs\\*", "*:\\Temp\\*", "*:\\Users\\Default\\*", "*:\\Windows\\Temp\\*", "*\\AppData\\Roaming\\*", "*\\Contacts\\*", "*\\Documents\\*", "*\\Downloads\\*", "*\\Favorites\\*", "*\\Favourites\\*", "*\\inetpub\\*", "*\\Music\\*", "*\\Photos\\*", "*\\Temporary Internet\\*", "*\\Users\\Public\\*", "*\\Videos\\*") OR CommandLine IN ("*.bat*", "*.cmd*", "*.cpl*", "*.hta*", "*.js*", "*.ps1*", "*.scr*", "*.vbe*", "*.vbs*") OR CommandLine IN ("* -nop *", "* -sta *", "*.downloadfile(*", "*.downloadstring(*", "*-noni *", "*-w hidden *")

# ── Potential Privilege Escalation Using Symlink Between Osk and Cmd ──
# Mức độ  : Cao
# Chi tiết: Detects the creation of a symbolic link between "cmd.exe" and the accessibility on-screen keyboard binary (osk.exe) using "mklink". This technique provides an elevated command prompt to the user from 
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*mklink*" CommandLine="*\\osk.exe*" CommandLine="*\\cmd.exe*"

# ── VolumeShadowCopy Symlink Creation Via Mklink ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Shadow Copies storage symbolic link creation using operating systems utilities
EventCode=4688 Channel="Security" CommandLine="*mklink*" CommandLine="*HarddiskVolumeShadowCopy*"

# ── Suspicious File Execution From Internet Hosted WebDav Share ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the execution of the "net use" command to mount a WebDAV server and then immediately execute some content in it. As seen being used in malicious LNK files
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe*" OR OriginalFileName="Cmd.EXE" CommandLine="* net use http*" CommandLine="*& start /b *" CommandLine="*\\DavWWWRoot\\*" CommandLine IN ("*.exe *", "*.dll *", "*.bat *", "*.vbs *", "*.ps1 *")

# ── Cmd.EXE Missing Space Characters Execution Anomaly ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Windows command lines that miss a space before or after the /c flag when running a command using the cmd.exe. This could be a sign of obfuscation of a fat finger problem (typo by the developer
EventCode=4688 Channel="Security" CommandLine IN ("*cmd.exe/c*", "*\\cmd/c*", "*\"cmd/c*", "*cmd.exe/k*", "*\\cmd/k*", "*\"cmd/k*", "*cmd.exe/r*", "*\\cmd/r*", "*\"cmd/r*") OR CommandLine IN ("*/cwhoami*", "*/cpowershell*", "*/cschtasks*", "*/cbitsadmin*", "*/ccertutil*", "*/kwhoami*", "*/kpowershell*", "*/kschtasks*", "*/kbitsadmin*", "*/kcertutil*") OR CommandLine IN ("*cmd.exe /c*", "*cmd /c*", "*cmd.exe /k*", "*cmd /k*", "*cmd.exe /r*", "*cmd /r*") NOT (CommandLine IN ("*cmd.exe /c *", "*cmd /c *", "*cmd.exe /k *", "*cmd /k *", "*cmd.exe /r *", "*cmd /r *") OR CommandLine IN ("*AppData\\Local\\Programs\\Microsoft VS Code\\resources\\app\\node_modules*", "*cmd.exe/c .", "cmd.exe /c", "cmd /c"))

# ── NtdllPipe Like Activity Execution ──
# Mức độ  : Cao
# Chi tiết: Detects command that type the content of ntdll.dll to a different file or a pipe in order to evade AV / EDR detection. As seen being used in the POC NtdllPipe
EventCode=4688 Channel="Security" CommandLine IN ("*type %windir%\\system32\\ntdll.dll*", "*type %systemroot%\\system32\\ntdll.dll*", "*type c:\\windows\\system32\\ntdll.dll*", "*\\ntdll.dll > \\\\.\\pipe\\*")

# ── Potential CommandLine Path Traversal Via Cmd.EXE ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects potential path traversal attempt via cmd.exe. Could indicate possible command/argument confusion/hijacking
EventCode=4688 Channel="Security" ParentProcessName="*\\cmd.exe" OR NewProcessName="*\\cmd.exe" OR OriginalFileName="cmd.exe" ParentCommandLine IN ("*/c*", "*/k*", "*/r*") OR CommandLine IN ("*/c*", "*/k*", "*/r*") ParentCommandLine="/../../" OR CommandLine="*/../../*" NOT CommandLine="*\\Tasktop\\keycloak\\bin\\/../../jre\\bin\\java*"

# ── Potentially Suspicious Ping/Copy Command Combination ──
# Mức độ  : Trung bình
# Mục đích: Xóa dấu vết
# Chi tiết: Detects uncommon and potentially suspicious one-liner command containing both "ping" and "copy" at the same time, which is usually used by malware.
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*ping*" CommandLine="*copy *" CommandLine="* -n *" OR CommandLine="* /n *" OR CommandLine="* –n *" OR CommandLine="* —n *" OR CommandLine="* ―n *" CommandLine="* -y *" OR CommandLine="* /y *" OR CommandLine="* –y *" OR CommandLine="* —y *" OR CommandLine="* ―y *"

# ── Suspicious Ping/Del Command Combination ──
# Mức độ  : Cao
# Mục đích: Xóa dấu vết
# Chi tiết: Detects a method often used by ransomware. Which combines the "ping" to wait a couple of seconds and then "del" to delete the file in question. Its used to hide the file responsible for the initial in
EventCode=4688 Channel="Security" CommandLine="* -n *" OR CommandLine="* /n *" OR CommandLine="* –n *" OR CommandLine="* —n *" OR CommandLine="* ―n *" CommandLine="*Nul*" CommandLine="* -f *" OR CommandLine="* /f *" OR CommandLine="* –f *" OR CommandLine="* —f *" OR CommandLine="* ―f *" OR CommandLine="* -q *" OR CommandLine="* /q *" OR CommandLine="* –q *" OR CommandLine="* —q *" OR CommandLine="* ―q *" CommandLine="*ping*" CommandLine="*del *"

# ── Potentially Suspicious CMD Shell Output Redirect ──
# Mức độ  : Trung bình
# Chi tiết: Detects inline Windows shell commands redirecting output via the ">" symbol to a suspicious location. This technique is sometimes used by malicious actors in order to redirect the output of reconnaiss
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine IN ("*>*%APPDATA%\\*", "*>*%TEMP%\\*", "*>*%TMP%\\*", "*>*%USERPROFILE%\\*", "*>*C:\\ProgramData\\*", "*>*C:\\Temp\\*", "*>*C:\\Users\\Public\\*", "*>*C:\\Windows\\Temp\\*") OR (CommandLine IN ("* >*", "*\">*", "*'>*") CommandLine="*C:\\Users\\*" CommandLine="*\\AppData\\Local\\*")

# ── Directory Removal Via Rmdir ──
# Mức độ  : Thấp
# Mục đích: Xóa dấu vết
# Chi tiết: Detects execution of the builtin "rmdir" command in order to delete directories. Adversaries may delete files left behind by the actions of their intrusion activity. Malware, tools, or other non-nativ
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*rmdir*" CommandLine IN ("*/s*", "*/q*")

# ── Copy From VolumeShadowCopy Via Cmd.EXE ──
# Mức độ  : Cao
# Mục đích: Phá hủy backup/recovery
# Chi tiết: Detects the execution of the builtin "copy" command that targets a shadow copy (sometimes used to copy registry hives that are in use)
EventCode=4688 Channel="Security" CommandLine="*copy *" CommandLine="*\\\\?\\GLOBALROOT\\Device\\HarddiskVolumeShadowCopy*"

# ── Read Contents From Stdin Via Cmd.EXE ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detect the use of "<" to read and potentially execute a file via cmd.exe
EventCode=4688 Channel="Security" OriginalFileName="Cmd.Exe" OR NewProcessName="*\\cmd.exe" CommandLine="*<*"

# ── Sticky Key Like Backdoor Execution ──
# Mức độ  : Nghiêm trọng
# Chi tiết: Detects the usage and installation of a backdoor that uses an option to register a malicious debugger for built-in tools that are accessible in the login screen
EventCode=4688 Channel="Security" CommandLine IN ("*sethc.exe*", "*utilman.exe*", "*osk.exe*", "*Magnify.exe*", "*Narrator.exe*", "*DisplaySwitch.exe*") ParentProcessName="*\\winlogon.exe" NewProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe", "*\\wt.exe")

# ── Persistence Via Sticky Key Backdoor ──
# Mức độ  : Nghiêm trọng
# Chi tiết: By replacing the sticky keys executable with the local admins CMD executable, an attacker is able to access a privileged windows console session without authenticating to the system. When the sticky k
EventCode=4688 Channel="Security" CommandLine="*copy *" CommandLine="*/y *" CommandLine="*C:\\windows\\system32\\cmd.exe C:\\windows\\system32\\sethc.exe*"

# ── Potential Download/Upload Activity Using Type Command ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects usage of the "type" command to download/upload data from WebDAV server
EventCode=4688 Channel="Security" (CommandLine="*type *" CommandLine="* > \\\\*") OR (CommandLine="*type \\\\*" CommandLine="* > *")

# ── Unusual Parent Process For Cmd.EXE ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious parent process for cmd.exe
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" ParentProcessName IN ("*\\csrss.exe", "*\\ctfmon.exe", "*\\dllhost.exe", "*\\epad.exe", "*\\FlashPlayerUpdateService.exe", "*\\GoogleUpdate.exe", "*\\jucheck.exe", "*\\jusched.exe", "*\\LogonUI.exe", "*\\lsass.exe", "*\\regsvr32.exe", "*\\SearchIndexer.exe", "*\\SearchProtocolHost.exe", "*\\SIHClient.exe", "*\\sihost.exe", "*\\slui.exe", "*\\spoolsv.exe", "*\\sppsvc.exe", "*\\taskhostw.exe", "*\\unsecapp.exe", "*\\WerFault.exe", "*\\wermgr.exe", "*\\wlanext.exe", "*\\WUDFHost.exe")

# ── New Generic Credentials Added Via Cmdkey.EXE ──
# Mức độ  : Trung bình
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects usage of "cmdkey.exe" to add generic credentials. As an example, this can be used before connecting to an RDP session via command line interface.
EventCode=4688 Channel="Security" NewProcessName="*\\cmdkey.exe" OR OriginalFileName="cmdkey.exe" CommandLine="* -g*" OR CommandLine="* /g*" OR CommandLine="* –g*" OR CommandLine="* —g*" OR CommandLine="* ―g*" CommandLine="* -u*" OR CommandLine="* /u*" OR CommandLine="* –u*" OR CommandLine="* —u*" OR CommandLine="* ―u*" CommandLine="* -p*" OR CommandLine="* /p*" OR CommandLine="* –p*" OR CommandLine="* —p*" OR CommandLine="* ―p*"

# ── Potential Reconnaissance For Cached Credentials Via Cmdkey.EXE ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects usage of cmdkey to look for cached credentials on the system
EventCode=4688 Channel="Security" NewProcessName="*\\cmdkey.exe" OR OriginalFileName="cmdkey.exe" CommandLine="* -l*" OR CommandLine="* /l*" OR CommandLine="* –l*" OR CommandLine="* —l*" OR CommandLine="* ―l*"

# ── Potential Arbitrary File Download Via Cmdl32.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of Cmdl32 with the "/vpn" and "/lan" flags. Attackers can abuse this utility in order to download arbitrary files via a configuration file. Inspect the location and the content of th
EventCode=4688 Channel="Security" NewProcessName="*\\cmdl32.exe" OR OriginalFileName="CMDL32.EXE" CommandLine="*/vpn*" CommandLine="*/lan*"

# ── CMSTP Execution Process Creation ──
# Mức độ  : Cao
# Chi tiết: Detects various indicators of Microsoft Connection Manager Profile Installer execution
EventCode=4688 Channel="Security" ParentProcessName="*\\cmstp.exe"

# ── OpenEDR Spawning Command Shell ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script; Di chuyển ngang mạng
# Chi tiết: Detects the OpenEDR ssh-shellhost.exe spawning a command shell (cmd.exe) or PowerShell with PTY (pseudo-terminal) capabilities. This may indicate remote command execution through OpenEDR's remote mana
EventCode=4688 Channel="Security" CommandLine="*--pty*" ParentProcessName="*\\ITSMService.exe" NewProcessName="*\\ssh-shellhost.exe" CommandLine IN ("*bash*", "*cmd*", "*powershell*", "*pwsh*")

# ── Arbitrary File Download Via ConfigSecurityPolicy.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of "ConfigSecurityPolicy.EXE", a binary part of Windows Defender used to manage settings in Windows Defender. Users can configure different pilot collections for each of the co-m
EventCode=4688 Channel="Security" CommandLine="*ConfigSecurityPolicy.exe*" OR NewProcessName="*\\ConfigSecurityPolicy.exe" OR OriginalFileName="ConfigSecurityPolicy.exe" CommandLine IN ("*ftp://*", "*http://*", "*https://*")

# ── Powershell Executed From Headless ConHost Process ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the use of powershell commands from headless ConHost window. The "--headless" flag hides the windows from the user upon execution.
EventCode=4688 Channel="Security" NewProcessName="*\\conhost.exe" OR OriginalFileName="CONHOST.EXE" CommandLine="*--headless*" CommandLine="*powershell*"

# ── Suspicious High IntegrityLevel Conhost Legacy Option ──
# Mức độ  : Thông tin
# Chi tiết: ForceV1 asks for information directly from the kernel space. Conhost connects to the console application. High IntegrityLevel means the process is running with elevated privileges, such as an Administ
EventCode=4688 Channel="Security" CommandLine="*conhost.exe*" CommandLine="*0xffffffff*" CommandLine="*-ForceV1*" MandatoryLabel IN ("S-1-16-12288", "None")

# ── Uncommon Child Process Of Conhost.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects uncommon "conhost" child processes. This could be a sign of "conhost" usage as a LOLBIN or potential process injection activity.
EventCode=4688 Channel="Security" ParentProcessName="*\\conhost.exe" NOT (NewProcessName="*:\\Windows\\System32\\conhost.exe" OR NOT NewProcessName=* OR NewProcessName="") NOT Provider_Name="SystemTraceProvider-Process"

# ── Potentially Suspicious Child Processes Spawned by ConHost ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious child processes related to Windows Shell utilities spawned by `conhost.exe`, which could indicate malicious activity using trusted system components.
EventCode=4688 Channel="Security" ParentProcessName="*\\conhost.exe" NewProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\wscript.exe") OR OriginalFileName IN ("cmd.exe", "cscript.exe", "mshta.exe", "powershell_ise.exe", "powershell.exe", "pwsh.dll", "regsvr32.exe", "wscript.exe")

# ── Conhost Spawned By Uncommon Parent Process ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects when the Console Window Host (conhost.exe) process is spawned by an uncommon parent process, which could be indicative of potential code injection activity.
EventCode=4688 Channel="Security" NewProcessName="*\\conhost.exe" ParentProcessName IN ("*\\explorer.exe", "*\\lsass.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\services.exe", "*\\smss.exe", "*\\spoolsv.exe", "*\\svchost.exe", "*\\userinit.exe", "*\\wininit.exe", "*\\winlogon.exe") NOT (ParentCommandLine IN ("*-k apphost -s AppHostSvc*", "*-k imgsvc*", "*-k localService -p -s RemoteRegistry*", "*-k LocalSystemNetworkRestricted -p -s NgcSvc*", "*-k NetSvcs -p -s NcaSvc*", "*-k netsvcs -p -s NetSetupSvc*", "*-k netsvcs -p -s wlidsvc*", "*-k NetworkService -p -s DoSvc*", "*-k wsappx -p -s AppXSvc*", "*-k wsappx -p -s ClipSVC*", "*-k wusvcs -p -s WaaSMedicSvc*")) NOT (ParentCommandLine IN ("*C:\\Program Files (x86)\\Dropbox\\Client\\*", "*C:\\Program Files\\Dropbox\\Client\\*"))

# ── Control Panel Items ──
# Mức độ  : Cao
# Chi tiết: Detects the malicious use of a control panel item
EventCode=4688 Channel="Security" (NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="*add*" CommandLine="*CurrentVersion\\Control Panel\\CPLs*") OR (CommandLine="*.cpl" NOT (CommandLine IN ("*\\System32\\*", "*%System%*", "*|C:\\Windows\\system32|*") OR (CommandLine="*regsvr32 *" CommandLine="* /s *" CommandLine="*igfxCPL.cpl*")))

# ── New DMSA Service Account Created in Specific OUs ──
# Mức độ  : Trung bình
# Mục đích: Dùng tài khoản hợp lệ
# Chi tiết: Detects the creation of a dMSASvc account using the New-ADServiceAccount cmdlet in certain OUs. The fact that the Cmdlet is used to create a dMSASvc account in a specific OU is highly suspicious. It i
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe", "*\\powershell_ise.exe") OR OriginalFileName IN ("powershell.exe", "pwsh.dll", "powershell_ise.exe") CommandLine="*New-ADServiceAccount*" CommandLine="*-CreateDelegatedServiceAccount*" CommandLine="*-path*"

# ── CreateDump Process Dump ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Dump thông tin xác thực
# Chi tiết: Detects uses of the createdump.exe LOLOBIN utility to dump process memory
EventCode=4688 Channel="Security" NewProcessName="*\\createdump.exe" OR OriginalFileName="FX_VER_INTERNALNAME_STR" CommandLine IN ("* -u *", "* --full *", "* -f *", "* --name *", "*.dmp *")

# ── Windows Credential Guard Registry Tampering Via CommandLine ──
# Mức độ  : Cao
# Chi tiết: Detects attempts to add, modify, or delete Windows Credential Guard related registry keys or values via command line tools such as Reg.exe or PowerShell. Credential Guard uses virtualization-based sec
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe", "*\\reg.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll", "reg.exe") CommandLine IN ("*add *", "*New-ItemProperty *", "*Set-ItemProperty *", "*si *", "*delete *", "*del *", "*Remove-ItemProperty *", "*rp *") CommandLine IN ("*\\Control\\DeviceGuard*", "*\\Control\\LSA*", "*Software\\Policies\\Microsoft\\Windows\\DeviceGuard*") CommandLine IN ("*EnableVirtualizationBasedSecurity*", "*RequirePlatformSecurityFeatures*", "*LsaCfgFlags*")

# ── Dynamic .NET Compilation Via Csc.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "csc.exe" to compile .NET code. Attackers often leverage this to compile code on the fly and use it in other stages.
EventCode=4688 Channel="Security" NewProcessName="*\\csc.exe"
| rex field=CommandLine "(?<CommandLineMatch>(?:[Pp]rogram[Dd]ata|%(?:[Ll]ocal)?[Aa]pp[Dd]ata%|\\\\[Aa]pp[Dd]ata\\\\(?:[Ll]ocal(?:[Ll]ow)?|[Rr]oaming))\\\\[^\\\\]{1,256}$)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| search CommandLine IN ("*:\\Perflogs\\*", "*:\\Users\\Public\\*", "*\\AppData\\Local\\Temp\\*", "*\\Temporary Internet*", "*\\Windows\\Temp\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Favorites\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Favourites\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Contacts\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Pictures\\*") OR CommandLineCondition="true" NOT (ParentProcessName IN ("C:\\Program Files (x86)\\*", "C:\\Program Files\\*") OR ParentProcessName="C:\\Windows\\System32\\sdiagnhost.exe" OR ParentProcessName="C:\\Windows\\System32\\inetsrv\\w3wp.exe") NOT (ParentProcessName IN ("C:\\ProgramData\\chocolatey\\choco.exe", "C:\\ProgramData\\chocolatey\\tools\\shimgen.exe") OR ParentCommandLine="*\\ProgramData\\Microsoft\\Windows Defender Advanced Threat Protection*" OR ParentCommandLine IN ("*JwB7ACIAZgBhAGkAbABlAGQAIgA6AHQAcgB1AGUALAAiAG0AcwBnACIAOgAiAEEAbgBzAGkAYgBsAGUAIAByAGUAcQB1AGkAcgBlAHMAIABQAG8AdwBlAHIAUwBoAGUAbABsACAAdgAzAC4AMAAgAG8AcgAgAG4AZQB3AGUAcgAiAH0AJw*", "*cAewAiAGYAYQBpAGwAZQBkACIAOgB0AHIAdQBlACwAIgBtAHMAZwAiADoAIgBBAG4AcwBpAGIAbABlACAAcgBlAHEAdQBpAHIAZQBzACAAUABvAHcAZQByAFMAaABlAGwAbAAgAHYAMwAuADAAIABvAHIAIABuAGUAdwBlAHIAIgB9ACcA*", "*nAHsAIgBmAGEAaQBsAGUAZAAiADoAdAByAHUAZQAsACIAbQBzAGcAIgA6ACIAQQBuAHMAaQBiAGwAZQAgAHIAZQBxAHUAaQByAGUAcwAgAFAAbwB3AGUAcgBTAGgAZQBsAGwAIAB2ADMALgAwACAAbwByACAAbgBlAHcAZQByACIAfQAnA*"))

# ── Csc.EXE Execution Form Potentially Suspicious Parent ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects a potentially suspicious parent of "csc.exe", which could be a sign of payload delivery.
EventCode=4688 Channel="Security" NewProcessName="*\\csc.exe"
| rex field=ParentCommandLine "(?<ParentCommandLineMatch>(?:[Pp]rogram[Dd]ata|%(?:[Ll]ocal)?[Aa]pp[Dd]ata%|\\\\[Aa]pp[Dd]ata\\\\(?:[Ll]ocal(?:[Ll]ow)?|[Rr]oaming))\\\\[^\\\\]{1,256}$)"
| eval ParentCommandLineCondition=if(isnotnull(ParentCommandLineMatch), "true", "false")
| search OR OriginalFileName="csc.exe" ParentProcessName IN ("*\\cscript.exe", "*\\excel.exe", "*\\mshta.exe", "*\\onenote.exe", "*\\outlook.exe", "*\\powerpnt.exe", "*\\winword.exe", "*\\wscript.exe") OR (ParentCommandLine IN ("*-Encoded *", "*FromBase64String*") ParentProcessName IN ("*\\powershell.exe", "*\\pwsh.exe")) OR ParentCommandLineCondition="true" OR ParentCommandLine IN ("*:\\PerfLogs\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Temp\\*", "*\\Temporary Internet*") OR (ParentCommandLine="*:\\Users\\*" ParentCommandLine="*\\Favorites\\*") OR (ParentCommandLine="*:\\Users\\*" ParentCommandLine="*\\Favourites\\*") OR (ParentCommandLine="*:\\Users\\*" ParentCommandLine="*\\Contacts\\*") OR (ParentCommandLine="*:\\Users\\*" ParentCommandLine="*\\Pictures\\*") NOT (ParentProcessName IN ("C:\\Program Files (x86)\\*", "C:\\Program Files\\*") OR ParentProcessName="C:\\Windows\\System32\\sdiagnhost.exe" OR ParentProcessName="C:\\Windows\\System32\\inetsrv\\w3wp.exe") NOT (ParentProcessName="C:\\ProgramData\\chocolatey\\choco.exe" OR ParentCommandLine="*\\ProgramData\\Microsoft\\Windows Defender Advanced Threat Protection*" OR ParentCommandLine IN ("*JwB7ACIAZgBhAGkAbABlAGQAIgA6AHQAcgB1AGUALAAiAG0AcwBnACIAOgAiAEEAbgBzAGkAYgBsAGUAIAByAGUAcQB1AGkAcgBlAHMAIABQAG8AdwBlAHIAUwBoAGUAbABsACAAdgAzAC4AMAAgAG8AcgAgAG4AZQB3AGUAcgAiAH0AJw*", "*cAewAiAGYAYQBpAGwAZQBkACIAOgB0AHIAdQBlACwAIgBtAHMAZwAiADoAIgBBAG4AcwBpAGIAbABlACAAcgBlAHEAdQBpAHIAZQBzACAAUABvAHcAZQByAFMAaABlAGwAbAAgAHYAMwAuADAAIABvAHIAIABuAGUAdwBlAHIAIgB9ACcA*", "*nAHsAIgBmAGEAaQBsAGUAZAAiADoAdAByAHUAZQAsACIAbQBzAGcAIgA6ACIAQQBuAHMAaQBiAGwAZQAgAHIAZQBxAHUAaQByAGUAcwAgAFAAbwB3AGUAcgBTAGgAZQBsAGwAIAB2ADMALgAwACAAbwByACAAbgBlAHcAZQByACIAfQAnA*"))

# ── Suspicious Csi.exe Usage ──
# Mức độ  : Trung bình
# Chi tiết: Csi.exe is a signed binary from Microsoft that comes with Visual Studio and provides C# interactive capabilities. It can be used to run C# code from a file passed as a parameter in command line. Early
EventCode=4688 Channel="Security" NewProcessName IN ("*\\csi.exe", "*\\rcsi.exe") OR OriginalFileName IN ("csi.exe", "rcsi.exe") Company="Microsoft Corporation"

# ── Active Directory Structure Export Via Csvde.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of "csvde.exe" in order to export organizational Active Directory structure.
EventCode=4688 Channel="Security" NewProcessName="*\\csvde.exe" OR OriginalFileName="csvde.exe" CommandLine="* -f*" NOT CommandLine="* -i*"

# ── Potential Cookies Session Hijacking ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "curl.exe" with the "-c" flag in order to save cookie data.
EventCode=4688 Channel="Security" NewProcessName="*\\curl.exe"
| rex field=CommandLine "(?<CommandLineMatch>\\s-c\\s)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| search OR OriginalFileName="curl.exe" CommandLineCondition="true" OR CommandLine="*--cookie-jar*"

# ── Curl Web Request With Potential Custom User-Agent ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "curl.exe" with a potential custom "User-Agent". Attackers can leverage this to download or exfiltrate data via "curl" to a domain that only accept specific "User-Agent" strings
EventCode=4688 Channel="Security" NewProcessName="*\\curl.exe"
| rex field=CommandLine "(?<CommandLineMatch>\\s-H\\s)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| search OR OriginalFileName="curl.exe" CommandLineCondition="true" OR CommandLine="*--header*" CommandLine="*User-Agent:*"

# ── File Download From IP URL Via Curl.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects file downloads directly from IP address URL using curl.exe
EventCode=4688 Channel="Security" NewProcessName="*\\curl.exe" OR OriginalFileName="curl.exe" CommandLine="*http*" CommandLine IN ("* -O*", "*--remote-name*", "*--output*") NOT (CommandLine IN ("*.bat", "*.bat\"", "*.dat", "*.dat\"", "*.dll", "*.dll\"", "*.exe", "*.exe\"", "*.gif", "*.gif\"", "*.hta", "*.hta\"", "*.jpeg", "*.jpeg\"", "*.log", "*.log\"", "*.msi", "*.msi\"", "*.png", "*.png\"", "*.ps1", "*.ps1\"", "*.psm1", "*.psm1\"", "*.vbe", "*.vbe\"", "*.vbs", "*.vbs\"", "*.bat'", "*.dat'", "*.dll'", "*.exe'", "*.gif'", "*.hta'", "*.jpeg'", "*.log'", "*.msi'", "*.png'", "*.ps1'", "*.psm1'", "*.vbe'", "*.vbs'"))
| regex CommandLine="://[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}"

# ── Suspicious File Download From IP Via Curl.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects potentially suspicious file downloads directly from IP addresses using curl.exe
EventCode=4688 Channel="Security" NewProcessName="*\\curl.exe" OR OriginalFileName="curl.exe" CommandLine="*http*" CommandLine IN ("* -O*", "*--remote-name*", "*--output*") CommandLine IN ("*.bat", "*.bat\"", "*.dat", "*.dat\"", "*.dll", "*.dll\"", "*.exe", "*.exe\"", "*.gif", "*.gif\"", "*.hta", "*.hta\"", "*.jpeg", "*.jpeg\"", "*.log", "*.log\"", "*.msi", "*.msi\"", "*.png", "*.png\"", "*.ps1", "*.ps1\"", "*.psm1", "*.psm1\"", "*.vbe", "*.vbe\"", "*.vbs", "*.vbs\"", "*.bat'", "*.dat'", "*.dll'", "*.exe'", "*.gif'", "*.hta'", "*.jpeg'", "*.log'", "*.msi'", "*.png'", "*.ps1'", "*.psm1'", "*.vbe'", "*.vbs'")
| regex CommandLine="://[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}"

# ── Suspicious File Download From File Sharing Domain Via Curl.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects potentially suspicious file download from file sharing domains using curl.exe
EventCode=4688 Channel="Security" NewProcessName="*\\curl.exe" OR OriginalFileName="curl.exe" CommandLine IN ("*.githubusercontent.com*", "*0x0.st*", "*anonfiles.com*", "*bashupload.com*", "*cdn.discordapp.com*", "*chunk.io*", "*ddns.net*", "*dl.dropboxusercontent.com*", "*ghostbin.co*", "*github.com*", "*glitch.me*", "*gofile.io*", "*hastebin.com*", "*mediafire.com*", "*mega.nz*", "*onrender.com*", "*pages.dev*", "*paste.ee*", "*pastebin.com*", "*pastebin.pl*", "*pastetext.net*", "*pixeldrain.com*", "*privatlab.com*", "*privatlab.net*", "*send.exploit.in*", "*sendspace.com*", "*storage.googleapis.com*", "*storjshare.io*", "*supabase.co*", "*temp.sh*", "*transfer.sh*", "*trycloudflare.com*", "*ufile.io*", "*w3spaces.com*", "*workers.dev*", "*x0.at*") CommandLine="*http*" CommandLine IN ("* -O*", "*--remote-name*", "*--output*") CommandLine IN ("*.ps1", "*.ps1'", "*.ps1\"", "*.dat", "*.dat'", "*.dat\"", "*.msi", "*.msi'", "*.msi\"", "*.bat", "*.bat'", "*.bat\"", "*.exe", "*.exe'", "*.exe\"", "*.vbs", "*.vbs'", "*.vbs\"", "*.vbe", "*.vbe'", "*.vbe\"", "*.hta", "*.hta'", "*.hta\"", "*.dll", "*.dll'", "*.dll\"", "*.psm1", "*.psm1'", "*.psm1\"")

# ── Insecure Transfer Via Curl.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "curl.exe" with the "--insecure" flag.
EventCode=4688 Channel="Security" NewProcessName="*\\curl.exe"
| rex field=CommandLine "(?<CommandLineMatch>\\s-k\\s)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| search OR OriginalFileName="curl.exe" CommandLineCondition="true" OR CommandLine="*--insecure*"

# ── Insecure Proxy/DOH Transfer Via Curl.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "curl.exe" with the "insecure" flag over proxy or DOH.
EventCode=4688 Channel="Security" NewProcessName="*\\curl.exe" OR OriginalFileName="curl.exe" CommandLine IN ("*--doh-insecure*", "*--proxy-insecure*")

# ── Local File Read Using Curl.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "curl.exe" with the "file://" protocol handler in order to read local files.
EventCode=4688 Channel="Security" NewProcessName="*\\curl.exe" OR OriginalFileName="curl.exe" CommandLine="*file:///*"

# ── NTLM Hash Leak Via Curl NTLM Authentication ──
# Mức độ  : Cao
# Chi tiết: Detects the use of curl with NTLM authentication and empty credentials (-u :), which can be abused to leak the currently logged-in user's NTLMv2 challenge-response to an attacker-controlled server, en
EventCode=4688 Channel="Security" NewProcessName="*\\curl.exe" OR OriginalFileName="curl.exe" CommandLine="*--ntlm*"
| regex CommandLine="(?i)\\s(-u|--user)\\s*:"

# ── Suspicious Curl.EXE Download ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects a suspicious curl process start on Windows and outputs the requested document to a local file
EventCode=4688 Channel="Security" NewProcessName="*\\curl.exe" OR Product="The curl executable" CommandLine IN ("*%AppData%*", "*%Public%*", "*%Temp%*", "*%tmp%*", "*\\AppData\\*", "*\\Desktop\\*", "*\\Temp\\*", "*\\Users\\Public\\*", "*C:\\PerfLogs\\*", "*C:\\ProgramData\\*", "*C:\\Windows\\Temp\\*") OR CommandLine IN ("*.dll", "*.gif", "*.jpeg", "*.jpg", "*.png", "*.temp", "*.tmp", "*.txt", "*.vbe", "*.vbs") NOT (CommandLine="*--silent --show-error --output *" CommandLine="*gfw-httpget-*" CommandLine="*AppData*" ParentProcessName="C:\\Program Files\\Git\\usr\\bin\\sh.exe" NewProcessName="C:\\Program Files\\Git\\mingw64\\bin\\curl.exe")

# ── Curl File Upload To File Sharing Websites ──
# Mức độ  : Cao
# Chi tiết: Detects usage of curl to upload files to known file sharing domains, which may indicate data exfiltration.
EventCode=4688 Channel="Security" NewProcessName="*\\curl.exe"
| rex field=CommandLine "(?<CommandLineMatch>\\s-[FTd]\\s)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch2>\\s-sT\\s)"
| eval CommandLineCondition2=if(isnotnull(CommandLineMatch2), "true", "false")
| search OR OriginalFileName="curl.exe" CommandLine IN ("*0x0.st*", "*bashupload.com*", "*chunk.io*", "*file.io*", "*filebin.net*", "*pastebin*", "*send.firefox.com*", "*temp.sh*", "*transfer.sh*", "*ufile.io*", "*uploadfiles.io*", "*wetransfer.com*", "*x0.at*") CommandLine IN ("* --form*", "* --upload-file*", "* --data*", "* -X POST*", "* --request POST *") OR CommandLineCondition="true" OR CommandLineCondition2="true"

# ── Suspicious CustomShellHost Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of CustomShellHost.exe where the child isn't located in 'C:\Windows\explorer.exe'. CustomShellHost is a known LOLBin that can be abused by attackers for defense evasion technique
EventCode=4688 Channel="Security" ParentProcessName="*\\CustomShellHost.exe" NOT NewProcessName="C:\\Windows\\explorer.exe"

# ── ManageEngine Endpoint Central Dctask64.EXE Potential Abuse ──
# Mức độ  : Cao
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: Detects the execution of "dctask64.exe", a signed binary by ZOHO Corporation part of ManageEngine Endpoint Central. This binary can be abused for DLL injection, arbitrary command and process execution
EventCode=4688 Channel="Security" NewProcessName="*\\dctask64.exe" OR Hashes IN ("*IMPHASH=6834B1B94E49701D77CCB3C0895E1AFD*", "*IMPHASH=1BB6F93B129F398C7C4A76BB97450BBA*", "*IMPHASH=FAA2AC19875FADE461C8D89DCF2710A3*", "*IMPHASH=F1039CED4B91572AB7847D26032E6BBF*") CommandLine IN ("* executecmd64 *", "* invokeexe *", "* injectDll *")

# ── Uncommon Child Process Of Defaultpack.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects uncommon child processes of "DefaultPack.EXE" binary as a proxy to launch other programs
EventCode=4688 Channel="Security" ParentProcessName="*\\DefaultPack.exe"

# ── PowerShell Defender Threat Severity Default Action Set to 'Allow' or 'NoAction' ──
# Mức độ  : Cao
# Chi tiết: Detects the use of PowerShell to execute the 'Set-MpPreference' cmdlet to configure Windows Defender's threat severity default action to 'Allow' (value '6') or 'NoAction' (value '9'). This is a highly
EventCode=4688 Channel="Security" CommandLine="*Set-MpPreference*" CommandLine IN ("*-LowThreatDefaultAction*", "*-ModerateThreatDefaultAction*", "*-HighThreatDefaultAction*", "*-SevereThreatDefaultAction*", "*-ltdefac *", "*-mtdefac *", "*-htdefac *", "*-stdefac *") CommandLine IN ("*Allow*", "*6*", "*NoAction*", "*9*")

# ── Windows Defender Context Menu Removed ──
# Mức độ  : Cao
# Chi tiết: Detects the use of reg.exe or PowerShell to delete the Windows Defender context menu handler registry keys. This action removes the "Scan with Microsoft Defender" option from the right-click menu for 
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\reg.exe") OR OriginalFileName IN ("powershell_ise.EXE", "PowerShell.EXE", "pwsh.dll", "reg.exe") CommandLine IN ("*del*", "*Remove-Item*", "*ri *") CommandLine="*\\shellex\\ContextMenuHandlers\\EPP*"

# ── Remote File Download Via Desktopimgdownldr Utility ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects the desktopimgdownldr utility being used to download a remote file. An adversary may use desktopimgdownldr to download arbitrary files as an alternative to certutil.
EventCode=4688 Channel="Security" CommandLine="*/lockscreenurl:http*" NewProcessName="*\\desktopimgdownldr.exe" ParentProcessName="*\\desktopimgdownldr.exe"

# ── Suspicious Desktopimgdownldr Command ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects a suspicious Microsoft desktopimgdownldr execution with parameters used to download files from the Internet
EventCode=4688 Channel="Security" (CommandLine="* /lockscreenurl:*" NOT (CommandLine IN ("*.jpg*", "*.jpeg*", "*.png*"))) OR (CommandLine="*reg delete*" CommandLine="*\\PersonalizationCSP*")

# ── Devcon Execution Disabling VMware VMCI Device ──
# Mức độ  : Cao
# Chi tiết: Detects execution of devcon.exe with commands that disable the VMware Virtual Machine Communication Interface (VMCI) device. This can be legitimate during VMware Tools troubleshooting or driver confli
EventCode=4688 Channel="Security" NewProcessName="*\\devcon.exe" OR OriginalFileName="DevCon.exe" CommandLine="* disable *" CommandLine IN ("*15AD&DEV_0740*", "*VMWVMCIHOSTDEV*")

# ── DeviceCredentialDeployment Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of DeviceCredentialDeployment to hide a process from view.
EventCode=4688 Channel="Security" NewProcessName="*\\DeviceCredentialDeployment.exe"

# ── Potential DLL Sideloading Via DeviceEnroller.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of the PhoneDeepLink parameter to potentially sideload a DLL file that does not exist. This non-existent DLL file is named "ShellChromeAPI.dll". Adversaries can drop their own renamed 
EventCode=4688 Channel="Security" NewProcessName="*\\deviceenroller.exe" OR OriginalFileName="deviceenroller.exe" CommandLine="*/PhoneDeepLink*"

# ── Arbitrary MSI Download Via Devinit.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects a certain command line flag combination used by "devinit.exe", which can be abused as a LOLBIN to download arbitrary MSI packages on a Windows system
EventCode=4688 Channel="Security" CommandLine="* -t msi-install *" CommandLine="* -i http*"

# ── Potentially Suspicious Child Process Of ClickOnce Application ──
# Mức độ  : Trung bình
# Chi tiết: Detects potentially suspicious child processes of a ClickOnce deployment application
EventCode=4688 Channel="Security" ParentProcessName="*\\AppData\\Local\\Apps\\2.0\\*" NewProcessName IN ("*\\calc.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\explorer.exe", "*\\mshta.exe", "*\\net.exe", "*\\net1.exe", "*\\nltest.exe", "*\\notepad.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\reg.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\schtasks.exe", "*\\werfault.exe", "*\\wscript.exe")

# ── DirLister Execution ──
# Mức độ  : Thấp
# Chi tiết: Detect the usage of "DirLister.exe" a utility for quickly listing folder or drive contents. It was seen used by BlackCat ransomware to create a list of accessible directories and files.
EventCode=4688 Channel="Security" OriginalFileName="DirLister.exe" OR NewProcessName="*\\DirLister.exe"

# ── System Information Discovery via Registry Queries ──
# Mức độ  : Thấp
# Mục đích: Thu thập thông tin hệ thống
# Chi tiết: Detects attempts to query system information directly from the Windows Registry.
EventCode=4688 Channel="Security" (CommandLine="*query*" CommandLine="*-v*" OR CommandLine="*/v*" OR CommandLine="*–v*" OR CommandLine="*—v*" OR CommandLine="*―v*" NewProcessName="*\\reg.exe") OR (CommandLine IN ("*Get-ItemPropertyValue*", "*gpv*") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe")) CommandLine IN ("*\\SOFTWARE\\Microsoft\\Windows Defender*", "*\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion*", "*\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall*", "*\\SYSTEM\\CurrentControlSet\\Control\\TimeZoneInformation*", "*\\SYSTEM\\CurrentControlSet\\Services*")

# ── Potentially Suspicious Child Process Of DiskShadow.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects potentially suspicious child processes of "Diskshadow.exe". This could be an attempt to bypass parent/child relationship detection or application whitelisting rules.
EventCode=4688 Channel="Security" ParentProcessName="*\\diskshadow.exe" NewProcessName IN ("*\\certutil.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe")

# ── Diskshadow Script Mode - Uncommon Script Extension Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "Diskshadow.exe" in script mode to execute an script with a potentially uncommon extension. Initial baselining of the allowed extension list is required.
EventCode=4688 Channel="Security" OriginalFileName="diskshadow.exe" OR NewProcessName="*\\diskshadow.exe" CommandLine="*-s *" OR CommandLine="*/s *" OR CommandLine="*–s *" OR CommandLine="*—s *" OR CommandLine="*―s *" NOT CommandLine="*.txt*"

# ── Diskshadow Script Mode - Execution From Potential Suspicious Location ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "Diskshadow.exe" in script mode using the "/s" flag where the script is located in a potentially suspicious location.
EventCode=4688 Channel="Security" OriginalFileName="diskshadow.exe" OR NewProcessName="*\\diskshadow.exe" CommandLine="*-s *" OR CommandLine="*/s *" OR CommandLine="*–s *" OR CommandLine="*—s *" OR CommandLine="*―s *" CommandLine IN ("*:\\Temp\\*", "*:\\Windows\\Temp\\*", "*\\AppData\\Local\\*", "*\\AppData\\Roaming\\*", "*\\ProgramData\\*", "*\\Users\\Public\\*")

# ── PowerShell Web Access Feature Enabled Via DISM ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects the use of DISM to enable the PowerShell Web Access feature, which could be used for remote access and potential abuse
EventCode=4688 Channel="Security" NewProcessName="*\\dism.exe" OR OriginalFileName="DISM.EXE" CommandLine="*WindowsPowerShellWebAccess*" CommandLine="*/online*" CommandLine="*/enable-feature*"

# ── Dism Remove Online Package ──
# Mức độ  : Trung bình
# Chi tiết: Deployment Image Servicing and Management tool. DISM is used to enumerate, install, uninstall, configure, and update features and packages in Windows images
EventCode=4688 Channel="Security" (ParentCommandLine="*/Online*" ParentCommandLine="*/Disable-Feature*" NewProcessName="*\\DismHost.exe") OR (CommandLine="*/Online*" CommandLine="*/Disable-Feature*" NewProcessName="*\\Dism.exe")

# ── DLL Sideloading by VMware Xfer Utility ──
# Mức độ  : Cao
# Chi tiết: Detects execution of VMware Xfer utility (VMwareXferlogs.exe) from the non-default directory which may be an attempt to sideload arbitrary DLL
EventCode=4688 Channel="Security" NewProcessName="*\\VMwareXferlogs.exe" NOT NewProcessName="C:\\Program Files\\VMware\\*"

# ── Dllhost.EXE Execution Anomaly ──
# Mức độ  : Cao
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: Detects a "dllhost" process spawning with no commandline arguments which is very rare to happen and could indicate process injection activity or malware mimicking similar system processes.
EventCode=4688 Channel="Security" CommandLine IN ("dllhost.exe", "dllhost") NewProcessName="*\\dllhost.exe" NOT NOT CommandLine=*

# ── DNS Exfiltration and Tunneling Tools Execution ──
# Mức độ  : Cao
# Chi tiết: Well-known DNS Exfiltration tools execution
EventCode=4688 Channel="Security" NewProcessName IN ("*\\iodine.exe", "*\\dnscat2*")

# ── Unusual Child Process of dns.exe ──
# Mức độ  : Cao
# Chi tiết: Detects an unexpected process spawning from dns.exe which may indicate activity related to remote code execution or other forms of exploitation as seen in CVE-2020-1350 (SigRed)
EventCode=4688 Channel="Security" ParentProcessName="*\\dns.exe" NOT NewProcessName="*\\conhost.exe"

# ── Potential Discovery Activity Via Dnscmd.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects an attempt to leverage dnscmd.exe to enumerate the DNS zones of a domain. DNS zones used to host the DNS records for a particular domain.
EventCode=4688 Channel="Security" NewProcessName="*\\dnscmd.exe" CommandLine IN ("*/enumrecords*", "*/enumzones*", "*/ZonePrint*", "*/info*")

# ── New DNS ServerLevelPluginDll Installed Via Dnscmd.EXE ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects the installation of a DNS plugin DLL via ServerLevelPluginDll parameter in registry, which can be used to execute code in context of the DNS server (restart required)
EventCode=4688 Channel="Security" CommandLine="*/config*" CommandLine="*/serverlevelplugindll*" NewProcessName="*\\dnscmd.exe"

# ── Potential Application Whitelisting Bypass via Dnx.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of Dnx.EXE. The Dnx utility allows for the execution of C# code. Attackers might abuse this in order to bypass application whitelisting.
EventCode=4688 Channel="Security" NewProcessName="*\\dnx.exe"

# ── Arbitrary DLL or Csproj Code Execution Via Dotnet.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of arbitrary DLLs or unsigned code via a ".csproj" files via Dotnet.EXE.
EventCode=4688 Channel="Security" NewProcessName="*\\dotnet.exe" OR OriginalFileName=".NET Host" CommandLine IN ("*.csproj", "*.csproj\"", "*.dll", "*.dll\"", "*.csproj'", "*.dll'") NOT (CommandLine="*C:\\ProgramData\\CSScriptNpp\\*" CommandLine="*-cscs_path:*" CommandLine="*\\cs-script\\cscs.dll*" ParentProcessName IN ("C:\\Program Files (x86)\\Notepad++\\notepad++.exe", "C:\\Program Files\\Notepad++\\notepad++.exe"))

# ── Binary Proxy Execution Via Dotnet-Trace.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects commandline arguments for executing a child process via dotnet-trace.exe
EventCode=4688 Channel="Security" NewProcessName="*\\dotnet-trace.exe" OR OriginalFileName="dotnet-trace.dll" CommandLine="*-- *" CommandLine="*collect*"

# ── Process Memory Dump Via Dotnet-Dump ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of "dotnet-dump" with the "collect" flag. The execution could indicate potential process dumping of critical processes such as LSASS.
EventCode=4688 Channel="Security" NewProcessName="*\\dotnet-dump.exe" OR OriginalFileName="dotnet-dump.dll" CommandLine="*collect*"

# ── Potential Recon Activity Using DriverQuery.EXE ──
# Mức độ  : Cao
# Chi tiết: Detect usage of the "driverquery" utility to perform reconnaissance on installed drivers
EventCode=4688 Channel="Security" NewProcessName="*driverquery.exe" OR OriginalFileName="drvqry.exe" ParentProcessName IN ("*\\cscript.exe", "*\\mshta.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") OR ParentProcessName IN ("*\\AppData\\Local\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*")

# ── DriverQuery.EXE Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detect usage of the "driverquery" utility. Which can be used to perform reconnaissance on installed drivers
EventCode=4688 Channel="Security" NewProcessName="*driverquery.exe" OR OriginalFileName="drvqry.exe" NOT (ParentProcessName IN ("*\\cscript.exe", "*\\mshta.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") OR ParentProcessName IN ("*\\AppData\\Local\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*"))

# ── Potentially Over Permissive Permissions Granted Using Dsacls.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of Dsacls to grant over permissive permissions
EventCode=4688 Channel="Security" NewProcessName="*\\dsacls.exe" OR OriginalFileName="DSACLS.EXE" CommandLine="* /G *" CommandLine IN ("*GR*", "*GE*", "*GW*", "*GA*", "*WP*", "*WD*")

# ── Potential Password Spraying Attempt Using Dsacls.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects possible password spraying attempts using Dsacls
EventCode=4688 Channel="Security" NewProcessName="*\\dsacls.exe" OR OriginalFileName="DSACLS.EXE" CommandLine="*/user:*" CommandLine="*/passwd:*"

# ── Domain Trust Discovery Via Dsquery ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "dsquery.exe" for domain trust discovery
EventCode=4688 Channel="Security" NewProcessName="*\\dsquery.exe" OR OriginalFileName="dsquery.exe" CommandLine="*trustedDomain*"

# ── Suspicious Kernel Dump Using Dtrace ──
# Mức độ  : Cao
# Mục đích: Thu thập thông tin hệ thống
# Chi tiết: Detects suspicious way to dump the kernel on Windows systems using dtrace.exe, which is available on Windows systems since Windows 10 19H1
EventCode=4688 Channel="Security" (CommandLine="*lkd(0)*" NewProcessName="*\\dtrace.exe") OR (CommandLine="*syscall:::return*" CommandLine="*lkd(*")

# ── Potential Windows Defender AV Bypass Via Dump64.EXE Rename ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects when a user is potentially trying to bypass the Windows Defender AV by renaming a tool to dump64.exe and placing it in the Visual Studio folder. Currently the rule is covering only usage of pr
EventCode=4688 Channel="Security" NewProcessName=":\\Program Files*" NewProcessName="*\\Microsoft Visual Studio\\*" NewProcessName="*\\dump64.exe" OriginalFileName="procdump" OR CommandLine IN ("* -ma *", "* -mp *")

# ── DumpMinitool Execution ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình; Dump thông tin xác thực
# Chi tiết: Detects the use of "DumpMinitool.exe" a tool that allows the dump of process memory via the use of the "MiniDumpWriteDump"
EventCode=4688 Channel="Security" NewProcessName IN ("*\\DumpMinitool.exe", "*\\DumpMinitool.x86.exe", "*\\DumpMinitool.arm64.exe") OR OriginalFileName IN ("DumpMinitool.exe", "DumpMinitool.x86.exe", "DumpMinitool.arm64.exe") CommandLine IN ("* Full*", "* Mini*", "* WithHeap*")

# ── Suspicious DumpMinitool Execution ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Dump thông tin xác thực
# Chi tiết: Detects suspicious ways to use the "DumpMinitool.exe" binary
EventCode=4688 Channel="Security" NewProcessName IN ("*\\DumpMinitool.exe", "*\\DumpMinitool.x86.exe", "*\\DumpMinitool.arm64.exe") OR OriginalFileName IN ("DumpMinitool.exe", "DumpMinitool.x86.exe", "DumpMinitool.arm64.exe") NOT (NewProcessName IN ("*\\Microsoft Visual Studio\\*", "*\\Extensions\\*")) OR CommandLine="*.txt*" OR (CommandLine IN ("* Full*", "* Mini*", "* WithHeap*") NOT CommandLine="*--dumpType*")

# ── New Capture Session Launched Via DXCap.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of "DXCap.EXE" with the "-c" flag, which allows a user to launch any arbitrary binary or windows package through DXCap itself. This can be abused to potentially bypass applicatio
EventCode=4688 Channel="Security" NewProcessName="*\\DXCap.exe" OR OriginalFileName="DXCap.exe" CommandLine="* -c *"

# ── Esentutl Gather Credentials ──
# Mức độ  : Trung bình
# Mục đích: Dump thông tin xác thực
# Chi tiết: Conti recommendation to its affiliates to use esentutl to access NTDS dumped file. Trickbot also uses this utilities to get MSEdge info via its module pwgrab.
EventCode=4688 Channel="Security" CommandLine="*esentutl*" CommandLine="* /p*"

# ── Copying Sensitive Files with Credential Data ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Files with well-known filenames (sensitive files with credential data) copying
EventCode=4688 Channel="Security" (NewProcessName="*\\esentutl.exe" OR OriginalFileName="\\esentutl.exe" CommandLine="*vss*" OR CommandLine="* -m *" OR CommandLine="* /m *" OR CommandLine="* –m *" OR CommandLine="* —m *" OR CommandLine="* ―m *" OR CommandLine="* -y *" OR CommandLine="* /y *" OR CommandLine="* –y *" OR CommandLine="* —y *" OR CommandLine="* ―y *") OR CommandLine IN ("*\\config\\RegBack\\sam*", "*\\config\\RegBack\\security*", "*\\config\\RegBack\\system*", "*\\config\\sam*", "*\\config\\security*", "*\\config\\system *", "*\\repair\\sam*", "*\\repair\\security*", "*\\repair\\system*", "*\\windows\\ntds\\ntds.dit*")

# ── Esentutl Steals Browser Information ──
# Mức độ  : Trung bình
# Chi tiết: One way Qbot steals sensitive information is by extracting browser data from Internet Explorer and Microsoft Edge by using the built-in utility esentutl.exe
EventCode=4688 Channel="Security" NewProcessName="*\\esentutl.exe" OR OriginalFileName="esentutl.exe" CommandLine="*-r*" OR CommandLine="*/r*" OR CommandLine="*–r*" OR CommandLine="*—r*" OR CommandLine="*―r*" CommandLine="*\\Windows\\WebCache*"

# ── Security Event Logging Disabled via MiniNt Registry Key - Process ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects attempts to disable security event logging by adding the `MiniNt` registry key. This key is used to disable the Windows Event Log service, which collects and stores event logs from the operati
EventCode=4688 Channel="Security" (NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="* add *" CommandLine="*\\SYSTEM\\CurrentControlSet\\Control\\MiniNt*") OR (NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe", "*\\powershell_ise.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine IN ("*New-Item *", "*ni *") CommandLine="*\\SYSTEM\\CurrentControlSet\\Control\\MiniNt*")

# ── Potentially Suspicious Event Viewer Child Process ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects uncommon or suspicious child processes of "eventvwr.exe" which might indicate a UAC bypass attempt
EventCode=4688 Channel="Security" ParentProcessName="*\\eventvwr.exe" NOT (NewProcessName IN ("*:\\Windows\\System32\\mmc.exe", "*:\\Windows\\System32\\WerFault.exe", "*:\\Windows\\SysWOW64\\WerFault.exe"))

# ── Potentially Suspicious Cabinet File Expansion ──
# Mức độ  : Trung bình
# Chi tiết: Detects the expansion or decompression of cabinet files from potentially suspicious or uncommon locations, e.g. seen in Iranian MeteorExpress related attacks
EventCode=4688 Channel="Security" CommandLine="*-F:*" OR CommandLine="*/F:*" OR CommandLine="*–F:*" OR CommandLine="*—F:*" OR CommandLine="*―F:*" NewProcessName="*\\expand.exe" CommandLine IN ("*:\\Perflogs\\*", "*:\\ProgramData*", "*:\\Users\\Public\\*", "*:\\Windows\\Temp\\*", "*\\Admin$\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Roaming\\*", "*\\C$\\*", "*\\Temporary Internet*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Favorites\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Favourites\\*") OR (CommandLine="*:\\Users\\*" CommandLine="*\\Contacts\\*") NOT (CommandLine="*C:\\ProgramData\\Dell\\UpdateService\\Temp\\*" ParentProcessName="C:\\Program Files (x86)\\Dell\\UpdateService\\ServiceShell.exe")

# ── Explorer Process Tree Break ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects a command line process that uses explorer.exe to launch arbitrary commands or binaries, which is similar to cmd.exe /c, only it breaks the process tree and makes its parent a new instance of e
EventCode=4688 Channel="Security" CommandLine="*/factory,{75dff2b7-6936-4c06-a8bb-676a7b00b24b}*" OR (CommandLine="*explorer.exe*" CommandLine="* -root,*" OR CommandLine="* /root,*" OR CommandLine="* –root,*" OR CommandLine="* —root,*" OR CommandLine="* ―root,*")

# ── File Explorer Folder Opened Using Explorer Folder Shortcut Via Shell ──
# Mức độ  : Cao
# Chi tiết: Detects the initial execution of "cmd.exe" which spawns "explorer.exe" with the appropriate command line arguments for opening the "My Computer" folder.
EventCode=4688 Channel="Security" CommandLine="*shell:mycomputerfolder*" ParentProcessName IN ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe") NewProcessName="*\\explorer.exe"

# ── Explorer NOUACCHECK Flag ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects suspicious starts of explorer.exe that use the /NOUACCHECK flag that allows to run all sub processes of that newly started explorer.exe without any UAC checks
EventCode=4688 Channel="Security" CommandLine="*/NOUACCHECK*" NewProcessName="*\\explorer.exe" NOT (ParentCommandLine="C:\\Windows\\system32\\svchost.exe -k netsvcs -p -s Schedule" OR ParentProcessName="C:\\Windows\\System32\\svchost.exe")

# ── Remote File Download Via Findstr.EXE ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects execution of "findstr" with specific flags and a remote share path. This specific set of CLI flags would allow "findstr" to download the content of the file located on the remote share as desc
EventCode=4688 Channel="Security" CommandLine="*findstr*" OR NewProcessName="*findstr.exe" OR OriginalFileName="FINDSTR.EXE" CommandLine="* -v *" OR CommandLine="* /v *" OR CommandLine="* –v *" OR CommandLine="* —v *" OR CommandLine="* ―v *" CommandLine="* -l *" OR CommandLine="* /l *" OR CommandLine="* –l *" OR CommandLine="* —l *" OR CommandLine="* ―l *" CommandLine="*\\\\*"

# ── Findstr GPP Passwords ──
# Mức độ  : Cao
# Chi tiết: Look for the encrypted cpassword value within Group Policy Preference files on the Domain Controller. This value can be decrypted with gpp-decrypt.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\find.exe", "*\\findstr.exe") OR OriginalFileName IN ("FIND.EXE", "FINDSTR.EXE") CommandLine="*cpassword*" CommandLine="*\\sysvol\\*" CommandLine="*.xml*"

# ── Findstr Launching .lnk File ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects usage of findstr to identify and execute a lnk file as seen within the HHS redirect attack
EventCode=4688 Channel="Security" NewProcessName IN ("*\\find.exe", "*\\findstr.exe") OR OriginalFileName IN ("FIND.EXE", "FINDSTR.EXE") CommandLine IN ("*.lnk", "*.lnk\"", "*.lnk'")

# ── LSASS Process Reconnaissance Via Findstr.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects findstring commands that include the keyword lsass, which indicates recon actviity for the LSASS process PID
EventCode=4688 Channel="Security" (NewProcessName IN ("*\\find.exe", "*\\findstr.exe") OR OriginalFileName IN ("FIND.EXE", "FINDSTR.EXE") CommandLine="*lsass*") OR CommandLine="* -i \"lsass*" OR CommandLine="* /i \"lsass*" OR CommandLine="* –i \"lsass*" OR CommandLine="* —i \"lsass*" OR CommandLine="* ―i \"lsass*" OR CommandLine="* -i lsass.exe*" OR CommandLine="* /i lsass.exe*" OR CommandLine="* –i lsass.exe*" OR CommandLine="* —i lsass.exe*" OR CommandLine="* ―i lsass.exe*" OR CommandLine="*findstr \"lsass*" OR CommandLine="*findstr lsass*" OR CommandLine="*findstr.exe \"lsass*" OR CommandLine="*findstr.exe lsass*"

# ── Permission Misconfiguration Reconnaissance Via Findstr.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of findstr with the "EVERYONE" or "BUILTIN" keywords. This was seen being used in combination with "icacls" and other utilities to spot misconfigured files or folders permissions.
EventCode=4688 Channel="Security" (NewProcessName IN ("*\\find.exe", "*\\findstr.exe") OR OriginalFileName IN ("FIND.EXE", "FINDSTR.EXE") CommandLine IN ("*\"Everyone\"*", "*'Everyone'*", "*\"BUILTIN\\\"*", "*'BUILTIN\\'*")) OR (CommandLine="*icacls *" CommandLine="*findstr *" CommandLine="*Everyone*")

# ── Recon Command Output Piped To Findstr.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of a potential recon command where the results are piped to "findstr". This is meant to trigger on inline calls of "cmd.exe" via the "/c" or "/k" for example. Attackers often tim
EventCode=4688 Channel="Security" CommandLine IN ("*ipconfig*|*find*", "*net*|*find*", "*netstat*|*find*", "*ping*|*find*", "*systeminfo*|*find*", "*tasklist*|*find*", "*whoami*|*find*") NOT (CommandLine="*cmd.exe /c TASKLIST /V |*" CommandLine="*FIND /I*" CommandLine="*\\xampp\\*" CommandLine="*\\catalina_start.bat*")

# ── Security Tools Keyword Lookup Via Findstr.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "findstr" to search for common names of security tools. Attackers often pipe the results of recon commands such as "tasklist" or "whoami" to "findstr" in order to filter out the r
EventCode=4688 Channel="Security" NewProcessName IN ("*\\find.exe", "*\\findstr.exe") OR OriginalFileName IN ("FIND.EXE", "FINDSTR.EXE") CommandLine IN ("* avira", "* avira\"", "* cb", "* cb\"", "* cylance", "* cylance\"", "* defender", "* defender\"", "* kaspersky", "* kaspersky\"", "* kes", "* kes\"", "* mc", "* mc\"", "* sec", "* sec\"", "* sentinel", "* sentinel\"", "* symantec", "* symantec\"", "* virus", "* virus\"")

# ── Insensitive Subfolder Search Via Findstr.EXE ──
# Mức độ  : Thấp
# Mục đích: Tải file từ mạng
# Chi tiết: Detects execution of findstr with the "s" and "i" flags for a "subfolder" and "insensitive" search respectively. Attackers sometimes leverage this built-in utility to search the system for interesting
EventCode=4688 Channel="Security" CommandLine="*findstr*" OR NewProcessName="*findstr.exe" OR OriginalFileName="FINDSTR.EXE" CommandLine="* -s *" OR CommandLine="* /s *" OR CommandLine="* –s *" OR CommandLine="* —s *" OR CommandLine="* ―s *" CommandLine="* -i *" OR CommandLine="* /i *" OR CommandLine="* –i *" OR CommandLine="* —i *" OR CommandLine="* ―i *"

# ── Sysmon Discovery Via Default Driver Altitude Using Findstr.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects usage of "findstr" with the argument "385201". Which could indicate potential discovery of an installed Sysinternals Sysmon service using the default driver altitude (even if the name is chang
EventCode=4688 Channel="Security" NewProcessName IN ("*\\find.exe", "*\\findstr.exe") OR OriginalFileName IN ("FIND.EXE", "FINDSTR.EXE") CommandLine="* 385201*"

# ── Finger.EXE Execution ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects execution of the "finger.exe" utility. Finger.EXE or "TCPIP Finger Command" is an old utility that is still present on modern Windows installation. It Displays information about users on a spe
EventCode=4688 Channel="Security" OriginalFileName="finger.exe" OR NewProcessName="*\\finger.exe"

# ── Filter Driver Unloaded Via Fltmc.EXE ──
# Mức độ  : Trung bình
# Mục đích: Xóa dấu vết
# Chi tiết: Detect filter driver unloading activity via fltmc.exe
EventCode=4688 Channel="Security" NewProcessName="*\\fltMC.exe" OR OriginalFileName="fltMC.exe" CommandLine="*unload*" NOT ((CommandLine IN ("*unload rtp_filesystem_filter", "*unload rtp_filter") ParentProcessName IN ("*\\AppData\\Local\\Temp\\*", "*:\\Windows\\Temp\\*") ParentProcessName="*\\endpoint-protection-installer-x64.tmp") OR (CommandLine="*unload DFMFilter" ParentProcessName="C:\\Program Files (x86)\\ManageEngine\\uems_agent\\bin\\dcfaservice64.exe"))

# ── Sysmon Driver Unloaded Via Fltmc.EXE ──
# Mức độ  : Cao
# Mục đích: Xóa dấu vết
# Chi tiết: Detects possible Sysmon filter driver unloaded via fltmc.exe
EventCode=4688 Channel="Security" NewProcessName="*\\fltMC.exe" OR OriginalFileName="fltMC.exe" CommandLine="*unload*" CommandLine="*sysmon*"

# ── Forfiles Command Execution ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the execution of "forfiles" with the "/c" flag. While this is an expected behavior of the tool, it can be abused in order to proxy execution through it with any binary. Can be used to bypass a
EventCode=4688 Channel="Security" NewProcessName="*\\forfiles.exe" OR OriginalFileName="forfiles.exe" CommandLine="* -c *" OR CommandLine="* /c *" OR CommandLine="* –c *" OR CommandLine="* —c *" OR CommandLine="* ―c *"

# ── Uncommon FileSystem Load Attempt By Format.com ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of format.com with an uncommon filesystem selection that could indicate a defense evasion activity in which "format.com" is used to load malicious DLL files or other programs.
EventCode=4688 Channel="Security" CommandLine="*/fs:*" NewProcessName="*\\format.com" NOT (CommandLine IN ("*/fs:exFAT*", "*/fs:FAT*", "*/fs:NTFS*", "*/fs:ReFS*", "*/fs:UDF*"))

# ── Use of FSharp Interpreters ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the execution of FSharp Interpreters "FsiAnyCpu.exe" and "FSi.exe" Both can be used for AWL bypass and to execute F# code via scripts or inline.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\fsi.exe", "*\\fsianycpu.exe") OR OriginalFileName IN ("fsi.exe", "fsianycpu.exe")

# ── Fsutil Drive Enumeration ──
# Mức độ  : Thấp
# Chi tiết: Attackers may leverage fsutil to enumerated connected drives.
EventCode=4688 Channel="Security" NewProcessName="*\\fsutil.exe" OR OriginalFileName="fsutil.exe" CommandLine="*drives*"

# ── Potentially Suspicious NTFS Symlink Behavior Modification ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the modification of NTFS symbolic link behavior using fsutil, which could be used to enable remote to local or remote to remote symlinks for potential attacks.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("Cmd.Exe", "PowerShell.EXE", "pwsh.dll") CommandLine="*fsutil*" CommandLine="*behavior*" CommandLine="*set*" CommandLine="*SymlinkEvaluation*" CommandLine IN ("*R2L:1*", "*R2R:1*", "*L2L:1*")

# ── Fsutil Suspicious Invocation ──
# Mức độ  : Cao
# Mục đích: Xóa dấu vết
# Chi tiết: Detects suspicious parameters of fsutil (deleting USN journal, configuring it with small size, etc). Might be used by ransomwares during the attack (seen by NotPetya and others).
EventCode=4688 Channel="Security" NewProcessName="*\\fsutil.exe" OR OriginalFileName="fsutil.exe" CommandLine IN ("*deletejournal*", "*createjournal*", "*setZeroData*")

# ── Potential Arbitrary Command Execution Via FTP.EXE ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution of "ftp.exe" script with the "-s" or "/s" flag and any child processes ran by "ftp.exe".
EventCode=4688 Channel="Security" ParentProcessName="*\\ftp.exe" OR (NewProcessName="*\\ftp.exe" OR OriginalFileName="ftp.exe" CommandLine="*-s:*" OR CommandLine="*/s:*" OR CommandLine="*–s:*" OR CommandLine="*—s:*" OR CommandLine="*―s:*")

# ── Arbitrary File Download Via GfxDownloadWrapper.EXE ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects execution of GfxDownloadWrapper.exe with a URL as an argument to download file.
EventCode=4688 Channel="Security" CommandLine IN ("*http://*", "*https://*") NewProcessName="*\\GfxDownloadWrapper.exe" NOT CommandLine="*https://gameplayapi.intel.com/*"

# ── Suspicious Git Clone ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "git" in order to clone a remote repository that contain suspicious keywords which might be suspicious
EventCode=4688 Channel="Security" NewProcessName IN ("*\\git.exe", "*\\git-remote-https.exe") OR OriginalFileName="git.exe" CommandLine IN ("* clone *", "*git-remote-https *") CommandLine IN ("*exploit*", "*Vulns*", "*vulnerability*", "*RemoteCodeExecution*", "*Invoke-*", "*CVE-*", "*poc-*", "*ProofOfConcept*", "*proxyshell*", "*log4shell*", "*eternalblue*", "*eternal-blue*", "*MS17-*")

# ── Github Self-Hosted Runner Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects GitHub self-hosted runners executing workflows on local infrastructure that could be abused for persistence and code execution. Shai-Hulud is an npm supply chain worm targeting CI/CD environme
EventCode=4688 Channel="Security" (NewProcessName="*\\Runner.Worker.exe" OR OriginalFileName="Runner.Worker.dll" CommandLine="*spawnclient*") OR (NewProcessName="*\\Runner.Listener.exe" OR OriginalFileName="Runner.Listener.dll" CommandLine IN ("*run*", "*configure*"))

# ── Potentially Suspicious GoogleUpdate Child Process ──
# Mức độ  : Cao
# Chi tiết: Detects potentially suspicious child processes of "GoogleUpdate.exe"
EventCode=4688 Channel="Security" ParentProcessName="*\\GoogleUpdate.exe" NOT (NewProcessName="*\\Google*" OR NewProcessName IN ("*\\setup.exe", "*chrome_updater.exe", "*chrome_installer.exe") OR NOT NewProcessName=*)

# ── File Decryption Using Gpg4win ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of Gpg4win to decrypt files
EventCode=4688 Channel="Security" NewProcessName IN ("*\\gpg.exe", "*\\gpg2.exe") OR Description="GnuPG’s OpenPGP tool" CommandLine="* -d *" CommandLine="*passphrase*"

# ── File Encryption Using Gpg4win ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of Gpg4win to encrypt files
EventCode=4688 Channel="Security" NewProcessName IN ("*\\gpg.exe", "*\\gpg2.exe") OR Description="GnuPG’s OpenPGP tool" CommandLine="* -c *" CommandLine="*passphrase*"

# ── Portable Gpg.EXE Execution ──
# Mức độ  : Trung bình
# Mục đích: Mã hóa dữ liệu (ransomware)
# Chi tiết: Detects the execution of "gpg.exe" from uncommon location. Often used by ransomware and loaders to decrypt/encrypt data.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\gpg.exe", "*\\gpg2.exe") OR OriginalFileName="gpg.exe" OR Description="GnuPG’s OpenPGP tool" NOT (NewProcessName IN ("*:\\Program Files (x86)\\GNU\\GnuPG\\bin\\*", "*:\\Program Files (x86)\\GnuPG VS-Desktop\\*", "*:\\Program Files (x86)\\GnuPG\\bin\\*", "*:\\Program Files (x86)\\Gpg4win\\bin\\*"))

# ── File Encryption/Decryption Via Gpg4win From Suspicious Locations ──
# Mức độ  : Cao
# Chi tiết: Detects usage of Gpg4win to encrypt/decrypt files located in potentially suspicious locations.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\gpg.exe", "*\\gpg2.exe") OR Product="GNU Privacy Guard (GnuPG)" OR Description="GnuPG’s OpenPGP tool" CommandLine="*-passphrase*" CommandLine IN ("*:\\PerfLogs\\*", "*:\\Temp\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Temp\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Roaming\\*")

# ── Gpresult Display Group Policy Information ──
# Mức độ  : Trung bình
# Chi tiết: Detects cases in which a user uses the built-in Windows utility gpresult to display the Resultant Set of Policy (RSoP) information
EventCode=4688 Channel="Security" CommandLine IN ("*/z*", "*/v*") NewProcessName="*\\gpresult.exe"

# ── Arbitrary Binary Execution Using GUP Utility ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of the Notepad++ updater (gup) to launch other commands or executables
EventCode=4688 Channel="Security" ParentProcessName="*\\gup.exe" NewProcessName="*\\explorer.exe" NOT ((CommandLine="*\\Notepad++\\notepad++.exe*" NewProcessName="*\\explorer.exe") OR ParentProcessName="*\\Notepad++\\updater\\*" OR NOT CommandLine=*)

# ── File Download Using Notepad++ GUP Utility ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects execution of the Notepad++ updater (gup) from a process other than Notepad++ to download files.
EventCode=4688 Channel="Security" NewProcessName="*\\GUP.exe" OR OriginalFileName="gup.exe" CommandLine="* -unzipTo *" CommandLine="*http*" NOT ParentProcessName="*\\notepad++.exe"

# ── Suspicious Child Process of Notepad++ Updater - GUP.Exe ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious child process creation by the Notepad++ updater process (gup.exe). This could indicate potential exploitation of the updater component to deliver unwanted malware.
EventCode=4688 Channel="Security" ParentProcessName="*\\gup.exe" NewProcessName IN ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\cscript.exe", "*\\wscript.exe", "*\\mshta.exe") OR CommandLine IN ("*bitsadmin*", "*certutil*", "*curl*", "*finger*", "*forfiles*", "*regsvr32*", "*rundll32*", "*wget*")

# ── Suspicious GUP Usage ──
# Mức độ  : Cao
# Chi tiết: Detects execution of the Notepad++ updater in a suspicious directory, which is often used in DLL side-loading attacks
EventCode=4688 Channel="Security" NewProcessName="*\\GUP.exe" NOT (NewProcessName IN ("*\\Program Files\\Notepad++\\updater\\GUP.exe", "*\\Program Files (x86)\\Notepad++\\updater\\GUP.exe") OR (NewProcessName="*\\Users\\*" NewProcessName IN ("*\\AppData\\Local\\Notepad++\\updater\\GUP.exe", "*\\AppData\\Roaming\\Notepad++\\updater\\GUP.exe")))

# ── HH.EXE Execution ──
# Mức độ  : Thấp
# Chi tiết: Detects the execution of "hh.exe" to open ".chm" files.
EventCode=4688 Channel="Security" OriginalFileName="HH.exe" OR NewProcessName="*\\hh.exe" CommandLine="*.chm*"

# ── Remote CHM File Download/Execution Via HH.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects the usage of "hh.exe" to execute/download remotely hosted ".chm" files.
EventCode=4688 Channel="Security" OriginalFileName="HH.exe" OR NewProcessName="*\\hh.exe" CommandLine IN ("*http://*", "*https://*", "*\\\\*")

# ── HTML Help HH.EXE Suspicious Child Process ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script; Phishing
# Chi tiết: Detects a suspicious child process of a Microsoft HTML Help (HH.exe)
EventCode=4688 Channel="Security" ParentProcessName="*\\hh.exe" NewProcessName IN ("*\\CertReq.exe", "*\\CertUtil.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\installutil.exe", "*\\MSbuild.exe", "*\\MSHTA.EXE", "*\\msiexec.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\schtasks.exe", "*\\wmic.exe", "*\\wscript.exe")

# ── Suspicious HH.EXE Execution ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script; Phishing
# Chi tiết: Detects a suspicious execution of a Microsoft HTML Help (HH.exe)
EventCode=4688 Channel="Security" OriginalFileName="HH.exe" OR NewProcessName="*\\hh.exe" CommandLine IN ("*.application*", "*\\AppData\\Local\\Temp\\*", "*\\Content.Outlook\\*", "*\\Downloads\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*")

# ── HackTool - ADCSPwn Execution ──
# Mức độ  : Cao
# Chi tiết: Detects command line parameters used by ADCSPwn, a tool to escalate privileges in an active directory network by coercing authenticate from machine accounts and relaying to the certificate service
EventCode=4688 Channel="Security" CommandLine="* --adcs *" CommandLine="* --port *"

# ── HackTool - Bloodhound/Sharphound Execution ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects command line parameters used by Bloodhound and Sharphound hack tools
EventCode=4688 Channel="Security" Product="*SharpHound*" OR Description="*SharpHound*" OR Company IN ("*SpecterOps*", "*evil corp*") OR NewProcessName IN ("*\\Bloodhound.exe*", "*\\SharpHound.exe*") OR CommandLine IN ("* -CollectionMethod All *", "* --CollectionMethods Session *", "* --Loop --Loopduration *", "* --PortScanTimeout *", "*.exe -c All -d *", "*Invoke-Bloodhound*", "*Get-BloodHoundData*") OR (CommandLine="* -JsonFolder *" CommandLine="* -ZipFileName *") OR (CommandLine="* DCOnly *" CommandLine="* --NoSaveCache *")

# ── HackTool - F-Secure C3 Load by Rundll32 ──
# Mức độ  : Nghiêm trọng
# Chi tiết: F-Secure C3 produces DLLs with a default exported StartNodeRelay function.
EventCode=4688 Channel="Security" CommandLine="*rundll32.exe*" CommandLine="*.dll*" CommandLine="*StartNodeRelay*"

# ── HackTool - Certify Execution ──
# Mức độ  : Cao
# Chi tiết: Detects Certify a tool for Active Directory certificate abuse based on PE metadata characteristics and common command line arguments.
EventCode=4688 Channel="Security" NewProcessName="*\\Certify.exe" OR OriginalFileName="Certify.exe" OR Description="*Certify*" OR (CommandLine IN ("*.exe cas *", "*.exe find *", "*.exe pkiobjects *", "*.exe request *", "*.exe download *") CommandLine IN ("* /vulnerable*", "* /template:*", "* /altname:*", "* /domain:*", "* /path:*", "* /ca:*"))

# ── HackTool - Certipy Execution ──
# Mức độ  : Cao
# Chi tiết: Detects Certipy execution, a tool for Active Directory Certificate Services enumeration and abuse based on PE metadata characteristics and common command line arguments.
EventCode=4688 Channel="Security" NewProcessName="*\\Certipy.exe" OR OriginalFileName="Certipy.exe" OR Description="*Certipy*" OR (CommandLine IN ("* account *", "* auth *", "* cert *", "* find *", "* forge *", "* ptt *", "* relay *", "* req *", "* shadow *", "* template *") CommandLine IN ("* -bloodhound*", "* -ca-pfx *", "* -dc-ip *", "* -kirbi*", "* -old-bloodhound*", "* -pfx *", "* -target*", "* -template*", "* -username *", "* -vulnerable*", "*auth -pfx*", "*shadow auto*", "*shadow list*"))

# ── Operator Bloopers Cobalt Strike Commands ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects use of Cobalt Strike commands accidentally entered in the CMD shell
EventCode=4688 Channel="Security" OriginalFileName="Cmd.Exe" OR NewProcessName="*\\cmd.exe" CommandLine IN ("cmd *", "cmd.exe*", "c:\\windows\\system32\\cmd.exe*") CommandLine IN ("*psinject*", "*spawnas*", "*make_token*", "*remote-exec*", "*rev2self*", "*dcsync*", "*logonpasswords*", "*execute-assembly*", "*getsystem*")

# ── Operator Bloopers Cobalt Strike Modules ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Cobalt Strike module/commands accidentally entered in CMD shell
EventCode=4688 Channel="Security" OriginalFileName="Cmd.Exe" OR NewProcessName="*\\cmd.exe" CommandLine IN ("*Invoke-UserHunter*", "*Invoke-ShareFinder*", "*Invoke-Kerberoast*", "*Invoke-SMBAutoBrute*", "*Invoke-Nightmare*", "*zerologon*", "*av_query*")

# ── CobaltStrike Load by Rundll32 ──
# Mức độ  : Cao
# Chi tiết: Rundll32 can be use by Cobalt Strike with StartW function to load DLLs from the command line.
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" OR CommandLine IN ("*rundll32.exe*", "*rundll32 *") CommandLine="*.dll*" CommandLine IN ("* StartW", "*,StartW")

# ── Potential CobaltStrike Process Patterns ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects potential process patterns related to Cobalt Strike beacon activity
EventCode=4688 Channel="Security" (CommandLine="*cmd.exe /C whoami" ParentProcessName="C:\\Temp\\*") OR (CommandLine="*cmd.exe /c echo*" CommandLine="*> \\\\.\\pipe*" ParentProcessName IN ("*\\runonce.exe", "*\\dllhost.exe")) OR (ParentCommandLine="*cmd.exe /C echo*" ParentCommandLine="* > \\\\.\\pipe*" CommandLine="*conhost.exe 0xffffffff -ForceV1") OR (ParentCommandLine="*/C whoami" CommandLine="*conhost.exe 0xffffffff -ForceV1")

# ── HackTool - CoercedPotato Execution ──
# Mức độ  : Cao
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: Detects the use of CoercedPotato, a tool for privilege escalation
EventCode=4688 Channel="Security" NewProcessName="*\\CoercedPotato.exe" OR CommandLine="* --exploitId *" OR Hashes IN ("*IMPHASH=A75D7669DB6B2E107A44C4057FF7F7D6*", "*IMPHASH=F91624350E2C678C5DCBE5E1F24E22C9*", "*IMPHASH=14C81850A079A87E83D50CA41C709A15*")

# ── HackTool - Covenant PowerShell Launcher ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious command lines used in Covenant luanchers
EventCode=4688 Channel="Security" (CommandLine="*-Sta*" CommandLine="*-Nop*" CommandLine="*-Window*" CommandLine="*Hidden*" CommandLine IN ("*-Command*", "*-EncodedCommand*")) OR CommandLine IN ("*sv o (New-Object IO.MemorySteam);sv d *", "*mshta file.hta*", "*GruntHTTP*", "*-EncodedCommand cwB2ACAAbwAgA*")

# ── HackTool - CrackMapExec Execution ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại; Thực thi lệnh/script
# Chi tiết: This rule detect common flag combinations used by CrackMapExec in order to detect its use even if the binary has been replaced.
EventCode=4688 Channel="Security" NewProcessName="*\\crackmapexec.exe" OR CommandLine="* -M pe_inject *" OR (CommandLine="* --local-auth*" CommandLine="* -u *" CommandLine="* -x *") OR (CommandLine="* --local-auth*" CommandLine="* -u *" CommandLine="* -p *" CommandLine="* -H 'NTHASH'*") OR (CommandLine="* mssql *" CommandLine="* -u *" CommandLine="* -p *" CommandLine="* -M *" CommandLine="* -d *") OR (CommandLine="* smb *" CommandLine="* -u *" CommandLine="* -H *" CommandLine="* -M *" CommandLine="* -o *") OR (CommandLine="* smb *" CommandLine="* -u *" CommandLine="* -p *" CommandLine="* --local-auth*") OR (CommandLine="* --local-auth*" CommandLine="* -u *" CommandLine="* -p *" CommandLine="* 10.*" CommandLine="* 192.168.*" CommandLine="*/24 *")

# ── HackTool - CrackMapExec Execution Patterns ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại; Thực thi lệnh/script
# Chi tiết: Detects various execution patterns of the CrackMapExec pentesting framework
EventCode=4688 Channel="Security" CommandLine IN ("*cmd.exe /Q /c * 1> \\\\*\\*\\* 2>&1*", "*cmd.exe /C * > \\\\*\\*\\* 2>&1*", "*cmd.exe /C * > *\\Temp\\* 2>&1*", "*powershell.exe -exec bypass -noni -nop -w 1 -C \"*", "*powershell.exe -noni -nop -w 1 -enc *")

# ── HackTool - CrackMapExec Process Patterns ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects suspicious process patterns found in logs when CrackMapExec is used
EventCode=4688 Channel="Security" (CommandLine="*tasklist /fi *" CommandLine="*Imagename eq lsass.exe*" CommandLine IN ("*cmd.exe /c *", "*cmd.exe /r *", "*cmd.exe /k *", "*cmd /c *", "*cmd /r *", "*cmd /k *") SubjectUserName IN ("*AUTHORI*", "*AUTORI*")) OR (CommandLine="*do rundll32.exe C:\\windows\\System32\\comsvcs.dll, MiniDump*" CommandLine="*\\Windows\\Temp\\*" CommandLine="* full*" CommandLine="*%%B*") OR (CommandLine="*tasklist /v /fo csv*" CommandLine="*findstr /i \"lsass\"*")

# ── HackTool - CrackMapExec PowerShell Obfuscation ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: The CrachMapExec pentesting framework implements a PowerShell obfuscation with some static strings detected by this rule.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll") CommandLine IN ("*join*split*", "*( $ShellId[1]+$ShellId[13]+'x')*", "*( $PSHome[*]+$PSHOME[*]+*", "*( $env:Public[13]+$env:Public[5]+'x')*", "*( $env:ComSpec[4,*,25]-Join'')*", "*[1,3]+'x'-Join'')*")

# ── HackTool - CreateMiniDump Execution ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the use of CreateMiniDump hack tool used to dump the LSASS process memory for credential extraction on the attacker's machine
EventCode=4688 Channel="Security" NewProcessName="*\\CreateMiniDump.exe" OR Hashes="*IMPHASH=4a07f944a83e8a7c2525efa35dd30e2f*"

# ── HackTool - DInjector PowerShell Cradle Execution ──
# Mức độ  : Nghiêm trọng
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: Detects the use of the Dinject PowerShell cradle based on the specific flags
EventCode=4688 Channel="Security" CommandLine="* /am51*" CommandLine="* /password*"

# ── HackTool - Doppelanger LSASS Dumper Execution ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the execution of the Doppelanger hacktool which is used to dump LSASS memory via process cloning while evading common detection methods
EventCode=4688 Channel="Security" NewProcessName="*\\Doppelganger.exe" OR Hashes IN ("*IMPHASH=AB94D5217896ADCD765A06B2D52F0AEB*", "*IMPHASH=65F0EA61156EE0C2A35421926F0C7F78*")

# ── Hacktool - EDR-Freeze Execution ──
# Mức độ  : Cao
# Chi tiết: Detects execution of EDR-Freeze, a tool that exploits the MiniDumpWriteDump function and WerFaultSecure.exe to suspend EDR and Antivirus processes on Windows. EDR-Freeze leverages a race-condition att
EventCode=4688 Channel="Security" (NewProcessName IN ("*\\EDR-Freeze*", "*\\EDRFreeze*") NewProcessName="*.exe") OR Hashes IN ("*IMPHASH=1195F7935954A2CD09157390C33F8E8C*", "*IMPHASH=129F58DE3D687FB7F012BF6C3D679997*", "*IMPHASH=2C617A175D0086251642C6619F7CC8BA*", "*IMPHASH=8828F0B906F7844358FB92A899E9520F*", "*IMPHASH=AF76D95157EC554DC1EF178E4E66D447*", "*IMPHASH=E1B04316B61ACA31DD52ABBEC0A37FD5*", "*IMPHASH=8B2D5B54AFCFEC60D54F6B31D80ED4A0*", "*IMPHASH=AB8BB31EDD91D2A05FE7B62A535E9EB7*")

# ── HackTool - EDRSilencer Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of EDRSilencer, a tool that leverages Windows Filtering Platform (WFP) to block Endpoint Detection and Response (EDR) agents from reporting security events to the server based on
EventCode=4688 Channel="Security" NewProcessName="*\\EDRSilencer.exe" OR OriginalFileName="EDRSilencer.exe" OR Description="*EDRSilencer*"

# ── HackTool - Empire PowerShell Launch Parameters ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious powershell command line parameters used in Empire
EventCode=4688 Channel="Security" CommandLine IN ("* -NoP -sta -NonI -W Hidden -Enc *", "* -noP -sta -w 1 -enc *", "* -NoP -NonI -W Hidden -enc *", "* -noP -sta -w 1 -enc*", "* -enc  SQB*", "* -nop -exec bypass -EncodedCommand *")

# ── HackTool - Empire PowerShell UAC Bypass ──
# Mức độ  : Nghiêm trọng
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects some Empire PowerShell UAC bypass methods
EventCode=4688 Channel="Security" CommandLine IN ("* -NoP -NonI -w Hidden -c $x=$((gp HKCU:Software\\Microsoft\\Windows Update).Update)*", "* -NoP -NonI -c $x=$((gp HKCU:Software\\Microsoft\\Windows Update).Update);*")

# ── HackTool - WinRM Access Via Evil-WinRM ──
# Mức độ  : Trung bình
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Adversaries may use Valid Accounts to log into a computer using the Remote Desktop Protocol (RDP). The adversary may then perform actions as the logged-on user.
EventCode=4688 Channel="Security" CommandLine="*-i *" CommandLine="*-u *" CommandLine="*-p *" NewProcessName="*\\ruby.exe"

# ── HackTool - GMER Rootkit Detector and Remover Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the execution GMER tool based on image and hash fields.
EventCode=4688 Channel="Security" NewProcessName="*\\gmer.exe" OR Hashes IN ("*MD5=E9DC058440D321AA17D0600B3CA0AB04*", "*SHA1=539C228B6B332F5AA523E5CE358C16647D8BBE57*", "*SHA256=E8A3E804A96C716A3E9B69195DB6FFB0D33E2433AF871E4D4E1EAB3097237173*")

# ── HackTool - HandleKatz LSASS Dumper Execution ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the use of HandleKatz, a tool that demonstrates the usage of cloned handles to Lsass in order to create an obfuscated memory dump of the same
EventCode=4688 Channel="Security" (CommandLine="*--pid:*" NewProcessName="*\\loader.exe") OR Hashes IN ("*IMPHASH=38D9E015591BBFD4929E0D0F47FA0055*", "*IMPHASH=0E2216679CA6E1094D63322E3412D650*") OR (CommandLine="*--pid:*" CommandLine="*--outfile:*" CommandLine IN ("*.dmp*", "*lsass*", "*.obf*", "*dump*"))

# ── HackTool - Hashcat Password Cracker Execution ──
# Mức độ  : Cao
# Chi tiết: Execute Hashcat.exe with provided SAM file from registry of Windows and Password list to crack against
EventCode=4688 Channel="Security" NewProcessName="*\\hashcat.exe" OR (CommandLine="*-a *" CommandLine="*-m 1000 *" CommandLine="*-r *")

# ── HackTool - HollowReaper Execution ──
# Mức độ  : Cao
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: Detects usage of HollowReaper, a process hollowing shellcode launcher used for stealth payload execution through process hollowing. It replaces the memory of a legitimate process with custom shellcode
EventCode=4688 Channel="Security" NewProcessName="*\\HollowReaper.exe"

# ── HackTool - Htran/NATBypass Execution ──
# Mức độ  : Cao
# Chi tiết: Detects executable names or flags used by Htran or Htran-like tools (e.g. NATBypass)
EventCode=4688 Channel="Security" NewProcessName IN ("*\\htran.exe", "*\\lcx.exe") OR CommandLine IN ("*.exe -tran *", "*.exe -slave *")

# ── HackTool - Hydra Password Bruteforce Execution ──
# Mức độ  : Cao
# Chi tiết: Detects command line parameters used by Hydra password guessing hack tool
EventCode=4688 Channel="Security" CommandLine="*-u *" CommandLine="*-p *" CommandLine IN ("*^USER^*", "*^PASS^*")

# ── HackTool - Potential Impacket Lateral Movement Activity ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects wmiexec/dcomexec/atexec/smbexec from Impacket framework
EventCode=4688 Channel="Security" (CommandLine="*cmd.exe*" CommandLine="*/Q*" CommandLine="*/c*" CommandLine="*\\\\127.0.0.1\\*" CommandLine="*&1*" ParentProcessName IN ("*\\wmiprvse.exe", "*\\mmc.exe", "*\\explorer.exe", "*\\services.exe")) OR (ParentCommandLine IN ("*svchost.exe -k netsvcs*", "*taskeng.exe*") CommandLine="*cmd.exe*" CommandLine="*/C*" CommandLine="*Windows\\Temp\\*" CommandLine="*&1*")

# ── HackTool - Impacket Tools Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of different compiled Windows binaries of the impacket toolset (based on names or part of their names - could lead to false positives)
EventCode=4688 Channel="Security" NewProcessName IN ("*\\goldenPac*", "*\\karmaSMB*", "*\\kintercept*", "*\\ntlmrelayx*", "*\\rpcdump*", "*\\samrdump*", "*\\secretsdump*", "*\\smbexec*", "*\\smbrelayx*", "*\\wmiexec*", "*\\wmipersist*") OR NewProcessName IN ("*\\atexec_windows.exe", "*\\dcomexec_windows.exe", "*\\dpapi_windows.exe", "*\\findDelegation_windows.exe", "*\\GetADUsers_windows.exe", "*\\GetNPUsers_windows.exe", "*\\getPac_windows.exe", "*\\getST_windows.exe", "*\\getTGT_windows.exe", "*\\GetUserSPNs_windows.exe", "*\\ifmap_windows.exe", "*\\mimikatz_windows.exe", "*\\netview_windows.exe", "*\\nmapAnswerMachine_windows.exe", "*\\opdump_windows.exe", "*\\psexec_windows.exe", "*\\rdp_check_windows.exe", "*\\sambaPipe_windows.exe", "*\\smbclient_windows.exe", "*\\smbserver_windows.exe", "*\\sniff_windows.exe", "*\\sniffer_windows.exe", "*\\split_windows.exe", "*\\ticketer_windows.exe")

# ── HackTool - Impersonate Execution ──
# Mức độ  : Trung bình
# Mục đích: Chiếm quyền token
# Chi tiết: Detects execution of the Impersonate tool. Which can be used to manipulate tokens on a Windows computers remotely (PsExec/WmiExec) or interactively
EventCode=4688 Channel="Security" (CommandLine="*impersonate.exe*" CommandLine IN ("* list *", "* exec *", "* adduser *")) OR Hashes IN ("*MD5=9520714AB576B0ED01D1513691377D01*", "*SHA256=E81CC96E2118DC4FBFE5BAD1604E0AC7681960143E2101E1A024D52264BB0A8A*", "*IMPHASH=0A358FFC1697B7A07D0E817AC740DF62*")

# ── HackTool - Inveigh Execution ──
# Mức độ  : Nghiêm trọng
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the use of Inveigh a cross-platform .NET IPv4/IPv6 machine-in-the-middle tool
EventCode=4688 Channel="Security" NewProcessName="*\\Inveigh.exe" OR OriginalFileName IN ("\\Inveigh.exe", "\\Inveigh.dll") OR Description="Inveigh" OR CommandLine IN ("* -SpooferIP*", "* -ReplyToIPs *", "* -ReplyToDomains *", "* -ReplyToMACs *", "* -SnifferIP*")

# ── Invoke-Obfuscation CLIP+ Launcher ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated use of Clip.exe to execute PowerShell
EventCode=4688 Channel="Security" CommandLine="*cmd*" CommandLine="*&&*" CommandLine="*clipboard]::*" CommandLine="*-f*" CommandLine IN ("*/c*", "*/r*")

# ── Invoke-Obfuscation Obfuscated IEX Invocation ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects all variations of obfuscated powershell IEX invocation code generated by Invoke-Obfuscation framework from the following code block
EventCode=4688 Channel="Security"
| rex field=CommandLine "(?<CommandLineMatch>\\$PSHome\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$PSHome\\[)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch2>\\$ShellId\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$ShellId\\[)"
| eval CommandLineCondition2=if(isnotnull(CommandLineMatch2), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch3>\\$env:Public\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$env:Public\\[)"
| eval CommandLineCondition3=if(isnotnull(CommandLineMatch3), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch4>\\$env:ComSpec\\[(?:\\s*\\d{1,3}\\s*,){2})"
| eval CommandLineCondition4=if(isnotnull(CommandLineMatch4), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch5>\\*mdr\\*\\W\\s*\\)\\.Name)"
| eval CommandLineCondition5=if(isnotnull(CommandLineMatch5), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch6>\\$VerbosePreference\\.ToString\\()"
| eval CommandLineCondition6=if(isnotnull(CommandLineMatch6), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch7>\\[String\\]\\s*\\$VerbosePreference)"
| eval CommandLineCondition7=if(isnotnull(CommandLineMatch7), "true", "false")
| search CommandLineCondition="true" OR CommandLineCondition2="true" OR CommandLineCondition3="true" OR CommandLineCondition4="true" OR CommandLineCondition5="true" OR CommandLineCondition6="true" OR CommandLineCondition7="true"

# ── Invoke-Obfuscation STDIN+ Launcher ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated use of stdin to execute PowerShell
EventCode=4688 Channel="Security"
| regex CommandLine="cmd.{0,5}(?:/c|/r).+powershell.+(?:\\$\\{?input\\}?|noexit).+\\\""

# ── Invoke-Obfuscation VAR+ Launcher ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated use of Environment Variables to execute PowerShell
EventCode=4688 Channel="Security"
| regex CommandLine="cmd.{0,5}(?:/c|/r)(?:\\s|)\\\"set\\s[a-zA-Z]{3,6}.*(?:\\{\\d\\}){1,}\\\\\\\"\\s+?\\-f(?:.*\\)){1,}.*\\\""

# ── Invoke-Obfuscation COMPRESS OBFUSCATION ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via COMPRESS OBFUSCATION
EventCode=4688 Channel="Security" CommandLine="*new-object*" CommandLine="*text.encoding]::ascii*" CommandLine IN ("*system.io.compression.deflatestream*", "*system.io.streamreader*", "*readtoend(*")

# ── Invoke-Obfuscation Via Stdin ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via Stdin in Scripts
EventCode=4688 Channel="Security"
| regex CommandLine="(?i)(?:set).*&&\\s?set.*(?:environment|invoke|\\$\\{?input).*&&.*\""

# ── Invoke-Obfuscation Via Use Clip ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via use Clip.exe in Scripts
EventCode=4688 Channel="Security"
| regex CommandLine="(?i)echo.*clip.*&&.*(?:Clipboard|i`?n`?v`?o`?k`?e`?)"

# ── Invoke-Obfuscation Via Use MSHTA ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via use MSHTA in Scripts
EventCode=4688 Channel="Security" CommandLine="*set*" CommandLine="*&&*" CommandLine="*mshta*" CommandLine="*vbscript:createobject*" CommandLine="*.run*" CommandLine="*(window.close)*"

# ── Invoke-Obfuscation VAR++ LAUNCHER OBFUSCATION ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via VAR++ LAUNCHER
EventCode=4688 Channel="Security" CommandLine="*&&set*" CommandLine="*cmd*" CommandLine="*/c*" CommandLine="*-f*" CommandLine IN ("*{0}*", "*{1}*", "*{2}*", "*{3}*", "*{4}*", "*{5}*")

# ── HackTool - Jlaive In-Memory Assembly Execution ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the use of Jlaive to execute assemblies in a copied PowerShell
EventCode=4688 Channel="Security" ParentCommandLine="*.bat" ParentProcessName="*\\cmd.exe" (CommandLine="*powershell.exe*" CommandLine="*.bat.exe*" NewProcessName="*\\xcopy.exe") OR (CommandLine="*pwsh.exe*" CommandLine="*.bat.exe*" NewProcessName="*\\xcopy.exe") OR (CommandLine="*+s*" CommandLine="*+h*" CommandLine="*.bat.exe*" NewProcessName="*\\attrib.exe")

# ── HackTool - Koadic Execution ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects command line parameters used by Koadic hack tool
EventCode=4688 Channel="Security" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*/q*" CommandLine="*/c*" CommandLine="*chcp*"

# ── HackTool - KrbRelay Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of KrbRelay, a Kerberos relaying tool
EventCode=4688 Channel="Security" NewProcessName="*\\KrbRelay.exe" OR OriginalFileName="KrbRelay.exe" OR (CommandLine="* -spn *" CommandLine="* -clsid *" CommandLine="* -rbcd *") OR (CommandLine="*shadowcred*" CommandLine="*clsid*" CommandLine="*spn*") OR (CommandLine="*spn *" CommandLine="*session *" CommandLine="*clsid *")

# ── HackTool - RemoteKrbRelay Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of RemoteKrbRelay, a Kerberos relaying tool via CommandLine flags and PE metadata.
EventCode=4688 Channel="Security" NewProcessName="*\\RemoteKrbRelay.exe" OR OriginalFileName="RemoteKrbRelay.exe" OR (CommandLine="* -clsid *" CommandLine="* -target *" CommandLine="* -victim *") OR (CommandLine="*-rbcd *" CommandLine IN ("*-cn *", "*--computername *")) OR (CommandLine="*-chp *" CommandLine="*-chpPass *" CommandLine="*-chpUser *") OR (CommandLine="*-addgroupmember *" CommandLine="*-group *" CommandLine="*-groupuser *") OR (CommandLine="*-smb *" CommandLine="*--smbkeyword *" CommandLine IN ("*interactive*", "*secrets*", "*service-add*"))

# ── HackTool - KrbRelayUp Execution ──
# Mức độ  : Cao
# Chi tiết: Detects KrbRelayUp used to perform a universal no-fix local privilege escalation in Windows domain environments where LDAP signing is not enforced
EventCode=4688 Channel="Security" NewProcessName="*\\KrbRelayUp.exe" OR OriginalFileName="KrbRelayUp.exe" OR (CommandLine="* relay *" CommandLine="* -Domain *" CommandLine="* -ComputerName *") OR (CommandLine="* krbscm *" CommandLine="* -sc *") OR (CommandLine="* spawn *" CommandLine="* -d *" CommandLine="* -cn *" CommandLine="* -cp *")

# ── HackTool - LaZagne Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of the LaZagne. A utility used to retrieve multiple types of passwords stored on a local computer. LaZagne has been leveraged multiple times by threat actors in order to dump cre
EventCode=4688 Channel="Security" NewProcessName="*\\lazagne.exe" OR (CommandLine IN ("*.exe all", "*.exe browsers", "*.exe chats", "*.exe databases", "*.exe games", "*.exe git", "*.exe mails", "*.exe maven", "*.exe memory", "*.exe multimedia", "*.exe sysadmin", "*.exe unused", "*.exe wifi", "*.exe windows") NewProcessName IN ("*:\\PerfLogs\\*", "*:\\ProgramData\\*", "*:\\Temp\\*", "*:\\Tmp\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Temp\\*", "*\\$Recycle.bin*", "*\\AppData\\*", "*\\Desktop\\*", "*\\Downloads\\*", "*\\Favorites\\*", "*\\Links\\*", "*\\Music\\*", "*\\Photos\\*", "*\\Pictures\\*", "*\\Saved Games\\*", "*\\Searches\\*", "*\\Users\\Contacts\\*", "*\\Users\\Default\\*", "*\\Users\\Searches\\*", "*\\Videos\\*", "*\\Windows\\addins\\*", "*\\Windows\\Fonts\\*", "*\\Windows\\IME\\*")) OR (CommandLine IN ("* all *", "* browsers *", "* chats *", "* databases *", "* games *", "* mails *", "* maven *", "* memory *", "* multimedia *", "* php *", "* svn *", "* sysadmin *", "* unused *", "* wifi *") CommandLine IN ("*-1Password*", "*-apachedirectorystudio*", "*-autologon*", "*-ChromiumBased*", "*-coreftp*", "*-credfiles*", "*-credman*", "*-cyberduck*", "*-dbvis*", "*-EyeCon*", "*-filezilla*", "*-filezillaserver*", "*-ftpnavigator*", "*-galconfusion*", "*-gitforwindows*", "*-hashdump*", "*-iisapppool*", "*-IISCentralCertP*", "*-kalypsomedia*", "*-keepass*", "*-keepassconfig*", "*-lsa_secrets*", "*-mavenrepositories*", "*-memory_dump*", "*-Mozilla*", "*-mRemoteNG*", "*-mscache*", "*-opensshforwindows*", "*-openvpn*", "*-outlook*", "*-pidgin*", "*-postgresql*", "*-psi-im*", "*-puttycm*", "*-pypykatz*", "*-Rclone*", "*-rdpmanager*", "*-robomongo*", "*-roguestale*", "*-skype*", "*-SQLDeveloper*", "*-squirrel*", "*-tortoise*", "*-turba*", "*-UCBrowser*", "*-unattended*", "*-vault*", "*-vaultfiles*", "*-vnc*", "*-winscp*"))

# ── HackTool - LocalPotato Execution ──
