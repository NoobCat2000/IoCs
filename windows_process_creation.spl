EventCode=4688 Channel="Security" ParentProcessName="*\\services.exe" (CommandLine="*/c*" CommandLine="*echo*" CommandLine="*\\pipe\\*" CommandLine IN ("*cmd*", "*%COMSPEC%*")) OR (CommandLine="*rundll32*" CommandLine="*.dll,a*" CommandLine="*/p:*") NOT CommandLine="*MpCmdRun*"

# ── HackTool - Mimikatz Execution ──
