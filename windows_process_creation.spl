EventCode=4688 Channel="Security" NewProcessName="*\\LocalPotato.exe" OR (CommandLine="*.exe -i C:\\*" CommandLine="*-o Windows\\*") OR Hashes IN ("*IMPHASH=E1742EE971D6549E8D4D81115F88F1FC*", "*IMPHASH=DD82066EFBA94D7556EF582F247C8BB5*")

# ── Potential Meterpreter/CobaltStrike Activity ──
