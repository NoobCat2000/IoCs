eb9171e42c948ab68c71afe7f2*", "*SHA256=5428a840fab6ac4a0ecb2fc20dbc5f928432b00b9297dd1cb6e69336f44eba66*", "*SHA256=e2517ae0fccaa4aefe039026a4fc855964f0c2a5f84177140200b0e58ddbfd27*", "*SHA256=75d05880de2593480254181215dd9a0075373876f2f4a2a4a9a654b2e0729a41*", "*SHA256=56490e14ce3817c3a1ddc0d97b96e90d6351bcd29914e7c9282f6a998cca84b1*", "*SHA256=f25d0a5e77e4ed9e7c4204a33cfc8e46281b43adbee550b15701dd00f41bdbe0*", "*SHA256=845a5fdcbb08e7efa7e0eabfcd881c9eebc0eec0a3a2f8689194e6b91b6eeaf8*", "*SHA256=9a89e6652e563d26a3f328ba23d91f464c9549da734557c5a02559df24b2700d*", "*SHA256=5614f2bc9b2ed414aab2c5c7997bdcbe8236e67ced8f91a63d1b6cfbe6e08726*", "*SHA256=37bf92dcedb47a90d8d38ebda8d8dd168ef5803dcb01161f8cf6d68b70d49d90*", "*SHA256=ec8590f91f5cc21e931c57345425f0625a6e37dfba026b222260450de40459f5*", "*SHA256=3994eb72b1c227c593e14b8cad7001de11d1c247d4fbf84d0714bb8a17853140*", "*SHA256=d654f870436d63c9d8e4390d9d4d898abdf0456736c7654d71cdf81a299c3f87*", "*SHA256=63fbfabd4d8afb497dee47d112eb9d683671b75a8bf6407c4bd5027fd211b892*", "*SHA256=47028053f05188e6a366fff19bedbcad2bc4daba8ff9e4df724b77d0181b7054*", "*SHA256=7c1b1e8c880a30c43b3a52ee245f963a977e1f40284f4b83f4b9afe3821753dd*") OR NewProcessName="*\\PingCastle.exe" OR OriginalFileName="PingCastle.exe" OR Product="Ping Castle" OR CommandLine IN ("*--scanner aclcheck*", "*--scanner antivirus*", "*--scanner computerversion*", "*--scanner foreignusers*", "*--scanner laps_bitlocker*", "*--scanner localadmin*", "*--scanner nullsession*", "*--scanner nullsession-trust*", "*--scanner oxidbindings*", "*--scanner remote*", "*--scanner share*", "*--scanner smb*", "*--scanner smb3querynetwork*", "*--scanner spooler*", "*--scanner startup*", "*--scanner zerologon*") OR CommandLine="*--no-enum-limit*" OR (CommandLine="*--healthcheck*" CommandLine="*--level Full*") OR (CommandLine="*--healthcheck*" CommandLine="*--server *")

# ── PUA - PingCastle Execution From Potentially Suspicious Parent ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of PingCastle, a tool designed to quickly assess the Active Directory security level via a script located in a potentially suspicious or uncommon location.
EventCode=4688 Channel="Security" ParentCommandLine IN ("*.bat*", "*.chm*", "*.cmd*", "*.hta*", "*.htm*", "*.html*", "*.js*", "*.lnk*", "*.ps1*", "*.vbe*", "*.vbs*", "*.wsf*") OR ParentCommandLine IN ("*:\\Perflogs\\*", "*:\\Temp\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Temp\\*", "*\\AppData\\Local\\Temp*", "*\\AppData\\Roaming\\*", "*\\Temporary Internet*") OR (ParentCommandLine="*:\\Users\\*" ParentCommandLine="*\\Favorites\\*") OR (ParentCommandLine="*:\\Users\\*" ParentCommandLine="*\\Favourites\\*") OR (ParentCommandLine="*:\\Users\\*" ParentCommandLine="*\\Contacts\\*") ParentCommandLine IN ("*.bat*", "*.chm*", "*.cmd*", "*.hta*", "*.htm*", "*.html*", "*.js*", "*.lnk*", "*.ps1*", "*.vbe*", "*.vbs*", "*.wsf*") NewProcessName="*\\PingCastle.exe" OR OriginalFileName="PingCastle.exe" OR Product="Ping Castle" OR CommandLine IN ("*--scanner aclcheck*", "*--scanner antivirus*", "*--scanner computerversion*", "*--scanner foreignusers*", "*--scanner laps_bitlocker*", "*--scanner localadmin*", "*--scanner nullsession*", "*--scanner nullsession-trust*", "*--scanner oxidbindings*", "*--scanner remote*", "*--scanner share*", "*--scanner smb*", "*--scanner smb3querynetwork*", "*--scanner spooler*", "*--scanner startup*", "*--scanner zerologon*") OR CommandLine="*--no-enum-limit*" OR (CommandLine="*--healthcheck*" CommandLine="*--level Full*") OR (CommandLine="*--healthcheck*" CommandLine="*--server *")

# ── PUA - Process Hacker Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of Process Hacker based on binary metadata information (Image, Hash, Imphash, etc). Process Hacker is a tool to view and manipulate processes, kernel options and other low level 
EventCode=4688 Channel="Security" NewProcessName="*\\ProcessHacker_*" OR NewProcessName="*\\ProcessHacker.exe" OR OriginalFileName IN ("ProcessHacker.exe", "Process Hacker") OR Description="Process Hacker" OR Product="Process Hacker" OR Hashes IN ("*MD5=68F9B52895F4D34E74112F3129B3B00D*", "*MD5=B365AF317AE730A67C936F21432B9C71*", "*SHA1=A0BDFAC3CE1880B32FF9B696458327CE352E3B1D*", "*SHA1=C5E2018BF7C0F314FED4FD7FE7E69FA2E648359E*", "*SHA256=D4A0FE56316A2C45B9BA9AC1005363309A3EDC7ACF9E4DF64D326A0FF273E80F*", "*SHA256=BD2C2CF0631D881ED382817AFCCE2B093F4E412FFB170A719E2762F250ABFEA4*", "*IMPHASH=3695333C60DEDECDCAFF1590409AA462*", "*IMPHASH=04DE0AD9C37EB7BD52043D2ECAC958DF*")

# ── PUA - Potential PE Metadata Tamper Using Rcedit ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects the use of rcedit to potentially alter executable PE metadata properties, which could conceal efforts to rename system utilities for defense evasion.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\rcedit-x64.exe", "*\\rcedit-x86.exe") OR Description="Edit resources of exe" OR Product="rcedit" CommandLine="*--set-*" CommandLine IN ("*OriginalFileName*", "*CompanyName*", "*FileDescription*", "*ProductName*", "*ProductVersion*", "*LegalCopyright*")

# ── PUA - Rclone Execution ──
# Mức độ  : Cao
# Chi tiết: Detects execution of RClone utility for exfiltration as used by various ransomwares strains like REvil, Conti, FiveHands, etc
EventCode=4688 Channel="Security" (CommandLine="*--config *" CommandLine="*--no-check-certificate *" CommandLine="* copy *") OR (NewProcessName="*\\rclone.exe" OR Description="Rsync for cloud storage" CommandLine IN ("*pass*", "*user*", "*copy*", "*sync*", "*config*", "*lsd*", "*remote*", "*ls*", "*mega*", "*pcloud*", "*ftp*", "*ignore-existing*", "*auto-confirm*", "*transfers*", "*multi-thread-streams*", "*no-check-certificate *"))

# ── PUA - Restic Backup Tool Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of the Restic backup tool, which can be used for data exfiltration. Threat actors may leverage Restic to back up and exfiltrate sensitive data to remote storage locations, includ
EventCode=4688 Channel="Security" (CommandLine="*--password-file*" CommandLine="*init*" CommandLine="* -r *") OR (CommandLine="*--use-fs-snapshot*" CommandLine="*backup*" CommandLine="* -r *") OR (CommandLine IN ("*sftp:*", "*rest:http*", "*s3:s3.*", "*s3.http*", "*azure:*", "* gs:*", "*rclone:*", "*swift:*", "* b2:*") CommandLine="* init *" CommandLine="* -r *")

# ── PUA - RunXCmd Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of the RunXCmd tool to execute commands with System or TrustedInstaller accounts
EventCode=4688 Channel="Security" CommandLine IN ("* /account=system *", "* /account=ti *") CommandLine="*/exec=*"

# ── PUA - Seatbelt Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of the PUA/Recon tool Seatbelt via PE information of command line parameters
EventCode=4688 Channel="Security" NewProcessName="*\\Seatbelt.exe" OR OriginalFileName="Seatbelt.exe" OR Description="Seatbelt" OR CommandLine IN ("* DpapiMasterKeys*", "* InterestingProcesses*", "* InterestingFiles*", "* CertificateThumbprints*", "* ChromiumBookmarks*", "* ChromiumHistory*", "* ChromiumPresence*", "* CloudCredentials*", "* CredEnum*", "* CredGuard*", "* FirefoxHistory*", "* ProcessCreationEvents*") OR (CommandLine IN ("* -group=misc*", "* -group=remote*", "* -group=chromium*", "* -group=slack*", "* -group=system*", "* -group=user*", "* -group=all*") CommandLine="* -outputfile=*")

# ── PUA - System Informer Execution ──
# Mức độ  : Trung bình
# Mục đích: Thu thập thông tin hệ thống
# Chi tiết: Detects the execution of System Informer, a task manager tool to view and manipulate processes, kernel options and other low level operations
EventCode=4688 Channel="Security" NewProcessName="*\\SystemInformer.exe" OR OriginalFileName="SystemInformer.exe" OR Description="System Informer" OR Product="System Informer" OR Hashes IN ("*MD5=19426363A37C03C3ED6FEDF57B6696EC*", "*SHA1=8B12C6DA8FAC0D5E8AB999C31E5EA04AF32D53DC*", "*SHA256=8EE9D84DE50803545937A63C686822388A3338497CDDB660D5D69CF68B68F287*", "*IMPHASH=B68908ADAEB5D662F87F2528AF318F12*")

# ── PUA - TruffleHog Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of TruffleHog, a tool used to search for secrets in different platforms like Git, Jira, Slack, SharePoint, etc. that could be used maliciously. While it is a legitimate tool, intende
EventCode=4688 Channel="Security" NewProcessName="*\\trufflehog.exe" OR (CommandLine IN ("* docker --image *", "* Git *", "* GitHub *", "* Jira *", "* Slack *", "* Confluence *", "* SharePoint *", "* s3 *", "* gcs *") CommandLine="* --results=verified*")

# ── PUA - WebBrowserPassView Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of WebBrowserPassView.exe. A password recovery tool that reveals the passwords stored by the following Web browsers, Internet Explorer (Version 4.0 - 11.0), Mozilla Firefox (All 
EventCode=4688 Channel="Security" Description="Web Browser Password Viewer" OR NewProcessName="*\\WebBrowserPassView.exe"

# ── PUA - Wsudo Suspicious Execution ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects usage of wsudo (Windows Sudo Utility). Which is a tool that let the user execute programs with different permissions (System, Trusted Installer, Administrator...etc)
EventCode=4688 Channel="Security" NewProcessName="*\\wsudo.exe" OR OriginalFileName="wsudo.exe" OR Description="Windows sudo utility" OR ParentProcessName="*\\wsudo-bridge.exe" OR CommandLine IN ("*-u System*", "*-uSystem*", "*-u TrustedInstaller*", "*-uTrustedInstaller*", "* --ti *")

# ── PUA - Adidnsdump Execution ──
# Mức độ  : Thấp
# Chi tiết: This tool enables enumeration and exporting of all DNS records in the zone for recon purposes of internal networks Python 3 and python.exe must be installed, Usee to Query/modify DNS records for Activ
EventCode=4688 Channel="Security" CommandLine="*adidnsdump*" NewProcessName="*\\python.exe"

# ── Python One-Liners with Base64 Decoding ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Python one-liners that use base64 decoding functions in command line executions. Malicious scripts or attackers often use python one-liners to decode and execute base64-encoded payloads, which
EventCode=4688 Channel="Security" NewProcessName="*\\python*" OR OriginalFileName="*python*" CommandLine="*import*" CommandLine="*base64*" CommandLine="* -c*" CommandLine IN ("*.decode*", "*b16decode*", "*b32decode*", "*b32hexdecode*", "*b64decode*", "*b85decode*", "*z85decode*")

# ── Python Inline Command Execution ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution of python using the "-c" flag. This is could be used as a way to launch a reverse shell or execute live python code.
EventCode=4688 Channel="Security" OriginalFileName="python.exe" OR NewProcessName IN ("*python.exe", "*python3.exe", "*python2.exe") CommandLine="* -c*" NOT ((ParentCommandLine="*-E -s -m ensurepip -U --default-pip*" ParentProcessName IN ("C:\\Program Files\\Python*", "C:\\Program Files (x86)\\Python*") ParentProcessName="*\\python.exe") OR (CommandLine="*-W ignore::DeprecationWarning*" CommandLine="*['install', '--no-cache-dir', '--no-index', '--find-links',*" CommandLine="*'--upgrade', 'pip'*" ParentProcessName IN ("C:\\Program Files\\Python*", "C:\\Program Files (x86)\\Python*"))) NOT (ParentProcessName="*\\AppData\\Local\\Programs\\Microsoft VS Code\\Code.exe" OR ParentProcessName IN ("C:\\Program Files\\Microsoft VS Code\\Code.exe", "C:\\Program Files (x86)\\Microsoft VS Code\\Code.exe") OR (CommandLine="*<pip-setuptools-caller>*" CommandLine="*exec(compile(*"))

# ── Python Spawning Pretty TTY on Windows ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects python spawning a pretty tty
EventCode=4688 Channel="Security" NewProcessName IN ("*python.exe", "*python3.exe", "*python2.exe") (CommandLine="*import pty*" CommandLine="*.spawn(*") OR CommandLine="*from pty import spawn*"

# ── Potentially Suspicious Usage Of Qemu ──
# Mức độ  : Trung bình
# Chi tiết: Detects potentially suspicious execution of the Qemu utility in a Windows environment. Threat actors have leveraged this utility and this technique for achieving network access as reported by Kaspersk
EventCode=4688 Channel="Security" CommandLine IN ("*-m 1M*", "*-m 2M*", "*-m 3M*") CommandLine="*restrict=off*" CommandLine="*-netdev *" CommandLine="*connect=*" CommandLine="*-nographic*" NOT (CommandLine IN ("* -cdrom *", "* type=virt *", "* -blockdev *"))

# ── Query Usage To Exfil Data ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of "query.exe" a system binary to exfil information such as "sessions" and "processes" for later use
EventCode=4688 Channel="Security" CommandLine IN ("*session >*", "*process >*") NewProcessName="*:\\Windows\\System32\\query.exe"

# ── QuickAssist Execution ──
# Mức độ  : Thấp
# Chi tiết: Detects the execution of Microsoft Quick Assist tool "QuickAssist.exe". This utility can be used by attackers to gain remote access.
EventCode=4688 Channel="Security" NewProcessName="*\\QuickAssist.exe"

# ── Files Added To An Archive Using Rar.EXE ──
# Mức độ  : Thấp
# Chi tiết: Detects usage of "rar" to add files to an archive for potential compression. An adversary may compress data (e.g. sensitive documents) that is collected prior to exfiltration in order to make it porta
EventCode=4688 Channel="Security" CommandLine="* a *" NewProcessName="*\\rar.exe"

# ── Rar Usage with Password and Compression Level ──
# Mức độ  : Cao
# Chi tiết: Detects the use of rar.exe, on the command line, to create an archive with password protection or with a specific compression level. This is pretty indicative of malicious actions.
EventCode=4688 Channel="Security" CommandLine="* -hp*" CommandLine IN ("* -m*", "* a *")

# ── Suspicious Greedy Compression Using Rar.EXE ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects RAR usage that creates an archive from a suspicious folder, either a system folder or one of the folders often used by attackers for staging purposes
EventCode=4688 Channel="Security" NewProcessName="*\\rar.exe" OR Description="Command line RAR" OR CommandLine IN ("*.exe a *", "* a -m*") CommandLine="* -hp*" CommandLine="* -r *" CommandLine IN ("* *:\\\*.*", "* *:\\\\\*.*", "* *:\\$Recycle.bin\\*", "* *:\\PerfLogs\\*", "* *:\\Temp*", "* *:\\Users\\Public\\*", "* *:\\Windows\\*", "* %public%*")

# ── Suspicious RASdial Activity ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious process related to rasdial.exe
EventCode=4688 Channel="Security" NewProcessName="*rasdial.exe"

# ── RDP Enable or Disable via Win32_TerminalServiceSetting WMI Class ──
# Mức độ  : Trung bình
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects enabling or disabling of Remote Desktop Protocol (RDP) using alternate methods such as WMIC or PowerShell. In PowerShell one-liner commands, the "SetAllowTSConnections" method of the "Win32_Te
EventCode=4688 Channel="Security" NewProcessName IN ("*\\wmic.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("wmic.exe", "PowerShell.EXE", "pwsh.dll") CommandLine IN ("*rdtoggle*", "*Win32_TerminalServiceSetting*") CommandLine="*SetAllowTSConnections*"

# ── Process Memory Dump via RdrLeakDiag.EXE ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the use of the Microsoft Windows Resource Leak Diagnostic tool "rdrleakdiag.exe" to dump process memory
EventCode=4688 Channel="Security" NewProcessName="*\\rdrleakdiag.exe" OR OriginalFileName="RdrLeakDiag.exe" CommandLine="*-memdmp*" OR CommandLine="*/memdmp*" OR CommandLine="*–memdmp*" OR CommandLine="*—memdmp*" OR CommandLine="*―memdmp*" OR CommandLine="*fullmemdmp*" CommandLine="* -o *" OR CommandLine="* /o *" OR CommandLine="* –o *" OR CommandLine="* —o *" OR CommandLine="* ―o *" OR CommandLine="* -p *" OR CommandLine="* /p *" OR CommandLine="* –p *" OR CommandLine="* —p *" OR CommandLine="* ―p *"

# ── Windows Recovery Environment Disabled Via Reagentc ──
# Mức độ  : Trung bình
# Mục đích: Phá hủy backup/recovery
# Chi tiết: Detects attempts to disable windows recovery environment using Reagentc. ReAgentc.exe is a command-line tool in Windows used to manage the Windows Recovery Environment (WinRE). It allows users to enab
EventCode=4688 Channel="Security" NewProcessName="*\\reagentc.exe" OR OriginalFileName="reagentc.exe" CommandLine="*-disable*" OR CommandLine="*/disable*" OR CommandLine="*–disable*" OR CommandLine="*—disable*" OR CommandLine="*―disable*"

# ── Potential Persistence Attempt Via Run Keys Using Reg.EXE ──
# Mức độ  : Trung bình
# Mục đích: Persistence qua autorun
# Chi tiết: Detects suspicious command line reg.exe tool adding key to RUN key in Registry
EventCode=4688 Channel="Security" CommandLine="*reg*" CommandLine="* add *" CommandLine IN ("*Software\\Microsoft\\Windows\\CurrentVersion\\Run*", "*\\Software\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Run*", "*\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\Run*") NewProcessName="*\\reg.exe"

# ── Add SafeBoot Keys Via Reg Utility ──
# Mức độ  : Cao
# Chi tiết: Detects execution of "reg.exe" commands with the "add" or "copy" flags on safe boot registry keys. Often used by attacker to allow the ransomware to work in safe mode as some security products do not
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="*\\SYSTEM\\CurrentControlSet\\Control\\SafeBoot*" CommandLine IN ("* copy *", "* add *")

# ── Suspicious Reg Add BitLocker ──
# Mức độ  : Cao
# Mục đích: Mã hóa dữ liệu (ransomware)
# Chi tiết: Detects suspicious addition to BitLocker related registry keys via the reg.exe utility
EventCode=4688 Channel="Security" CommandLine="*REG*" CommandLine="*ADD*" CommandLine="*\\SOFTWARE\\Policies\\Microsoft\\FVE*" CommandLine="*/v*" CommandLine="*/f*" CommandLine IN ("*EnableBDEWithNoTPM*", "*UseAdvancedStartup*", "*UseTPM*", "*UseTPMKey*", "*UseTPMKeyPIN*", "*RecoveryKeyMessageSource*", "*UseTPMPIN*", "*RecoveryKeyMessage*")

# ── Dropping Of Password Filter DLL ──
# Mức độ  : Trung bình
# Chi tiết: Detects dropping of dll files in system32 that may be used to retrieve user credentials from LSASS
EventCode=4688 Channel="Security" CommandLine="*HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa*" CommandLine="*scecli\\0*" CommandLine="*reg add*"

# ── Suspicious Windows Defender Folder Exclusion Added Via Reg.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the usage of "reg.exe" to add Defender folder exclusions. Qbot has been seen using this technique to add exclusions for folders within AppData and ProgramData.
EventCode=4688 Channel="Security" CommandLine IN ("*SOFTWARE\\Microsoft\\Windows Defender\\Exclusions\\Paths*", "*SOFTWARE\\Microsoft\\Microsoft Antimalware\\Exclusions\\Paths*") CommandLine="*ADD *" CommandLine="*/t *" CommandLine="*REG_DWORD *" CommandLine="*/v *" CommandLine="*/d *" CommandLine="*0*" NewProcessName="*\\reg.exe"

# ── RunMRU Registry Key Deletion ──
# Mức độ  : Cao
# Mục đích: Xóa dấu vết
# Chi tiết: Detects deletion of the RunMRU registry key, which stores the history of commands executed via the Run dialog. In the clickfix techniques, the phishing lures instruct users to open a run dialog throug
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="* del*" CommandLine="*\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\RunMRU*"

# ── SafeBoot Registry Key Deleted Via Reg.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects execution of "reg.exe" commands with the "delete" flag on safe boot registry keys. Often used by attacker to prevent safeboot execution of security products
EventCode=4688 Channel="Security" NewProcessName="*reg.exe" OR OriginalFileName="reg.exe" CommandLine="* delete *" CommandLine="*\\SYSTEM\\CurrentControlSet\\Control\\SafeBoot*"

# ── Service Registry Key Deleted Via Reg.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects execution of "reg.exe" commands with the "delete" flag on services registry key. Often used by attacker to remove AV software services
EventCode=4688 Channel="Security" NewProcessName="*reg.exe" OR OriginalFileName="reg.exe" CommandLine="* delete *" CommandLine="*\\SYSTEM\\CurrentControlSet\\services\\*"

# ── Potentially Suspicious Desktop Background Change Using Reg.EXE ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects the execution of "reg.exe" to alter registry keys that would replace the user's desktop background. This is a common technique used by malware to change the desktop background to a ransom note
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="*add*" CommandLine IN ("*Control Panel\\Desktop*", "*CurrentVersion\\Policies\\ActiveDesktop*", "*CurrentVersion\\Policies\\System*") (CommandLine="*/v NoChangingWallpaper*" CommandLine="*/d 1*") OR (CommandLine="*/v Wallpaper*" CommandLine="*/t REG_SZ*") OR (CommandLine="*/v WallpaperStyle*" CommandLine="*/d 2*")

# ── Direct Autorun Keys Modification ──
# Mức độ  : Trung bình
# Mục đích: Persistence qua autorun
# Chi tiết: Detects direct modification of autostart extensibility point (ASEP) in registry using reg.exe.
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="*add*" CommandLine IN ("*\\software\\Microsoft\\Windows\\CurrentVersion\\Run*", "*\\software\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Run*", "*\\software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\Run*", "*\\software\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon\\Userinit*", "*\\software\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon\\Shell*", "*\\software\\Microsoft\\Windows NT\\CurrentVersion\\Windows*", "*\\system\\CurrentControlSet\\Control\\SafeBoot\\AlternateShell*")

# ── Disabling Windows Defender WMI Autologger Session via Reg.exe ──
# Mức độ  : Cao
# Chi tiết: Detects the use of reg.exe to disable the Event Tracing for Windows (ETW) Autologger session for Windows Defender API and Audit events. By setting the 'Start' value to '0' for the 'DefenderApiLogger' 
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine IN ("*\\Control\\WMI\\Autologger\\DefenderApiLogger\\Start*", "*\\Control\\WMI\\Autologger\\DefenderAuditLogger\\Start*") CommandLine="*add*" CommandLine="*0*" NOT CommandLine="*0x00000001*"

# ── Security Service Disabled Via Reg.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects execution of "reg.exe" to disable security services such as Windows Defender.
EventCode=4688 Channel="Security" CommandLine="*reg*" CommandLine="*add*" CommandLine="*d 4*" CommandLine="*v Start*" CommandLine IN ("*\\AppIDSvc*", "*\\MsMpSvc*", "*\\NisSrv*", "*\\SecurityHealthService*", "*\\Sense*", "*\\UsoSvc*", "*\\WdBoot*", "*\\WdFilter*", "*\\WdNisDrv*", "*\\WdNisSvc*", "*\\WinDefend*", "*\\wscsvc*", "*\\wuauserv*")

# ── Dumping of Sensitive Hives Via Reg.EXE ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the usage of "reg.exe" in order to dump sensitive registry hives. This includes SAM, SYSTEM and SECURITY hives.
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine IN ("* save *", "* export *", "* ˢave *", "* eˣport *") CommandLine IN ("*hklm*", "*hk˪m*", "*hkey_local_machine*", "*hkey_˪ocal_machine*", "*hkey_loca˪_machine*", "*hkey_˪oca˪_machine*") CommandLine IN ("*\\system*", "*\\sam*", "*\\security*", "*\\ˢystem*", "*\\syˢtem*", "*\\ˢyˢtem*", "*\\ˢam*", "*\\ˢecurity*")

# ── Windows Recall Feature Enabled Via Reg.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the enabling of the Windows Recall feature via registry manipulation. Windows Recall can be enabled by deleting the existing "DisableAIDataAnalysis" value, or setting it to 0. Adversaries may 
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="*Microsoft\\Windows\\WindowsAI*" CommandLine="*DisableAIDataAnalysis*" CommandLine IN ("*add*", "*0*") OR CommandLine="*delete*"

# ── Enumeration for Credentials in Registry ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may search the Registry on compromised systems for insecurely stored credentials. The Windows Registry stores configuration information that can be used by the system or other programs. Ad
EventCode=4688 Channel="Security" CommandLine="* query *" CommandLine="*/t *" CommandLine="*REG_SZ*" CommandLine="*/s*" NewProcessName="*\\reg.exe" (CommandLine="*/f *" CommandLine="*HKLM*") OR (CommandLine="*/f *" CommandLine="*HKCU*") OR CommandLine="*HKCU\\Software\\SimonTatham\\PuTTY\\Sessions*"

# ── Potential Suspicious Registry File Imported Via Reg.EXE ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects the import of '.reg' files from suspicious paths using the 'reg.exe' utility
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="* import *" CommandLine IN ("*C:\\Users\\*", "*%temp%*", "*%tmp%*", "*%appdata%*", "*\\AppData\\Local\\Temp\\*", "*C:\\Windows\\Temp\\*", "*C:\\ProgramData\\*")

# ── RestrictedAdminMode Registry Value Tampering - ProcCreation ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects changes to the "DisableRestrictedAdmin" registry value in order to disable or enable RestrictedAdmin mode. RestrictedAdmin mode prevents the transmission of reusable credentials to the remote 
EventCode=4688 Channel="Security" CommandLine="*\\System\\CurrentControlSet\\Control\\Lsa*" CommandLine="*DisableRestrictedAdmin*"

# ── Suspicious Query of MachineGUID ──
# Mức độ  : Thấp
# Mục đích: Thu thập thông tin hệ thống
# Chi tiết: Use of reg to get MachineGuid information
EventCode=4688 Channel="Security" CommandLine="*SOFTWARE\\Microsoft\\Cryptography*" CommandLine="*/v *" CommandLine="*MachineGuid*" NewProcessName="*\\reg.exe"

# ── Modify Group Policy Settings ──
# Mức độ  : Trung bình
# Chi tiết: Detect malicious GPO modifications can be used to implement many other malicious behaviors.
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="*\\SOFTWARE\\Policies\\Microsoft\\Windows\\System*" CommandLine IN ("*GroupPolicyRefreshTimeDC*", "*GroupPolicyRefreshTimeOffsetDC*", "*GroupPolicyRefreshTime*", "*GroupPolicyRefreshTimeOffset*", "*EnableSmartScreen*", "*ShellSmartScreenLevel*")

# ── Enable LM Hash Storage - ProcCreation ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects changes to the "NoLMHash" registry value in order to allow Windows to store LM Hashes. By setting this registry value to "0" (DWORD), Windows will be allowed to store a LAN manager hash of you
EventCode=4688 Channel="Security" CommandLine="*\\System\\CurrentControlSet\\Control\\Lsa*" CommandLine="*NoLMHash*" CommandLine="* 0*"

# ── Potential Configuration And Service Reconnaissance Via Reg.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the usage of "reg.exe" in order to query reconnaissance information from the registry. Adversaries may interact with the Windows registry to gather information about credentials, the system, c
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="*query*" CommandLine IN ("*currentVersion\\windows*", "*winlogon\\*", "*currentVersion\\shellServiceObjectDelayLoad*", "*currentVersion\\run*", "*currentVersion\\policies\\explorer\\run*", "*currentcontrolset\\services*")

# ── Potential Tampering With RDP Related Registry Keys Via Reg.EXE ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng; Sửa registry
# Chi tiết: Detects the execution of "reg.exe" for enabling/disabling the RDP service on the host by tampering with the 'CurrentControlSet\Control\Terminal Server' values
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="* add *" CommandLine="*\\CurrentControlSet\\Control\\Terminal Server*" CommandLine="*REG_DWORD*" CommandLine="* /f*" (CommandLine="*Licensing Core*" CommandLine="*EnableConcurrentSessions*") OR CommandLine IN ("*AllowTSConnections*", "*fDenyTSConnections*", "*fEnableWinStation*", "*fSingleSessionPerUser*", "*IdleWinStationPoolCount*", "*MaxInstanceCount*", "*SecurityLayer*", "*TSAdvertise*", "*TSAppCompat*", "*TSEnabled*", "*TSUserEnabled*", "*WinStations\\RDP-Tcp*") NOT (CommandLine="*SecurityLayer*" CommandLine="*02*")

# ── Suspicious ScreenSave Change by Reg.exe ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may establish persistence by executing malicious content triggered by user inactivity. Screensavers are programs that execute after a configurable time of user inactivity and consist of Po
EventCode=4688 Channel="Security" CommandLine IN ("*HKEY_CURRENT_USER\\Control Panel\\Desktop*", "*HKCU\\Control Panel\\Desktop*") NewProcessName="*\\reg.exe" (CommandLine="*/v ScreenSaveActive*" CommandLine="*/t REG_SZ*" CommandLine="*/d 1*" CommandLine="*/f*") OR (CommandLine="*/v ScreenSaveTimeout*" CommandLine="*/t REG_SZ*" CommandLine="*/d *" CommandLine="*/f*") OR (CommandLine="*/v ScreenSaverIsSecure*" CommandLine="*/t REG_SZ*" CommandLine="*/d 0*" CommandLine="*/f*") OR (CommandLine="*/v SCRNSAVE.EXE*" CommandLine="*/t REG_SZ*" CommandLine="*/d *" CommandLine="*.scr*" CommandLine="*/f*")

# ── Changing Existing Service ImagePath Value Via Reg.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may execute their own malicious payloads by hijacking the Registry entries used by services. Adversaries may use flaws in the permissions for registry to redirect from the originally speci
EventCode=4688 Channel="Security" CommandLine="*add *" CommandLine="*SYSTEM\\CurrentControlSet\\Services\\*" CommandLine="* ImagePath *" NewProcessName="*\\reg.exe" CommandLine="* -d *" OR CommandLine="* /d *" OR CommandLine="* –d *" OR CommandLine="* —d *" OR CommandLine="* ―d *"

# ── Detected Windows Software Discovery ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may attempt to enumerate software for a variety of reasons, such as figuring out what security measures are present or if the compromised system has a version of software that is vulnerabl
EventCode=4688 Channel="Security" CommandLine="*query*" CommandLine="*\\software\\*" CommandLine="*/v*" CommandLine="*svcversion*" NewProcessName="*\\reg.exe"

# ── Reg Add Suspicious Paths ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects when an adversary uses the reg.exe utility to add or modify new keys or subkeys
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine IN ("*\\AppDataLow\\Software\\Microsoft\\*", "*\\Policies\\Microsoft\\Windows\\OOBE*", "*\\Policies\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon*", "*\\SOFTWARE\\Microsoft\\Windows NT\\Currentversion\\Winlogon*", "*\\CurrentControlSet\\Control\\SecurityProviders\\WDigest*", "*\\Microsoft\\Windows Defender\\*")

# ── System Language Discovery via Reg.Exe ──
# Mức độ  : Trung bình
# Chi tiết: Detects the usage of Reg.Exe to query system language settings. Attackers may discover the system language to determine the geographic location of victims, customize payloads for specific regions, or 
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine="*query*" CommandLine="*Control\\Nls\\Language*"

# ── System Restore Registry Modification via CommandLine ──
# Mức độ  : Cao
# Mục đích: Phá hủy backup/recovery
# Chi tiết: Detects system restore registry modification via command line, which can be used by adversaries to disable system restore on the computer.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe", "*\\reg.exe") OR OriginalFileName IN ("powershell.exe", "pwsh.dll", "reg.exe") CommandLine IN ("* add *", "*Set-ItemProperty*", "*New-ItemProperty*") CommandLine IN ("*\\SOFTWARE\\Policies\\Microsoft\\Windows NT\\SystemRestore*", "*\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\SystemRestore*") CommandLine IN ("*DisableConfig*", "*DisableSR*")

# ── Disabled Volume Snapshots ──
# Mức độ  : Cao
# Chi tiết: Detects commands that temporarily turn off Volume Snapshots
EventCode=4688 Channel="Security" CommandLine="*\\Services\\VSS\\Diag*" CommandLine="*/d Disabled*"

# ── Suspicious Windows Defender Registry Key Tampering Via Reg.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects the usage of "reg.exe" to tamper with different Windows Defender registry keys in order to disable some important features related to protection and detection
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine IN ("*SOFTWARE\\Microsoft\\Windows Defender\\*", "*SOFTWARE\\Policies\\Microsoft\\Windows Defender Security Center*", "*SOFTWARE\\Policies\\Microsoft\\Windows Defender\\*") (CommandLine="* add *" CommandLine="*d 0*" CommandLine IN ("*DisallowExploitProtectionOverride*", "*EnableControlledFolderAccess*", "*MpEnablePus*", "*PUAProtection*", "*SpynetReporting*", "*SubmitSamplesConsent*", "*TamperProtection*")) OR (CommandLine="* add *" CommandLine="*d 1*" CommandLine IN ("*DisableAccess*", "*DisableAntiSpyware*", "*DisableAntiSpywareRealtimeProtection*", "*DisableAntiVirus*", "*DisableAntiVirusSignatures*", "*DisableArchiveScanning*", "*DisableBehaviorMonitoring*", "*DisableBlockAtFirstSeen*", "*DisableCloudProtection*", "*DisableConfig*", "*DisableEnhancedNotifications*", "*DisableIntrusionPreventionSystem*", "*DisableIOAVProtection*", "*DisableNetworkProtection*", "*DisableOnAccessProtection*", "*DisablePrivacyMode*", "*DisableRealtimeMonitoring*", "*DisableRoutinelyTakingAction*", "*DisableScanOnRealtimeEnable*", "*DisableScriptScanning*", "*DisableSecurityCenter*", "*Notification_Suppress*", "*SignatureDisableUpdateOnStartupWithoutEngine*"))

# ── Write Protect For Storage Disabled ──
# Mức độ  : Trung bình
# Chi tiết: Detects applications trying to modify the registry in order to disable any write-protect property for storage devices. This could be a precursor to a ransomware attack and has been an observed techniq
EventCode=4688 Channel="Security" CommandLine="*\\System\\CurrentControlSet\\Control*" CommandLine="*Write Protection*" CommandLine="*0*" CommandLine="*storage*"

# ── RegAsm.EXE Execution Without CommandLine Flags or Files ──
# Mức độ  : Thấp
# Chi tiết: Detects the execution of "RegAsm.exe" without a commandline flag or file, which might indicate potential process injection activity. Usually "RegAsm.exe" should point to a dedicated DLL file or call t
EventCode=4688 Channel="Security" NewProcessName="*\\RegAsm.exe" OR OriginalFileName="RegAsm.exe" CommandLine IN ("*RegAsm", "*RegAsm.exe", "*RegAsm.exe\"", "*RegAsm.exe'")

# ── Potentially Suspicious Execution Of Regasm/Regsvcs With Uncommon Extension ──
# Mức độ  : Trung bình
# Chi tiết: Detects potentially suspicious execution of the Regasm/Regsvcs utilities with an uncommon extension.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\Regsvcs.exe", "*\\Regasm.exe") OR OriginalFileName IN ("RegSvcs.exe", "RegAsm.exe") CommandLine IN ("*.dat*", "*.gif*", "*.jpeg*", "*.jpg*", "*.png*", "*.txt*")

# ── Potentially Suspicious Execution Of Regasm/Regsvcs From Uncommon Location ──
# Mức độ  : Trung bình
# Chi tiết: Detects potentially suspicious execution of the Regasm/Regsvcs utilities from a potentially suspicious location
EventCode=4688 Channel="Security" NewProcessName IN ("*\\Regsvcs.exe", "*\\Regasm.exe") OR OriginalFileName IN ("RegSvcs.exe", "RegAsm.exe") CommandLine IN ("*\\AppData\\Local\\Temp\\*", "*\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\\*", "*\\PerfLogs\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*")

# ── Exports Critical Registry Keys To a File ──
# Mức độ  : Cao
# Chi tiết: Detects the export of a crital Registry key to a file.
EventCode=4688 Channel="Security" NewProcessName="*\\regedit.exe" OR OriginalFileName="REGEDIT.EXE" CommandLine="* -E *" OR CommandLine="* /E *" OR CommandLine="* –E *" OR CommandLine="* —E *" OR CommandLine="* ―E *" CommandLine IN ("*hklm*", "*hkey_local_machine*") CommandLine IN ("*\\system", "*\\sam", "*\\security")

# ── Exports Registry Key To a File ──
# Mức độ  : Thấp
# Chi tiết: Detects the export of the target Registry key to a file.
EventCode=4688 Channel="Security" NewProcessName="*\\regedit.exe" OR OriginalFileName="REGEDIT.EXE" CommandLine="* -E *" OR CommandLine="* /E *" OR CommandLine="* –E *" OR CommandLine="* —E *" OR CommandLine="* ―E *" NOT (CommandLine IN ("*hklm*", "*hkey_local_machine*") CommandLine IN ("*\\system", "*\\sam", "*\\security"))

# ── Imports Registry Key From a File ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry
# Chi tiết: Detects the import of the specified file to the registry with regedit.exe.
EventCode=4688 Channel="Security" NewProcessName="*\\regedit.exe" OR OriginalFileName="REGEDIT.EXE" CommandLine IN ("* /i *", "* /s *", "*.reg*") NOT (CommandLine="* -e *" OR CommandLine="* /e *" OR CommandLine="* –e *" OR CommandLine="* —e *" OR CommandLine="* ―e *" OR CommandLine="* -a *" OR CommandLine="* /a *" OR CommandLine="* –a *" OR CommandLine="* —a *" OR CommandLine="* ―a *" OR CommandLine="* -c *" OR CommandLine="* /c *" OR CommandLine="* –c *" OR CommandLine="* —c *" OR CommandLine="* ―c *")
| regex CommandLine=":[^ \\\\]"

# ── Imports Registry Key From an ADS ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects the import of a alternate datastream to the registry with regedit.exe.
EventCode=4688 Channel="Security" NewProcessName="*\\regedit.exe" OR OriginalFileName="REGEDIT.EXE" CommandLine IN ("* /i *", "*.reg*") NOT (CommandLine="* -e *" OR CommandLine="* /e *" OR CommandLine="* –e *" OR CommandLine="* —e *" OR CommandLine="* ―e *" OR CommandLine="* -a *" OR CommandLine="* /a *" OR CommandLine="* –a *" OR CommandLine="* —a *" OR CommandLine="* ―a *" OR CommandLine="* -c *" OR CommandLine="* /c *" OR CommandLine="* –c *" OR CommandLine="* —c *" OR CommandLine="* ―c *")
| regex CommandLine=":[^ \\\\]"

# ── Regedit as Trusted Installer ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects a regedit started with TrustedInstaller privileges or by ProcessHacker.exe
EventCode=4688 Channel="Security" NewProcessName="*\\regedit.exe" ParentProcessName IN ("*\\TrustedInstaller.exe", "*\\ProcessHacker.exe")

# ── Suspicious Registry Modification From ADS Via Regini.EXE ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects the import of an alternate data stream with regini.exe, regini.exe can be used to modify registry keys.
EventCode=4688 Channel="Security" NewProcessName="*\\regini.exe" OR OriginalFileName="REGINI.EXE"
| regex CommandLine=":[^ \\\\]"

# ── Registry Modification Via Regini.EXE ──
# Mức độ  : Thấp
# Mục đích: Sửa registry
# Chi tiết: Detects the execution of regini.exe which can be used to modify registry keys, the changes are imported from one or more text files.
EventCode=4688 Channel="Security" NewProcessName="*\\regini.exe" OR OriginalFileName="REGINI.EXE"
| regex CommandLine!=":[^ \\\\]"

# ── DLL Execution Via Register-cimprovider.exe ──
# Mức độ  : Trung bình
# Chi tiết: Detects using register-cimprovider.exe to execute arbitrary dll file.
EventCode=4688 Channel="Security" CommandLine="*-path*" CommandLine="*dll*" NewProcessName="*\\register-cimprovider.exe"

# ── Enumeration for 3rd Party Creds From CLI ──
# Mức độ  : Trung bình
# Chi tiết: Detects processes that query known 3rd party registry keys that holds credentials via commandline
EventCode=4688 Channel="Security" CommandLine IN ("*\\Software\\Aerofox\\Foxmail\\V3.1*", "*\\Software\\Aerofox\\FoxmailPreview*", "*\\Software\\DownloadManager\\Passwords*", "*\\Software\\FTPWare\\COREFTP\\Sites*", "*\\Software\\IncrediMail\\Identities*", "*\\Software\\Martin Prikryl\\WinSCP 2\\Sessions*", "*\\Software\\Mobatek\\MobaXterm\\*", "*\\Software\\OpenSSH\\Agent\\Keys*", "*\\Software\\OpenVPN-GUI\\configs*", "*\\Software\\ORL\\WinVNC3\\Password*", "*\\Software\\Qualcomm\\Eudora\\CommandLine*", "*\\Software\\RealVNC\\WinVNC4*", "*\\Software\\RimArts\\B2\\Settings*", "*\\Software\\SimonTatham\\PuTTY\\Sessions*", "*\\Software\\SimonTatham\\PuTTY\\SshHostKeys\\*", "*\\Software\\Sota\\FFFTP*", "*\\Software\\TightVNC\\Server*", "*\\Software\\WOW6432Node\\Radmin\\v3.0\\Server\\Parameters\\Radmin*") NOT (CommandLine IN ("*export*", "*save*") NewProcessName="*reg.exe")

# ── Registry Export of Third-Party Credentials ──
# Mức độ  : Cao
# Chi tiết: Detects the use of reg.exe to export registry paths associated with third-party credentials. Credential stealers have been known to use this technique to extract sensitive information from the registr
EventCode=4688 Channel="Security" NewProcessName="*\\reg.exe" OR OriginalFileName="reg.exe" CommandLine IN ("*save*", "*export*") CommandLine IN ("*\\Software\\Aerofox\\Foxmail\\V3.1*", "*\\Software\\Aerofox\\FoxmailPreview*", "*\\Software\\DownloadManager\\Passwords*", "*\\Software\\FTPWare\\COREFTP\\Sites*", "*\\Software\\IncrediMail\\Identities*", "*\\Software\\Martin Prikryl\\WinSCP 2\\Sessions*", "*\\Software\\Mobatek\\MobaXterm*", "*\\Software\\OpenSSH\\Agent\\Keys*", "*\\Software\\OpenVPN-GUI\\configs*", "*\\Software\\ORL\\WinVNC3\\Password*", "*\\Software\\Qualcomm\\Eudora\\CommandLine*", "*\\Software\\RealVNC\\WinVNC4*", "*\\Software\\RimArts\\B2\\Settings*", "*\\Software\\SimonTatham\\PuTTY\\Sessions*", "*\\Software\\SimonTatham\\PuTTY\\SshHostKeys*", "*\\Software\\Sota\\FFFTP*", "*\\Software\\TightVNC\\Server*", "*\\Software\\WOW6432Node\\Radmin\\v3.0\\Server\\Parameters\\Radmin*")

# ── IE ZoneMap Setting Downgraded To MyComputer Zone For HTTP Protocols Via CLI ──
# Mức độ  : Cao
# Chi tiết: Detects changes to Internet Explorer's (IE / Windows Internet properties) ZoneMap configuration of the "HTTP" and "HTTPS" protocols to point to the "My Computer" zone. This allows downloaded files fro
EventCode=4688 Channel="Security" CommandLine="*\\Microsoft\\Windows\\CurrentVersion\\Internet Settings\\ZoneMap\\ProtocolDefaults*" CommandLine="*http*" CommandLine="* 0*"

# ── Suspicious Debugger Registration Cmdline ──
# Mức độ  : Cao
# Chi tiết: Detects the registration of a debugger for a program that is available in the logon screen (sticky key backdoor).
EventCode=4688 Channel="Security" CommandLine="*\\CurrentVersion\\Image File Execution Options\\*" CommandLine IN ("*sethc.exe*", "*utilman.exe*", "*osk.exe*", "*magnify.exe*", "*narrator.exe*", "*displayswitch.exe*", "*atbroker.exe*", "*HelpPane.exe*")

# ── Potential Persistence Via Logon Scripts - CommandLine ──
# Mức độ  : Cao
# Chi tiết: Detects the addition of a new LogonScript to the registry value "UserInitMprLogonScript" for potential persistence
EventCode=4688 Channel="Security" CommandLine="*UserInitMprLogonScript*"

# ── Potential Credential Dumping Attempt Using New NetworkProvider - CLI ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects when an attacker tries to add a new network provider in order to dump clear text credentials, similar to how the NPPSpy tool does it
EventCode=4688 Channel="Security" CommandLine="*\\System\\CurrentControlSet\\Services\\*" CommandLine="*\\NetworkProvider*"

# ── Python Function Execution Security Warning Disabled In Excel ──
# Mức độ  : Cao
# Chi tiết: Detects changes to the registry value "PythonFunctionWarnings" that would prevent any warnings or alerts from showing when Python functions are about to be executed. Threat actors could run malicious 
EventCode=4688 Channel="Security" CommandLine="*\\Microsoft\\Office\\*" CommandLine="*\\Excel\\Security*" CommandLine="*PythonFunctionWarnings*" CommandLine="* 0*"

# ── Potential Privilege Escalation via Service Permissions Weakness ──
# Mức độ  : Cao
# Chi tiết: Detect modification of services configuration (ImagePath, FailureCommand and ServiceDLL) in registry by processes with Medium integrity level
EventCode=4688 Channel="Security" CommandLine="*ControlSet*" CommandLine="*services*" CommandLine IN ("*\\ImagePath*", "*\\FailureCommand*", "*\\ServiceDll*") MandatoryLabel IN ("S-1-16-8192", "None")

# ── Potential Provisioning Registry Key Abuse For Binary Proxy Execution ──
# Mức độ  : Cao
# Chi tiết: Detects potential abuse of the provisioning registry key for indirect command execution through "Provlaunch.exe".
EventCode=4688 Channel="Security" CommandLine="*SOFTWARE\\Microsoft\\Provisioning\\Commands\\*"

# ── Potential PowerShell Execution Policy Tampering - ProcCreation ──
# Mức độ  : Cao
# Chi tiết: Detects changes to the PowerShell execution policy registry key in order to bypass signing requirements for script execution from the CommandLine
EventCode=4688 Channel="Security" CommandLine IN ("*\\ShellIds\\Microsoft.PowerShell\\ExecutionPolicy*", "*\\Policies\\Microsoft\\Windows\\PowerShell\\ExecutionPolicy*") CommandLine IN ("*Bypass*", "*RemoteSigned*", "*Unrestricted*")

# ── Hiding User Account Via SpecialAccounts Registry Key - CommandLine ──
# Mức độ  : Trung bình
# Chi tiết: Detects changes to the registry key "HKLM\Software\Microsoft\Windows NT\CurrentVersion\Winlogon\SpecialAccounts\Userlist" where the value is set to "0" in order to hide user account from being listed 
EventCode=4688 Channel="Security" CommandLine="*\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon\\SpecialAccounts\\UserList*" CommandLine="*add*" CommandLine="*/v*" CommandLine="*/d 0*" NewProcessName="*\\reg.exe"

# ── Persistence Via TypedPaths - CommandLine ──
# Mức độ  : Trung bình
# Chi tiết: Detects modification addition to the 'TypedPaths' key in the user or admin registry via the commandline. Which might indicate persistence attempt
EventCode=4688 Channel="Security" CommandLine="*\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\TypedPaths*"

# ── Potential Regsvr32 Commandline Flag Anomaly ──
# Mức độ  : Trung bình
# Chi tiết: Detects a potential command line flag anomaly related to "regsvr32" in which the "/i" flag is used without the "/n" which should be uncommon.
EventCode=4688 Channel="Security" CommandLine="* -i:*" OR CommandLine="* /i:*" OR CommandLine="* –i:*" OR CommandLine="* —i:*" OR CommandLine="* ―i:*" NewProcessName="*\\regsvr32.exe" NOT CommandLine="* -n *" OR CommandLine="* /n *" OR CommandLine="* –n *" OR CommandLine="* —n *" OR CommandLine="* ―n *"

# ── Potentially Suspicious Regsvr32 HTTP IP Pattern ──
# Mức độ  : Cao
# Chi tiết: Detects regsvr32 execution to download and install DLLs located remotely where the address is an IP address.
EventCode=4688 Channel="Security" NewProcessName="*\\regsvr32.exe" OR OriginalFileName="REGSVR32.EXE" CommandLine IN ("* /i:http://1*", "* /i:http://2*", "* /i:http://3*", "* /i:http://4*", "* /i:http://5*", "* /i:http://6*", "* /i:http://7*", "* /i:http://8*", "* /i:http://9*", "* /i:https://1*", "* /i:https://2*", "* /i:https://3*", "* /i:https://4*", "* /i:https://5*", "* /i:https://6*", "* /i:https://7*", "* /i:https://8*", "* /i:https://9*", "* -i:http://1*", "* -i:http://2*", "* -i:http://3*", "* -i:http://4*", "* -i:http://5*", "* -i:http://6*", "* -i:http://7*", "* -i:http://8*", "* -i:http://9*", "* -i:https://1*", "* -i:https://2*", "* -i:https://3*", "* -i:https://4*", "* -i:https://5*", "* -i:https://6*", "* -i:https://7*", "* -i:https://8*", "* -i:https://9*")

# ── Potentially Suspicious Regsvr32 HTTP/FTP Pattern ──
# Mức độ  : Trung bình
# Chi tiết: Detects regsvr32 execution to download/install/register new DLLs that are hosted on Web or FTP servers.
EventCode=4688 Channel="Security" NewProcessName="*\\regsvr32.exe" OR OriginalFileName="REGSVR32.EXE" CommandLine IN ("* /i*", "* -i*") CommandLine IN ("*ftp*", "*http*")

# ── Suspicious Regsvr32 Execution From Remote Share ──
# Mức độ  : Cao
# Chi tiết: Detects REGSVR32.exe to execute DLL hosted on remote shares
EventCode=4688 Channel="Security" NewProcessName="*\\regsvr32.exe" OR OriginalFileName="\\REGSVR32.EXE" CommandLine="* \\\\*"

# ── Potentially Suspicious Child Process Of Regsvr32 ──
# Mức độ  : Cao
# Chi tiết: Detects potentially suspicious child processes of "regsvr32.exe".
EventCode=4688 Channel="Security" ParentProcessName="*\\regsvr32.exe" NewProcessName IN ("*\\calc.exe", "*\\cscript.exe", "*\\explorer.exe", "*\\mshta.exe", "*\\net.exe", "*\\net1.exe", "*\\nltest.exe", "*\\notepad.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\reg.exe", "*\\schtasks.exe", "*\\werfault.exe", "*\\wscript.exe") NOT (CommandLine="* -u -p *" NewProcessName="*\\werfault.exe")

# ── Regsvr32 Execution From Potential Suspicious Location ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of regsvr32 where the DLL is located in a potentially suspicious location.
EventCode=4688 Channel="Security" NewProcessName="*\\regsvr32.exe" OR OriginalFileName="REGSVR32.EXE" CommandLine IN ("*:\\ProgramData\\*", "*:\\Temp\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Temp\\*", "*\\AppData\\Local\\Temp\\*", "*\\AppData\\Roaming\\*")

# ── Regsvr32 Execution From Highly Suspicious Location ──
# Mức độ  : Cao
# Chi tiết: Detects execution of regsvr32 where the DLL is located in a highly suspicious locations
EventCode=4688 Channel="Security" NewProcessName="*\\regsvr32.exe" OR OriginalFileName="REGSVR32.EXE" CommandLine IN ("*:\\PerfLogs\\*", "*:\\Temp\\*", "*\\Windows\\Registration\\CRMLog*", "*\\Windows\\System32\\com\\dmp\\*", "*\\Windows\\System32\\FxsTmp\\*", "*\\Windows\\System32\\Microsoft\\Crypto\\RSA\\MachineKeys\\*", "*\\Windows\\System32\\spool\\drivers\\color\\*", "*\\Windows\\System32\\spool\\PRINTERS\\*", "*\\Windows\\System32\\spool\\SERVERS\\*", "*\\Windows\\System32\\Tasks_Migrated\\*", "*\\Windows\\System32\\Tasks\\Microsoft\\Windows\\SyncCenter\\*", "*\\Windows\\SysWOW64\\com\\dmp\\*", "*\\Windows\\SysWOW64\\FxsTmp\\*", "*\\Windows\\SysWOW64\\Tasks\\Microsoft\\Windows\\PLA\\System\\*", "*\\Windows\\SysWOW64\\Tasks\\Microsoft\\Windows\\SyncCenter\\*", "*\\Windows\\Tasks\\*", "*\\Windows\\Tracing\\*") OR (CommandLine IN ("* \"C:\\*", "* C:\\*", "* 'C:\\*", "*D:\\*") NOT (CommandLine IN ("*C:\\Program Files (x86)\\*", "*C:\\Program Files\\*", "*C:\\ProgramData\\*", "*C:\\Users\\*", "* C:\\Windows\\*", "* \"C:\\Windows\\*", "* 'C:\\Windows\\*"))) NOT (CommandLine="" OR NOT CommandLine=*)

# ── Regsvr32 DLL Execution With Suspicious File Extension ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of REGSVR32.exe with DLL files masquerading as other files
EventCode=4688 Channel="Security" NewProcessName="*\\regsvr32.exe" OR OriginalFileName="REGSVR32.EXE" CommandLine IN ("*.bin", "*.bmp", "*.cr2", "*.dat", "*.eps", "*.gif", "*.ico", "*.jpeg", "*.jpg", "*.log", "*.nef", "*.orf", "*.png", "*.raw", "*.rtf", "*.sr2", "*.temp", "*.tif", "*.tiff", "*.tmp", "*.txt")

# ── Scripting/CommandLine Process Spawned Regsvr32 ──
# Mức độ  : Trung bình
# Chi tiết: Detects various command line and scripting engines/processes such as "PowerShell", "Wscript", "Cmd", etc. spawning a "regsvr32" instance.
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wscript.exe") NewProcessName="*\\regsvr32.exe" NOT (CommandLine="* /s C:\\Windows\\System32\\RpcProxy\\RpcProxy.dll" ParentProcessName="C:\\Windows\\System32\\cmd.exe")

# ── Regsvr32 DLL Execution With Uncommon Extension ──
# Mức độ  : Trung bình
# Chi tiết: Detects a "regsvr32" execution where the DLL doesn't contain a common file extension.
EventCode=4688 Channel="Security" NewProcessName="*\\regsvr32.exe" OR OriginalFileName="REGSVR32.EXE" NOT (CommandLine IN ("*.ax*", "*.cpl*", "*.dll*", "*.ocx*") OR NOT CommandLine=* OR CommandLine="") NOT (CommandLine IN ("*.ppl*", "*.bav*"))

# ── Remote Access Tool - AnyDesk Execution ──
# Mức độ  : Trung bình
# Chi tiết: An adversary may use legitimate desktop support and remote access software, such as Team Viewer, Go2Assist, LogMein, AmmyyAdmin, etc, to establish an interactive command and control channel to target 
EventCode=4688 Channel="Security" NewProcessName IN ("*\\AnyDesk.exe", "*\\AnyDeskMSI.exe") OR Description="AnyDesk" OR Product="AnyDesk" OR Company="AnyDesk Software GmbH"

# ── Remote Access Tool - AnyDesk Piped Password Via CLI ──
# Mức độ  : Trung bình
# Chi tiết: Detects piping the password to an anydesk instance via CMD and the '--set-password' flag.
EventCode=4688 Channel="Security" CommandLine="*/c *" CommandLine="*echo *" CommandLine="*.exe --set-password*"

# ── Remote Access Tool - AnyDesk Execution With Known Revoked Signing Certificate ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of an AnyDesk binary with a version prior to 8.0.8. Prior to version 8.0.8, the Anydesk application used a signing certificate that got compromised by threat actors. Use this rul
EventCode=4688 Channel="Security" NewProcessName="*\\AnyDesk.exe" OR Description="AnyDesk" OR Product="AnyDesk" OR Company="AnyDesk Software GmbH" FileVersion IN ("7.0.*", "7.1.*", "8.0.1*", "8.0.2*", "8.0.3*", "8.0.4*", "8.0.5*", "8.0.6*", "8.0.7*") NOT (CommandLine IN ("* --remove*", "* --uninstall*"))

# ── Remote Access Tool - AnyDesk Silent Installation ──
# Mức độ  : Cao
# Chi tiết: Detects AnyDesk Remote Desktop silent installation. Which can be used by attackers to gain remote access.
EventCode=4688 Channel="Security" CommandLine="*--install*" CommandLine="*--start-with-win*" CommandLine="*--silent*"

# ── Remote Access Tool - Anydesk Execution From Suspicious Folder ──
# Mức độ  : Cao
# Chi tiết: An adversary may use legitimate desktop support and remote access software, such as Team Viewer, Go2Assist, LogMein, AmmyyAdmin, etc, to establish an interactive command and control channel to target 
EventCode=4688 Channel="Security" NewProcessName IN ("*\\AnyDesk.exe", "*\\AnyDeskMSI.exe") OR Description="AnyDesk" OR Product="AnyDesk" OR Company="AnyDesk Software GmbH" NOT (NewProcessName IN ("*\\AppData\\*", "*Program Files (x86)\\AnyDesk*", "*Program Files\\AnyDesk*"))

# ── Remote Access Tool - Potential MeshAgent Execution - Windows ──
# Mức độ  : Trung bình
# Chi tiết: Detects potential execution of MeshAgent which is a tool used for remote access. Historical data shows that threat actors rename MeshAgent binary to evade detection. Matching command lines with the '-
EventCode=4688 Channel="Security" CommandLine="*--meshServiceName*"

# ── Remote Access Tool - MeshAgent Command Execution via MeshCentral ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of MeshAgent to execute commands on the target host, particularly when threat actors might abuse it to execute commands directly. MeshAgent can execute commands on the target host by l
EventCode=4688 Channel="Security" ParentProcessName="*\\meshagent.exe" NewProcessName IN ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe")

# ── Remote Access Tool - NetSupport Execution From Unusual Location ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of client32.exe (NetSupport RAT) from an unusual location (outside of 'C:\Program Files')
EventCode=4688 Channel="Security" NewProcessName="*\\client32.exe" OR Product="*NetSupport Remote Control*" OR OriginalFileName="*client32.exe*" OR Hashes="*IMPHASH=a9d50692e95b79723f3e76fcf70d023e*" NOT (NewProcessName IN ("C:\\Program Files\\*", "C:\\Program Files (x86)\\*"))

# ── Remote Access Tool - Renamed MeshAgent Execution - Windows ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects the execution of a renamed instance of the Remote Monitoring and Management (RMM) tool, MeshAgent. RMM tools such as MeshAgent are commonly utilized by IT administrators for legitimate remote 
EventCode=4688 Channel="Security" CommandLine="*--meshServiceName*" OR OriginalFileName="*meshagent*" NOT NewProcessName="*\\meshagent.exe"

# ── Remote Access Tool - RURAT Execution From Unusual Location ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of Remote Utilities RAT (RURAT) from an unusual location (outside of 'C:\Program Files')
EventCode=4688 Channel="Security" NewProcessName IN ("*\\rutserv.exe", "*\\rfusclient.exe") OR Product="Remote Utilities" NOT (NewProcessName IN ("C:\\Program Files\\Remote Utilities*", "C:\\Program Files (x86)\\Remote Utilities*"))

# ── Remote Access Tool - ScreenConnect Installation Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects ScreenConnect program starts that establish a remote access to a system.
EventCode=4688 Channel="Security" CommandLine="*e=Access&*" CommandLine="*y=Guest&*" CommandLine="*&p=*" CommandLine="*&c=*" CommandLine="*&k=*"

# ── Remote Access Tool - ScreenConnect Remote Command Execution ──
# Mức độ  : Thấp
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the execution of a system command via the ScreenConnect RMM service.
EventCode=4688 Channel="Security" ParentProcessName="*\\ScreenConnect.ClientService.exe" NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*\\TEMP\\ScreenConnect\\*"

# ── Remote Access Tool - ScreenConnect Server Web Shell Execution ──
# Mức độ  : Cao
# Mục đích: Khai thác dịch vụ công khai
# Chi tiết: Detects potential web shell execution from the ScreenConnect server process.
EventCode=4688 Channel="Security" ParentProcessName="*\\ScreenConnect.Service.exe" NewProcessName IN ("*\\cmd.exe", "*\\csc.exe")

# ── Remote Access Tool - Simple Help Execution ──
# Mức độ  : Trung bình
# Chi tiết: An adversary may use legitimate desktop support and remote access software, such as Team Viewer, Go2Assist, LogMein, AmmyyAdmin, etc, to establish an interactive command and control channel to target 
EventCode=4688 Channel="Security" NewProcessName IN ("*\\JWrapper-Remote Access\\*", "*\\JWrapper-Remote Support\\*") NewProcessName="*\\SimpleService.exe"

# ── Remote Access Tool - TacticalRMM Agent Registration to Potentially Attacker-Controlled Server ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects TacticalRMM agent installations where the --api, --auth, and related flags are used on the command line. These parameters configure the agent to connect to a specific RMM server with authentic
EventCode=4688 Channel="Security" CommandLine="*--api*" CommandLine="*--auth*" CommandLine="*--client-id*" CommandLine="*--site-id*" CommandLine="*--agent-type*" NewProcessName="*\\TacticalAgent\\tacticalrmm.exe*"

# ── Remote Access Tool - Team Viewer Session Started On Windows Host ──
# Mức độ  : Thấp
# Chi tiết: Detects the command line executed when TeamViewer starts a session started by a remote host. Once a connection has been started, an investigator can verify the connection details by viewing the "incom
EventCode=4688 Channel="Security" CommandLine="*TeamViewer_Desktop.exe --IPCport 5939 --Module 1" NewProcessName="TeamViewer_Desktop.exe" ParentProcessName="TeamViewer_Service.exe"

# ── Discovery of a System Time ──
# Mức độ  : Thấp
# Chi tiết: Identifies use of various commands to query a systems time. This technique may be used before executing a scheduled task or to discover the time zone of a target system.
EventCode=4688 Channel="Security" (CommandLine="*time*" NewProcessName IN ("*\\net.exe", "*\\net1.exe")) OR (CommandLine="*tz*" NewProcessName="*\\w32tm.exe")

# ── Renamed AdFind Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the use of a renamed Adfind.exe. AdFind continues to be seen across majority of breaches. It is used to domain trust discovery to plan out subsequent steps in the attack chain.
EventCode=4688 Channel="Security" CommandLine IN ("*domainlist*", "*trustdmp*", "*dcmodes*", "*adinfo*", "* dclist *", "*computer_pwdnotreqd*", "*objectcategory=*", "*-subnets -f*", "*name=\"Domain Admins\"*", "*-sc u:*", "*domainncs*", "*dompol*", "* oudmp *", "*subnetdmp*", "*gpodmp*", "*fspdmp*", "*users_noexpire*", "*computers_active*", "*computers_pwdnotreqd*") OR Hashes IN ("*IMPHASH=BCA5675746D13A1F246E2DA3C2217492*", "*IMPHASH=53E117A96057EAF19C41380D0E87F1C2*", "*IMPHASH=d144de8117df2beceaba2201ad304764*", "*IMPHASH=12ce1c0f3f5837ecc18a3782408fa975*", "*IMPHASH=4fbf3f084fbbb2470b80b2013134df35*", "*IMPHASH=49b639b4acbecc49d72a01f357aa4930*", "*IMPHASH=680dad9e300346e05a85023965867201*", "*IMPHASH=21aa085d54992511b9f115355e468782*") OR OriginalFileName="AdFind.exe" NOT NewProcessName="*\\AdFind.exe"

# ── Renamed AutoIt Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of a renamed AutoIt2.exe or AutoIt3.exe. AutoIt is a scripting language and automation tool for Windows systems. While primarily used for legitimate automation tasks, it can be m
EventCode=4688 Channel="Security" CommandLine IN ("* /AutoIt3ExecuteScript*", "* /ErrorStdOut*") OR Hashes IN ("*IMPHASH=FDC554B3A8683918D731685855683DDF*", "*IMPHASH=CD30A61B60B3D60CECDB034C8C83C290*", "*IMPHASH=F8A00C72F2D667D2EDBB234D0C0AE000*") OR OriginalFileName IN ("AutoIt3.exe", "AutoIt2.exe", "AutoIt.exe") NOT (NewProcessName IN ("*\\AutoIt.exe", "*\\AutoIt2.exe", "*\\AutoIt3_x64.exe", "*\\AutoIt3.exe"))

# ── Renamed Cloudflared.EXE Execution ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of a renamed "cloudflared" binary.
EventCode=4688 Channel="Security" (CommandLine="* tunnel *" CommandLine="*cleanup *" CommandLine IN ("*-config *", "*-connector-id *")) OR (CommandLine="* tunnel *" CommandLine="* run *" CommandLine IN ("*-config *", "*-credentials-contents *", "*-credentials-file *", "*-token *")) OR (CommandLine="*-url*" CommandLine="*tunnel*") OR Hashes IN ("*SHA256=2fb6c04c4f95fb8d158af94c137f90ac820716deaf88d8ebec956254e046cb29*", "*SHA256=b3d21940a10fdef5e415ad70331ce257c24fe3bcf7722262302e0421791f87e8*", "*SHA256=1fbd8362b2d2d2e6a5750ae3db69cd1815e6c1d31da48a98b796450971a8e039*", "*SHA256=0409c9b12f9d0eda86e461ed9bdabeefb00172b26322079681a0bdf48e68dc28*", "*SHA256=7cfb411d04bac42ef93d1f0c93c0a481e38c6f4612b97ae89d4702595988edc7*", "*SHA256=5b3c2d846ab162dc6bc595cce3a49de5731afde5d6060be7066d21b013a28373*", "*SHA256=ce95df7f69664c3df19b76028e115931919a71517b776da7b42d353e2ff4a670*", "*SHA256=1293525a19cfe3bc8296b62fbfe19f083632ed644a1c18c10b045a1d3030d81a*", "*SHA256=af2b9161cfcb654b16408cd6b098afe9d1fb61a037d18d7090a119d4c0c8e0f0*", "*SHA256=39ddceb56a15798826a5fc4892fa2b474c444bb4d7a8bf2fa95e41cab10fa7a1*", "*SHA256=ccd11f2328023a0e7929e845d5b6e7bc783fb4650d65faef3ae090239d4bbce2*", "*SHA256=b6e5c5d2567ae8c69cc012ebcae30e6c9b5359d64a58d17ba75ec89f8bce71ac*", "*SHA256=f813484ea441404f18caad96f28138e8aaf0cb256163c09c2ab8a3acab87f69f*", "*SHA256=fc4a0802ab9c7409b892ca00636bec61e2acfc911bccfdeb9978b8ab5a2f828d*", "*SHA256=083150724b49604c8765c1ba19541fa260b133be0acb0647fcd936d81f054499*", "*SHA256=44303d6572956f28a0f2e4b188934fb9874f2584f5c81fa431a463cfbf28083b*", "*SHA256=5d38c46032a58e28ae5f7d174d8761ec3d64d186677f3ec53af5f51afb9bfd2f*", "*SHA256=e1e70fa42059911bc6685fafef957f9a73fc66f214d0704a9b932683a5204032*", "*SHA256=c01356092a365b84f84f0e66870bd1a05ba3feb53cafd973fa5fea2534bee234*", "*SHA256=b3f9c06151e30ee43d39e788a79cd918a314f24e04fe87f3de8272a2057b624f*", "*SHA256=cd81b2792f0739f473c31c9cb7cf2313154bfa28b839975802b90e8790bb5058*", "*SHA256=9ec7e6c8e1bfd883663d8d9d62c9e4f9ae373b731407181e32491b27a7218a2c*", "*SHA256=c2cfd23fdc6c0e1b1ffa0e545cbe556f18d11b362b4a89ba0713f6ab01c4827f*", "*SHA256=53f8adbd76c0eb16f5e43cadde422474d8a06f9c8f959389c1930042ad8beaa5*", "*SHA256=648c8d2f8001c113d2986dd00b7bbd181593d462bef73522cee212c4f71f95b3*", "*SHA256=ae047e2095e46c3f9c518b2be67ec753f4f0aad23b261a361fcb6144dcdb63b4*", "*SHA256=3153d2baa462978dd22ab33d1c2274ecc88c200225d6a3327f98d5b752d08f5c*", "*SHA256=f49cde976e628012c9db73e1c8d76081944ecf2297cdafeb78bb13290da274c4*", "*SHA256=d2513e58bb03ccc83affde685c6ef987924c37ce6707d8e9857e2524b0d7e90f*", "*SHA256=bb67c7623ba92fe64ffd9816b8d5b3b1ea3013960a30bd4cf6e295b3eb5b1bad*", "*SHA256=b34b3c3a91e3165d1481f0b3ec23eab93a1cfba94345a6cbfe5b18ddbd48eac7*", "*SHA256=f7848034e010d55f15e474ca998f96391e320ff29b00cfcc4c5e536529703e75*", "*SHA256=b6fc9493778cbe3bfc062d73f5cc604bc0ff058bc5e5dc6aac87f3a4008b54b6*", "*SHA256=f5c5e962577e2293c4ad10603816dce7cc273585969615fbf4e4bfa9eaff1688*", "*SHA256=d14c52d9220b606f428a8fe9f7c108b0d6f14cf71e7384749e98e6a95962e68f*", "*SHA256=d3a0e1a79158f3985cd49607ebe0cdfcc49cb9af96b8f43aefd0cdfe2f22e663*", "*SHA256=2fbbfc8299537ff80cadf9d0e27c223fe0ccb9052bf9d8763ad717bbfa521c77*", "*SHA256=19074674c6fbdaa573b3081745e5e26144fdf7a086d14e0e220d1814f1f13078*") NOT (NewProcessName IN ("*\\cloudflared.exe", "*\\cloudflared-windows-386.exe", "*\\cloudflared-windows-amd64.exe"))

# ── Renamed CreateDump Utility Execution ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Dump thông tin xác thực
# Chi tiết: Detects uses of a renamed legitimate createdump.exe LOLOBIN utility to dump process memory
EventCode=4688 Channel="Security" OriginalFileName="FX_VER_INTERNALNAME_STR" OR (CommandLine="* -u *" CommandLine="* -f *" CommandLine="*.dmp*") OR (CommandLine="* --full *" CommandLine="* --name *" CommandLine="*.dmp*") NOT NewProcessName="*\\createdump.exe"

# ── Potential Renamed Rundll32 Execution ──
# Mức độ  : Cao
# Chi tiết: Detects when 'DllRegisterServer' is called in the commandline and the image is not rundll32. This could mean that the 'rundll32' utility has been renamed in order to avoid detection
EventCode=4688 Channel="Security" CommandLine="*DllRegisterServer*" NOT NewProcessName="*\\rundll32.exe"

# ── Renamed Schtasks Execution ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Lên lịch tác vụ độc hại
# Chi tiết: Detects the execution of renamed schtasks.exe binary, which is a legitimate Windows utility used for scheduling tasks. One of the very common persistence techniques is schedule malicious tasks using s
EventCode=4688 Channel="Security" (CommandLine="* -create *" OR CommandLine="* /create *" OR CommandLine="* –create *" OR CommandLine="* —create *" OR CommandLine="* ―create *" OR CommandLine="* -delete *" OR CommandLine="* /delete *" OR CommandLine="* –delete *" OR CommandLine="* —delete *" OR CommandLine="* ―delete *" OR CommandLine="* -query *" OR CommandLine="* /query *" OR CommandLine="* –query *" OR CommandLine="* —query *" OR CommandLine="* ―query *" OR CommandLine="* -change *" OR CommandLine="* /change *" OR CommandLine="* –change *" OR CommandLine="* —change *" OR CommandLine="* ―change *" OR CommandLine="* -run *" OR CommandLine="* /run *" OR CommandLine="* –run *" OR CommandLine="* —run *" OR CommandLine="* ―run *" OR CommandLine="* -end *" OR CommandLine="* /end *" OR CommandLine="* –end *" OR CommandLine="* —end *" OR CommandLine="* ―end *" CommandLine="* -tn *" OR CommandLine="* /tn *" OR CommandLine="* –tn *" OR CommandLine="* —tn *" OR CommandLine="* ―tn *" OR CommandLine="* -tr *" OR CommandLine="* /tr *" OR CommandLine="* –tr *" OR CommandLine="* —tr *" OR CommandLine="* ―tr *" OR CommandLine="* -sc *" OR CommandLine="* /sc *" OR CommandLine="* –sc *" OR CommandLine="* —sc *" OR CommandLine="* ―sc *" OR CommandLine="* -st *" OR CommandLine="* /st *" OR CommandLine="* –st *" OR CommandLine="* —st *" OR CommandLine="* ―st *" OR CommandLine="* -ru *" OR CommandLine="* /ru *" OR CommandLine="* –ru *" OR CommandLine="* —ru *" OR CommandLine="* ―ru *" OR CommandLine="* -fo *" OR CommandLine="* /fo *" OR CommandLine="* –fo *" OR CommandLine="* —fo *" OR CommandLine="* ―fo *" NOT CommandLine="*schtasks*") OR (OriginalFileName="schtasks.exe" NOT NewProcessName="*\\schtasks.exe")

# ── Renamed ProcDump Execution ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects the execution of a renamed ProcDump executable. This often done by attackers or malware in order to evade defensive mechanisms.
EventCode=4688 Channel="Security" OriginalFileName="procdump" OR (CommandLine="* -ma *" OR CommandLine="* /ma *" OR CommandLine="* –ma *" OR CommandLine="* —ma *" OR CommandLine="* ―ma *" OR CommandLine="* -mp *" OR CommandLine="* /mp *" OR CommandLine="* –mp *" OR CommandLine="* —mp *" OR CommandLine="* ―mp *" CommandLine="* -accepteula*" OR CommandLine="* /accepteula*" OR CommandLine="* –accepteula*" OR CommandLine="* —accepteula*" OR CommandLine="* ―accepteula*") NOT (NewProcessName IN ("*\\procdump.exe", "*\\procdump64.exe", "*\\procdump64a.exe"))

# ── Capture Credentials with Rpcping.exe ──
# Mức độ  : Trung bình
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects using Rpcping.exe to send a RPC test connection to the target server (-s) and force the NTLM hash to be sent in the process.
EventCode=4688 Channel="Security" NewProcessName="*\\RpcPing.exe" OR OriginalFileName="\\RpcPing.exe" CommandLine="*-s*" OR CommandLine="*/s*" OR CommandLine="*–s*" OR CommandLine="*—s*" OR CommandLine="*―s*" (CommandLine="*-u*" OR CommandLine="*/u*" OR CommandLine="*–u*" OR CommandLine="*—u*" OR CommandLine="*―u*" CommandLine="*NTLM*") OR (CommandLine="*-t*" OR CommandLine="*/t*" OR CommandLine="*–t*" OR CommandLine="*—t*" OR CommandLine="*―t*" CommandLine="*ncacn_np*")

# ── Ruby Inline Command Execution ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution of ruby using the "-e" flag. This is could be used as a way to launch a reverse shell or execute live ruby code.
EventCode=4688 Channel="Security" NewProcessName="*\\ruby.exe" OR OriginalFileName="ruby.exe" CommandLine="* -e*"

# ── Potential Rundll32 Execution With DLL Stored In ADS ──
# Mức độ  : Cao
# Chi tiết: Detects execution of rundll32 where the DLL being called is stored in an Alternate Data Stream (ADS).
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE"
| regex CommandLine="[Rr][Uu][Nn][Dd][Ll][Ll]32(?:\\.[Ee][Xx][Ee])? \\S+?\\w:\\S+?:"

# ── Suspicious Advpack Call Via Rundll32.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects execution of "rundll32" calling "advpack.dll" with potential obfuscated ordinal calls in order to leverage the "RegisterOCX" function
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" OR CommandLine="*rundll32*" CommandLine="*advpack*" (CommandLine="*#+*" CommandLine="*12*") OR CommandLine="*#-*"

# ── Suspicious Rundll32 Invoking Inline VBScript ──
# Mức độ  : Cao
# Mục đích: Chèn mã vào tiến trình
# Chi tiết: Detects suspicious process related to rundll32 based on command line that invokes inline VBScript as seen being used by UNC2452
EventCode=4688 Channel="Security" CommandLine="*rundll32.exe*" CommandLine="*Execute*" CommandLine="*RegRead*" CommandLine="*window.close*"

# ── Rundll32 InstallScreenSaver Execution ──
# Mức độ  : Trung bình
# Chi tiết: An attacker may execute an application as a SCR File using rundll32.exe desk.cpl,InstallScreenSaver
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" CommandLine="*InstallScreenSaver*"

# ── Suspicious Key Manager Access ──
# Mức độ  : Cao
# Chi tiết: Detects the invocation of the Stored User Names and Passwords dialogue (Key Manager)
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" CommandLine="*keymgr*" CommandLine="*KRShowKeyMgr*"

# ── Mshtml.DLL RunHTMLApplication Suspicious Usage ──
# Mức độ  : Cao
# Chi tiết: Detects execution of commands that leverage the "mshtml.dll" RunHTMLApplication export to run arbitrary code via different protocol handlers (vbscript, javascript, file, http...)
EventCode=4688 Channel="Security" CommandLine="*\\..\\*" CommandLine="*mshtml*" CommandLine IN ("*#135*", "*RunHTMLApplication*")

# ── Rundll32 Execution Without CommandLine Parameters ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious start of rundll32.exe without any parameters as found in CobaltStrike beacon activity
EventCode=4688 Channel="Security" CommandLine IN ("*\\rundll32.exe", "*\\rundll32.exe\"", "*\\rundll32") NOT (ParentProcessName IN ("*\\AppData\\Local\\*", "*\\Microsoft\\Edge\\*"))

# ── Suspicious NTLM Authentication on the Printer Spooler Service ──
# Mức độ  : Cao
# Chi tiết: Detects a privilege elevation attempt by coercing NTLM authentication on the Printer Spooler service
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" CommandLine="*C:\\windows\\system32\\davclnt.dll,DavSetCookie*" CommandLine="*http*" CommandLine IN ("*spoolss*", "*srvsvc*", "*/print/pipe/*")

# ── Potential Obfuscated Ordinal Call Via Rundll32 ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "rundll32" with potential obfuscated ordinal calls
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" OR CommandLine="*rundll32*" CommandLine IN ("*#+*", "*#-*", "*#0*", "*#655*", "*#656*")

# ── Rundll32 Spawned Via Explorer.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "rundll32.exe" with a parent process of Explorer.exe. This has been observed by variants of Raspberry Robin, as first reported by Red Canary.
EventCode=4688 Channel="Security" ParentProcessName="*\\explorer.exe" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" NOT (CommandLine IN ("* C:\\Windows\\System32\\*", "* -localserver 22d8c27b-47a1-48d1-ad08-7da7abd79617"))

# ── Process Memory Dump Via Comsvcs.DLL ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình; Dump thông tin xác thực
# Chi tiết: Detects a process memory dump via "comsvcs.dll" using rundll32, covering multiple different techniques (ordinal, minidump function, etc.)
EventCode=4688 Channel="Security" (NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" OR CommandLine="*rundll32*" CommandLine="*comsvcs*" CommandLine="*full*" CommandLine IN ("*#-*", "*#+*", "*#24*", "*24 *", "*MiniDump*", "*#65560*")) OR (CommandLine="*24*" CommandLine="*comsvcs*" CommandLine="*full*" CommandLine IN ("* #*", "*,#*", "*, #*", "*\"#*"))

# ── Rundll32 Registered COM Objects ──
# Mức độ  : Cao
# Chi tiết: load malicious registered COM objects
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" CommandLine IN ("*-sta *", "*-localserver *") CommandLine="*{*" CommandLine="*}*"

# ── Suspicious Process Start Locations ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects suspicious process run from unusual locations
EventCode=4688 Channel="Security" NewProcessName IN ("*:\\RECYCLER\\*", "*:\\SystemVolumeInformation\\*") OR NewProcessName IN ("C:\\Windows\\Tasks\\*", "C:\\Windows\\debug\\*", "C:\\Windows\\fonts\\*", "C:\\Windows\\help\\*", "C:\\Windows\\drivers\\*", "C:\\Windows\\addins\\*", "C:\\Windows\\cursors\\*", "C:\\Windows\\system32\\tasks\\*")

# ── Shell32 DLL Execution in Suspicious Directory ──
# Mức độ  : Cao
# Chi tiết: Detects shell32.dll executing a DLL in a suspicious directory
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" CommandLine="*shell32.dll*" CommandLine="*Control_RunDLL*" CommandLine IN ("*%AppData%*", "*%LocalAppData%*", "*%Temp%*", "*%tmp%*", "*\\AppData\\*", "*\\Temp\\*", "*\\Users\\Public\\*")

# ── Potential ShellDispatch.DLL Functionality Abuse ──
# Mức độ  : Trung bình
# Chi tiết: Detects potential "ShellDispatch.dll" functionality abuse to execute arbitrary binaries via "ShellExecute"
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" CommandLine="*RunDll_ShellExecuteW*"

# ── Potentially Suspicious Rundll32 Activity ──
# Mức độ  : Trung bình
# Chi tiết: Detects suspicious execution of rundll32, with specific calls to some DLLs with known LOLBIN functionalities
EventCode=4688 Channel="Security" (CommandLine="*javascript:*" CommandLine="*.RegisterXLL*") OR (CommandLine="*url.dll*" CommandLine="*OpenURL*") OR (CommandLine="*url.dll*" CommandLine="*OpenURLA*") OR (CommandLine="*url.dll*" CommandLine="*FileProtocolHandler*") OR (CommandLine="*zipfldr.dll*" CommandLine="*RouteTheCall*") OR (CommandLine="*shell32.dll*" CommandLine="*Control_RunDLL*") OR (CommandLine="*shell32.dll*" CommandLine="*ShellExec_RunDLL*") OR (CommandLine="*mshtml.dll*" CommandLine="*PrintHTML*") OR (CommandLine="*advpack.dll*" CommandLine="*LaunchINFSection*") OR (CommandLine="*advpack.dll*" CommandLine="*RegisterOCX*") OR (CommandLine="*ieadvpack.dll*" CommandLine="*LaunchINFSection*") OR (CommandLine="*ieadvpack.dll*" CommandLine="*RegisterOCX*") OR (CommandLine="*ieframe.dll*" CommandLine="*OpenURL*") OR (CommandLine="*shdocvw.dll*" CommandLine="*OpenURL*") OR (CommandLine="*syssetup.dll*" CommandLine="*SetupInfObjectInstallAction*") OR (CommandLine="*setupapi.dll*" CommandLine="*InstallHinfSection*") OR (CommandLine="*pcwutl.dll*" CommandLine="*LaunchApplication*") OR (CommandLine="*dfshim.dll*" CommandLine="*ShOpenVerbApplication*") OR (CommandLine="*dfshim.dll*" CommandLine="*ShOpenVerbShortcut*") OR (CommandLine="*scrobj.dll*" CommandLine="*GenerateTypeLib*" CommandLine="*http*") OR (CommandLine="*shimgvw.dll*" CommandLine="*ImageView_Fullscreen*" CommandLine="*http*") OR (CommandLine="*comsvcs.dll*" CommandLine="*MiniDump*") NOT (CommandLine="*shell32.dll,Control_RunDLL desk.cpl,screensaver,@screensaver*" OR (ParentCommandLine="*.cpl*" CommandLine="*Shell32.dll*" CommandLine="*Control_RunDLL*" CommandLine="*.cpl*" ParentProcessName="C:\\Windows\\System32\\control.exe") OR (CommandLine="\"C:\\Windows\\system32\\rundll32.exe\" Shell32.dll,Control_RunDLL \"C:\\Windows\\System32\\*" CommandLine="*.cpl\"," ParentProcessName="C:\\Windows\\System32\\control.exe"))

# ── Suspicious Control Panel DLL Load ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious Rundll32 execution from control.exe as used by Equation Group and Exploit Kits
EventCode=4688 Channel="Security" ParentProcessName="*\\System32\\control.exe" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" NOT CommandLine="*Shell32.dll*"

# ── Suspicious Rundll32 Execution With Image Extension ──
# Mức độ  : Cao
# Chi tiết: Detects the execution of Rundll32.exe with DLL files masquerading as image files
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.exe" CommandLine IN ("*.bmp*", "*.cr2*", "*.eps*", "*.gif*", "*.ico*", "*.jpeg*", "*.jpg*", "*.nef*", "*.orf*", "*.png*", "*.raw*", "*.sr2*", "*.tif*", "*.tiff*")

# ── Suspicious Usage Of ShellExec_RunDLL ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious usage of the ShellExec_RunDLL function to launch other commands as seen in the the raspberry-robin attack
EventCode=4688 Channel="Security" CommandLine="*ShellExec_RunDLL*" CommandLine IN ("*\\Desktop\\*", "*\\Temp\\*", "*\\Users\\Public\\*", "*comspec*", "*iex*", "*Invoke-*", "*msiexec*", "*odbcconf*", "*regsvr32*")

# ── Suspicious ShellExec_RunDLL Call Via Ordinal ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious call to the "ShellExec_RunDLL" exported function of SHELL32.DLL through the ordinal number to launch other commands. Adversary might only use the ordinal number in order to bypass e
EventCode=4688 Channel="Security" ParentCommandLine="*SHELL32.DLL*" ParentCommandLine IN ("*#568*", "*#570*", "*#572*", "*#576*") ParentCommandLine IN ("*comspec*", "*iex*", "*Invoke-*", "*msiexec*", "*odbcconf*", "*regsvr32*") OR ParentCommandLine IN ("*\\Desktop\\*", "*\\ProgramData\\*", "*\\Temp\\*", "*\\Users\\Public\\*") OR NewProcessName IN ("*\\bash.exe", "*\\bitsadmin.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\curl.exe", "*\\mshta.exe", "*\\msiexec.exe", "*\\msxsl.exe", "*\\odbcconf.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\schtasks.exe", "*\\wmic.exe", "*\\wscript.exe")

# ── ShimCache Flush ──
# Mức độ  : Cao
# Mục đích: Sửa registry
# Chi tiết: Detects actions that clear the local ShimCache and remove forensic evidence
EventCode=4688 Channel="Security" (CommandLine="*rundll32*" CommandLine="*apphelp.dll*" CommandLine IN ("*ShimFlushCache*", "*#250*")) OR (CommandLine="*rundll32*" CommandLine="*kernel32.dll*" CommandLine IN ("*BaseFlushAppcompatCache*", "*#46*"))

# ── Suspicious Rundll32 Activity Invoking Sys File ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious process related to rundll32 based on command line that includes a *.sys file as seen being used by UNC2452
EventCode=4688 Channel="Security" CommandLine="*rundll32.exe*" CommandLine IN ("*.sys,*", "*.sys *")

# ── Potentially Suspicious Rundll32.EXE Execution of UDL File ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of rundll32.exe with the oledb32.dll library to open a UDL file. Threat actors can abuse this technique as a phishing vector to capture authentication credentials or other sensit
EventCode=4688 Channel="Security" ParentProcessName="*\\explorer.exe" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" CommandLine="*oledb32.dll*" CommandLine="*,OpenDSLFile *" CommandLine="*\\Users\\*\\Downloads\\*" CommandLine="*.udl"

# ── Rundll32 UNC Path Execution ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects rundll32 execution where the DLL is located on a remote location (share)
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" OR CommandLine="*rundll32*" CommandLine="* \\\\*"

# ── Rundll32 Execution With Uncommon DLL Extension ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of rundll32 with a command line that doesn't contain a common extension
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" NOT (NOT CommandLine=* OR CommandLine="" OR CommandLine IN ("*.cpl *", "*.cpl,*", "*.cpl\"*", "*.cpl'*", "*.dll *", "*.dll,*", "*.dll\"*", "*.dll'*", "*.inf *", "*.inf,*", "*.inf\"*", "*.inf'*") OR CommandLine IN ("*.cpl", "*.dll", "*.inf") OR CommandLine="* -localserver *" OR (CommandLine="*:\\Windows\\Installer\\*" CommandLine="*.tmp*" CommandLine="*zzzzInvokeManagedCustomActionOutOfProc*" ParentProcessName="*\\msiexec.exe")) NOT (ParentCommandLine="*:\\Users\\*" ParentCommandLine="*\\AppData\\Local\\Microsoft\\EdgeUpdate\\Install\\{*" ParentCommandLine="*\\EDGEMITMP_*" ParentCommandLine="*.tmp\\setup.exe*" ParentCommandLine="*--install-archive=*" ParentCommandLine="*--previous-version=*" ParentCommandLine="*--msedgewebview --verbose-logging --do-not-launch-msedge --user-level*")

# ── Suspicious Workstation Locking via Rundll32 ──
# Mức độ  : Trung bình
# Chi tiết: Detects a suspicious call to the user32.dll function that locks the user workstation
EventCode=4688 Channel="Security" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" ParentProcessName="*\\cmd.exe" CommandLine="*user32.dll,*" CommandLine="*LockWorkStation*"

# ── WebDav Client Execution Via Rundll32.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects "svchost.exe" spawning "rundll32.exe" with command arguments like "C:\windows\system32\davclnt.dll,DavSetCookie". This could be an indicator of exfiltration or use of WebDav to launch code (ho
EventCode=4688 Channel="Security" ParentProcessName="*\\svchost.exe" NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" CommandLine="*C:\\windows\\system32\\davclnt.dll,DavSetCookie*"

# ── Rundll32 Execution Without Parameters ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects rundll32 execution without parameters as observed when running Metasploit windows/smb/psexec exploit module
EventCode=4688 Channel="Security" CommandLine IN ("rundll32.exe", "rundll32")

# ── Run Once Task Execution as Configured in Registry ──
# Mức độ  : Thấp
# Mục đích: Sửa registry
# Chi tiết: This rule detects the execution of Run Once task as configured in the registry
EventCode=4688 Channel="Security" NewProcessName="*\\runonce.exe" OR Description="Run Once Wrapper" CommandLine IN ("*/AlternateShellStartup*", "*/r")

# ── Possible Privilege Escalation via Weak Service Permissions ──
# Mức độ  : Cao
# Chi tiết: Detection of sc.exe utility spawning by user with Medium integrity level to change service ImagePath or FailureCommand
EventCode=4688 Channel="Security" NewProcessName="*\\sc.exe" MandatoryLabel IN ("S-1-16-8192", "None") (CommandLine="*config*" CommandLine="*binPath*") OR (CommandLine="*failure*" CommandLine="*command*")

# ── New Service Creation Using Sc.EXE ──
# Mức độ  : Thấp
# Chi tiết: Detects the creation of a new service using the "sc.exe" utility.
EventCode=4688 Channel="Security" CommandLine="*create*" CommandLine="*binPath*" NewProcessName="*\\sc.exe" NOT (ParentProcessName IN ("C:\\Program Files (x86)\\Dropbox\\Client\\*", "C:\\Program Files\\Dropbox\\Client\\*") ParentProcessName="*\\Dropbox.exe")

# ── Service StartupType Change Via Sc.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detect the use of "sc.exe" to change the startup type of a service to "disabled" or "demand"
EventCode=4688 Channel="Security" NewProcessName="*\\sc.exe" OR OriginalFileName="sc.exe" CommandLine="* config *" CommandLine="*start*" CommandLine IN ("*disabled*", "*demand*")

# ── New Kernel Driver Via SC.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects creation of a new service (kernel driver) with the type "kernel"
EventCode=4688 Channel="Security" CommandLine IN ("*create*", "*config*") CommandLine="*binPath*" CommandLine="*type*" CommandLine="*kernel*" NewProcessName="*\\sc.exe" NOT ((CommandLine="*create netprotection_network_filter*" CommandLine="*type= kernel start= *" CommandLine="*binPath= System32\\drivers\\netprotection_network_filter*" CommandLine="*DisplayName= netprotection_network_filter*" CommandLine="*group= PNP_TDI tag= yes*") OR (CommandLine="*create avelam binpath=C:\\Windows\\system32\\drivers\\avelam.sys*" CommandLine="*type=kernel start=boot error=critical group=Early-Launch*"))

# ── Interesting Service Enumeration Via Sc.EXE ──
# Mức độ  : Thấp
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the enumeration and query of interesting and in some cases sensitive services on the system via "sc.exe". Attackers often try to enumerate the services currently running on a system in order t
EventCode=4688 Channel="Security" NewProcessName="*\\sc.exe" OR OriginalFileName="sc.exe" CommandLine="*query*" CommandLine="*termservice*"

# ── Allow Service Access Using Security Descriptor Tampering Via Sc.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious DACL modifications to allow access to a service from a suspicious trustee. This can be used to override access restrictions set by previous ACLs.
EventCode=4688 Channel="Security" NewProcessName="*\\sc.exe" OR OriginalFileName="sc.exe" CommandLine="*sdset*" CommandLine="*A;*" CommandLine IN ("*;IU*", "*;SU*", "*;BA*", "*;SY*", "*;WD*") NOT ParentProcessName="C:\\Hexnode\\Hexnode Agent\\Current\\HexnodeAgent.exe"

# ── Deny Service Access Using Security Descriptor Tampering Via Sc.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious DACL modifications to deny access to a service that affects critical trustees. This can be used to hide services or make them unstoppable.
EventCode=4688 Channel="Security" NewProcessName="*\\sc.exe" OR OriginalFileName="sc.exe" CommandLine="*sdset*" CommandLine="*D;*" CommandLine IN ("*;IU*", "*;SU*", "*;BA*", "*;SY*", "*;WD*")

# ── Service DACL Abuse To Hide Services Via Sc.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects usage of the "sc.exe" utility adding a new service with special permission seen used by threat actors which makes the service hidden and unremovable.
EventCode=4688 Channel="Security" NewProcessName="*\\sc.exe" OR OriginalFileName="sc.exe" CommandLine="*sdset*" CommandLine="*DCLCWPDTSD*"

# ── Service Security Descriptor Tampering Via Sc.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detection of sc.exe utility adding a new service with special permission which hides that service.
EventCode=4688 Channel="Security" NewProcessName="*\\sc.exe" OR OriginalFileName="sc.exe" CommandLine="*sdset*"

# ── Suspicious Service Path Modification ──
# Mức độ  : Cao
# Chi tiết: Detects service path modification via the "sc" binary to a suspicious command or path
EventCode=4688 Channel="Security" CommandLine="*config*" CommandLine="*binPath*" CommandLine IN ("*powershell*", "*cmd *", "*mshta*", "*wscript*", "*cscript*", "*rundll32*", "*svchost*", "*dllhost*", "*cmd.exe /c*", "*cmd.exe /k*", "*cmd.exe /r*", "*cmd /c*", "*cmd /k*", "*cmd /r*", "*C:\\Users\\Public*", "*\\Downloads\\*", "*\\Desktop\\*", "*\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\\*", "*C:\\Windows\\TEMP\\*", "*\\AppData\\Local\\Temp*") NewProcessName="*\\sc.exe"

# ── Potential Persistence Attempt Via Existing Service Tampering ──
# Mức độ  : Trung bình
# Chi tiết: Detects the modification of an existing service in order to execute an arbitrary payload when the service is started or killed as a potential method for persistence.
EventCode=4688 Channel="Security" (CommandLine="*sc *" CommandLine="*config *" CommandLine="*binpath=*") OR (CommandLine="*sc *" CommandLine="*failure*" CommandLine="*command=*") OR ((CommandLine="*reg *" CommandLine="*add *" CommandLine="*FailureCommand*") OR (CommandLine="*reg *" CommandLine="*add *" CommandLine="*ImagePath*") CommandLine IN ("*.sh*", "*.exe*", "*.dll*", "*.bin$*", "*.bat*", "*.cmd*", "*.js*", "*.msh$*", "*.reg$*", "*.scr*", "*.ps*", "*.vb*", "*.jar*", "*.pl*"))

# ── Stop Windows Service Via Sc.EXE ──
# Mức độ  : Thấp
# Chi tiết: Detects the stopping of a Windows service via the "sc.exe" utility
EventCode=4688 Channel="Security" OriginalFileName="sc.exe" OR NewProcessName="*\\sc.exe" CommandLine="* stop *"

# ── Suspicious Schtasks Execution AppData Folder ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại; Thực thi lệnh/script
# Chi tiết: Detects the creation of a schtask that executes a file from C:\Users\<USER>\AppData\Local
EventCode=4688 Channel="Security" CommandLine="*/Create*" CommandLine="*/RU*" CommandLine="*/TR*" CommandLine="*C:\\Users\\*" CommandLine="*\\AppData\\Local\\*" CommandLine IN ("*NT AUT*", "* SYSTEM *") NewProcessName="*\\schtasks.exe" NOT (CommandLine="*/TN TVInstallRestore*" ParentProcessName="*\\AppData\\Local\\Temp\\*" ParentProcessName="*TeamViewer_.exe*" NewProcessName="*\\schtasks.exe")

# ── Suspicious Modification Of Scheduled Tasks ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects when an attacker tries to modify an already existing scheduled tasks to run from a suspicious location Attackers can create a simple looking task in order to avoid detection on creation as it'
EventCode=4688 Channel="Security" CommandLine="* /Change *" CommandLine="* /TN *" NewProcessName="*\\schtasks.exe" CommandLine IN ("*\\AppData\\Local\\Temp*", "*\\AppData\\Roaming\\*", "*\\Users\\Public\\*", "*\\WINDOWS\\Temp\\*", "*\\Desktop\\*", "*\\Downloads\\*", "*\\Temporary Internet*", "*C:\\ProgramData\\*", "*C:\\Perflogs\\*", "*%ProgramData%*", "*%appdata%*", "*%comspec%*", "*%localappdata%*") CommandLine IN ("*regsvr32*", "*rundll32*", "*cmd /c *", "*cmd /k *", "*cmd /r *", "*cmd.exe /c *", "*cmd.exe /k *", "*cmd.exe /r *", "*powershell*", "*mshta*", "*wscript*", "*cscript*", "*certutil*", "*bitsadmin*", "*bash.exe*", "*bash *", "*scrcons*", "*wmic *", "*wmic.exe*", "*forfiles*", "*scriptrunner*", "*hh.exe*", "*hh *")

# ── Scheduled Task Creation Via Schtasks.EXE ──
# Mức độ  : Thấp
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects the creation of scheduled tasks by user accounts via the "schtasks" utility.
EventCode=4688 Channel="Security" CommandLine="* /create *" NewProcessName="*\\schtasks.exe" NOT (SubjectUserName IN ("*AUTHORI*", "*AUTORI*")) NOT (CommandLine="*Microsoft\\Office\\Office Performance Monitor*" ParentProcessName IN ("C:\\Program Files\\Microsoft Office\\root\\integration\\integrator.exe", "C:\\Program Files (x86)\\Microsoft Office\\root\\integration\\integrator.exe") NewProcessName IN ("C:\\Windows\\System32\\schtasks.exe", "C:\\Windows\\SysWOW64\\schtasks.exe"))

# ── Suspicious Scheduled Task Creation Involving Temp Folder ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects the creation of scheduled tasks that involves a temporary folder and runs only once
EventCode=4688 Channel="Security" CommandLine="* /create *" CommandLine="* /sc once *" CommandLine="*\\Temp\\*" NewProcessName="*\\schtasks.exe"

# ── Scheduled Task Creation with Curl and PowerShell Execution Combo ──
# Mức độ  : Trung bình
# Mục đích: Lên lịch tác vụ độc hại; Tải file từ mạng
# Chi tiết: Detects the creation of a scheduled task using schtasks.exe, potentially in combination with curl for downloading payloads and PowerShell for executing them. This facilitates executing malicious paylo
EventCode=4688 Channel="Security" CommandLine="* -create *" OR CommandLine="* /create *" OR CommandLine="* –create *" OR CommandLine="* —create *" OR CommandLine="* ―create *" NewProcessName="*\\schtasks.exe" CommandLine="*curl *" CommandLine="*http*" CommandLine="*-o*" CommandLine="*powershell*"

# ── Delete Important Scheduled Task ──
# Mức độ  : Cao
# Chi tiết: Detects when adversaries stop services or processes by deleting their respective scheduled tasks in order to conduct data destructive activities
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe" OR OriginalFileName="schtasks.exe" CommandLine="*-delete*" OR CommandLine="*/delete*" OR CommandLine="*–delete*" OR CommandLine="*—delete*" OR CommandLine="*―delete*" CommandLine IN ("*\\Windows\\BitLocker*", "*\\Windows\\ExploitGuard*", "*\\Windows\\SystemRestore\\SR*", "*\\Windows\\UpdateOrchestrator\\*", "*\\Windows\\Windows Defender\\*", "*\\Windows\\WindowsBackup\\*", "*\\Windows\\WindowsUpdate\\*")

# ── Delete All Scheduled Tasks ──
# Mức độ  : Cao
# Chi tiết: Detects the usage of schtasks with the delete flag and the asterisk symbol to delete all tasks from the schedule of the local computer, including tasks scheduled by other users.
EventCode=4688 Channel="Security" CommandLine="* /delete *" CommandLine="*/tn \**" CommandLine="* /f*" NewProcessName="*\\schtasks.exe"

# ── Disable Important Scheduled Task ──
# Mức độ  : Cao
# Chi tiết: Detects when adversaries stop services or processes by disabling their respective scheduled tasks in order to conduct data destructive activities
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe" OR OriginalFileName="schtasks.exe" CommandLine="*-disable*" OR CommandLine="*/disable*" OR CommandLine="*–disable*" OR CommandLine="*—disable*" OR CommandLine="*―disable*" CommandLine IN ("*\\Windows\\BitLocker*", "*\\Windows\\ExploitGuard*", "*\\Windows\\ExploitGuard\\ExploitGuard MDM policy Refresh*", "*\\Windows\\SystemRestore\\SR*", "*\\Windows\\UpdateOrchestrator\\*", "*\\Windows\\Windows Defender\\*", "*\\Windows\\WindowsBackup\\*", "*\\Windows\\WindowsUpdate\\*")

# ── Schedule Task Creation From Env Variable Or Potentially Suspicious Path Via Schtasks.EXE ──
# Mức độ  : Trung bình
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects Schtask creations that point to a suspicious folder or an environment variable often used by malware
EventCode=4688 Channel="Security" (CommandLine="* -create *" OR CommandLine="* /create *" OR CommandLine="* –create *" OR CommandLine="* —create *" OR CommandLine="* ―create *" NewProcessName="*\\schtasks.exe" CommandLine IN ("*:\\Perflogs*", "*:\\Users\\All Users\\*", "*:\\Users\\Default\\*", "*:\\Users\\Public*", "*:\\Windows\\Temp*", "*\\AppData\\Local\\*", "*\\AppData\\Roaming\\*", "*%AppData%*", "*%Public%*")) OR (ParentCommandLine="*\\svchost.exe -k netsvcs -p -s Schedule" CommandLine IN ("*:\\Perflogs*", "*:\\Windows\\Temp*", "*\\Users\\Public*", "*%Public%*")) NOT (ParentCommandLine="*unattended.ini*" OR CommandLine="*update_task.xml*" OR CommandLine="*/Create /TN TVInstallRestore /TR*" OR (CommandLine="*/Create /Xml *" CommandLine="*\\Temp\\.CR.*" CommandLine="*\\Avira_Security_Installation.xml*") OR (CommandLine="*/Create /F /TN*" CommandLine="*/Xml *" CommandLine="*\\Temp\\*" CommandLine="*Avira_*" CommandLine IN ("*.tmp\\UpdateFallbackTask.xml*", "*.tmp\\WatchdogServiceControlManagerTimeout.xml*", "*.tmp\\SystrayAutostart.xml*", "*.tmp\\MaintenanceTask.xml*")) OR (CommandLine="*\\Temp\\*" CommandLine="*/Create /TN \"klcp_update\" /XML *" CommandLine="*\\klcp_update_task.xml*"))

# ── Schtasks From Suspicious Folders ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects scheduled task creations that have suspicious action command and folder combinations
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe" OR OriginalFileName="schtasks.exe" CommandLine="* /create *" CommandLine IN ("*powershell*", "*pwsh*", "*cmd /c *", "*cmd /k *", "*cmd /r *", "*cmd.exe /c *", "*cmd.exe /k *", "*cmd.exe /r *") CommandLine IN ("*C:\\ProgramData\\*", "*%ProgramData%*")

# ── Suspicious Scheduled Task Name As GUID ──
# Mức độ  : Trung bình
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects creation of a scheduled task with a GUID like name
EventCode=4688 Channel="Security" CommandLine="*/Create *" NewProcessName="*\\schtasks.exe" CommandLine IN ("*/TN \"{*", "*/TN '{*", "*/TN {*") CommandLine IN ("*}\"*", "*}'*", "*} *")

# ── Uncommon One Time Only Scheduled Task At 00:00 ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects scheduled task creation events that include suspicious actions, and is run once at 00:00
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe*" OR OriginalFileName="schtasks.exe" CommandLine IN ("*wscript*", "*vbscript*", "*cscript*", "*wmic *", "*wmic.exe*", "*regsvr32.exe*", "*powershell*", "*\\AppData\\*") CommandLine="*once*" CommandLine="*00:00*"

# ── Potential SSH Tunnel Persistence Install Using A Scheduled Task ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects the creation of new scheduled tasks via commandline, using Schtasks.exe. This rule detects tasks creating that call OpenSSH, which may indicate the creation of reverse SSH tunnel to the attack
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe" OR OriginalFileName="schtasks.exe" (CommandLine="* /create *" CommandLine="*sshd.exe*" CommandLine="*-f*") OR (CommandLine="* /create *" CommandLine="*ssh.exe*" CommandLine="*-i*")

# ── Potential Persistence Via Microsoft Compatibility Appraiser ──
# Mức độ  : Trung bình
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects manual execution of the "Microsoft Compatibility Appraiser" task via schtasks. In order to trigger persistence stored in the "\AppCompatFlags\TelemetryController" registry key.
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe" OR OriginalFileName="schtasks.exe" CommandLine="*run *" CommandLine="*\\Application Experience\\Microsoft Compatibility Appraiser*"

# ── Scheduled Task Executing Payload from Registry ──
# Mức độ  : Trung bình
# Mục đích: Lên lịch tác vụ độc hại; Thực thi lệnh/script
# Chi tiết: Detects the creation of a schtasks that potentially executes a payload stored in the Windows Registry using PowerShell.
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe" OR OriginalFileName="schtasks.exe" CommandLine="*/Create*" CommandLine IN ("*Get-ItemProperty*", "* gp *") CommandLine IN ("*HKCU:*", "*HKLM:*", "*registry::*", "*HKEY_*") NOT (CommandLine IN ("*FromBase64String*", "*encodedcommand*"))

# ── Scheduled Task Executing Encoded Payload from Registry ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại; Thực thi lệnh/script
# Chi tiết: Detects the creation of a schtask that potentially executes a base64 encoded payload stored in the Windows Registry using PowerShell.
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe" OR OriginalFileName="schtasks.exe" CommandLine="*/Create*" CommandLine IN ("*FromBase64String*", "*encodedcommand*") CommandLine IN ("*Get-ItemProperty*", "* gp *") CommandLine IN ("*HKCU:*", "*HKLM:*", "*registry::*", "*HKEY_*")

# ── Suspicious Schtasks Schedule Types ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects scheduled task creations or modification on a suspicious schedule type
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe" OR OriginalFileName="schtasks.exe" CommandLine IN ("* ONLOGON *", "* ONSTART *", "* ONCE *", "* ONIDLE *") NOT (CommandLine IN ("*NT AUT*", "* SYSTEM*", "*HIGHEST*"))

# ── Suspicious Schtasks Schedule Type With High Privileges ──
# Mức độ  : Trung bình
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects scheduled task creations or modification to be run with high privileges on a suspicious schedule type
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe" OR OriginalFileName="schtasks.exe" CommandLine IN ("* ONLOGON *", "* ONSTART *", "* ONCE *", "* ONIDLE *") CommandLine IN ("*NT AUT*", "* SYSTEM*", "*HIGHEST*")

# ── Suspicious Scheduled Task Creation via Masqueraded XML File ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình; Lên lịch tác vụ độc hại
# Chi tiết: Detects the creation of a scheduled task using the "-XML" flag with a file without the '.xml' extension. This behavior could be indicative of potential defense evasion attempt during persistence
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe" OR OriginalFileName="schtasks.exe" CommandLine IN ("*/create*", "*-create*") CommandLine IN ("*/xml*", "*-xml*") NOT (CommandLine="*.xml*" OR MandatoryLabel IN ("S-1-16-16384", "None") OR (ParentCommandLine="*:\\WINDOWS\\Installer\\MSI*" ParentCommandLine="*.tmp,zzzzInvokeManagedCustomActionOutOfProc*" ParentProcessName="*\\rundll32.exe")) NOT (ParentProcessName IN ("*:\\ProgramData\\OEM\\UpgradeTool\\CareCenter_*\\BUnzip\\Setup_msi.exe", "*:\\Program Files\\Axis Communications\\AXIS Camera Station\\SetupActions.exe", "*:\\Program Files\\Axis Communications\\AXIS Device Manager\\AdmSetupActions.exe", "*:\\Program Files (x86)\\Zemana\\AntiMalware\\AntiMalware.exe", "*:\\Program Files\\Dell\\SupportAssist\\pcdrcui.exe"))

# ── Suspicious Command Patterns In Scheduled Task Creation ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects scheduled task creation using "schtasks" that contain potentially suspicious or uncommon commands
EventCode=4688 Channel="Security" CommandLine="*/Create *" NewProcessName="*\\schtasks.exe" (CommandLine IN ("*/sc minute *", "*/ru system *") CommandLine IN ("*cmd /c*", "*cmd /k*", "*cmd /r*", "*cmd.exe /c *", "*cmd.exe /k *", "*cmd.exe /r *")) OR CommandLine IN ("* -decode *", "* -enc *", "* -w hidden *", "* bypass *", "* IEX*", "*.DownloadData*", "*.DownloadFile*", "*.DownloadString*", "*/c start /min *", "*FromBase64String*", "*mshta http*", "*mshta.exe http*") OR (CommandLine IN ("*:\\ProgramData\\*", "*:\\Temp\\*", "*:\\Tmp\\*", "*:\\Users\\Public\\*", "*:\\Windows\\Temp\\*", "*\\AppData\\*", "*%AppData%*", "*%Temp%*", "*%tmp%*") CommandLine IN ("*cscript*", "*curl*", "*wscript*"))

# ── Schtasks Creation Or Modification With SYSTEM Privileges ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Detects the creation or update of a scheduled task to run with "NT AUTHORITY\SYSTEM" privileges
EventCode=4688 Channel="Security" CommandLine IN ("* /change *", "* /create *") NewProcessName="*\\schtasks.exe" CommandLine="*/ru *" CommandLine IN ("*NT AUT*", "* SYSTEM *") NOT ((CommandLine="*/TN TVInstallRestore*" CommandLine="*\\TeamViewer_.exe*" NewProcessName="*\\schtasks.exe") OR (CommandLine="*Subscription Heartbeat*" CommandLine="*\\HeartbeatConfig.xml*" CommandLine="*\\Microsoft Shared\\OFFICE*") OR CommandLine IN ("*/Create /F /RU System /SC WEEKLY /TN AviraSystemSpeedupVerify /TR *", "*:\\Program Files (x86)\\Avira\\System Speedup\\setup\\avira_speedup_setup.exe*", "*/VERIFY /VERYSILENT /NOSTART /NODOTNET /NORESTART\" /RL HIGHEST*"))

# ── Scheduled Task Creation Masquerading as System Processes ──
# Mức độ  : Cao
# Mục đích: Lên lịch tác vụ độc hại; Giả mạo tên tiến trình
# Chi tiết: Detects the creation of scheduled tasks that involve system processes, which may indicate malicious actors masquerading as or abusing these processes to execute payloads or maintain persistence.
EventCode=4688 Channel="Security" NewProcessName="*\\schtasks.exe" OR OriginalFileName="schtasks.exe" CommandLine="* -create *" OR CommandLine="* /create *" OR CommandLine="* –create *" OR CommandLine="* —create *" OR CommandLine="* ―create *" CommandLine IN ("* audiodg*", "* conhost*", "* dwm.exe*", "* explorer*", "* lsass*", "* lsm*", "* mmc*", "* msiexec*", "* regsvr32*", "* rundll32*", "* services*", "* spoolsv*", "* svchost*", "* taskeng*", "* taskhost*", "* wininit*", "* winlogon*")

# ── Script Event Consumer Spawning Process ──
# Mức độ  : Cao
# Chi tiết: Detects a suspicious child process of Script Event Consumer (scrcons.exe).
EventCode=4688 Channel="Security" ParentProcessName="*\\scrcons.exe" NewProcessName IN ("*\\svchost.exe", "*\\dllhost.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wscript.exe", "*\\cscript.exe", "*\\schtasks.exe", "*\\regsvr32.exe", "*\\mshta.exe", "*\\rundll32.exe", "*\\msiexec.exe", "*\\msbuild.exe")

# ── Potential Shim Database Persistence via Sdbinst.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects installation of a new shim using sdbinst.exe. Adversaries may establish persistence and/or elevate privileges by executing malicious content triggered by application shims
EventCode=4688 Channel="Security" NewProcessName="*\\sdbinst.exe" OR OriginalFileName="sdbinst.exe" CommandLine="*.sdb*" NOT (CommandLine IN ("*:\\Program Files (x86)\\IIS Express\\iisexpressshim.sdb*", "*:\\Program Files\\IIS Express\\iisexpressshim.sdb*") ParentProcessName="*\\msiexec.exe")

# ── Uncommon Extension Shim Database Installation Via Sdbinst.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects installation of a potentially suspicious new shim with an uncommon extension using sdbinst.exe. Adversaries may establish persistence and/or elevate privileges by executing malicious content t
EventCode=4688 Channel="Security" NewProcessName="*\\sdbinst.exe" OR OriginalFileName="sdbinst.exe" NOT (CommandLine="*.sdb*" OR CommandLine IN ("* -c", "* -f", "* -mm", "* -t") OR CommandLine="* -m -bg*" OR NOT CommandLine=* OR CommandLine="")

# ── Sdclt Child Processes ──
# Mức độ  : Trung bình
# Mục đích: Leo thang đặc quyền
# Chi tiết: A General detection for sdclt spawning new processes. This could be an indicator of sdclt being used for bypass UAC techniques.
EventCode=4688 Channel="Security" ParentProcessName="*\\sdclt.exe"

# ── Sdiagnhost Calling Suspicious Child Process ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects sdiagnhost.exe calling a suspicious child process (e.g. used in exploits for Follina / CVE-2022-30190)
EventCode=4688 Channel="Security" ParentProcessName="*\\sdiagnhost.exe" NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe", "*\\cmd.exe", "*\\mshta.exe", "*\\cscript.exe", "*\\wscript.exe", "*\\taskkill.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\calc.exe") NOT ((CommandLine="*bits*" NewProcessName="*\\cmd.exe") OR (CommandLine IN ("*-noprofile -", "*-noprofile") NewProcessName="*\\powershell.exe"))

# ── Potential Suspicious Activity Using SeCEdit ──
# Mức độ  : Trung bình
# Mục đích: Persistence qua autorun; Thu thập thông tin hệ thống
# Chi tiết: Detects potential suspicious behaviour using secedit.exe. Such as exporting or modifying the security policy
EventCode=4688 Channel="Security" NewProcessName="*\\secedit.exe" OR OriginalFileName="SeCEdit" (CommandLine="*/export*" CommandLine="*/cfg*") OR (CommandLine="*/configure*" CommandLine="*/db*")

# ── NodeJS Execution of JavaScript File ──
# Mức độ  : Thấp
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution of JavaScript or JSC files using NodeJs binary node.exe, that could be potentially suspicious. Node.js is a popular open-source JavaScript runtime that runs code outside browsers and
EventCode=4688 Channel="Security" NewProcessName="*\\node.exe" OR OriginalFileName="node.exe" OR Product="Node.js" CommandLine="*.js*"

# ── Suspicious Serv-U Process Pattern ──
# Mức độ  : Cao
# Chi tiết: Detects a suspicious process pattern which could be a sign of an exploited Serv-U service
EventCode=4688 Channel="Security" ParentProcessName="*\\Serv-U.exe" NewProcessName IN ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wscript.exe", "*\\cscript.exe", "*\\sh.exe", "*\\bash.exe", "*\\schtasks.exe", "*\\regsvr32.exe", "*\\wmic.exe", "*\\mshta.exe", "*\\rundll32.exe", "*\\msiexec.exe", "*\\forfiles.exe", "*\\scriptrunner.exe")

# ── Uncommon Child Process Of Setres.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects uncommon child process of Setres.EXE. Setres.EXE is a Windows server only process and tool that can be used to set the screen resolution. It can potentially be abused in order to launch any ar
EventCode=4688 Channel="Security" ParentProcessName="*\\setres.exe" NewProcessName="*\\choice*" NOT (NewProcessName IN ("*C:\\Windows\\System32\\choice.exe", "*C:\\Windows\\SysWOW64\\choice.exe"))

# ── Potential SPN Enumeration Via Setspn.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects service principal name (SPN) enumeration used for Kerberoasting
EventCode=4688 Channel="Security" NewProcessName="*\\setspn.exe" OR OriginalFileName="setspn.exe" OR (Description="*Query or reset the computer*" Description="*SPN attribute*") CommandLine IN ("* -q *", "* /q *")

# ── Indirect Command Execution via SFTP ProxyCommand ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of SFTP.exe to execute commands indirectly via ProxyCommand parameter. Threat actors were seen leveraging this legitimate Windows binary to bypass security controls and execute arbitra
EventCode=4688 Channel="Security" CommandLine="*ProxyCommand=*" NewProcessName="*\\sftp.exe"

# ── Suspicious Execution of Shutdown ──
# Mức độ  : Trung bình
# Chi tiết: Use of the commandline to shutdown or reboot windows
EventCode=4688 Channel="Security" CommandLine IN ("*/r *", "*/s *") NewProcessName="*\\shutdown.exe"

# ── Suspicious Execution of Shutdown to Log Out ──
# Mức độ  : Trung bình
# Chi tiết: Detects the rare use of the command line tool shutdown to logoff a user
EventCode=4688 Channel="Security" CommandLine="*/l*" NewProcessName="*\\shutdown.exe"

# ── Uncommon Sigverif.EXE Child Process ──
# Mức độ  : Trung bình
# Chi tiết: Detects uncommon child processes spawning from "sigverif.exe", which could indicate potential abuse of the latter as a living of the land binary in order to proxy execution.
EventCode=4688 Channel="Security" ParentProcessName="*\\sigverif.exe" NOT (NewProcessName IN ("C:\\Windows\\System32\\WerFault.exe", "C:\\Windows\\SysWOW64\\WerFault.exe"))

# ── Uncommon Child Processes Of SndVol.exe ──
# Mức độ  : Trung bình
# Chi tiết: Detects potentially uncommon child processes of SndVol.exe (the Windows volume mixer)
EventCode=4688 Channel="Security" ParentProcessName="*\\SndVol.exe" NOT (CommandLine="* shell32.dll,Control_RunDLL *" NewProcessName="*\\rundll32.exe")

# ── Audio Capture via SoundRecorder ──
# Mức độ  : Trung bình
# Chi tiết: Detect attacker collecting audio via SoundRecorder application.
EventCode=4688 Channel="Security" CommandLine="*/FILE*" NewProcessName="*\\SoundRecorder.exe"

# ── Suspicious Speech Runtime Binary Child Process ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects suspicious Speech Runtime Binary Execution by monitoring its child processes. Child processes spawned by SpeechRuntime.exe could indicate an attempt for lateral movement via COM & DCOM hijacki
EventCode=4688 Channel="Security" ParentProcessName="*\\SpeechRuntime.exe"

# ── Suspicious Splwow64 Without Params ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious Splwow64.exe process without any command line parameters
EventCode=4688 Channel="Security" CommandLine="*splwow64.exe" NewProcessName="*\\splwow64.exe"

# ── Suspicious Spool Service Child Process ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious print spool service (spoolsv.exe) child processes.
EventCode=4688 Channel="Security" ParentProcessName="*\\spoolsv.exe" MandatoryLabel IN ("S-1-16-16384", "None") NewProcessName IN ("*\\gpupdate.exe", "*\\whoami.exe", "*\\nltest.exe", "*\\taskkill.exe", "*\\wmic.exe", "*\\taskmgr.exe", "*\\sc.exe", "*\\findstr.exe", "*\\curl.exe", "*\\wget.exe", "*\\certutil.exe", "*\\bitsadmin.exe", "*\\accesschk.exe", "*\\wevtutil.exe", "*\\bcdedit.exe", "*\\fsutil.exe", "*\\cipher.exe", "*\\schtasks.exe", "*\\write.exe", "*\\wuauclt.exe", "*\\systeminfo.exe", "*\\reg.exe", "*\\query.exe") OR (NewProcessName IN ("*\\net.exe", "*\\net1.exe") NOT CommandLine="*start*") OR (NewProcessName="*\\cmd.exe" NOT (CommandLine IN ("*.spl*", "*route add*", "*program files*"))) OR (NewProcessName="*\\netsh.exe" NOT (CommandLine IN ("*add portopening*", "*rule name*"))) OR (NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe") NOT CommandLine="*.spl*") OR (NewProcessName="*\\rundll32.exe" OR OriginalFileName="RUNDLL32.EXE" CommandLine="*rundll32.exe")

# ── Veeam Backup Database Suspicious Query ──
# Mức độ  : Trung bình
# Chi tiết: Detects potentially suspicious SQL queries using SQLCmd targeting the Veeam backup databases in order to steal information.
EventCode=4688 Channel="Security" CommandLine="*VeeamBackup*" CommandLine="*From *" NewProcessName="*\\sqlcmd.exe" CommandLine IN ("*BackupRepositories*", "*Backups*", "*Credentials*", "*HostCreds*", "*SmbFileShares*", "*Ssh_creds*", "*VSphereInfo*")

# ── VeeamBackup Database Credentials Dump Via Sqlcmd.EXE ──
# Mức độ  : Cao
# Chi tiết: Detects dump of credentials in VeeamBackup dbo
EventCode=4688 Channel="Security" NewProcessName="*\\sqlcmd.exe" CommandLine="*SELECT*" CommandLine="*TOP*" CommandLine="*[VeeamBackup].[dbo].[Credentials]*"

# ── SQLite Chromium Profile Data DB Access ──
# Mức độ  : Cao
# Chi tiết: Detect usage of the "sqlite" binary to query databases in Chromium-based browsers for potential data stealing.
EventCode=4688 Channel="Security" Product="SQLite" OR NewProcessName IN ("*\\sqlite.exe", "*\\sqlite3.exe") CommandLine IN ("*\\User Data\\*", "*\\Opera Software\\*", "*\\ChromiumViewer\\*") CommandLine IN ("*Login Data*", "*Cookies*", "*Web Data*", "*History*", "*Bookmarks*")

# ── SQLite Firefox Profile Data DB Access ──
# Mức độ  : Cao
# Chi tiết: Detect usage of the "sqlite" binary to query databases in Firefox and other Gecko-based browsers for potential data stealing.
EventCode=4688 Channel="Security" Product="SQLite" OR NewProcessName IN ("*\\sqlite.exe", "*\\sqlite3.exe") CommandLine IN ("*cookies.sqlite*", "*places.sqlite*")

# ── Arbitrary File Download Via Squirrel.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the usage of the "Squirrel.exe" to download arbitrary files. This binary is part of multiple Electron based software installations (Slack, Teams, Discord, etc.)
EventCode=4688 Channel="Security" NewProcessName IN ("*\\squirrel.exe", "*\\update.exe") CommandLine IN ("* --download *", "* --update *", "* --updateRollback=*") CommandLine="*http*"

# ── Process Proxy Execution Via Squirrel.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detects the usage of the "Squirrel.exe" binary to execute arbitrary processes. This binary is part of multiple Electron based software installations (Slack, Teams, Discord, etc.)
EventCode=4688 Channel="Security" NewProcessName IN ("*\\squirrel.exe", "*\\update.exe") CommandLine IN ("*--processStart*", "*--processStartAndWait*", "*--createShortcut*") NOT ((CommandLine="*:\\Users\\*" CommandLine="*\\AppData\\Local\\Discord\\Update.exe*" CommandLine="*Discord.exe*" CommandLine IN ("*--createShortcut*", "*--processStart*")) OR (CommandLine="*:\\Users\\*" CommandLine="*\\AppData\\Local\\GitHubDesktop\\Update.exe*" CommandLine="*GitHubDesktop.exe*" CommandLine IN ("*--createShortcut*", "*--processStartAndWait*")) OR (CommandLine="*:\\Users\\*" CommandLine="*\\AppData\\Local\\Microsoft\\Teams\\Update.exe*" CommandLine="*Teams.exe*" CommandLine IN ("*--processStart*", "*--createShortcut*")) OR (CommandLine="*:\\Users\\*" CommandLine="*\\AppData\\Local\\yammerdesktop\\Update.exe*" CommandLine="*Yammer.exe*" CommandLine IN ("*--processStart*", "*--createShortcut*")))

# ── Port Forwarding Activity Via SSH.EXE ──
# Mức độ  : Trung bình
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects port forwarding activity via SSH.exe
EventCode=4688 Channel="Security" CommandLine="* -R *" OR CommandLine="* /R *" OR CommandLine="* –R *" OR CommandLine="* —R *" OR CommandLine="* ―R *" NewProcessName="*\\ssh.exe"

# ── Program Executed Using Proxy/Local Command Via SSH.EXE ──
# Mức độ  : Trung bình
# Chi tiết: Detect usage of the "ssh.exe" binary as a proxy to launch other programs.
EventCode=4688 Channel="Security" ParentProcessName="C:\\Windows\\System32\\OpenSSH\\sshd.exe" OR (NewProcessName="*\\ssh.exe" OR Product="OpenSSH for Windows" OR Hashes IN ("*IMPHASH=55b4964d29aad5438b9e950052dbbbc0*", "*IMPHASH=334d66c33503ccbf647c15b47c27eef4*", "*IMPHASH=27b0da080ef92afb37983d30d839141e*", "*IMPHASH=977eb4c263d384e47daa0712d34713ab*", "*IMPHASH=3eaadce9ae43d5a918bb082065815c3b*", "*IMPHASH=980fe6cf0d996ab1eedf877222e722aa*", "*IMPHASH=5f959422308ac3d721010d66647e100e*", "*IMPHASH=a49aaa3d03d1cd9c8dc7fca60f7f480b*", "*IMPHASH=dd335f759b6d5d6a8382b71dd9d65791*") CommandLine="*ProxyCommand=*" OR (CommandLine="*PermitLocalCommand=yes*" CommandLine="* LocalCommand*"))

# ── Potential RDP Tunneling Via SSH ──
# Mức độ  : Cao
# Chi tiết: Execution of ssh.exe to perform data exfiltration and tunneling through RDP
EventCode=4688 Channel="Security" CommandLine="*:3389*" NewProcessName="*\\ssh.exe"

# ── Potential Amazon SSM Agent Hijacking ──
# Mức độ  : Trung bình
# Chi tiết: Detects potential Amazon SSM agent hijack attempts as outlined in the Mitiga research report.
EventCode=4688 Channel="Security" CommandLine="*-register *" CommandLine="*-code *" CommandLine="*-id *" CommandLine="*-region *" NewProcessName="*\\amazon-ssm-agent.exe"

# ── Execution via stordiag.exe ──
# Mức độ  : Cao
# Chi tiết: Detects the use of stordiag.exe to execute schtasks.exe systeminfo.exe and fltmc.exe
EventCode=4688 Channel="Security" ParentProcessName="*\\stordiag.exe" NewProcessName IN ("*\\schtasks.exe", "*\\systeminfo.exe", "*\\fltmc.exe") NOT (ParentProcessName IN ("c:\\windows\\system32\\*", "c:\\windows\\syswow64\\*"))

# ── Start of NT Virtual DOS Machine ──
# Mức độ  : Trung bình
# Chi tiết: Ntvdm.exe allows the execution of 16-bit Windows applications on 32-bit Windows operating systems, as well as the execution of both 16-bit and 32-bit DOS applications
EventCode=4688 Channel="Security" NewProcessName IN ("*\\ntvdm.exe", "*\\csrstub.exe")

# ── Abused Debug Privilege by Arbitrary Parent Processes ──
# Mức độ  : Cao
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detection of unusual child processes by different system processes
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\winlogon.exe", "*\\services.exe", "*\\lsass.exe", "*\\csrss.exe", "*\\smss.exe", "*\\wininit.exe", "*\\spoolsv.exe", "*\\searchindexer.exe") SubjectUserName IN ("*AUTHORI*", "*AUTORI*") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe", "*\\cmd.exe") OR OriginalFileName IN ("PowerShell.EXE", "pwsh.dll", "Cmd.Exe") NOT (CommandLine="* route *" CommandLine="* ADD *")

# ── User Added to Local Administrators Group ──
# Mức độ  : Trung bình
# Chi tiết: Detects addition of users to the local administrator group via "Net" or "Add-LocalGroupMember".
EventCode=4688 Channel="Security" (CommandLine="*localgroup *" CommandLine="* /add*") OR (CommandLine="*Add-LocalGroupMember *" CommandLine="* -Group *") CommandLine IN ("* administrators *", "* administrateur*")

# ── User Added To Highly Privileged Group ──
# Mức độ  : Cao
# Chi tiết: Detects addition of users to highly privileged groups via "Net" or "Add-LocalGroupMember".
EventCode=4688 Channel="Security" (CommandLine="*localgroup *" CommandLine="* /add*") OR (CommandLine="*Add-LocalGroupMember *" CommandLine="* -Group *") CommandLine IN ("*Group Policy Creator Owners*", "*Schema Admins*")

# ── User Added to Remote Desktop Users Group ──
# Mức độ  : Cao
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects addition of users to the local Remote Desktop Users group via "Net" or "Add-LocalGroupMember".
EventCode=4688 Channel="Security" (CommandLine="*localgroup *" CommandLine="* /add*") OR (CommandLine="*Add-LocalGroupMember *" CommandLine="* -Group *") CommandLine IN ("*Remote Desktop Users*", "*Utilisateurs du Bureau à distance*", "*Usuarios de escritorio remoto*")

# ── Execute From Alternate Data Streams ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution from an Alternate Data Stream (ADS). Adversaries may use NTFS file attributes to hide their malicious data in order to evade detection
EventCode=4688 Channel="Security" CommandLine="*txt:*" (CommandLine="*type *" CommandLine="* > *") OR (CommandLine="*makecab *" CommandLine="*.cab*") OR (CommandLine="*reg *" CommandLine="* export *") OR (CommandLine="*regedit *" CommandLine="* /E *") OR (CommandLine="*esentutl *" CommandLine="* /y *" CommandLine="* /d *" CommandLine="* /o *")

# ── Always Install Elevated Windows Installer ──
# Mức độ  : Trung bình
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects Windows Installer service (msiexec.exe) trying to install MSI packages with SYSTEM privilege
EventCode=4688 Channel="Security" (NewProcessName="*\\Windows\\Installer\\*" NewProcessName="*msi*" NewProcessName="*tmp") OR (NewProcessName="*\\msiexec.exe" MandatoryLabel IN ("S-1-16-16384", "None")) SubjectUserName IN ("*AUTHORI*", "*AUTORI*") NOT (ParentProcessName="C:\\Windows\\System32\\services.exe" OR CommandLine="*\\system32\\msiexec.exe /V" OR ParentCommandLine="*\\system32\\msiexec.exe /V" OR ParentProcessName="C:\\ProgramData\\Sophos\\*" OR ParentProcessName="C:\\ProgramData\\Avira\\*" OR ParentProcessName IN ("C:\\Program Files\\Avast Software\\*", "C:\\Program Files (x86)\\Avast Software\\*") OR ParentProcessName IN ("C:\\Program Files\\Google\\Update\\*", "C:\\Program Files (x86)\\Google\\Update\\*"))

# ── Potentially Suspicious Windows App Activity ──
# Mức độ  : Trung bình
# Chi tiết: Detects potentially suspicious child process of applications launched from inside the WindowsApps directory. This could be a sign of a rogue ".appx" package installation/execution
EventCode=4688 Channel="Security" ParentProcessName="*C:\\Program Files\\WindowsApps\\*" NewProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe") OR CommandLine IN ("*cmd /c*", "*Invoke-*", "*Base64*") NOT ((ParentProcessName="*:\\Program Files\\WindowsApps\\Microsoft.WindowsTerminal*" ParentProcessName="*\\WindowsTerminal.exe" NewProcessName IN ("*\\powershell.exe", "*\\cmd.exe", "*\\pwsh.exe")) OR (ParentProcessName="C:\\Program Files\\WindowsApps\\Microsoft.SysinternalsSuite*" NewProcessName="*\\cmd.exe"))

# ── Arbitrary Shell Command Execution Via Settingcontent-Ms ──
# Mức độ  : Trung bình
# Mục đích: Phishing
# Chi tiết: The .SettingContent-ms file type was introduced in Windows 10 and allows a user to create "shortcuts" to various Windows 10 setting pages. These files are simply XML and contain paths to various Windo
EventCode=4688 Channel="Security" CommandLine="*.SettingContent-ms*" NOT CommandLine="*immersivecontrolpanel*"

# ── Phishing Pattern ISO in Archive ──
# Mức độ  : Cao
# Mục đích: Phishing
# Chi tiết: Detects cases in which an ISO files is opend within an archiver like 7Zip or Winrar, which is a sign of phishing as threat actors put small ISO files in archives as email attachments to bypass certain
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\Winrar.exe", "*\\7zFM.exe", "*\\peazip.exe") NewProcessName IN ("*\\isoburn.exe", "*\\PowerISO.exe", "*\\ImgBurn.exe")

# ── Automated Collection Command Prompt ──
# Mức độ  : Trung bình
# Chi tiết: Once established within a system or network, an adversary may use automated techniques for collecting internal data.
EventCode=4688 Channel="Security" CommandLine IN ("*.doc*", "*.docx*", "*.xls*", "*.xlsx*", "*.ppt*", "*.pptx*", "*.rtf*", "*.pdf*", "*.txt*") (CommandLine="*dir *" CommandLine="* /b *" CommandLine="* /s *") OR (OriginalFileName="FINDSTR.EXE" CommandLine IN ("* /e *", "* /si *"))

# ── Bad Opsec Defaults Sacrificial Processes With Improper Arguments ──
# Mức độ  : Cao
# Chi tiết: Detects attackers using tooling with bad opsec defaults. E.g. spawning a sacrificial process to inject a capability into the process without taking into account how the process is normally run. One tr
EventCode=4688 Channel="Security" (CommandLine="*WerFault.exe" NewProcessName="*\\WerFault.exe") OR (CommandLine="*rundll32.exe" NewProcessName="*\\rundll32.exe") OR (CommandLine="*regsvcs.exe" NewProcessName="*\\regsvcs.exe") OR (CommandLine="*regasm.exe" NewProcessName="*\\regasm.exe") OR (CommandLine="*regsvr32.exe" NewProcessName="*\\regsvr32.exe") NOT ((CommandLine="*rundll32.exe" ParentProcessName="*\\AppData\\Local\\Microsoft\\EdgeUpdate\\Install\\{*" NewProcessName="*\\rundll32.exe") OR (ParentCommandLine="*--uninstall *" CommandLine="*rundll32.exe" ParentProcessName IN ("*\\AppData\\Local\\BraveSoftware\\Brave-Browser\\Application\\*", "*\\AppData\\Local\\Google\\Chrome\\Application\\*") ParentProcessName="*\\Installer\\setup.exe" NewProcessName="*\\rundll32.exe"))

# ── Potential Suspicious Browser Launch From Document Reader Process ──
# Mức độ  : Trung bình
# Chi tiết: Detects when a browser process or browser tab is launched from an application that handles document files such as Adobe, Microsoft Office, etc. And connects to a web application over http(s), this cou
EventCode=4688 Channel="Security" CommandLine="*http*" ParentProcessName IN ("*Acrobat Reader*", "*Microsoft Office*", "*PDF Reader*") NewProcessName IN ("*\\brave.exe", "*\\chrome.exe", "*\\firefox.exe", "*\\msedge.exe", "*\\opera.exe", "*\\maxthon.exe", "*\\seamonkey.exe", "*\\vivaldi.exe") NOT CommandLine="*https://go.microsoft.com/fwlink/*" NOT (CommandLine IN ("*http://ad.foxitsoftware.com/adlog.php**", "*https://globe-map.foxitservice.com/go.php*do=redirect*"))

# ── Potential Commandline Obfuscation Using Escape Characters ──
# Mức độ  : Trung bình
# Chi tiết: Detects potential commandline obfuscation using known escape characters
EventCode=4688 Channel="Security" CommandLine IN ("*h^t^t^p*", "*h\"t\"t\"p*")

# ── Potential CommandLine Obfuscation Using Unicode Characters From Suspicious Image ──
# Mức độ  : Cao
# Chi tiết: Detects potential commandline obfuscation using unicode characters. Adversaries may attempt to make an executable or file difficult to discover or analyze by encrypting, encoding, or otherwise obfusca
EventCode=4688 Channel="Security" OriginalFileName IN ("Cmd.EXE", "cscript.exe", "PowerShell.EXE", "PowerShell_ISE.EXE", "pwsh.dll", "wscript.exe") NewProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe", "*\\wscript.exe") CommandLine IN ("*ˣ*", "*˪*", "*ˢ*", "*∕*", "*⁄*", "*―*", "*—*", "* *", "*¯*", "*®*", "*¶*", "*⠀*")

# ── Suspicious ClickFix/FileFix Execution Pattern ──
# Mức độ  : Cao
# Chi tiết: Detects suspicious execution patterns where users are tricked into running malicious commands via clipboard manipulation, either through the Windows Run dialog (ClickFix) or File Explorer address bar 
EventCode=4688 Channel="Security" CommandLine="*#*" ParentProcessName="*\\explorer.exe" CommandLine IN ("*account*", "*anti-bot*", "*botcheck*", "*captcha*", "*challenge*", "*confirmation*", "*fraud*", "*human*", "*identification*", "*identificator*", "*identity*", "*robot*", "*validation*", "*verification*", "*verify*")

# ── Suspicious Explorer Process with Whitespace Padding - ClickFix/FileFix ──
# Mức độ  : Cao
# Chi tiết: Detects process creation with suspicious whitespace padding followed by a '#' character, which may indicate ClickFix or FileFix techniques used to conceal malicious commands from visual inspection. Cl
EventCode=4688 Channel="Security" CommandLine="*#*" ParentProcessName="*\\explorer.exe" CommandLine IN ("*            *", "*            *", "*            *", "*            *", "*            *", "*            *", "*            *", "*            *", "*            *", "*            *", "*            *", "*            *", "*            *")

# ── Suspicious Usage of For Loop with Recursive Directory Search in CMD ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious usage of the cmd.exe 'for /f' loop combined with the 'tokens=' parameter and a recursive directory listing. This pattern may indicate an attempt to discover and execute system binar
EventCode=4688 Channel="Security" (CommandLine="*for /f*" CommandLine="*tokens=*" CommandLine="*in (*" CommandLine="*dir*") OR (ParentCommandLine="*for /f*" ParentCommandLine="*tokens=*" ParentCommandLine="*in (*" ParentCommandLine="*dir*")

# ── Potential Command Line Path Traversal Evasion Attempt ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects potential evasion or obfuscation attempts using bogus path traversal via the commandline
EventCode=4688 Channel="Security" (CommandLine IN ("*\\..\\Windows\\*", "*\\..\\System32\\*", "*\\..\\..\\*") NewProcessName="*\\Windows\\*") OR CommandLine="*.exe\\..\\*" NOT (CommandLine IN ("*\\Google\\Drive\\googledrivesync.exe\\..\\*", "*\\Citrix\\Virtual Smart Card\\Citrix.Authentication.VirtualSmartcard.Launcher.exe\\..\\*"))

# ── Potential Browser Data Stealing ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may acquire credentials from web browsers by reading files specific to the target browser. Web browsers commonly save credentials such as website usernames and passwords so that they do no
EventCode=4688 Channel="Security" CommandLine IN ("*copy-item*", "*copy *", "*cpi *", "* cp *", "*move *", "*move-item*", "* mi *", "* mv *") OR NewProcessName IN ("*\\esentutl.exe", "*\\xcopy.exe", "*\\robocopy.exe") OR OriginalFileName IN ("esentutl.exe", "XCOPY.EXE", "robocopy.exe") CommandLine IN ("*\\Amigo\\User Data*", "*\\BraveSoftware\\Brave-Browser\\User Data*", "*\\CentBrowser\\User Data*", "*\\Chromium\\User Data*", "*\\CocCoc\\Browser\\User Data*", "*\\Comodo\\Dragon\\User Data*", "*\\Elements Browser\\User Data*", "*\\Epic Privacy Browser\\User Data*", "*\\Google\\Chrome Beta\\User Data*", "*\\Google\\Chrome SxS\\User Data*", "*\\Google\\Chrome\\User Data\\*", "*\\Kometa\\User Data*", "*\\Maxthon5\\Users*", "*\\Microsoft\\Edge\\User Data*", "*\\Mozilla\\Firefox\\Profiles*", "*\\Nichrome\\User Data*", "*\\Opera Software\\Opera GX Stable\\*", "*\\Opera Software\\Opera Neon\\User Data*", "*\\Opera Software\\Opera Stable\\*", "*\\Orbitum\\User Data*", "*\\QIP Surf\\User Data*", "*\\Sputnik\\User Data*", "*\\Torch\\User Data*", "*\\uCozMedia\\Uran\\User Data*", "*\\Vivaldi\\User Data*")

# ── Copy From Or To Admin Share Or Sysvol Folder ──
# Mức độ  : Trung bình
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Detects a copy command or a copy utility execution to or from an Admin share or remote
EventCode=4688 Channel="Security" CommandLine IN ("*\\\\*\\*$*", "*\\Sysvol\\*") NewProcessName IN ("*\\robocopy.exe", "*\\xcopy.exe") OR OriginalFileName IN ("robocopy.exe", "XCOPY.EXE") OR (NewProcessName="*\\cmd.exe" OR OriginalFileName="Cmd.Exe" CommandLine="*copy*") OR (NewProcessName IN ("*\\powershell_ise.exe*", "*\\powershell.exe*", "*\\pwsh.exe*") OR OriginalFileName IN ("powershell_ise.exe", "PowerShell.EXE", "pwsh.dll") CommandLine IN ("*copy-item*", "*copy *", "*cpi *", "* cp *", "*move *", "* move-item*", "* mi *", "* mv *"))

# ── Suspicious Copy From or To System Directory ──
# Mức độ  : Trung bình
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects a suspicious copy operation that tries to copy a program from system (System32, SysWOW64, WinSxS) directories to another on disk. Often used to move LOLBINs such as 'certutil' or 'desktopimgdo
EventCode=4688 Channel="Security" (CommandLine="*copy *" NewProcessName="*\\cmd.exe") OR (CommandLine IN ("*copy-item*", "* copy *", "*cpi *", "* cp *") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe")) OR NewProcessName IN ("*\\robocopy.exe", "*\\xcopy.exe") OR OriginalFileName IN ("robocopy.exe", "XCOPY.EXE") NOT (CommandLine="*/c copy*" CommandLine="*\\Temp\\*" CommandLine="*\\avira_system_speedup.exe*" CommandLine IN ("*C:\\Program Files\\Avira\\*", "*C:\\Program Files (x86)\\Avira\\*") NewProcessName="*\\cmd.exe")
| regex CommandLine="(?i)\\s['\"]?C:\\\\Windows\\\\(?:System32|SysWOW64|WinSxS)"

# ── LOL-Binary Copied From System Directory ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detects a suspicious copy operation that tries to copy a known LOLBIN from system (System32, SysWOW64, WinSxS) directories to another on disk in order to bypass detections based on locations.
EventCode=4688 Channel="Security" (CommandLine="*copy *" NewProcessName="*\\cmd.exe") OR (CommandLine IN ("*copy-item*", "* copy *", "*cpi *", "* cp *") NewProcessName IN ("*\\powershell.exe", "*\\pwsh.exe")) OR NewProcessName IN ("*\\robocopy.exe", "*\\xcopy.exe") OR OriginalFileName IN ("robocopy.exe", "XCOPY.EXE") CommandLine IN ("*\\System32*", "*\\SysWOW64*", "*\\WinSxS*") CommandLine IN ("*\\bitsadmin.exe*", "*\\calc.exe*", "*\\certutil.exe*", "*\\cmdl32.exe*", "*\\cscript.exe*", "*\\mshta.exe*", "*\\rundll32.exe*", "*\\wscript.exe*", "*\\ie4uinit.exe*")

# ── Potential Crypto Mining Activity ──
# Mức độ  : Cao
# Chi tiết: Detects command line parameters or strings often used by crypto miners
EventCode=4688 Channel="Security" CommandLine IN ("* --cpu-priority=*", "*--donate-level=0*", "* -o pool.*", "* --nicehash*", "* --algo=rx/0 *", "*stratum+tcp://*", "*stratum+udp://*", "*LS1kb25hdGUtbGV2ZWw9*", "*0tZG9uYXRlLWxldmVsP*", "*tLWRvbmF0ZS1sZXZlbD*", "*c3RyYXR1bSt0Y3A6Ly*", "*N0cmF0dW0rdGNwOi8v*", "*zdHJhdHVtK3RjcDovL*", "*c3RyYXR1bSt1ZHA6Ly*", "*N0cmF0dW0rdWRwOi8v*", "*zdHJhdHVtK3VkcDovL*") NOT (CommandLine IN ("* pool.c *", "* pool.o *", "*gcc -*"))

# ── Potential Data Exfiltration Activity Via CommandLine Tools ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the use of various CLI utilities exfiltrating data via web requests
EventCode=4688 Channel="Security"
| rex field=CommandLine "(?<CommandLineMatch>net\\s+view)"
| eval CommandLineCondition=if(isnotnull(CommandLineMatch), "true", "false")
| rex field=CommandLine "(?<CommandLineMatch2>sc\\s+query)"
| eval CommandLineCondition2=if(isnotnull(CommandLineMatch2), "true", "false")
| search (CommandLine IN ("*curl *", "*Invoke-RestMethod*", "*Invoke-WebRequest*", "*irm *", "*iwr *", "*wget *") CommandLine="* -ur*" CommandLine="* -me*" CommandLine="* -b*" CommandLine="* POST *" NewProcessName IN ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\cmd.exe")) OR (CommandLine="*--ur*" NewProcessName="*\\curl.exe" CommandLine IN ("* -d *", "* --data *")) OR (CommandLine IN ("*--post-data*", "*--post-file*") NewProcessName="*\\wget.exe") CommandLineCondition="true" OR CommandLineCondition2="true" OR CommandLine IN ("*Get-Content*", "*GetBytes*", "*hostname*", "*ifconfig*", "*ipconfig*", "*netstat*", "*nltest*", "*qprocess*", "*systeminfo*", "*tasklist*", "*ToBase64String*", "*whoami*") OR (CommandLine="*type *" CommandLine="* > *" CommandLine="* C:\\*")

# ── Raccine Uninstall ──
# Mức độ  : Cao
# Chi tiết: Detects commands that indicate a Raccine removal from an end system. Raccine is a free ransomware protection tool.
EventCode=4688 Channel="Security" (CommandLine="*taskkill *" CommandLine="*RaccineSettings.exe*") OR (CommandLine="*reg.exe*" CommandLine="*delete*" CommandLine="*Raccine Tray*") OR (CommandLine="*schtasks*" CommandLine="*/DELETE*" CommandLine="*Raccine Rules Updater*")

# ── Suspicious Double Extension File Execution ──
# Mức độ  : Cao
# Mục đích: Phishing
# Chi tiết: Detects suspicious use of an .exe extension after a non-executable file extension like .pdf.exe, a set of spaces or underlines to cloak the executable file in spear phishing campaigns
EventCode=4688 Channel="Security" CommandLine IN ("*      .exe*", "*______.exe*", "*.doc.exe*", "*.doc.js*", "*.docx.exe*", "*.docx.js*", "*.gif.exe*", "*.jpeg.exe*", "*.jpg.exe*", "*.mkv.exe*", "*.mov.exe*", "*.mp3.exe*", "*.mp4.exe*", "*.pdf.exe*", "*.pdf.js*", "*.png.exe*", "*.ppt.exe*", "*.ppt.js*", "*.pptx.exe*", "*.pptx.js*", "*.rtf.exe*", "*.rtf.js*", "*.svg.exe*", "*.txt.exe*", "*.txt.js*", "*.xls.exe*", "*.xls.js*", "*.xlsx.exe*", "*.xlsx.js*", "*⠀⠀⠀⠀⠀⠀.exe*") NewProcessName IN ("*      .exe", "*______.exe", "*.doc.exe", "*.doc.js", "*.docx.exe", "*.docx.js", "*.gif.exe", "*.jpeg.exe", "*.jpg.exe", "*.mkv.exe", "*.mov.exe", "*.mp3.exe", "*.mp4.exe", "*.pdf.exe", "*.pdf.js", "*.png.exe", "*.ppt.exe", "*.ppt.js", "*.pptx.exe", "*.pptx.js", "*.rtf.exe", "*.rtf.js", "*.svg.exe", "*.txt.exe", "*.txt.js", "*.xls.exe", "*.xls.js", "*.xlsx.exe", "*.xlsx.js", "*⠀⠀⠀⠀⠀⠀.exe")

# ── Suspicious Parent Double Extension File Execution ──
# Mức độ  : Cao
# Mục đích: Giả mạo tên tiến trình
# Chi tiết: Detect execution of suspicious double extension files in ParentCommandLine
EventCode=4688 Channel="Security" ParentProcessName IN ("*.doc.lnk", "*.docx.lnk", "*.xls.lnk", "*.xlsx.lnk", "*.ppt.lnk", "*.pptx.lnk", "*.rtf.lnk", "*.pdf.lnk", "*.txt.lnk", "*.doc.js", "*.docx.js", "*.xls.js", "*.xlsx.js", "*.ppt.js", "*.pptx.js", "*.rtf.js", "*.pdf.js", "*.txt.js") OR ParentCommandLine IN ("*.doc.lnk*", "*.docx.lnk*", "*.xls.lnk*", "*.xlsx.lnk*", "*.ppt.lnk*", "*.pptx.lnk*", "*.rtf.lnk*", "*.pdf.lnk*", "*.txt.lnk*", "*.doc.js*", "*.docx.js*", "*.xls.js*", "*.xlsx.js*", "*.ppt.js*", "*.pptx.js*", "*.rtf.js*", "*.pdf.js*", "*.txt.js*")

# ── Suspicious Download from Office Domain ──
# Mức độ  : Cao
# Mục đích: Tải file từ mạng
# Chi tiết: Detects suspicious ways to download files from Microsoft domains that are used to store attachments in Emails or OneNote documents
EventCode=4688 Channel="Security" NewProcessName IN ("*\\curl.exe", "*\\wget.exe") OR CommandLine IN ("*Invoke-WebRequest*", "*iwr *", "*curl *", "*wget *", "*Start-BitsTransfer*", "*.DownloadFile(*", "*.DownloadString(*") CommandLine IN ("*https://attachment.outlook.live.net/owa/*", "*https://onenoteonlinesync.onenote.com/onenoteonlinesync/*")

# ── DumpStack.log Defender Evasion ──
# Mức độ  : Nghiêm trọng
# Chi tiết: Detects the use of the filename DumpStack.log to evade Microsoft Defender
EventCode=4688 Channel="Security" NewProcessName="*\\DumpStack.log" OR CommandLine="* -o DumpStack.log*"

# ── Always Install Elevated MSI Spawned Cmd And Powershell ──
# Mức độ  : Trung bình
# Mục đích: Leo thang đặc quyền
# Chi tiết: Detects Windows Installer service (msiexec.exe) spawning "cmd" or "powershell"
EventCode=4688 Channel="Security" NewProcessName IN ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe") OR OriginalFileName IN ("Cmd.Exe", "PowerShell.EXE", "pwsh.dll") ParentProcessName="*\\Windows\\Installer\\*" ParentProcessName="*msi*" ParentProcessName="*tmp"

# ── Suspicious Electron Application Child Processes ──
# Mức độ  : Trung bình
# Chi tiết: Detects suspicious child processes of electron apps (teams, discord, slack, etc.). This could be a potential sign of ".asar" file tampering (See reference section for more information) or binary execu
EventCode=4688 Channel="Security" ParentProcessName IN ("*\\chrome.exe", "*\\discord.exe", "*\\GitHubDesktop.exe", "*\\keybase.exe", "*\\msedge.exe", "*\\msedgewebview2.exe", "*\\msteams.exe", "*\\slack.exe", "*\\teams.exe") NewProcessName IN ("*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\whoami.exe", "*\\wscript.exe") OR NewProcessName IN ("*:\\ProgramData\\*", "*:\\Temp\\*", "*\\AppData\\Local\\Temp\\*", "*\\Users\\Public\\*", "*\\Windows\\Temp\\*") NOT (CommandLine="*\\NVSMI\\nvidia-smi.exe*" ParentProcessName="*\\Discord.exe" NewProcessName="*\\cmd.exe")

# ── Potentially Suspicious Electron Application CommandLine ──
# Mức độ  : Trung bình
# Chi tiết: Detects potentially suspicious CommandLine of electron apps (teams, discord, slack, etc.). This could be a sign of abuse to proxy execution through a signed binary.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\chrome.exe", "*\\code.exe", "*\\discord.exe", "*\\GitHubDesktop.exe", "*\\keybase.exe", "*\\msedge_proxy.exe", "*\\msedge.exe", "*\\msedgewebview2.exe", "*\\msteams.exe", "*\\slack.exe", "*\\Teams.exe") OR OriginalFileName IN ("chrome.exe", "code.exe", "discord.exe", "GitHubDesktop.exe", "keybase.exe", "msedge_proxy.exe", "msedge.exe", "msedgewebview2.exe", "msteams.exe", "slack.exe", "Teams.exe") CommandLine IN ("*--browser-subprocess-path*", "*--gpu-launcher*", "*--renderer-cmd-prefix*", "*--utility-cmd-prefix*")

# ── Elevated System Shell Spawned From Uncommon Parent Location ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects when a shell program such as the Windows command prompt or PowerShell is launched with system privileges from a uncommon parent location.
EventCode=4688 Channel="Security" NewProcessName IN ("*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe", "*\\cmd.exe") OR OriginalFileName IN ("PowerShell.EXE", "powershell_ise.EXE", "pwsh.dll", "Cmd.Exe") SubjectUserName IN ("*AUTHORI*", "*AUTORI*") SubjectLogonId="0x3e7" NOT (ParentProcessName IN ("*:\\Program Files (x86)\\*", "*:\\Program Files\\*", "*:\\ProgramData\\*", "*:\\Windows\\System32\\*", "*:\\Windows\\SysWOW64\\*", "*:\\Windows\\Temp\\*", "*:\\Windows\\WinSxS\\*") OR NOT ParentProcessName=* OR ParentProcessName IN ("", "-")) NOT ((ParentProcessName="*:\\ManageEngine\\ADManager Plus\\pgsql\\bin\\postgres.exe" NewProcessName="*\\cmd.exe") OR (CommandLine="*:\\WINDOWS\\system32\\cmd.exe /c \"*" CurrentDirectory="*:\\WINDOWS\\Temp\\asgard2-agent\\*") OR (CommandLine="*:\\IBM\\SpectrumProtect\\webserver\\scripts\\*" ParentProcessName="*:\\IBM\\SpectrumProtect\\webserver\\scripts\\*"))

# ── Hidden Powershell in Link File Pattern ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects events that appear when a user click on a link file with a powershell command in it
EventCode=4688 Channel="Security" CommandLine="*powershell*" CommandLine="*.lnk*" ParentProcessName="C:\\Windows\\explorer.exe" NewProcessName="C:\\Windows\\System32\\cmd.exe"

# ── Potential Defense Evasion Activity Via Emoji Usage In CommandLine - 1 ──
# Mức độ  : Cao
