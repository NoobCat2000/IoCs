source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*[Windows.Input.Keyboard]::IsKeyDown([System.Windows.Input.Key]::*"

# ── Potential Suspicious PowerShell Keywords ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects potentially suspicious keywords that could indicate the use of a PowerShell exploitation framework
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*System.Reflection.Assembly.Load($*", "*[System.Reflection.Assembly]::Load($*", "*[Reflection.Assembly]::Load($*", "*System.Reflection.AssemblyName*", "*Reflection.Emit.AssemblyBuilderAccess*", "*Reflection.Emit.CustomAttributeBuilder*", "*Runtime.InteropServices.UnmanagedType*", "*Runtime.InteropServices.DllImportAttribute*", "*SuspendThread*", "*rundll32*")

# ── Suspicious Get Local Groups Information - PowerShell ──
# Mức độ  : Thấp
# Chi tiết: Detects the use of PowerShell modules and cmdlets to gather local group information. Adversaries may use local system permission groups to determine which groups exist and which users belong to a part
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*get-localgroup *", "*get-localgroupmember *") OR (ScriptBlockText IN ("*get-wmiobject *", "*gwmi *", "*get-ciminstance *", "*gcim *") ScriptBlockText="*win32_group*")

# ── Powershell Local Email Collection ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may target user email on local systems to collect sensitive information. Files containing email data can be acquired from a users local system, such as Outlook storage or cache files.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Get-Inbox.ps1*", "*Microsoft.Office.Interop.Outlook*", "*Microsoft.Office.Interop.Outlook.olDefaultFolders*", "*-comobject outlook.application*")

