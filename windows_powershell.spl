source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*-SecurityDescriptorSddl *", "*-sd *") ScriptBlockText="*Set-Service *" ScriptBlockText="*D;;*" ScriptBlockText IN ("*;;;IU*", "*;;;SU*", "*;;;BA*", "*;;;SY*", "*;;;WD*")

# ── Potential PowerShell Obfuscation Using Alias Cmdlets ──
