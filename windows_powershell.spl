source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Get-Service *", "*Get-ChildItem *", "*Get-Process *") ScriptBlockText="*> $env:TEMP\\*"

