# ── AADInternals PowerShell Cmdlets Execution - PsScript ──
# Mức độ  : Cao
# Chi tiết: Detects ADDInternals Cmdlet execution. A tool for administering Azure AD and Office 365. Which can be abused by threat actors to attack Azure AD or Office 365.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Add-AADInt*", "*ConvertTo-AADInt*", "*Disable-AADInt*", "*Enable-AADInt*", "*Export-AADInt*", "*Find-AADInt*", "*Get-AADInt*", "*Grant-AADInt*", "*Initialize-AADInt*", "*Install-AADInt*", "*Invoke-AADInt*", "*Join-AADInt*", "*New-AADInt*", "*Open-AADInt*", "*Read-AADInt*", "*Register-AADInt*", "*Remove-AADInt*", "*Reset-AADInt*", "*Resolve-AADInt*", "*Restore-AADInt*", "*Save-AADInt*", "*Search-AADInt*", "*Send-AADInt*", "*Set-AADInt*", "*Start-AADInt*", "*Unprotect-AADInt*", "*Update-AADInt*")

# ── Access to Browser Login Data ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may acquire credentials from web browsers by reading files specific to the target browser. Web browsers commonly save credentials such as website usernames and passwords so that they do no
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Copy-Item*" ScriptBlockText="*-Destination*" ScriptBlockText IN ("*\\Opera Software\\Opera Stable\\Login Data*", "*\\Mozilla\\Firefox\\Profiles*", "*\\Microsoft\\Edge\\User Data\\Default*", "*\\Google\\Chrome\\User Data\\Default\\Login Data*", "*\\Google\\Chrome\\User Data\\Default\\Login Data For Account*")

# ── Potential Active Directory Enumeration Using AD Module - PsScript ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the "Import-Module" cmdlet to load the "Microsoft.ActiveDirectory.Management.dl" DLL. Which is often used by attackers to perform AD enumeration.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") (ScriptBlockText="*Import-Module *" ScriptBlockText="*Microsoft.ActiveDirectory.Management.dll*") OR ScriptBlockText="*ipmo Microsoft.ActiveDirectory.Management.dll*"

# ── Powershell Add Name Resolution Policy Table Rule ──
# Mức độ  : Cao
# Chi tiết: Detects powershell scripts that adds a Name Resolution Policy Table (NRPT) rule for the specified namespace. This will bypass the default DNS server and uses a specified server for answering the query
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Add-DnsClientNrptRule*" ScriptBlockText="*-Namesp*" ScriptBlockText="*-NameSe*"

# ── Add Windows Capability Via PowerShell Script ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the "Add-WindowsCapability" cmdlet to add Windows capabilities. Notable capabilities could be "OpenSSH" and others.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Add-WindowsCapability *" ScriptBlockText="*-Name OpenSSH.*"

# ── PowerShell ADRecon Execution ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution of ADRecon.ps1 for AD reconnaissance which has been reported to be actively used by FIN7
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Function Get-ADRExcelComOb*", "*Get-ADRGPO*", "*Get-ADRDomainController*", "*ADRecon-Report.xlsx*")

# ── AMSI Bypass Pattern Assembly GetType ──
# Mức độ  : Cao
# Chi tiết: Detects code fragments found in small and obfuscated AMSI bypass PowerShell scripts
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*[Ref].Assembly.GetType*" ScriptBlockText="*SetValue($null,$true)*" ScriptBlockText="*NonPublic,Static*"

# ── Potential AMSI Bypass Script Using NULL Bits ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of special strings/null bits in order to potentially bypass AMSI functionalities
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*if(0){{{0}}}' -f $(0 -as [char]) +*", "*#<NULL>*")

# ── Silence.EDA Detection ──
# Mức độ  : Nghiêm trọng
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Silence EmpireDNSAgent as described in the Group-IP report
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*System.Diagnostics.Process*" ScriptBlockText="*Stop-Computer*" ScriptBlockText="*Restart-Computer*" ScriptBlockText="*Exception in execution*" ScriptBlockText="*$cmdargs*" ScriptBlockText="*Close-Dnscat2Tunnel*" ScriptBlockText="*set type=$LookupType`nserver*" ScriptBlockText="*$Command | nslookup 2>&1 | Out-String*" ScriptBlockText="*New-RandomDNSField*" ScriptBlockText="*[Convert]::ToString($SYNOptions, 16)*" ScriptBlockText="*$Session.Dead = $True*" ScriptBlockText="*$Session[\"Driver\"] -eq*"

# ── Get-ADUser Enumeration Using UserAccountControl Flags ──
# Mức độ  : Trung bình
# Mục đích: Thu thập thông tin user
# Chi tiết: Detects AS-REP roasting is an attack that is often-overlooked. It is not very common as you have to explicitly set accounts that do not require pre-authentication.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-ADUser*" ScriptBlockText="*-Filter*" ScriptBlockText="*useraccountcontrol*" ScriptBlockText="*-band*" ScriptBlockText="*4194304*"

# ── Potential Data Exfiltration Via Audio File ──
# Mức độ  : Trung bình
# Chi tiết: Detects potential exfiltration attempt via audio file using PowerShell
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*[System.Math]::*" ScriptBlockText="*[IO.FileMode]::*" ScriptBlockText="*BinaryWriter*" ScriptBlockText="*0x52*" ScriptBlockText="*0x49*" ScriptBlockText="*0x46*" ScriptBlockText="*0x57*" ScriptBlockText="*0x41*" ScriptBlockText="*0x56*" ScriptBlockText="*0x45*" ScriptBlockText="*0xAC*"

# ── Automated Collection Command PowerShell ──
# Mức độ  : Trung bình
# Chi tiết: Once established within a system or network, an adversary may use automated techniques for collecting internal data.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*.doc*", "*.docx*", "*.xls*", "*.xlsx*", "*.ppt*", "*.pptx*", "*.rtf*", "*.pdf*", "*.txt*") ScriptBlockText="*Get-ChildItem*" ScriptBlockText="* -Recurse *" ScriptBlockText="* -Include *"

# ── Windows Screen Capture with CopyFromScreen ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may attempt to take screen captures of the desktop to gather information over the course of an operation. Screen capturing functionality may be included as a feature of a remote access too
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*.CopyFromScreen*"

# ── Clear PowerShell History - PowerShell ──
# Mức độ  : Trung bình
# Mục đích: Xóa dấu vết
# Chi tiết: Detects keywords that could indicate clearing PowerShell history
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") (ScriptBlockText="*Set-PSReadlineOption*" ScriptBlockText="*–HistorySaveStyle*" ScriptBlockText="*SaveNothing*") OR (ScriptBlockText="*Set-PSReadlineOption*" ScriptBlockText="*-HistorySaveStyle*" ScriptBlockText="*SaveNothing*") OR (ScriptBlockText IN ("*del*", "*Remove-Item*", "*rm*") ScriptBlockText="*(Get-PSReadlineOption).HistorySavePath*")

# ── Clearing Windows Console History ──
# Mức độ  : Cao
# Mục đích: Xóa dấu vết
# Chi tiết: Identifies when a user attempts to clear console history. An adversary may clear the command history of a compromised account to conceal the actions undertaken during an intrusion.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Clear-History*" OR (ScriptBlockText IN ("*Remove-Item*", "*rm*") ScriptBlockText IN ("*ConsoleHost_history.txt*", "*(Get-PSReadlineOption).HistorySavePath*"))

# ── Powershell Create Scheduled Task ──
# Mức độ  : Trung bình
# Mục đích: Lên lịch tác vụ độc hại
# Chi tiết: Adversaries may abuse the Windows Task Scheduler to perform task scheduling for initial or recurring execution of malicious code
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*New-ScheduledTaskAction*", "*New-ScheduledTaskTrigger*", "*New-ScheduledTaskPrincipal*", "*New-ScheduledTaskSettingsSet*", "*New-ScheduledTask*", "*Register-ScheduledTask*") OR (ScriptBlockText="*Invoke-CimMethod*" ScriptBlockText="*-ClassName*" ScriptBlockText="*PS_ScheduledTask*" ScriptBlockText="*-NameSpace*" ScriptBlockText="*Root\\Microsoft\\Windows\\TaskScheduler*") NOT (ScriptBlockText="*Microsoft.PowerShell.Core\\Export-ModuleMember*" ScriptBlockText="*Microsoft.Management.Infrastructure.CimInstance*" ScriptBlockText="*__cmdletization_methodParameter*")

# ── Computer Discovery And Export Via Get-ADComputer Cmdlet - PowerShell ──
# Mức độ  : Trung bình
# Mục đích: Thu thập thông tin user
# Chi tiết: Detects usage of the Get-ADComputer cmdlet to collect computer information and output it to a file
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-ADComputer *" ScriptBlockText="* -Filter \**" ScriptBlockText IN ("* | Select *", "*Out-File*", "*Set-Content*", "*Add-Content*")

# ── Powershell Install a DLL in System Directory ──
# Mức độ  : Cao
# Chi tiết: Uses PowerShell to install/copy a file into a system directory such as "System32" or "SysWOW64"
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational")
| regex ScriptBlockText="(Copy-Item|cpi) .{2,128} -Destination .{1,32}\\\\Windows\\\\(System32|SysWOW64)"

# ── Registry-Free Process Scope COR_PROFILER ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may leverage the COR_PROFILER environment variable to hijack the execution flow of programs that load the .NET CLR. The COR_PROFILER is a .NET Framework feature which allows developers to 
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*$env:COR_ENABLE_PROFILING*" ScriptBlockText="*$env:COR_PROFILER*" ScriptBlockText="*$env:COR_PROFILER_PATH*"

# ── PowerShell Create Local User ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects creation of a local user via PowerShell
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*New-LocalUser*"

# ── DMSA Service Account Created in Specific OUs - PowerShell ──
# Mức độ  : Trung bình
# Mục đích: Dùng tài khoản hợp lệ
# Chi tiết: Detects the creation of a dMSA service account using the New-ADServiceAccount cmdlet in certain OUs. The fact that the cmdlet is used to create a dMSASvc account in a specific OU is highly suspicious.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*New-ADServiceAccount*" ScriptBlockText="*-CreateDelegatedServiceAccount*" ScriptBlockText="*-path*"

# ── Create Volume Shadow Copy with Powershell ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Adversaries may attempt to access or create a copy of the Active Directory domain database in order to steal credential information
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Win32_ShadowCopy*" ScriptBlockText="*).Create(*" ScriptBlockText="*ClientAccessible*"

# ── Powershell Detect Virtualization Environment ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may employ various system checks to detect and avoid virtualization and analysis environments. This may include changing behaviors based on the results of checks for the presence of artifa
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Get-WmiObject*", "*gwmi*") ScriptBlockText IN ("*MSAcpi_ThermalZoneTemperature*", "*Win32_ComputerSystem*")

# ── DirectorySearcher Powershell Exploitation ──
# Mức độ  : Trung bình
# Chi tiết: Enumerates Active Directory to determine computers that are joined to the domain
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*New-Object *" ScriptBlockText="*System.DirectoryServices.DirectorySearcher*" ScriptBlockText="*.PropertiesToLoad.Add*" ScriptBlockText="*.findall()*" ScriptBlockText="*Properties.name*"

# ── Manipulation of User Computer or Group Security Principals Across AD ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may create a domain account to maintain access to victim systems. Domain accounts are those managed by Active Directory Domain Services where access and permissions are configured across s
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*System.DirectoryServices.AccountManagement*"

# ── Disable Powershell Command History ──
# Mức độ  : Cao
# Mục đích: Xóa dấu vết
# Chi tiết: Detects scripts or commands that disabled the Powershell command history by removing psreadline module
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Remove-Module*" ScriptBlockText="*psreadline*"

# ── Disable-WindowsOptionalFeature Command PowerShell ──
# Mức độ  : Cao
# Chi tiết: Detect built in PowerShell cmdlet Disable-WindowsOptionalFeature, Deployment Image Servicing and Management tool. Similar to DISM.exe, this cmdlet is used to enumerate, install, uninstall, configure, 
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Disable-WindowsOptionalFeature*" ScriptBlockText="*-Online*" ScriptBlockText="*-FeatureName*" ScriptBlockText IN ("*Windows-Defender-Gui*", "*Windows-Defender-Features*", "*Windows-Defender*", "*Windows-Defender-ApplicationGuard*")

# ── Potential In-Memory Execution Using Reflection.Assembly ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of "Reflection.Assembly" load functions to dynamically load assemblies in memory
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*[Reflection.Assembly]::load*"

# ── Potential COM Objects Download Cradles Usage - PS Script ──
# Mức độ  : Trung bình
# Mục đích: Tải file từ mạng
# Chi tiết: Detects usage of COM objects that can be abused to download files in PowerShell by CLSID
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*[Type]::GetTypeFromCLSID(*" ScriptBlockText IN ("*0002DF01-0000-0000-C000-000000000046*", "*F6D90F16-9C73-11D3-B32E-00C04F990BB4*", "*F5078F35-C551-11D3-89B9-0000F81FE221*", "*88d96a0a-f192-11d4-a65f-0040963251e5*", "*AFBA6B42-5692-48EA-8141-DC517DCF0EF1*", "*AFB40FFD-B609-40A3-9828-F88BBE11E4E3*", "*88d96a0b-f192-11d4-a65f-0040963251e5*", "*2087c2f4-2cef-4953-a8ab-66779b670495*", "*000209FF-0000-0000-C000-000000000046*", "*00024500-0000-0000-C000-000000000046*")

# ── DSInternals Suspicious PowerShell Cmdlets - ScriptBlock ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects execution and usage of the DSInternals PowerShell module. Which can be used to perform what might be considered as suspicious activity such as dumping DPAPI backup keys or manipulating NTDS.DI
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Add-ADDBSidHistory*", "*Add-ADNgcKey*", "*Add-ADReplNgcKey*", "*ConvertFrom-ADManagedPasswordBlob*", "*ConvertFrom-GPPrefPassword*", "*ConvertFrom-ManagedPasswordBlob*", "*ConvertFrom-UnattendXmlPassword*", "*ConvertFrom-UnicodePassword*", "*ConvertTo-AADHash*", "*ConvertTo-GPPrefPassword*", "*ConvertTo-KerberosKey*", "*ConvertTo-LMHash*", "*ConvertTo-MsoPasswordHash*", "*ConvertTo-NTHash*", "*ConvertTo-OrgIdHash*", "*ConvertTo-UnicodePassword*", "*Disable-ADDBAccount*", "*Enable-ADDBAccount*", "*Get-ADDBAccount*", "*Get-ADDBBackupKey*", "*Get-ADDBDomainController*", "*Get-ADDBGroupManagedServiceAccount*", "*Get-ADDBKdsRootKey*", "*Get-ADDBSchemaAttribute*", "*Get-ADDBServiceAccount*", "*Get-ADDefaultPasswordPolicy*", "*Get-ADKeyCredential*", "*Get-ADPasswordPolicy*", "*Get-ADReplAccount*", "*Get-ADReplBackupKey*", "*Get-ADReplicationAccount*", "*Get-ADSIAccount*", "*Get-AzureADUserEx*", "*Get-BootKey*", "*Get-KeyCredential*", "*Get-LsaBackupKey*", "*Get-LsaPolicy*", "*Get-SamPasswordPolicy*", "*Get-SysKey*", "*Get-SystemKey*", "*New-ADDBRestoreFromMediaScript*", "*New-ADKeyCredential*", "*New-ADNgcKey*", "*New-NTHashSet*", "*Remove-ADDBObject*", "*Save-DPAPIBlob*", "*Set-ADAccountPasswordHash*", "*Set-ADDBAccountPassword*", "*Set-ADDBBootKey*", "*Set-ADDBDomainController*", "*Set-ADDBPrimaryGroup*", "*Set-ADDBSysKey*", "*Set-AzureADUserEx*", "*Set-LsaPolicy*", "*Set-SamAccountPasswordHash*", "*Set-WinUserPasswordHash*", "*Test-ADDBPasswordQuality*", "*Test-ADPasswordQuality*", "*Test-ADReplPasswordQuality*", "*Test-PasswordQuality*", "*Unlock-ADDBAccount*", "*Write-ADNgcKey*", "*Write-ADReplNgcKey*")

# ── Dump Credentials from Windows Credential Manager With PowerShell ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may search for common password storage locations to obtain user credentials. Passwords are stored in several places on a system, depending on the operating system or application holding th
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Get-PasswordVaultCredentials*", "*Get-CredManCreds*") OR (ScriptBlockText="*New-Object*" ScriptBlockText="*Windows.Security.Credentials.PasswordVault*") OR (ScriptBlockText="*New-Object*" ScriptBlockText="*Microsoft.CSharp.CSharpCodeProvider*" ScriptBlockText="*[System.Runtime.InteropServices.RuntimeEnvironment]::GetRuntimeDirectory())*" ScriptBlockText="*Collections.ArrayList*" ScriptBlockText="*System.CodeDom.Compiler.CompilerParameters*")

# ── Enable Windows Remote Management ──
# Mức độ  : Trung bình
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Adversaries may use Valid Accounts to interact with remote systems using Windows Remote Management (WinRM). The adversary may then perform actions as the logged-on user.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Enable-PSRemoting *"

# ── Potential Suspicious Windows Feature Enabled ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the built-in PowerShell cmdlet "Enable-WindowsOptionalFeature" used as a Deployment Image Servicing and Management tool. Similar to DISM.exe, this cmdlet is used to enumerate, install
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Enable-WindowsOptionalFeature*" ScriptBlockText="*-Online*" ScriptBlockText="*-FeatureName*" ScriptBlockText IN ("*TelnetServer*", "*Internet-Explorer-Optional-amd64*", "*TFTP*", "*SMB1Protocol*", "*Client-ProjFS*", "*Microsoft-Windows-Subsystem-Linux*")

# ── Enumerate Credentials from Windows Credential Manager With PowerShell ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may search for common password storage locations to obtain user credentials. Passwords are stored in several places on a system, depending on the operating system or application holding th
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*vaultcmd*" ScriptBlockText="*/listcreds:*" ScriptBlockText IN ("*Windows Credentials*", "*Web Credentials*")

# ── Disable of ETW Trace - Powershell ──
# Mức độ  : Cao
# Mục đích: Xóa dấu vết
# Chi tiết: Detects usage of powershell cmdlets to disable or remove ETW trace sessions
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Remove-EtwTraceProvider *" OR (ScriptBlockText="*Set-EtwTraceProvider *" ScriptBlockText="*0x11*")

# ── Certificate Exported Via PowerShell - ScriptBlock ──
# Mức độ  : Trung bình
# Chi tiết: Detects calls to cmdlets inside of PowerShell scripts that are used to export certificates from the local certificate store. Threat actors were seen abusing this to steal private keys from compromised
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Export-PfxCertificate*", "*Export-Certificate*") NOT ScriptBlockText="*CmdletsToExport = @(*"

# ── Suspicious FromBase64String Usage On Gzip Archive - Ps Script ──
# Mức độ  : Trung bình
# Chi tiết: Detects attempts of decoding a base64 Gzip archive in a PowerShell script. This technique is often used as a method to load malicious content into memory afterward.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*FromBase64String*" ScriptBlockText="*MemoryStream*" ScriptBlockText="*H4sI*"

# ── Service Registry Permissions Weakness Check ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may execute their own malicious payloads by hijacking the Registry entries used by services. Adversaries may use flaws in the permissions for registry to redirect from the originally speci
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*get-acl*" ScriptBlockText="*REGISTRY::HKLM\\SYSTEM\\CurrentControlSet\\Services\\*"

# ── Active Directory Computers Enumeration With Get-AdComputer ──
# Mức độ  : Thấp
# Chi tiết: Detects usage of the "Get-AdComputer" to enumerate Computers or properties within Active Directory.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-AdComputer *" ScriptBlockText IN ("*-Filter *", "*-LDAPFilter *", "*-Properties *")

# ── Active Directory Group Enumeration With Get-AdGroup ──
# Mức độ  : Thấp
# Chi tiết: Detects usage of the "Get-AdGroup" cmdlet to enumerate Groups within Active Directory
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-AdGroup *" ScriptBlockText="*-Filter*"

# ── Suspicious Get-ADReplAccount ──
# Mức độ  : Trung bình
# Mục đích: Dump thông tin xác thực
# Chi tiết: The DSInternals PowerShell Module exposes several internal features of Active Directory and Azure Active Directory. These include FIDO2 and NGC key auditing, offline ntds.dit file manipulation, passwo
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-ADReplAccount*" ScriptBlockText="*-All *" ScriptBlockText="*-Server *"

# ── Automated Collection Bookmarks Using Get-ChildItem PowerShell ──
# Mức độ  : Thấp
# Chi tiết: Adversaries may enumerate browser bookmarks to learn more about compromised hosts. Browser bookmarks may reveal personal information about users (ex: banking sites, interests, social media, etc.) as w
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-ChildItem*" ScriptBlockText="* -Recurse *" ScriptBlockText="* -Path *" ScriptBlockText="* -Filter Bookmarks*" ScriptBlockText="* -ErrorAction SilentlyContinue*" ScriptBlockText="* -Force*"

# ── Security Software Discovery Via Powershell Script ──
# Mức độ  : Trung bình
# Chi tiết: Detects calls to "get-process" where the output is piped to a "where-object" filter to search for security solution processes. Adversaries may attempt to get a listing of security software, configurat
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*get-process | ?*", "*get-process | where*", "*gps | ?*", "*gps | where*") ScriptBlockText IN ("*Company -like*", "*Description -like*", "*Name -like*", "*Path -like*", "*Product -like*") ScriptBlockText IN ("*\*avira\**", "*\*carbonblack\**", "*\*cylance\**", "*\*defender\**", "*\*kaspersky\**", "*\*malware\**", "*\*sentinel\**", "*\*symantec\**", "*\*virus\**")

# ── HackTool - Rubeus Execution - ScriptBlock ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects the execution of the hacktool Rubeus using specific command line flags
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*asreproast *", "*dump /service:krbtgt *", "*dump /luid:0x*", "*kerberoast *", "*createnetonly /program:*", "*ptt /ticket:*", "*/impersonateuser:*", "*renew /ticket:*", "*asktgt /user:*", "*harvest /interval:*", "*s4u /user:*", "*s4u /ticket:*", "*hash /password:*", "*golden /aes256:*", "*silver /user:*")

# ── HackTool - WinPwn Execution - ScriptBlock ──
# Mức độ  : Cao
# Mục đích: Thu thập thông tin hệ thống; Leo thang đặc quyền
# Chi tiết: Detects scriptblock text keywords indicative of potential usge of the tool WinPwn. A tool for Windows and Active Directory reconnaissance and exploitation.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Offline_Winpwn*", "*WinPwn *", "*WinPwn.exe*", "*WinPwn.ps1*")

# ── PowerShell Hotfix Enumeration ──
# Mức độ  : Trung bình
# Chi tiết: Detects call to "Win32_QuickFixEngineering" in order to enumerate installed hotfixes often used in "enum" scripts by attackers
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Win32_QuickFixEngineering*" ScriptBlockText="*HotFixID*"

# ── PowerShell ICMP Exfiltration ──
# Mức độ  : Trung bình
# Chi tiết: Detects Exfiltration Over Alternative Protocol - ICMP. Adversaries may steal data by exfiltrating it over an un-encrypted network protocol other than that of the existing command and control channel.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*New-Object*" ScriptBlockText="*System.Net.NetworkInformation.Ping*" ScriptBlockText="*.Send(*"

# ── Import PowerShell Modules From Suspicious Directories ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects powershell scripts that import modules from suspicious directories
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Import-Module \"$Env:Temp\\*", "*Import-Module '$Env:Temp\\*", "*Import-Module $Env:Temp\\*", "*Import-Module \"$Env:Appdata\\*", "*Import-Module '$Env:Appdata\\*", "*Import-Module $Env:Appdata\\*", "*Import-Module C:\\Users\\Public\\*", "*ipmo \"$Env:Temp\\*", "*ipmo '$Env:Temp\\*", "*ipmo $Env:Temp\\*", "*ipmo \"$Env:Appdata\\*", "*ipmo '$Env:Appdata\\*", "*ipmo $Env:Appdata\\*", "*ipmo C:\\Users\\Public\\*")

# ── Unsigned AppX Installation Attempt Using Add-AppxPackage - PsScript ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the "Add-AppxPackage" or it's alias "Add-AppPackage" to install unsigned AppX packages
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Add-AppPackage *", "*Add-AppxPackage *") ScriptBlockText="* -AllowUnsigned*"

# ── Execute Invoke-command on Remote Host ──
# Mức độ  : Trung bình
# Mục đích: Di chuyển ngang mạng
# Chi tiết: Adversaries may use Valid Accounts to interact with remote systems using Windows Remote Management (WinRM). The adversary may then perform actions as the logged-on user.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*invoke-command *" ScriptBlockText="* -ComputerName *"

# ── Powershell DNSExfiltration ──
# Mức độ  : Cao
# Chi tiết: DNSExfiltrator allows for transferring (exfiltrate) a file over a DNS request covert channel
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Invoke-DNSExfiltrator*" OR (ScriptBlockText="* -i *" ScriptBlockText="* -d *" ScriptBlockText="* -p *" ScriptBlockText="* -doh *" ScriptBlockText="* -t *")

# ── Invoke-Obfuscation CLIP+ Launcher - PowerShell ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated use of Clip.exe to execute PowerShell
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational")
| regex ScriptBlockText="cmd.{0,5}(?:/c|/r).+clip(?:\\.exe)?.{0,4}&&.+clipboard]::\\(\\s\\\\\"\\{\\d\\}.+-f.+\""

# ── Invoke-Obfuscation Obfuscated IEX Invocation - PowerShell ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects all variations of obfuscated powershell IEX invocation code generated by Invoke-Obfuscation framework from the following code block \u2014
| rex field=ScriptBlockText "(?<ScriptBlockTextMatch>\\$PSHome\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$PSHome\\[)"
| eval ScriptBlockTextCondition=if(isnotnull(ScriptBlockTextMatch), "true", "false")
| rex field=ScriptBlockText "(?<ScriptBlockTextMatch2>\\$ShellId\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$ShellId\\[)"
| eval ScriptBlockTextCondition2=if(isnotnull(ScriptBlockTextMatch2), "true", "false")
| rex field=ScriptBlockText "(?<ScriptBlockTextMatch3>\\$env:Public\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$env:Public\\[)"
| eval ScriptBlockTextCondition3=if(isnotnull(ScriptBlockTextMatch3), "true", "false")
| rex field=ScriptBlockText "(?<ScriptBlockTextMatch4>\\$env:ComSpec\\[(\\s*\\d{1,3}\\s*,){2})"
| eval ScriptBlockTextCondition4=if(isnotnull(ScriptBlockTextMatch4), "true", "false")
| rex field=ScriptBlockText "(?<ScriptBlockTextMatch5>\\*mdr\\*\\W\\s*\\)\\.Name)"
| eval ScriptBlockTextCondition5=if(isnotnull(ScriptBlockTextMatch5), "true", "false")
| rex field=ScriptBlockText "(?<ScriptBlockTextMatch6>\\$VerbosePreference\\.ToString\\()"
| eval ScriptBlockTextCondition6=if(isnotnull(ScriptBlockTextMatch6), "true", "false")
| search source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockTextCondition="true" OR ScriptBlockTextCondition2="true" OR ScriptBlockTextCondition3="true" OR ScriptBlockTextCondition4="true" OR ScriptBlockTextCondition5="true" OR ScriptBlockTextCondition6="true"

# ── Invoke-Obfuscation STDIN+ Launcher - Powershell ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated use of stdin to execute PowerShell
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational")
| regex ScriptBlockText="cmd.{0,5}(?:/c|/r).+powershell.+(?:\\$?\\{?input\\}?|noexit).+\""

# ── Invoke-Obfuscation VAR+ Launcher - PowerShell ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated use of Environment Variables to execute PowerShell
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational")
| regex ScriptBlockText="cmd.{0,5}(?:/c|/r)(?:\\s|)\"set\\s[a-zA-Z]{3,6}.*(?:\\{\\d\\}){1,}\\\\\"\\s+?-f(?:.*\\)){1,}.*\""

# ── Invoke-Obfuscation COMPRESS OBFUSCATION - PowerShell ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via COMPRESS OBFUSCATION
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*new-object*" ScriptBlockText="*text.encoding]::ascii*" ScriptBlockText IN ("*system.io.compression.deflatestream*", "*system.io.streamreader*") ScriptBlockText="*readtoend"

# ── Invoke-Obfuscation RUNDLL LAUNCHER - PowerShell ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via RUNDLL LAUNCHER
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*rundll32.exe*" ScriptBlockText="*shell32.dll*" ScriptBlockText="*shellexec_rundll*" ScriptBlockText="*powershell*"

# ── Invoke-Obfuscation Via Stdin - Powershell ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via Stdin in Scripts
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational")
| regex ScriptBlockText="(?i)(set).*&&\\s?set.*(environment|invoke|\\$\\{?input).*&&.*\""

# ── Invoke-Obfuscation Via Use Clip - Powershell ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via use Clip.exe in Scripts
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational")
| regex ScriptBlockText="(?i)echo.*clip.*&&.*(Clipboard|i`?n`?v`?o`?k`?e`?)"

# ── Invoke-Obfuscation Via Use MSHTA - PowerShell ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via use MSHTA in Scripts
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*set*" ScriptBlockText="*&&*" ScriptBlockText="*mshta*" ScriptBlockText="*vbscript:createobject*" ScriptBlockText="*.run*" ScriptBlockText="*(window.close)*"

# ── Invoke-Obfuscation Via Use Rundll32 - PowerShell ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via use Rundll32 in Scripts
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*&&*" ScriptBlockText="*rundll32*" ScriptBlockText="*shell32.dll*" ScriptBlockText="*shellexec_rundll*" ScriptBlockText IN ("*value*", "*invoke*", "*comspec*", "*iex*")

# ── Invoke-Obfuscation VAR++ LAUNCHER OBFUSCATION - PowerShell ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Obfuscated Powershell via VAR++ LAUNCHER
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational")
| regex ScriptBlockText="(?i)&&set.*(\\{\\d\\}){2,}\\\\\"\\s+?-f.*&&.*cmd.*/c"

# ── Powershell Keylogging ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may log user keystrokes to intercept credentials as the user types them.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-Keystrokes*" OR (ScriptBlockText="*Get-ProcAddress user32.dll GetAsyncKeyState*" ScriptBlockText="*Get-ProcAddress user32.dll GetForegroundWindow*")

# ── Powershell LocalAccount Manipulation ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may manipulate accounts to maintain access to victim systems. Account manipulation may consist of any action that preserves adversary access to a compromised account, such as modifying cre
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Disable-LocalUser*", "*Enable-LocalUser*", "*Get-LocalUser*", "*Set-LocalUser*", "*New-LocalUser*", "*Rename-LocalUser*", "*Remove-LocalUser*")

# ── Suspicious PowerShell Mailbox Export to Share - PS ──
# Mức độ  : Nghiêm trọng
# Chi tiết: Detects usage of the powerShell New-MailboxExportRequest Cmdlet to exports a mailbox to a remote or local share, as used in ProxyShell exploitations
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*New-MailboxExportRequest*" ScriptBlockText="* -Mailbox *" ScriptBlockText="* -FilePath \\\\*"

