# ── Live Memory Dump Using Powershell ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects usage of a PowerShell command to dump the live memory of a Windows machine
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-StorageDiagnosticInfo*" ScriptBlockText="*-IncludeLiveDump*"

# ── DMSA Link Attributes Modified ──
# Mức độ  : Thấp
# Mục đích: Dùng tài khoản hợp lệ
# Chi tiết: Detects modification of dMSA link attributes (msDS-ManagedAccountPrecededByLink) via PowerShell scripts. This command line pattern could be an indicator an attempt to exploit the BadSuccessor privileg
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*.Put(\"msDS-ManagedAccountPrecededByLink*" ScriptBlockText="*CN=*"

# ── Modify Group Policy Settings - ScriptBlockLogging ──
# Mức độ  : Trung bình
# Chi tiết: Detect malicious GPO modifications can be used to implement many other malicious behaviors.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*\\SOFTWARE\\Policies\\Microsoft\\Windows\\System*" ScriptBlockText IN ("*GroupPolicyRefreshTimeDC*", "*GroupPolicyRefreshTimeOffsetDC*", "*GroupPolicyRefreshTime*", "*GroupPolicyRefreshTimeOffset*", "*EnableSmartScreen*", "*ShellSmartScreenLevel*")

# ── Powershell MsXml COM Object ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Adversaries may abuse PowerShell commands and scripts for execution. PowerShell is a powerful interactive command-line interface and scripting environment included in the Windows operating system. (Ci
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*New-Object*" ScriptBlockText="*-ComObject*" ScriptBlockText="*MsXml2.*" ScriptBlockText="*XmlHttp*"

# ── Malicious Nishang PowerShell Commandlets ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Commandlet names and arguments from the Nishang exploitation framework
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Add-ConstrainedDelegationBackdoor*", "*Copy-VSS*", "*Create-MultipleSessions*", "*DataToEncode*", "*DNS_TXT_Pwnage*", "*Do-Exfiltration-Dns*", "*Download_Execute*", "*Download-Execute-PS*", "*DownloadAndExtractFromRemoteRegistry*", "*DumpCerts*", "*DumpCreds*", "*DumpHashes*", "*Enable-DuplicateToken*", "*Enable-Duplication*", "*Execute-Command-MSSQL*", "*Execute-DNSTXT-Code*", "*Execute-OnTime*", "*ExetoText*", "*exfill*", "*ExfilOption*", "*FakeDC*", "*FireBuster*", "*FireListener*", "*Get-Information *", "*Get-PassHints*", "*Get-Web-Credentials*", "*Get-WebCredentials*", "*Get-WLAN-Keys*", "*HTTP-Backdoor*", "*Invoke-AmsiBypass*", "*Invoke-BruteForce*", "*Invoke-CredentialsPhish*", "*Invoke-Decode*", "*Invoke-Encode*", "*Invoke-Interceptor*", "*Invoke-JSRatRegsvr*", "*Invoke-JSRatRundll*", "*Invoke-MimikatzWDigestDowngrade*", "*Invoke-NetworkRelay*", "*Invoke-PowerShellIcmp*", "*Invoke-PowerShellUdp*", "*Invoke-Prasadhak*", "*Invoke-PSGcat*", "*Invoke-PsGcatAgent*", "*Invoke-SessionGopher*", "*Invoke-SSIDExfil*", "*LoggedKeys*", "*Nishang*", "*NotAllNameSpaces*", "*Out-CHM*", "*OUT-DNSTXT*", "*Out-HTA*", "*Out-RundllCommand*", "*Out-SCF*", "*Out-SCT*", "*Out-Shortcut*", "*Out-WebQuery*", "*Out-Word*", "*Parse_Keys*", "*Password-List*", "*Powerpreter*", "*Remove-Persistence*", "*Remove-PoshRat*", "*Remove-Update*", "*Run-EXEonRemote*", "*Set-DCShadowPermissions*", "*Set-RemotePSRemoting*", "*Set-RemoteWMI*", "*Shellcode32*", "*Shellcode64*", "*StringtoBase64*", "*TexttoExe*")

# ── NTFS Alternate Data Stream ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects writing data into NTFS alternate data streams from powershell. Needs Script Block Logging.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*set-content*", "*add-content*") ScriptBlockText="*-stream*"

# ── Code Executed Via Office Add-in XLL File ──
# Mức độ  : Cao
# Chi tiết: Adversaries may abuse Microsoft Office add-ins to obtain persistence on a compromised system. Office add-ins can be used to add functionality to Office programs
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*new-object *" ScriptBlockText="*-ComObject *" ScriptBlockText="*.application*" ScriptBlockText="*.RegisterXLL*"

# ── Potential Packet Capture Activity Via Start-NetEventSession - ScriptBlock ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of powershell scripts with calls to the "Start-NetEventSession" cmdlet. Which allows an attacker to start event and packet capture for a network event session. Adversaries may at
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Start-NetEventSession*"

# ── Potential Invoke-Mimikatz PowerShell Script ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects Invoke-Mimikatz PowerShell script and alike. Mimikatz is a credential dumper capable of obtaining plaintext Windows account logins and passwords.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") (ScriptBlockText="*DumpCreds*" ScriptBlockText="*DumpCerts*") OR ScriptBlockText="*sekurlsa::logonpasswords*" OR (ScriptBlockText="*crypto::certificates*" ScriptBlockText="*CERT_SYSTEM_STORE_LOCAL_MACHINE*")

# ── Potential Unconstrained Delegation Discovery Via Get-ADComputer - ScriptBlock ──
# Mức độ  : Trung bình
# Chi tiết: Detects the use of the "Get-ADComputer" cmdlet in order to identify systems which are configured for unconstrained delegation.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*-Properties*TrustedForDelegation*", "*-Properties*TrustedToAuthForDelegation*", "*-Properties*msDS-AllowedToDelegateTo*", "*-Properties*PrincipalsAllowedToDelegateToAccount*", "*-LDAPFilter*(userAccountControl:1.2.840.113556.1.4.803:=524288)*")

# ── PowerShell Web Access Installation - PsScript ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the installation and configuration of PowerShell Web Access, which could be used for remote access and potential abuse
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Install-WindowsFeature WindowsPowerShellWebAccess*" OR ScriptBlockText="*Install-PswaWebApplication*" OR (ScriptBlockText="*Add-PswaAuthorizationRule*" ScriptBlockText="*-UserName *" ScriptBlockText="*-ComputerName *")

# ── PowerView PowerShell Cmdlets - ScriptBlock ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Cmdlet names from PowerView of the PowerSploit exploitation framework.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Export-PowerViewCSV*", "*Find-DomainLocalGroupMember*", "*Find-DomainObjectPropertyOutlier*", "*Find-DomainProcess*", "*Find-DomainShare*", "*Find-DomainUserEvent*", "*Find-DomainUserLocation*", "*Find-ForeignGroup*", "*Find-ForeignUser*", "*Find-GPOComputerAdmin*", "*Find-GPOLocation*", "*Find-InterestingDomain*", "*Find-InterestingFile*", "*Find-LocalAdminAccess*", "*Find-ManagedSecurityGroups*", "*Get-CachedRDPConnection*", "*Get-DFSshare*", "*Get-DomainDFSShare*", "*Get-DomainDNSRecord*", "*Get-DomainDNSZone*", "*Get-DomainFileServer*", "*Get-DomainGPOComputerLocalGroupMapping*", "*Get-DomainGPOLocalGroup*", "*Get-DomainGPOUserLocalGroupMapping*", "*Get-LastLoggedOn*", "*Get-LoggedOnLocal*", "*Get-NetFileServer*", "*Get-NetForest*", "*Get-NetGPOGroup*", "*Get-NetProcess*", "*Get-NetRDPSession*", "*Get-RegistryMountedDrive*", "*Get-RegLoggedOn*", "*Get-WMIRegCachedRDPConnection*", "*Get-WMIRegLastLoggedOn*", "*Get-WMIRegMountedDrive*", "*Get-WMIRegProxy*", "*Invoke-ACLScanner*", "*Invoke-CheckLocalAdminAccess*", "*Invoke-EnumerateLocalAdmin*", "*Invoke-EventHunter*", "*Invoke-FileFinder*", "*Invoke-Kerberoast*", "*Invoke-MapDomainTrust*", "*Invoke-ProcessHunter*", "*Invoke-RevertToSelf*", "*Invoke-ShareFinder*", "*Invoke-UserHunter*", "*Invoke-UserImpersonation*", "*Remove-RemoteConnection*", "*Request-SPNTicket*", "*Resolve-IPAddress*")

# ── PowerShell Credential Prompt ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects PowerShell calling a credential prompt
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*PromptForCredential*"

# ── PSAsyncShell - Asynchronous TCP Reverse Shell ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the use of PSAsyncShell an Asynchronous TCP Reverse Shell written in powershell
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*PSAsyncShell*"

# ── PowerShell PSAttack ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the use of PSAttack PowerShell hack tool
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*PS ATTACK!!!*"

# ── PowerShell Remote Session Creation ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Adversaries may abuse PowerShell commands and scripts for execution. PowerShell is a powerful interactive command-line interface and scripting environment included in the Windows operating system
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*New-PSSession*" ScriptBlockText="*-ComputerName *"

# ── Potential RemoteFXvGPUDisablement.EXE Abuse - PowerShell ScriptBlock ──
# Mức độ  : Cao
# Chi tiết: Detects PowerShell module creation where the module Contents are set to "function Get-VMRemoteFXPhysicalVideoAdapter". This could be a sign of potential abuse of the "RemoteFXvGPUDisablement.exe" bina
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="function Get-VMRemoteFXPhysicalVideoAdapter {*"

# ── Suspicious Kerberos Ticket Request via PowerShell Script - ScriptBlock ──
# Mức độ  : Cao
# Chi tiết: Detects PowerShell scripts that utilize native PowerShell Identity modules to request Kerberos tickets. This behavior is typically seen during a Kerberos or silver ticket attack. A successful executio
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*System.IdentityModel.Tokens.KerberosRequestorSecurityToken*" ScriptBlockText="*.GetRequest()*"

# ── PowerShell Script With File Hostname Resolving Capabilities ──
# Mức độ  : Trung bình
# Chi tiết: Detects PowerShell scripts that have capabilities to read files, loop through them and resolve DNS host entries.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-content *" ScriptBlockText="*foreach*" ScriptBlockText="*[System.Net.Dns]::GetHostEntry*" ScriptBlockText="*Out-File*"

# ── Root Certificate Installed - PowerShell ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may install a root certificate on a compromised system to avoid warnings when connecting to adversary controlled web servers.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") (ScriptBlockText="*Move-Item*" ScriptBlockText="*Cert:\\LocalMachine\\Root*") OR (ScriptBlockText="*Import-Certificate*" ScriptBlockText="*Cert:\\LocalMachine\\Root*")

# ── Suspicious Invoke-Item From Mount-DiskImage ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may abuse container files such as disk image (.iso, .vhd) file formats to deliver malicious payloads that may not be tagged with MOTW.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Mount-DiskImage *" ScriptBlockText="*-ImagePath *" ScriptBlockText="*Get-Volume*" ScriptBlockText="*.DriveLetter*" ScriptBlockText="*invoke-item *" ScriptBlockText="*):\\*"

# ── PowerShell Script With File Upload Capabilities ──
# Mức độ  : Thấp
# Chi tiết: Detects PowerShell scripts leveraging the "Invoke-WebRequest" cmdlet to send data via either "PUT" or "POST" method.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Invoke-RestMethod*", "*Invoke-WebRequest*", "*irm *", "*iwr *") ScriptBlockText IN ("*-Method \"POST\"*", "*-Method \"PUT\"*", "*-Method POST*", "*-Method PUT*", "*-Method 'POST'*", "*-Method 'PUT'*")

# ── Powershell Sensitive File Discovery ──
# Mức độ  : Trung bình
# Chi tiết: Detect adversaries enumerate sensitive files
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*ls*", "*get-childitem*", "*gci*") ScriptBlockText="*-recurse*" ScriptBlockText IN ("*.pass*", "*.kdbx*", "*.kdb*")

# ── PowerShell Script Change Permission Via Set-Acl - PsScript ──
# Mức độ  : Thấp
# Chi tiết: Detects PowerShell scripts set ACL to of a file or a folder
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Set-Acl *" ScriptBlockText="*-AclObject *" ScriptBlockText="*-Path *"

# ── PowerShell Set-Acl On Windows Folder - PsScript ──
# Mức độ  : Cao
# Chi tiết: Detects PowerShell scripts to set the ACL to a file in the Windows folder
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Set-Acl *" ScriptBlockText="*-AclObject *" ScriptBlockText IN ("*-Path \"C:\\Windows*", "*-Path \"C:/Windows*", "*-Path 'C:\\Windows*", "*-Path 'C:/Windows*", "*-Path C:\\Windows*", "*-Path C:/Windows*", "*-Path $env:windir*", "*-Path \"$env:windir*", "*-Path '$env:windir*") ScriptBlockText IN ("*FullControl*", "*Allow*")

# ── Change PowerShell Policies to an Insecure Level - PowerShell ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects changing the PowerShell script execution policy to a potentially insecure level using the "Set-ExecutionPolicy" cmdlet.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Set-ExecutionPolicy*" ScriptBlockText IN ("*Unrestricted*", "*bypass*") NOT (ScriptBlockText IN ("*(New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1')*", "*(New-Object System.Net.WebClient).DownloadString('https://chocolatey.org/install.ps1')*"))

# ── PowerShell ShellCode ──
# Mức độ  : Cao
# Mục đích: Chèn mã vào tiến trình; Thực thi lệnh/script
# Chi tiết: Detects Base64 encoded Shellcode
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*OiCAAAAYInlM*", "*OiJAAAAYInlM*")

# ── Malicious ShellIntel PowerShell Commandlets ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects Commandlet names from ShellIntel exploitation scripts.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Invoke-SMBAutoBrute*", "*Invoke-GPOLinks*", "*Invoke-Potato*")

# ── Detected Windows Software Discovery - PowerShell ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may attempt to enumerate software for a variety of reasons, such as figuring out what security measures are present or if the compromised system has a version of software that is vulnerabl
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*get-itemProperty*" ScriptBlockText="*\\software\\*" ScriptBlockText="*select-object*" ScriptBlockText="*format-table*"

# ── Powershell Store File In Alternate Data Stream ──
# Mức độ  : Trung bình
# Chi tiết: Storing files in Alternate Data Stream (ADS) similar to Astaroth malware.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Start-Process*" ScriptBlockText="*-FilePath \"$env:comspec\" *" ScriptBlockText="*-ArgumentList *" ScriptBlockText="*>*"

# ── Potential Persistence Via Security Descriptors - ScriptBlock ──
# Mức độ  : Cao
# Chi tiết: Detects usage of certain functions and keywords that are used to manipulate security descriptors in order to potentially set a backdoor. As seen used in the DAMP project.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*win32_Trustee*" ScriptBlockText="*win32_Ace*" ScriptBlockText="*.AccessMask*" ScriptBlockText="*.AceType*" ScriptBlockText="*.SetSecurityDescriptor*" ScriptBlockText IN ("*\\Lsa\\JD*", "*\\Lsa\\Skew1*", "*\\Lsa\\Data*", "*\\Lsa\\GBG*")

# ── AD Groups Or Users Enumeration Using PowerShell - ScriptBlock ──
# Mức độ  : Thấp
# Chi tiết: Adversaries may attempt to find domain-level groups and permission settings. The knowledge of domain-level permission groups can help adversaries determine which groups exist and which users belong to
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*get-ADPrincipalGroupMembership*" OR (ScriptBlockText="*get-aduser*" ScriptBlockText="*-f *" ScriptBlockText="*-pr *" ScriptBlockText="*DoesNotRequirePreAuth*")

# ── Potential PowerShell Obfuscation Using Character Join ──
# Mức độ  : Thấp
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects specific techniques often seen used inside of PowerShell scripts to obfscuate Alias creation
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*-Alias*" ScriptBlockText="* -Value (-join(*"

# ── Suspicious Eventlog Clear ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of known powershell cmdlets such as "Clear-EventLog" to clear the Windows event logs
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Clear-EventLog *", "*Remove-EventLog *", "*Limit-EventLog *", "*Clear-WinEvent *") OR (ScriptBlockText="*Eventing.Reader.EventLogSession*" ScriptBlockText="*ClearLog*") OR (ScriptBlockText="*Diagnostics.EventLog*" ScriptBlockText="*Clear*")

# ── Powershell Directory Enumeration ──
# Mức độ  : Trung bình
