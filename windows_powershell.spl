# Mục đích: Dùng tài khoản hợp lệ
# Chi tiết: The Reset-ComputerMachinePassword cmdlet changes the computer account password that the computers use to authenticate to the domain controllers in the domain. You can use it to reset the password of t
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4103 EventCode=4103 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ContextInfo="*Reset-ComputerMachinePassword*"

# ── Suspicious Get Information for SMB Share - PowerShell Module ──
# Mức độ  : Thấp
# Chi tiết: Adversaries may look for folders and drives shared on remote systems as a means of identifying sources of information to gather as a precursor for Collection and to identify potential systems of inter
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4103 EventCode=4103 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") Payload="*get-smbshare*" OR ContextInfo="*get-smbshare*"

# ── Zip A Folder With PowerShell For Staging In Temp  - PowerShell Module ──
# Mức độ  : Trung bình
# Chi tiết: Detects PowerShell scripts that make use of the "Compress-Archive" Cmdlet in order to compress folders and files where the output is stored in a potentially suspicious location that is used often by m
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4103 EventCode=4103 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ContextInfo="*Compress-Archive -Path*-DestinationPath $env:TEMP*" ContextInfo="*Compress-Archive -Path*-DestinationPath*\\AppData\\Local\\Temp\\*" ContextInfo="*Compress-Archive -Path*-DestinationPath*:\\Windows\\Temp\\*"

# ── SyncAppvPublishingServer Bypass Powershell Restriction - PS Module ──
# Mức độ  : Trung bình
