source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*[System.Net.HttpWebRequest]*" ScriptBlockText="*System.Net.Sockets.TcpListener*" ScriptBlockText="*AcceptTcpClient*"

# ── Recon Information for Export with PowerShell ──
