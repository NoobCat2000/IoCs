# Mức độ  : Trung bình
# Chi tiết: Detects PowerShell scripts that make use of the "Compress-Archive" Cmdlet in order to compress folders and files where the output is stored in a potentially suspicious location that is used often by m
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Compress-Archive -Path*-DestinationPath $env:TEMP*", "*Compress-Archive -Path*-DestinationPath*\\AppData\\Local\\Temp\\*", "*Compress-Archive -Path*-DestinationPath*:\\Windows\\Temp\\*")

# ── SyncAppvPublishingServer Execution to Bypass Powershell Restriction ──
# Mức độ  : Trung bình
# Chi tiết: Detects SyncAppvPublishingServer process execution which usually utilized by adversaries to bypass PowerShell execution restrictions.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*SyncAppvPublishingServer.exe*"

# ── Tamper Windows Defender Remove-MpPreference - ScriptBlockLogging ──
# Mức độ  : Cao
# Chi tiết: Detects attempts to remove Windows Defender configuration using the 'MpPreference' cmdlet
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Remove-MpPreference*" ScriptBlockText IN ("*-ControlledFolderAccessProtectedFolders *", "*-AttackSurfaceReductionRules_Ids *", "*-AttackSurfaceReductionRules_Actions *", "*-CheckForSignaturesBeforeRunningScan *")

# ── Tamper Windows Defender - ScriptBlockLogging ──
# Mức độ  : Cao
# Chi tiết: Detects PowerShell scripts attempting to disable scheduled scanning and other parts of Windows Defender ATP or set default actions to allow.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") (ScriptBlockText="*Set-MpPreference*" ScriptBlockText IN ("*-dbaf $true*", "*-dbaf 1*", "*-dbm $true*", "*-dbm 1*", "*-dips $true*", "*-dips 1*", "*-DisableArchiveScanning $true*", "*-DisableArchiveScanning 1*", "*-DisableBehaviorMonitoring $true*", "*-DisableBehaviorMonitoring 1*", "*-DisableBlockAtFirstSeen $true*", "*-DisableBlockAtFirstSeen 1*", "*-DisableCatchupFullScan $true*", "*-DisableCatchupFullScan 1*", "*-DisableCatchupQuickScan $true*", "*-DisableCatchupQuickScan 1*", "*-DisableIntrusionPreventionSystem $true*", "*-DisableIntrusionPreventionSystem 1*", "*-DisableIOAVProtection $true*", "*-DisableIOAVProtection 1*", "*-DisableRealtimeMonitoring $true*", "*-DisableRealtimeMonitoring 1*", "*-DisableRemovableDriveScanning $true*", "*-DisableRemovableDriveScanning 1*", "*-DisableScanningMappedNetworkDrivesForFullScan $true*", "*-DisableScanningMappedNetworkDrivesForFullScan 1*", "*-DisableScanningNetworkFiles $true*", "*-DisableScanningNetworkFiles 1*", "*-DisableScriptScanning $true*", "*-DisableScriptScanning 1*", "*-MAPSReporting $false*", "*-MAPSReporting 0*", "*-drdsc $true*", "*-drdsc 1*", "*-drtm $true*", "*-drtm 1*", "*-dscrptsc $true*", "*-dscrptsc 1*", "*-dsmndf $true*", "*-dsmndf 1*", "*-dsnf $true*", "*-dsnf 1*", "*-dss $true*", "*-dss 1*")) OR (ScriptBlockText="*Set-MpPreference*" ScriptBlockText IN ("*HighThreatDefaultAction Allow*", "*htdefac Allow*", "*LowThreatDefaultAction Allow*", "*ltdefac Allow*", "*ModerateThreatDefaultAction Allow*", "*mtdefac Allow*", "*SevereThreatDefaultAction Allow*", "*stdefac Allow*"))

# ── Testing Usage of Uncommonly Used Port ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may communicate using a protocol and port paring that are typically not associated. For example, HTTPS over port 8088(Citation: Symantec Elfin Mar 2019) or port 587(Citation: Fortinet Agen
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Test-NetConnection*" ScriptBlockText="*-ComputerName *" ScriptBlockText="*-port *" NOT (ScriptBlockText IN ("* 443 *", "* 80 *"))

# ── Powershell Timestomp ──
# Mức độ  : Trung bình
# Mục đích: Xóa dấu vết
# Chi tiết: Adversaries may modify file time attributes to hide new or changes to existing files. Timestomping is a technique that modifies the timestamps of a file (the modify, access, create, and change times),
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*.CreationTime =*", "*.LastWriteTime =*", "*.LastAccessTime =*", "*[IO.File]::SetCreationTime*", "*[IO.File]::SetLastAccessTime*", "*[IO.File]::SetLastWriteTime*")

# ── User Discovery And Export Via Get-ADUser Cmdlet - PowerShell ──
# Mức độ  : Trung bình
# Mục đích: Thu thập thông tin user
# Chi tiết: Detects usage of the Get-ADUser cmdlet to collect user information and output it to a file
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-ADUser *" ScriptBlockText="* -Filter \**" ScriptBlockText IN ("* > *", "* | Select *", "*Out-File*", "*Set-Content*", "*Add-Content*")

# ── Potential Persistence Via PowerShell User Profile Using Add-Content ──
# Mức độ  : Trung bình
# Chi tiết: Detects calls to "Add-Content" cmdlet in order to modify the content of the user profile and potentially adding suspicious commands for persistence
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Add-Content $profile*" ScriptBlockText IN ("*-Value \"IEX *", "*-Value \"Invoke-Expression*", "*-Value \"Invoke-WebRequest*", "*-Value \"Start-Process*", "*-Value 'IEX *", "*-Value 'Invoke-Expression*", "*-Value 'Invoke-WebRequest*", "*-Value 'Start-Process*")

# ── Abuse of Service Permissions to Hide Services Via Set-Service - PS ──
# Mức độ  : Cao
# Chi tiết: Detects usage of the "Set-Service" powershell cmdlet to configure a new SecurityDescriptor that allows a service to be hidden from other utilities such as "sc.exe", "Get-Service"...etc. (Works only in
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Set-Service *" ScriptBlockText="*DCLCWPDTSD*" ScriptBlockText IN ("*-SecurityDescriptorSddl *", "*-sd *")

# ── Registry Modification Attempt Via VBScript - PowerShell ──
# Mức độ  : Trung bình
# Mục đích: Sửa registry; Thực thi lệnh/script
# Chi tiết: Detects attempts to modify the registry using VBScript's CreateObject("Wscript.shell") and RegWrite methods embedded within PowerShell scripts or commands. Threat actors commonly embed VBScript code w
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*CreateObject*" ScriptBlockText="*Wscript.shell*" ScriptBlockText="*.RegWrite*"

# ── Veeam Backup Servers Credential Dumping Script Execution ──
# Mức độ  : Cao
# Chi tiết: Detects execution of a PowerShell script that contains calls to the "Veeam.Backup" class, in order to dump stored credentials.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*[Credentials]*" ScriptBlockText="*[Veeam.Backup.Common.ProtectedStorage]::GetLocalString*" ScriptBlockText="*Invoke-Sqlcmd*" ScriptBlockText="*Veeam Backup and Replication*"

# ── Usage Of Web Request Commands And Cmdlets - ScriptBlock ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects the use of various web request commands with commandline tools and Windows PowerShell cmdlets (including aliases) via PowerShell scriptblock logs
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*[System.Net.WebRequest]::create*", "*curl *", "*Invoke-RestMethod*", "*Invoke-WebRequest*", "* irm *", "*iwr *", "*Resume-BitsTransfer*", "*Start-BitsTransfer*", "*wget *", "*WinHttp.WinHttpRequest*") NOT Path="C:\\Packages\\Plugins\\Microsoft.GuestConfiguration.ConfigurationforWindows\\*"

# ── Potentially Suspicious Call To Win32_NTEventlogFile Class - PSScript ──
# Mức độ  : Trung bình
# Chi tiết: Detects usage of the WMI class "Win32_NTEventlogFile" in a potentially suspicious way (delete, backup, change permissions, etc.) from a PowerShell script
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Win32_NTEventlogFile*" ScriptBlockText IN ("*.BackupEventlog(*", "*.ChangeSecurityPermissions(*", "*.ChangeSecurityPermissionsEx(*", "*.ClearEventLog(*", "*.Delete(*", "*.DeleteEx(*", "*.Rename(*", "*.TakeOwnerShip(*", "*.TakeOwnerShipEx(*")

# ── PowerShell WMI Win32_Product Install MSI ──
# Mức độ  : Trung bình
# Chi tiết: Detects the execution of an MSI file using PowerShell and the WMI Win32_Product class
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Invoke-CimMethod *" ScriptBlockText="*-ClassName *" ScriptBlockText="*Win32_Product *" ScriptBlockText="*-MethodName *" ScriptBlockText="*.msi*"

# ── Potential WinAPI Calls Via PowerShell Scripts ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects usage of WinAPI functions in PowerShell scripts. It may indicate attempts to perform actions such as process injection, token stealing, or other malicious activities that leverage Windows API 
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") (ScriptBlockText="*VirtualAlloc*" ScriptBlockText="*OpenProcess*" ScriptBlockText="*WriteProcessMemory*" ScriptBlockText="*CreateRemoteThread*") OR (ScriptBlockText="*OpenProcessToken*" ScriptBlockText="*LookupPrivilegeValue*" ScriptBlockText="*AdjustTokenPrivileges*") OR (ScriptBlockText="*OpenProcessToken*" ScriptBlockText="*DuplicateTokenEx*" ScriptBlockText="*CloseHandle*") OR (ScriptBlockText="*WriteProcessMemory*" ScriptBlockText="*VirtualAlloc*" ScriptBlockText="*ReadProcessMemory*" ScriptBlockText="*VirtualFree*") OR (ScriptBlockText="*VirtualAlloc*" ScriptBlockText="*GetDelegateForFunctionPointer*" ScriptBlockText="*Marshal.Copy*")

# ── Windows Defender Exclusions Added - PowerShell ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects modifications to the Windows Defender configuration settings using PowerShell to add exclusions
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("* -ExclusionPath *", "* -ExclusionExtension *", "* -ExclusionProcess *", "* -ExclusionIpAddress *") ScriptBlockText IN ("*Add-MpPreference *", "*Set-MpPreference *")

# ── Windows Firewall Profile Disabled ──
# Mức độ  : Trung bình
# Chi tiết: Detects when a user disables the Windows Firewall via a Profile to help evade defense.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Set-NetFirewallProfile *" ScriptBlockText="* -Enabled *" ScriptBlockText="* False*" ScriptBlockText IN ("* -All *", "*Public*", "*Domain*", "*Private*")

# ── Winlogon Helper DLL ──
# Mức độ  : Trung bình
# Mục đích: Persistence qua autorun
# Chi tiết: Winlogon.exe is a Windows component responsible for actions at logon/logoff as well as the secure attention sequence (SAS) triggered by Ctrl-Alt-Delete. Registry entries in HKLM\Software[Wow6432Node]M
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*CurrentVersion\\Winlogon*" ScriptBlockText IN ("*Set-ItemProperty*", "*New-Item*")

# ── Powershell WMI Persistence ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may establish persistence and elevate privileges by executing malicious content triggered by a Windows Management Instrumentation (WMI) event subscription.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") (ScriptBlockText="*New-CimInstance *" ScriptBlockText="*-Namespace root/subscription *" ScriptBlockText="*-ClassName __EventFilter *" ScriptBlockText="*-Property *") OR (ScriptBlockText="*New-CimInstance *" ScriptBlockText="*-Namespace root/subscription *" ScriptBlockText="*-ClassName CommandLineEventConsumer *" ScriptBlockText="*-Property *")

# ── WMIC Unquoted Services Path Lookup - PowerShell ──
# Mức độ  : Trung bình
# Chi tiết: Detects known WMI recon method to look for unquoted service paths, often used by pentest inside of powershell scripts attackers enum scripts
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*Get-WmiObject *", "*gwmi *") ScriptBlockText="* Win32_Service *" ScriptBlockText="*Name*" ScriptBlockText="*DisplayName*" ScriptBlockText="*PathName*" ScriptBlockText="*StartMode*"

# ── WMImplant Hack Tool ──
# Mức độ  : Cao
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects parameters used by WMImplant
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*WMImplant*", "* change_user *", "* gen_cli *", "* command_exec *", "* disable_wdigest *", "* disable_winrm *", "* enable_wdigest *", "* enable_winrm *", "* registry_mod *", "* remote_posh *", "* sched_job *", "* service_mod *", "* process_kill *", "* active_users *", "* basic_info *", "* power_off *", "* vacant_system *", "* logon_events *")

# ── Suspicious X509Enrollment - Ps Script ──
# Mức độ  : Trung bình
# Chi tiết: Detect use of X509Enrollment
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*X509Enrollment.CBinaryConverter*", "*884e2002-217d-11da-b2a4-000e7bbb2b09*")

# ── Powershell XML Execute Command ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Adversaries may abuse PowerShell commands and scripts for execution. PowerShell is a powerful interactive command-line interface and scripting environment included in the Windows operating system. (Ci
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*New-Object*" ScriptBlockText="*System.Xml.XmlDocument*" ScriptBlockText="*.Load*" ScriptBlockText IN ("*IEX *", "*Invoke-Expression *", "*Invoke-Command *", "*ICM -*")
