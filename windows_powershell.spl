source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*foreach*" ScriptBlockText="*Get-ChildItem*" ScriptBlockText="*-Path *" ScriptBlockText="*-ErrorAction *" ScriptBlockText="*SilentlyContinue*" ScriptBlockText="*Out-File *" ScriptBlockText="*-append*"

# ── Suspicious PowerShell Download - Powershell Script ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Detects suspicious PowerShell download command
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*System.Net.WebClient*" ScriptBlockText IN ("*.DownloadFile(*", "*.DownloadFileAsync(*", "*.DownloadString(*", "*.DownloadStringAsync(*")

# ── Powershell Execute Batch Script ──
# Mức độ  : Trung bình
# Mục đích: Thực thi lệnh/script
# Chi tiết: Adversaries may abuse the Windows command shell for execution. The Windows command shell ([cmd](https://attack.mitre.org/software/S0106)) is the primary command prompt on Windows systems. The Windows 
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Start-Process*" ScriptBlockText IN ("*.cmd*", "*.bat*")

# ── Extracting Information with PowerShell ──
# Mức độ  : Trung bình
# Chi tiết: Adversaries may search local file systems and remote file shares for files containing insecurely stored credentials. These can be files created by users to store their own credentials, shared credenti
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*ls*" ScriptBlockText="* -R*" ScriptBlockText="*select-string *" ScriptBlockText="*-Pattern *"

# ── Troubleshooting Pack Cmdlet Execution ──
# Mức độ  : Trung bình
# Chi tiết: Detects execution of "TroubleshootingPack" cmdlets to leverage CVE-2022-30190 or action similar to "msdt" lolbin (as described in LOLBAS)
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Invoke-TroubleshootingPack*" ScriptBlockText="*C:\\Windows\\Diagnostics\\System\\PCW*" ScriptBlockText="*-AnswerFile*" ScriptBlockText="*-Unattended*"

# ── Password Policy Discovery With Get-AdDefaultDomainPasswordPolicy ──
# Mức độ  : Thấp
# Chi tiết: Detetcts PowerShell activity in which Get-Addefaultdomainpasswordpolicy is used to get the default password policy for an Active Directory domain.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-AdDefaultDomainPasswordPolicy*"

# ── Suspicious PowerShell Get Current User ──
# Mức độ  : Thấp
# Mục đích: Thu thập thông tin user
# Chi tiết: Detects the use of PowerShell to identify the current logged user.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText IN ("*[System.Environment]::UserName*", "*$env:UserName*", "*[System.Security.Principal.WindowsIdentity]::GetCurrent()*")

# ── Suspicious GPO Discovery With Get-GPO ──
# Mức độ  : Thấp
# Chi tiết: Detect use of Get-GPO to get one GPO or all the GPOs in a domain.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-GPO*"

# ── Suspicious Process Discovery With Get-Process ──
# Mức độ  : Thấp
# Chi tiết: Get the processes that are running on the local computer.
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-Process*"

# ── PowerShell Get-Process LSASS in ScriptBlock ──
# Mức độ  : Cao
# Mục đích: Dump thông tin xác thực
# Chi tiết: Detects a Get-Process command on lsass process, which is in almost all cases a sign of malicious activity
source IN ("WinEventLog:Microsoft-Windows-PowerShell/Operational", "WinEventLog:PowerShellCore/Operational") Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") EventCode=4104 EventCode=4104 Channel IN ("Microsoft-Windows-PowerShell/Operational", "PowerShellCore/Operational") ScriptBlockText="*Get-Process lsass*"

# ── Suspicious GetTypeFromCLSID ShellExecute ──
